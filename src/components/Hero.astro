---
// Hero.astro - Inversax — Full Responsive
import { Globe, Users, FileText, BarChart2, ArrowRight, Zap } from 'lucide-astro';

// ── Sin fetch de APIs externas en SSR ───────────────────────────
// Cripto, forex y metales cargan client-side para no bloquear TTFB.

const stats = [
  { label: "Activos seguidos", value: "600+",  icon: "chart" },
  { label: "Países",           value: "36",     icon: "globe" },
  { label: "Lectores/mes",     value: "50K+",   icon: "users" },
  { label: "Artículos",        value: "1,200+", icon: "file"  },
];

// Skeletons estáticos — se reemplazan client-side con datos reales
const CRYPTO_SKELETON = [
  { id: 'bitcoin',     name: 'Bitcoin',  symbol: 'BTC' },
  { id: 'ethereum',    name: 'Ethereum', symbol: 'ETH' },
  { id: 'solana',      name: 'Solana',   symbol: 'SOL' },
  { id: 'binancecoin', name: 'BNB',      symbol: 'BNB' },
];

const FOREX_SKELETON = [
  { par: 'EUR/USD', base: 'eu', cotizada: 'us' },
  { par: 'USD/MXN', base: 'us', cotizada: 'mx' },
  { par: 'USD/ARS', base: 'us', cotizada: 'ar' },
  { par: 'USD/BRL', base: 'us', cotizada: 'br' },
];

const METALES_SKELETON = [
  { nombre: 'Oro',   simbolo: 'XAU', slug: 'oro',   color: 'text-yellow-400' },
  { nombre: 'Plata', simbolo: 'XAG', slug: 'plata', color: 'text-slate-300'  },
];

const heroTabs = [
  { id: 'cripto',   label: 'Cripto',   color: '#D4A843', href: '/herramientas/cripto'   },
  { id: 'forex',    label: 'Forex',    color: '#EC4899', href: '/herramientas/forex'    },
  { id: 'metales',  label: 'Metales',  color: '#FBBF24', href: '/herramientas/metales'  },
  { id: 'acciones', label: 'Acciones', color: '#10B981', href: '/herramientas/acciones' },
];
---

<section
  class="relative bg-[#0A0B0D] overflow-hidden w-full"
  style="font-family: 'DM Sans', sans-serif;"
>
  <!-- Fondo grid -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Glows -->
  <div class="absolute top-0 right-0 w-72 sm:w-[500px] h-64 sm:h-[400px] rounded-full pointer-events-none" style="background: rgba(212,168,67,0.07); filter: blur(100px); transform: translate(30%, -30%);"></div>
  <div class="absolute bottom-0 left-0 w-64 sm:w-[350px] h-48 sm:h-[280px] rounded-full pointer-events-none" style="background: rgba(34,197,94,0.05); filter: blur(100px); transform: translate(-20%, 20%);"></div>

  <!-- Chart de fondo -->
  <div class="absolute bottom-0 left-0 right-0 h-32 sm:h-48 opacity-30 pointer-events-none">
    <svg viewBox="0 0 1200 200" preserveAspectRatio="none" fill="none" class="w-full h-full">
      <defs>
        <linearGradient id="cg" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#D4A843" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#D4A843" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="M0,180 L100,155 L220,165 L340,120 L460,130 L580,85 L700,100 L820,55 L940,68 L1060,28 L1200,15" stroke="#D4A843" stroke-width="2" stroke-opacity="0.35"/>
      <path d="M0,180 L100,155 L220,165 L340,120 L460,130 L580,85 L700,100 L820,55 L940,68 L1060,28 L1200,15 L1200,200 L0,200Z" fill="url(#cg)"/>
    </svg>
  </div>

  <!-- Contenido -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center">

      <!-- IZQUIERDA -->
      <div class="flex flex-col gap-6">
        <div
          class="inline-flex items-center gap-2 self-start px-3 py-1.5 rounded-full border text-xs sm:text-[12.5px] font-medium text-[#E8C060]"
          style="background: rgba(212,168,67,0.1); border-color: rgba(212,168,67,0.25);"
        >
          <Zap size={12} />
          Cripto · Forex · Bolsa · Metales · Más
        </div>

        <h1
          class="font-extrabold leading-[1.08] tracking-tight text-white text-[36px] sm:text-[52px] lg:text-[64px]"
          style="font-family: 'Syne', sans-serif;"
        >
          Invierte con <br/>
          <span class="text-[#D4A843] relative inline-block hero-underline">
            información real
          </span>
        </h1>

        <p class="text-white/50 text-base sm:text-[17px] leading-relaxed font-light max-w-md">
          Noticias, precios en vivo y herramientas de cripto, forex, bolsa y metales. Todo en español, para Latinoamérica.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/herramientas"
            class="inline-flex items-center gap-2 bg-[#D4A843] hover:bg-[#E8C060] text-[#0A0B0D] font-semibold text-sm px-5 py-3 rounded-xl transition-all duration-200 no-underline hover:-translate-y-px"
          >
            Ver todos los mercados <ArrowRight size={15} />
          </a>
          <a
            href="/noticias"
            class="inline-flex items-center bg-white/5 border border-white/[0.07] hover:bg-white/10 hover:border-white/20 text-white/50 hover:text-white text-sm px-5 py-3 rounded-xl transition-all duration-200 no-underline"
          >
            Últimas noticias
          </a>
        </div>

        <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-4 sm:gap-6 pt-3 border-t border-white/[0.07]">
          {stats.map((stat) => (
            <div class="flex items-center gap-2.5">
              <span class="text-[#D4A843] opacity-80 flex-shrink-0">
                {stat.icon === "chart" && <BarChart2 size={15} />}
                {stat.icon === "globe" && <Globe size={15} />}
                {stat.icon === "users" && <Users size={15} />}
                {stat.icon === "file"  && <FileText size={15} />}
              </span>
              <div>
                <div class="font-bold text-base sm:text-[17px] text-white leading-tight" style="font-family: 'Syne', sans-serif;">{stat.value}</div>
                <div class="text-[11px] text-white/40">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- DERECHA: Card de mercado con tabs -->
      <div class="relative w-full lg:justify-self-end lg:max-w-[420px]">

        <div
          class="absolute inset-0 rounded-full pointer-events-none hidden lg:block"
          style="background: radial-gradient(ellipse at center, rgba(212,168,67,0.12), transparent 70%); transform: scale(1.4);"
        ></div>

        <div class="relative bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden card-float">

          <!-- Header card -->
          <div class="flex items-center justify-between px-5 py-3.5 border-b border-white/[0.07]">
            <span class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">Mercado ahora</span>
            <span class="flex items-center gap-1.5 text-xs font-medium text-emerald-400">
              <span class="live-dot inline-block w-[7px] h-[7px] bg-emerald-400 rounded-full flex-shrink-0"></span>
              En vivo
            </span>
          </div>

          <!-- Tabs -->
          <div class="flex border-b border-white/[0.07]">
            {heroTabs.map((tab, i) => (
              <button
                data-hero-tab={tab.id}
                data-color={tab.color}
                class={`hero-tab flex-1 text-xs py-2.5 font-medium transition-all duration-200 cursor-pointer border-none border-b-2 ${
                  i === 0
                    ? 'text-[#D4A843] border-[#D4A843] bg-[#D4A843]/5'
                    : 'text-white/35 border-transparent bg-transparent hover:text-white/60'
                }`}
              >
                {tab.label}
              </button>
            ))}
          </div>

          <!-- Panel CRIPTO (skeleton → datos reales client-side) -->
          <div id="hero-panel-cripto" class="hero-panel">
            {CRYPTO_SKELETON.map((coin) => (
              <a
                href={`/herramientas/cripto/${coin.id}`}
                class="flex items-center justify-between px-5 py-3 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 no-underline"
                data-hero-symbol={coin.symbol}
              >
                <div class="flex items-center gap-2.5 min-w-0">
                  <div class="w-7 h-7 rounded-full bg-white/10 flex-shrink-0 overflow-hidden flex items-center justify-center" data-coin-img={coin.id}>
                    <span class="text-[9px] font-bold text-white/30 animate-pulse">{coin.symbol.slice(0,2)}</span>
                  </div>
                  <div>
                    <div class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">{coin.symbol}</div>
                    <div class="text-[11px] text-white/35">{coin.name}</div>
                  </div>
                </div>
                <div class="flex flex-col items-end gap-0.5 flex-shrink-0">
                  <span class="hero-price font-semibold text-sm text-white/30 animate-pulse">···</span>
                  <span class="hero-change text-xs font-medium text-white/20">—</span>
                </div>
              </a>
            ))}
          </div>

          <!-- Panel FOREX (skeleton → datos reales client-side) -->
          <div id="hero-panel-forex" class="hero-panel hidden">
            {FOREX_SKELETON.map((f) => (
              <a
                href={`/herramientas/forex/${f.par.replace('/', '-').toLowerCase()}`}
                class="flex items-center justify-between px-5 py-3 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 no-underline"
                data-forex-par={f.par}
              >
                <div class="flex items-center gap-2.5 min-w-0">
                  <div class="relative w-7 h-7 flex-shrink-0">
                    <img src={`https://flagcdn.com/w40/${f.base}.png`} class="absolute top-0 left-0 w-4 h-4 rounded-full object-cover border border-white/10" onerror="this.style.display='none'" />
                    <img src={`https://flagcdn.com/w40/${f.cotizada}.png`} class="absolute bottom-0 right-0 w-4 h-4 rounded-full object-cover border border-white/10" onerror="this.style.display='none'" />
                  </div>
                  <span class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">{f.par}</span>
                </div>
                <span class="forex-price font-semibold text-sm text-white/30 animate-pulse">···</span>
              </a>
            ))}
          </div>

          <!-- Panel METALES (skeleton → datos reales client-side) -->
          <div id="hero-panel-metales" class="hero-panel hidden">
            {METALES_SKELETON.map((m) => (
              <a
                href={`/herramientas/metales/${m.slug}`}
                class="flex items-center justify-between px-5 py-3 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 no-underline"
                data-metal-simbolo={m.simbolo}
              >
                <div class="flex items-center gap-2.5 min-w-0">
                  <div class="w-7 h-7 rounded-full bg-white/5 border border-white/[0.07] flex-shrink-0 flex items-center justify-center">
                    <span class={`text-[10px] font-bold ${m.color}`}>{m.simbolo.slice(0,2)}</span>
                  </div>
                  <div>
                    <div class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">{m.nombre}</div>
                    <div class="text-[11px] text-white/35">{m.simbolo} · oz troy</div>
                  </div>
                </div>
                <span class="metal-price font-semibold text-sm text-white/30 animate-pulse">···</span>
              </a>
            ))}
          </div>

          <!-- Panel ACCIONES (skeleton + carga client-side) -->
          <div id="hero-panel-acciones" class="hero-panel hidden">
            <div id="hero-acciones-loading">
              {[...Array(4)].map((_) => (
                <div class="flex items-center justify-between px-5 py-3 border-b border-white/[0.07] last:border-none">
                  <div class="flex items-center gap-2.5">
                    <div class="w-7 h-7 rounded-full bg-white/5 animate-pulse flex-shrink-0"></div>
                    <div class="flex flex-col gap-1.5">
                      <div class="w-10 h-3 bg-white/5 rounded animate-pulse"></div>
                      <div class="w-16 h-2.5 bg-white/5 rounded animate-pulse"></div>
                    </div>
                  </div>
                  <div class="flex flex-col items-end gap-1.5">
                    <div class="w-14 h-3 bg-white/5 rounded animate-pulse"></div>
                    <div class="w-10 h-2.5 bg-white/5 rounded animate-pulse"></div>
                  </div>
                </div>
              ))}
            </div>
            <div id="hero-acciones-content" class="hidden"></div>
            <div id="hero-acciones-error" class="hidden px-5 py-8 text-center text-white/25 text-sm">No se pudieron cargar las acciones</div>
          </div>

          <!-- Footer: link dinámico por tab -->
          <a
            id="hero-card-link"
            href="/herramientas/cripto"
            class="flex items-center justify-center gap-1.5 px-6 py-3.5 bg-white/5 hover:bg-white/10 text-[#D4A843] text-sm font-medium no-underline transition-colors duration-200 border-t border-white/[0.07]"
          >
            Ver todos los precios <ArrowRight size={14} />
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-underline::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #D4A843, transparent);
    border-radius: 2px;
  }

  @media (min-width: 1024px) {
    .card-float {
      animation: card-float 5s ease-in-out infinite;
    }
  }

  @keyframes card-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  .live-dot {
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1;   transform: scale(1);   }
    50%       { opacity: 0.4; transform: scale(0.8); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
</style>

<script>
  // ── Helpers de formato ────────────────────────────────────────
  function fmtPrice(p: number): string {
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  }
  function fmtForex(p: number): string {
    if (!p) return '—';
    if (p >= 100) return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  }
  function stopPulse(el: Element | null) {
    if (!el) return;
    el.classList.remove('animate-pulse', 'text-white/30', 'text-white/20');
    el.classList.add('text-white');
  }

  // ── Tabs ──────────────────────────────────────────────────────
  const heroLinks: Record<string, string> = {
    cripto:   '/herramientas/cripto',
    forex:    '/herramientas/forex',
    metales:  '/herramientas/metales',
    acciones: '/herramientas/acciones',
  };

  const tabs     = document.querySelectorAll<HTMLButtonElement>('.hero-tab');
  const panels   = document.querySelectorAll<HTMLElement>('.hero-panel');
  const cardLink = document.getElementById('hero-card-link') as HTMLAnchorElement | null;

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.heroTab!;
      const color  = tab.dataset.color ?? '#D4A843';

      tabs.forEach((t) => {
        t.style.color       = '';
        t.style.borderColor = '';
        t.style.background  = '';
        t.classList.remove('font-semibold');
        t.classList.add('text-white/35');
      });

      tab.style.color       = color;
      tab.style.borderColor = color;
      tab.style.background  = `${color}10`;
      tab.classList.add('font-semibold');
      tab.classList.remove('text-white/35');

      panels.forEach((p) => {
        p.classList.toggle('hidden', p.id !== `hero-panel-${target}`);
      });

      if (cardLink) {
        cardLink.href        = heroLinks[target] ?? '/herramientas';
        cardLink.style.color = color;
      }
    });
  });

  // ── Carga cripto ──────────────────────────────────────────────
  const HERO_SYMBOLS = ['BTC', 'ETH', 'SOL', 'BNB'];

  async function cargarCripto() {
    try {
      const res = await fetch('/api/precios');
      if (!res.ok) return;
      const data = await res.json() as any;

      data
        .filter((c: any) => HERO_SYMBOLS.includes(c.symbol?.toUpperCase()))
        .forEach((coin: any) => {
          const sym  = coin.symbol?.toUpperCase();
          const fila = document.querySelector(`[data-hero-symbol="${sym}"]`);
          if (!fila) return;

          // Actualizar imagen si tenemos URL
          if (coin.image) {
            const imgWrap = fila.querySelector('[data-coin-img]') as HTMLElement | null;
            if (imgWrap) {
              imgWrap.innerHTML = `<img src="${coin.image}" alt="${sym}" class="w-full h-full object-cover" loading="lazy" />`;
            }
          }

          const up       = coin.change24 >= 0;
          const priceEl  = fila.querySelector('.hero-price');
          const changeEl = fila.querySelector('.hero-change');

          if (priceEl) {
            priceEl.textContent = fmtPrice(coin.price);
            stopPulse(priceEl);
          }
          if (changeEl) {
            changeEl.textContent = `${up ? '+' : ''}${coin.change24.toFixed(2)}%`;
            changeEl.className   = `hero-change text-xs font-medium ${up ? 'text-emerald-400' : 'text-red-400'}`;
          }
        });
    } catch (e) {
      console.warn('[Hero cripto]', e);
    }
  }

  // ── Carga forex (solo al abrir el tab, una vez) ───────────────
  const FOREX_SHOW = ['EUR/USD', 'USD/MXN', 'USD/ARS', 'USD/BRL'];
  let forexCargado = false;

  async function cargarForex() {
    if (forexCargado) return;
    forexCargado = true;
    try {
      const res = await fetch('/api/forex');
      if (!res.ok) return;
      const json = await res.json() as any;
      const data = json.data ?? json;

      data
        .filter((f: any) => FOREX_SHOW.includes(f.par))
        .forEach((f: any) => {
          const fila = document.querySelector(`[data-forex-par="${f.par}"]`);
          if (!fila) return;
          const el = fila.querySelector('.forex-price');
          if (el) {
            el.textContent = fmtForex(f.precio);
            stopPulse(el);
          }
        });
    } catch (e) {
      console.warn('[Hero forex]', e);
    }
  }

  // ── Carga metales (solo al abrir el tab, una vez) ─────────────
  let metalesCargado = false;

  async function cargarMetales() {
    if (metalesCargado) return;
    metalesCargado = true;
    try {
      const res = await fetch('/api/metales');
      if (!res.ok) return;
      const json = await res.json() as any;
      const data = json.data ?? json;

      data.forEach((m: any) => {
        const fila = document.querySelector(`[data-metal-simbolo="${m.simbolo}"]`);
        if (!fila) return;
        const el = fila.querySelector('.metal-price');
        if (el) {
          el.textContent = `$${m.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
          stopPulse(el);
        }
      });
    } catch (e) {
      console.warn('[Hero metales]', e);
    }
  }

  // ── Carga acciones (solo al abrir el tab, una vez) ────────────
  const dominios: Record<string, string> = {
    AAPL: 'apple.com',        MSFT: 'microsoft.com',    GOOGL: 'google.com',
    AMZN: 'amazon.com',       NVDA: 'nvidia.com',        META: 'meta.com',
    TSLA: 'tesla.com',        JPM:  'jpmorganchase.com', BAC:  'bankofamerica.com',
    GS:   'goldmansachs.com', XOM:  'exxonmobil.com',   CVX:  'chevron.com',
    KO:   'coca-cola.com',    MCD:  'mcdonalds.com',     SPY:  'ssga.com',
    QQQ:  'invesco.com',
  };
  const ACCIONES_SHOW = ['AAPL', 'NVDA', 'TSLA', 'MSFT'];

  async function cargarAcciones() {
    try {
      const res  = await fetch('/api/acciones');
      const json = await res.json() as any;
      if (!json.ok) throw new Error();

      const content = document.getElementById('hero-acciones-content')!;
      const items   = json.data.filter((a: any) => ACCIONES_SHOW.includes(a.ticker) && a.precio > 0);

      content.innerHTML = items.map((a: any) => {
        const precio  = `$${a.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        const cambio  = `${a.cambioPct >= 0 ? '+' : ''}${a.cambioPct.toFixed(2)}%`;
        const color   = a.alza ? 'text-emerald-400' : 'text-red-400';
        const dominio = dominios[a.ticker] ?? '';
        const logo    = dominio
          ? `<img src="https://www.google.com/s2/favicons?domain=${dominio}&sz=64" alt="${a.ticker}" class="w-4 h-4 object-contain" onerror="this.style.display='none'" />`
          : `<span class="text-[9px] font-bold text-white/50">${a.ticker.slice(0, 2)}</span>`;

        return `
          <a href="/herramientas/acciones/${a.slug}" class="flex items-center justify-between px-5 py-3 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 no-underline">
            <div class="flex items-center gap-2.5 min-w-0">
              <div class="w-7 h-7 rounded-full bg-white/5 border border-white/[0.07] flex-shrink-0 flex items-center justify-center overflow-hidden">${logo}</div>
              <div>
                <div class="font-bold text-sm text-white">${a.ticker}</div>
                <div class="text-[11px] text-white/35">${a.nombre}</div>
              </div>
            </div>
            <div class="flex flex-col items-end gap-0.5">
              <span class="font-semibold text-sm text-white">${precio}</span>
              <span class="text-xs font-medium ${color}">${cambio}</span>
            </div>
          </a>`;
      }).join('');

      document.getElementById('hero-acciones-loading')!.classList.add('hidden');
      content.classList.remove('hidden');
    } catch {
      document.getElementById('hero-acciones-loading')!.classList.add('hidden');
      document.getElementById('hero-acciones-error')!.classList.remove('hidden');
    }
  }

  // ── Disparar cargas según tab activo ──────────────────────────
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.heroTab!;
      if (target === 'forex'    ) cargarForex();
      if (target === 'metales'  ) cargarMetales();
      if (target === 'acciones' ) {
        const content = document.getElementById('hero-acciones-content')!;
        if (content.innerHTML === '') cargarAcciones();
      }
    });
  });

  // ── Carga inicial: cripto visible al montar ───────────────────
  cargarCripto();

  // ── Polling: refrescar cripto cada 5 min ─────────────────────
  setInterval(cargarCripto, 300_000);
</script>
