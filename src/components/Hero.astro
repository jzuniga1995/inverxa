---
// Hero.astro - Inversax — Full Responsive
import { TrendingUp, TrendingDown, Globe, Users, FileText, BarChart2, ArrowRight, Zap } from 'lucide-astro';

const stats = [
  { label: "Criptomonedas", value: "500+",  icon: "chart" },
  { label: "Países",        value: "36",     icon: "globe" },
  { label: "Lectores/mes",  value: "50K+",   icon: "users" },
  { label: "Artículos",     value: "1,200+", icon: "file"  },
];

// ── TRENDING — carga inicial SSR ───────────────────────────────
type TrendingItem = { name: string; symbol: string; price: string; change: string; up: boolean };
let trending: TrendingItem[] = [];

const HERO_IDS = ['bitcoin', 'ethereum', 'solana', 'binancecoin'];

try {
  const res  = await fetch(new URL('/api/precios', Astro.url));
  const data = await res.json();
  trending = data
    .filter((c: any) => HERO_IDS.includes(c.id))
    .map((c: any) => ({
      name:   c.name,
      symbol: c.symbol,
      price:  c.price >= 1000
                ? `$${c.price.toLocaleString('en-US', { maximumFractionDigits: 0 })}`
                : `$${c.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
      change: `${c.change24 >= 0 ? '+' : ''}${c.change24.toFixed(2)}%`,
      up:     c.change24 >= 0,
    }));
} catch (e) {
  trending = [
    { name: "Bitcoin",  symbol: "BTC", price: "—", change: "—", up: true },
    { name: "Ethereum", symbol: "ETH", price: "—", change: "—", up: true },
    { name: "Solana",   symbol: "SOL", price: "—", change: "—", up: true },
    { name: "BNB",      symbol: "BNB", price: "—", change: "—", up: true },
  ];
}
---

<section
  class="relative bg-[#0A0B0D] overflow-hidden w-full"
  style="font-family: 'DM Sans', sans-serif;"
>

  <!-- Fondo grid -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 60px 60px;"
  ></div>

  <!-- Glows -->
  <div class="absolute top-0 right-0 w-72 sm:w-[500px] h-64 sm:h-[400px] rounded-full pointer-events-none" style="background: rgba(212,168,67,0.07); filter: blur(100px); transform: translate(30%, -30%);"></div>
  <div class="absolute bottom-0 left-0 w-64 sm:w-[350px] h-48 sm:h-[280px] rounded-full pointer-events-none" style="background: rgba(34,197,94,0.05); filter: blur(100px); transform: translate(-20%, 20%);"></div>

  <!-- Chart de fondo -->
  <div class="absolute bottom-0 left-0 right-0 h-32 sm:h-48 opacity-30 pointer-events-none">
    <svg viewBox="0 0 1200 200" preserveAspectRatio="none" fill="none" class="w-full h-full">
      <defs>
        <linearGradient id="cg" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#D4A843" stop-opacity="0.15"/>
          <stop offset="100%" stop-color="#D4A843" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="M0,180 L100,155 L220,165 L340,120 L460,130 L580,85 L700,100 L820,55 L940,68 L1060,28 L1200,15" stroke="#D4A843" stroke-width="2" stroke-opacity="0.35"/>
      <path d="M0,180 L100,155 L220,165 L340,120 L460,130 L580,85 L700,100 L820,55 L940,68 L1060,28 L1200,15 L1200,200 L0,200Z" fill="url(#cg)"/>
    </svg>
  </div>

  <!-- Contenido -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 lg:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center">

      <!-- IZQUIERDA -->
      <div class="flex flex-col gap-6">

        <div
          class="inline-flex items-center gap-2 self-start px-3 py-1.5 rounded-full border text-xs sm:text-[12.5px] font-medium text-[#E8C060]"
          style="background: rgba(212,168,67,0.1); border-color: rgba(212,168,67,0.25);"
        >
          <Zap size={12} />
          Finanzas en tiempo real para Latinoamérica
        </div>

        <h1
          class="font-extrabold leading-[1.08] tracking-tight text-white text-[36px] sm:text-[52px] lg:text-[64px]"
          style="font-family: 'Syne', sans-serif;"
        >
          Invierte con <br/>
          <span class="text-[#D4A843] relative inline-block hero-underline">
            información real
          </span>
        </h1>

        <p class="text-white/50 text-base sm:text-[17px] leading-relaxed font-light max-w-md">
          Noticias, análisis y herramientas de cripto, trading y bolsa actualizadas cada día. Todo en español, para tu país.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <a
            href="/herramientas/cripto"
            class="inline-flex items-center gap-2 bg-[#D4A843] hover:bg-[#E8C060] text-[#0A0B0D] font-semibold text-sm px-5 py-3 rounded-xl transition-all duration-200 no-underline hover:-translate-y-px"
          >
            Explorar mercados <ArrowRight size={15} />
          </a>
          <a
            href="/herramientas"
            class="inline-flex items-center bg-white/5 border border-white/[0.07] hover:bg-white/10 hover:border-white/20 text-white/50 hover:text-white text-sm px-5 py-3 rounded-xl transition-all duration-200 no-underline"
          >
            Ver herramientas
          </a>
        </div>

        <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-4 sm:gap-6 pt-3 border-t border-white/[0.07]">
          {stats.map((stat) => (
            <div class="flex items-center gap-2.5">
              <span class="text-[#D4A843] opacity-80 flex-shrink-0">
                {stat.icon === "chart" && <BarChart2 size={15} />}
                {stat.icon === "globe" && <Globe size={15} />}
                {stat.icon === "users" && <Users size={15} />}
                {stat.icon === "file"  && <FileText size={15} />}
              </span>
              <div>
                <div class="font-bold text-base sm:text-[17px] text-white leading-tight" style="font-family: 'Syne', sans-serif;">{stat.value}</div>
                <div class="text-[11px] text-white/40">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- DERECHA: Card de precios -->
      <div class="relative w-full lg:justify-self-end lg:max-w-[420px]">

        <div
          class="absolute inset-0 rounded-full pointer-events-none hidden lg:block"
          style="background: radial-gradient(ellipse at center, rgba(212,168,67,0.12), transparent 70%); transform: scale(1.4);"
        ></div>

        <div class="relative bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden card-float">

          <div class="flex items-center justify-between px-5 sm:px-6 py-4 border-b border-white/[0.07]">
            <span class="font-bold text-sm sm:text-[15px] text-white" style="font-family: 'Syne', sans-serif;">Mercado ahora</span>
            <span class="flex items-center gap-1.5 text-xs font-medium text-emerald-400">
              <span class="live-dot inline-block w-[7px] h-[7px] bg-emerald-400 rounded-full flex-shrink-0"></span>
              En vivo
            </span>
          </div>

          <div id="hero-precios">
            {trending.map((coin) => (
              <div
                class="hero-coin flex items-center justify-between px-5 sm:px-6 py-3 sm:py-3.5 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 cursor-default"
                data-symbol={coin.symbol}
              >
                <div class="flex flex-col gap-0.5 min-w-0">
                  <span class="font-bold text-sm text-white truncate" style="font-family: 'Syne', sans-serif;">{coin.symbol}</span>
                  <span class="text-xs text-white/40 truncate">{coin.name}</span>
                </div>
                <div class="flex flex-col items-end gap-0.5 flex-shrink-0 pl-4">
                  <span class="hero-price font-semibold text-sm sm:text-[15px] text-white" style="font-family: 'Syne', sans-serif;">{coin.price}</span>
                  <span class={`hero-change flex items-center gap-1 text-xs font-medium ${coin.up ? 'text-emerald-400' : 'text-red-400'}`}>
                    {coin.change}
                  </span>
                </div>
              </div>
            ))}
          </div>

          <!-- Link a herramientas/cripto para ver todos los precios -->
          <a
            href="/herramientas/cripto"
            class="flex items-center justify-center gap-1.5 px-6 py-3.5 bg-white/5 hover:bg-white/10 text-[#D4A843] text-sm font-medium no-underline transition-colors duration-200 border-t border-white/[0.07]"
          >
            Ver todos los precios <ArrowRight size={14} />
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-underline::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #D4A843, transparent);
    border-radius: 2px;
  }

  @media (min-width: 1024px) {
    .card-float {
      animation: card-float 5s ease-in-out infinite;
    }
  }

  @keyframes card-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }

  .live-dot {
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1;   transform: scale(1);   }
    50%       { opacity: 0.4; transform: scale(0.8); }
  }
</style>

<script>
  const HERO_SYMBOLS = ['BTC', 'ETH', 'SOL', 'BNB'];

  function formatPrice(p: number): string {
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  }

  async function actualizarHero() {
    try {
      const res = await fetch('/api/precios');
      if (!res.ok) return;
      const data = await res.json();

      const heroData = data.filter((c: any) => HERO_SYMBOLS.includes(c.symbol));

      heroData.forEach((coin: any) => {
        const fila = document.querySelector(`[data-symbol="${coin.symbol}"]`);
        if (!fila) return;

        const up     = coin.change24 >= 0;
        const precio = formatPrice(coin.price);
        const cambio = `${up ? '+' : ''}${coin.change24.toFixed(2)}%`;

        const priceEl  = fila.querySelector('.hero-price');
        const changeEl = fila.querySelector('.hero-change');

        if (priceEl)  priceEl.textContent = precio;
        if (changeEl) {
          changeEl.textContent = cambio;
          changeEl.className = `hero-change flex items-center gap-1 text-xs font-medium ${up ? 'text-emerald-400' : 'text-red-400'}`;
        }
      });
    } catch (e) {
      console.warn('[Hero polling]', e);
    }
  }

  setInterval(actualizarHero, 300_000);
</script>
