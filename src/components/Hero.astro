---
// Hero.astro - Inversax — Editorial Hero
import { ArrowRight, Clock } from 'lucide-astro';
import { getCloudinaryUrl } from '../lib/cloudinary';

interface Props {
  noticiaPrincipal: {
    slug: string;
    titulo: string;
    resumen: string | null;
    imagen: string | null;
    creadoEn: Date | null;
    categoria: { nombre: string; slug: string } | null;
    pais: { nombre: string; codigo: string } | null;
  } | null;
  noticiasSecundarias: Array<{
    slug: string;
    titulo: string;
    creadoEn: Date | null;
    categoria: { nombre: string; slug: string } | null;
  }>;
}

const { noticiaPrincipal, noticiasSecundarias } = Astro.props;

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas}h`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<section style="background: #FAFAF8; border-bottom: 2px solid #1C1917;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Franja editorial superior -->
    <div class="flex items-center justify-between py-2.5 border-b border-[#E5E0D8]"
         style="font-family: 'DM Sans', sans-serif;">
      <span class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[#A8A29E]">
        Finanzas · Inversiones · Latinoamérica
      </span>
      <span id="hero-fecha" class="text-[10px] text-[#A8A29E] hidden sm:block"></span>
    </div>

    <!-- Grid editorial principal -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-0 py-8 sm:py-10">

      <!-- IZQUIERDA: Artículo principal (60%) -->
      <div class="lg:col-span-3 lg:pr-10 lg:border-r-2 lg:border-[#E5E0D8] pb-8 lg:pb-0">
        {noticiaPrincipal ? (
          <a href={`/noticias/${noticiaPrincipal.slug}`} class="flex flex-col group no-underline">
            {/* Mobile: imagen primero (order-first). Desktop: después del texto (order-last) */}
            <div class="order-first lg:order-last lg:mt-0 mb-5">
              {noticiaPrincipal.imagen
                ? <div class="overflow-hidden" style="aspect-ratio: 16/9;">
                    <img src={getCloudinaryUrl(noticiaPrincipal.imagen, 800)!}
                         alt={noticiaPrincipal.titulo}
                         width="800" height="450"
                         loading="eager"
                         fetchpriority="high"
                         class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
                  </div>
                : <div class="border border-[#E5E0D8]" style="aspect-ratio: 16/9; background: #F0EDE7;"></div>
              }
            </div>
            <div class="order-last lg:order-first lg:mb-5">
              {noticiaPrincipal.categoria && (
                <span class="text-[11px] font-bold uppercase tracking-[0.2em] mb-3 block"
                      style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                  {noticiaPrincipal.categoria.nombre}
                </span>
              )}
              <h1 class="font-bold leading-[1.08] text-[#1C1917] mb-4 group-hover:text-[#B91C1C] transition-colors duration-200"
                  style="font-family: 'Playfair Display', serif; font-size: clamp(26px, 3.8vw, 52px);">
                {noticiaPrincipal.titulo}
              </h1>
              {noticiaPrincipal.resumen && (
                <p class="text-[15px] sm:text-base leading-relaxed line-clamp-3 mb-4"
                   style="color: #57534E; font-family: 'DM Sans', sans-serif;">
                  {noticiaPrincipal.resumen}
                </p>
              )}
              <div class="flex items-center gap-2 text-xs" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
                <Clock size={11} />
                <span>{formatFecha(noticiaPrincipal.creadoEn)}</span>
                {noticiaPrincipal.pais && noticiaPrincipal.pais.codigo !== 'global' && (
                  <>
                    <span>·</span>
                    <span style="color: #B91C1C;">{noticiaPrincipal.pais.nombre}</span>
                  </>
                )}
              </div>
            </div>
          </a>
        ) : (
          <div class="flex items-center justify-center border border-[#E5E0D8]" style="aspect-ratio: 16/9; background: #F0EDE7;">
            <p class="text-sm" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Sin noticias disponibles</p>
          </div>
        )}

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 mt-8 pt-6 border-t border-[#E5E0D8]">
          <a href="/herramientas"
             class="inline-flex items-center gap-2 font-semibold text-sm px-5 py-2.5 no-underline transition-colors duration-200"
             style="background: #B91C1C; color: white; font-family: 'DM Sans', sans-serif;"
             onmouseover="this.style.background='#991B1B'"
             onmouseout="this.style.background='#B91C1C'">
            Ver todos los mercados <ArrowRight size={14} />
          </a>
          <a href="/noticias"
             class="inline-flex items-center text-sm px-5 py-2.5 no-underline transition-colors duration-200"
             style="border: 1.5px solid #1C1917; color: #1C1917; font-family: 'DM Sans', sans-serif;"
             onmouseover="this.style.color='#B91C1C'; this.style.borderColor='#B91C1C'"
             onmouseout="this.style.color='#1C1917'; this.style.borderColor='#1C1917'">
            Últimas noticias
          </a>
        </div>
      </div>

      <!-- DERECHA: 3 artículos secundarios (40%) -->
      <div class="lg:col-span-2 lg:pl-10 border-t-2 border-[#1C1917] lg:border-t-0 pt-8 lg:pt-0">
        <p class="text-[10px] font-bold uppercase tracking-[0.22em] pb-4 mb-1 border-b border-[#E5E0D8]"
           style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
          También hoy
        </p>
        {noticiasSecundarias.slice(0, 3).map((n, i) => (
          <a href={`/noticias/${n.slug}`}
             class={`block group no-underline py-5 ${i < 2 ? 'border-b border-[#E5E0D8]' : ''}`}>
            {n.categoria && (
              <span class="text-[10px] font-bold uppercase tracking-[0.15em] mb-2 block"
                    style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                {n.categoria.nombre}
              </span>
            )}
            <h3 class="font-bold leading-snug text-[#1C1917] group-hover:text-[#B91C1C] transition-colors duration-200 line-clamp-3"
                style="font-family: 'Playfair Display', serif; font-size: 18px;">
              {n.titulo}
            </h3>
            <span class="text-xs mt-2 block" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
              {formatFecha(n.creadoEn)}
            </span>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>

<script>
  const el = document.getElementById('hero-fecha');
  if (el) {
    el.textContent = new Intl.DateTimeFormat('es', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    }).format(new Date());
  }
</script>
