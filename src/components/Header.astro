---
// Header.astro - Inversax
import { Search, Globe, Menu, ChevronDown } from 'lucide-astro';
import { getCategorias, getPaises } from '../db/queries';

const categorias    = await getCategorias();
const paises        = await getPaises();
const paisesLocales = paises.filter(p => p.codigo !== 'global');

const navLinks = [
  { label: "Noticias",     href: "/noticias"     },
  { label: "Herramientas", href: "/herramientas" },
];

// ── TICKER ──────────────────────────────────────────────────────
type TickerItem = { symbol: string; price: string; change: string; up: boolean };
let ticker: TickerItem[] = [];

const formatPrice = (p: number) => {
  if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
  if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
};

try {
  const res  = await fetch(new URL('/api/precios', Astro.url));
  const data = await res.json();
  ticker = data.slice(0, 10).map((c: any) => ({
    symbol: c.symbol,
    price:  formatPrice(c.price),
    change: `${c.change24 >= 0 ? '+' : ''}${c.change24.toFixed(2)}%`,
    up:     c.change24 >= 0,
  }));
} catch (e) {
  ticker = ['BTC','ETH','USDT','BNB','SOL','XRP','USDC','DOGE','ADA','TRX'].map(s => ({
    symbol: s, price: '—', change: '—', up: true,
  }));
}
---

<header class="fixed top-0 left-0 right-0 w-full z-[100] bg-[#0A0B0D]" style="font-family: 'DM Sans', sans-serif;">

  <!-- TOP BAR: ticker + selector de país -->
  <div class="bg-[#111318] border-b border-white/[0.07] h-9 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex items-center justify-between">

      <!-- Ticker -->
      <div class="flex-1 overflow-hidden" style="mask-image: linear-gradient(to right, transparent, black 50px, black calc(100% - 50px), transparent);">
        <div id="ticker-track" class="ticker-track flex gap-8 whitespace-nowrap w-max">
          {[...ticker, ...ticker].map((coin) => (
            <span class="ticker-item inline-flex items-center gap-1.5 text-[11.5px]">
              <span class="font-bold text-white/40 tracking-widest text-[10px]">{coin.symbol}</span>
              <span class="ticker-price text-white/80 font-medium">{coin.price}</span>
              <span class={`ticker-change text-[11px] font-medium ${coin.up ? 'text-emerald-400' : 'text-red-400'}`}>
                {coin.change}
              </span>
            </span>
          ))}
        </div>
      </div>

      <!-- Selector de país (desktop) — navega a /pais/{codigo} -->
      <div class="hidden md:flex items-center gap-1.5 pl-6 flex-shrink-0">
        <Globe size={13} class="text-white/40" />
        <select
          id="country-select"
          class="bg-transparent border-none text-white/40 text-xs cursor-pointer outline-none max-w-[140px]"
          style="font-family: 'DM Sans', sans-serif;"
        >
          <option value="global" class="bg-[#1A1D24] text-white">Global</option>
          {paisesLocales.map((p) => (
            <option value={p.codigo} class="bg-[#1A1D24] text-white text-xs">{p.nombre}</option>
          ))}
        </select>
      </div>

    </div>
  </div>

  <!-- MAIN NAV -->
  <div class="border-b border-white/[0.07]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center gap-6">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 no-underline">
        <svg width="26" height="26" viewBox="0 0 28 28" fill="none">
          <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="none" stroke="#D4A843" stroke-width="2"/>
          <polyline points="8,16 12,12 16,15 20,10" stroke="#D4A843" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-extrabold text-[22px] text-white tracking-tight leading-none" style="font-family: 'Syne', sans-serif;">
          Inversax<span class="text-[#D4A843] font-normal text-sm">.com</span>
        </span>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-1 flex-1">

        <!-- Dropdown Mercados → links a /{cat.slug} -->
        <div class="relative" id="mercados-wrapper">
          <button
            id="mercados-toggle"
            class="flex items-center gap-1.5 text-white/50 hover:text-white hover:bg-white/5 text-sm px-3 py-1.5 rounded-lg transition-colors duration-200 cursor-pointer border-none bg-transparent"
          >
            Mercados
            <ChevronDown size={14} id="mercados-chevron" class="transition-transform duration-200" />
          </button>

          <div
            id="mercados-dropdown"
            class="absolute top-full left-0 mt-2 bg-[#111318] border border-white/[0.07] rounded-2xl p-3 hidden"
            style="min-width: 260px; box-shadow: 0 20px 60px rgba(0,0,0,0.7);"
          >
            <div class="grid grid-cols-2 gap-0.5">
              {categorias.map((cat) => (
                <a
                  href={`/${cat.slug}`}
                  class="flex flex-col gap-0.5 px-3 py-2.5 rounded-xl no-underline hover:bg-white/5 transition-colors duration-150 group"
                >
                  <span class="text-white/80 group-hover:text-white text-sm font-medium transition-colors duration-150">
                    {cat.nombre}
                  </span>
                </a>
              ))}
            </div>
            <!-- Atajo a todas las noticias -->
            <div class="border-t border-white/[0.07] mt-2 pt-2">
              <a
                href="/noticias"
                class="flex items-center justify-center px-3 py-2 rounded-xl no-underline hover:bg-white/5 text-white/40 hover:text-white text-xs transition-colors duration-150"
              >
                Ver todas las noticias →
              </a>
            </div>
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-white/50 hover:text-white hover:bg-white/5 text-sm px-3 py-1.5 rounded-lg transition-colors duration-200 no-underline whitespace-nowrap"
          >
            {link.label}
          </a>
        ))}

      </nav>

      <!-- Acciones -->
      <div class="flex items-center gap-2 flex-shrink-0 ml-auto lg:ml-0">
        <button
          id="search-toggle"
          class="w-9 h-9 flex items-center justify-center bg-white/5 border border-white/[0.07] text-white/50 hover:text-white hover:border-white/20 rounded-lg transition-colors duration-200 cursor-pointer"
        >
          <Search size={16} />
        </button>
        <button
          id="menu-toggle"
          class="lg:hidden w-9 h-9 flex items-center justify-center text-white/50 hover:text-white transition-colors duration-200 cursor-pointer bg-transparent border-none"
        >
          <Menu size={20} />
        </button>
      </div>
    </div>

    <!-- Search bar -->
    <div id="search-bar" class="overflow-hidden border-t border-white/[0.07] bg-[#111318]" style="max-height: 0; transition: max-height 0.3s ease;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-3 text-white/40">
        <Search size={16} />
        <input
          id="search-input"
          type="text"
          placeholder="Buscar noticias, criptos, indicadores..."
          class="flex-1 bg-transparent border-none outline-none text-white text-sm placeholder:text-white/30"
          style="font-family: 'DM Sans', sans-serif;"
        />
        <kbd class="bg-white/5 border border-white/[0.07] text-white/30 text-[10px] px-1.5 py-0.5 rounded">ESC</kbd>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden overflow-hidden bg-[#111318] border-b border-white/[0.07]" style="max-height: 0; transition: max-height 0.4s ease;">
    <nav class="flex flex-col px-4 sm:px-6 py-3 gap-0.5">

      <span class="text-white/25 text-[10px] uppercase tracking-widest px-3 pt-2 pb-1">Mercados</span>
      {categorias.map((cat) => (
        <a
          href={`/${cat.slug}`}
          class="text-white/50 hover:text-white hover:bg-white/5 text-sm px-3 py-2 rounded-lg transition-colors duration-200 no-underline"
        >
          {cat.nombre}
        </a>
      ))}

      <div class="border-t border-white/[0.07] my-2" />

      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-white/50 hover:text-white hover:bg-white/5 text-sm px-3 py-2.5 rounded-lg transition-colors duration-200 no-underline"
        >
          {link.label}
        </a>
      ))}

      <!-- Selector de país mobile → navega a /pais/{codigo} -->
      <div class="flex items-center gap-2 px-3 py-2.5 border-t border-white/[0.07] mt-1">
        <Globe size={14} class="text-white/40 flex-shrink-0" />
        <select
          id="country-select-mobile"
          class="bg-transparent border-none text-white/40 text-sm outline-none flex-1 cursor-pointer"
          style="font-family: 'DM Sans', sans-serif;"
        >
          <option value="global" class="bg-[#1A1D24] text-white">Global</option>
          {paisesLocales.map((p) => (
            <option value={p.codigo} class="bg-[#1A1D24] text-white">{p.nombre}</option>
          ))}
        </select>
      </div>

    </nav>
  </div>

</header>

<style>
  .ticker-track {
    animation: ticker-scroll 35s linear infinite;
  }
  .ticker-track:hover {
    animation-play-state: paused;
  }
  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  // ── Búsqueda ──────────────────────────────────────────────────
  const searchToggle = document.getElementById('search-toggle');
  const searchBar    = document.getElementById('search-bar') as HTMLElement;
  const searchInput  = document.getElementById('search-input') as HTMLInputElement;

  searchToggle?.addEventListener('click', () => {
    const isOpen = searchBar.style.maxHeight !== '0px' && searchBar.style.maxHeight !== '';
    searchBar.style.maxHeight = isOpen ? '0px' : '56px';
    if (!isOpen) searchInput?.focus();
  });

  // ── Menú móvil ───────────────────────────────────────────────
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu.style.maxHeight !== '0px' && mobileMenu.style.maxHeight !== '';
    mobileMenu.style.maxHeight = isOpen ? '0px' : '600px';
  });

  // ── Dropdown Mercados ────────────────────────────────────────
  const mercadosToggle   = document.getElementById('mercados-toggle');
  const mercadosDropdown = document.getElementById('mercados-dropdown') as HTMLElement;
  const mercadosChevron  = document.getElementById('mercados-chevron') as HTMLElement;
  const mercadosWrapper  = document.getElementById('mercados-wrapper');

  function openDropdown() {
    mercadosDropdown.classList.remove('hidden');
    mercadosChevron.style.transform = 'rotate(180deg)';
  }
  function closeDropdown() {
    mercadosDropdown.classList.add('hidden');
    mercadosChevron.style.transform = 'rotate(0deg)';
  }

  mercadosToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    mercadosDropdown.classList.contains('hidden') ? openDropdown() : closeDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!mercadosWrapper?.contains(e.target as Node)) closeDropdown();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      searchBar.style.maxHeight = '0px';
      closeDropdown();
    }
  });

  // ── Selector de país → navega a /pais/{codigo} o / si global ─
  function onCountryChange(codigo: string) {
    if (codigo === 'global') {
      window.location.href = '/';
    } else {
      window.location.href = `/pais/${codigo}`;
    }
  }

  // Sincronizar select con la URL actual
  const pathParts = window.location.pathname.split('/');
  // Si estamos en /pais/hn → pathParts = ['', 'pais', 'hn']
  const paisEnUrl = pathParts[1] === 'pais' ? pathParts[2] : 'global';

  const selectDesktop = document.getElementById('country-select') as HTMLSelectElement;
  const selectMobile  = document.getElementById('country-select-mobile') as HTMLSelectElement;

  if (selectDesktop) selectDesktop.value = paisEnUrl;
  if (selectMobile)  selectMobile.value  = paisEnUrl;

  selectDesktop?.addEventListener('change', () => onCountryChange(selectDesktop.value));
  selectMobile?.addEventListener('change',  () => onCountryChange(selectMobile.value));

  // ── Active link ──────────────────────────────────────────────
  const path = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach((link) => {
    if (link.getAttribute('href') === path) {
      link.classList.replace('text-white/50', 'text-[#D4A843]');
    }
  });

  // ── POLLING TICKER cada 5 min ────────────────────────────────
  const TICKER_COUNT = 10;

  function formatPrice(p: number): string {
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  }

  async function actualizarTicker() {
    try {
      const res = await fetch('/api/precios');
      if (!res.ok) return;
      const data = await res.json();
      const items = document.querySelectorAll('#ticker-track .ticker-item');

      data.slice(0, TICKER_COUNT).forEach((coin: any, i: number) => {
        const up     = coin.change24 >= 0;
        const precio = formatPrice(coin.price);
        const cambio = `${up ? '+' : ''}${coin.change24.toFixed(2)}%`;

        [items[i], items[i + TICKER_COUNT]].forEach((item) => {
          if (!item) return;
          const priceEl  = item.querySelector('.ticker-price');
          const changeEl = item.querySelector('.ticker-change');
          if (priceEl)  priceEl.textContent = precio;
          if (changeEl) {
            changeEl.textContent = cambio;
            changeEl.className = `ticker-change text-[11px] font-medium ${up ? 'text-emerald-400' : 'text-red-400'}`;
          }
        });
      });
    } catch (e) {
      console.warn('[Ticker polling]', e);
    }
  }

  setInterval(actualizarTicker, 300_000);
</script>
