---
// Header.astro — Inversax (diseño naranja, sin selector de país)
import { Search, Menu } from 'lucide-astro';
import { getCategorias } from '../db/queries';

interface Props {
  categorias?: Array<{ nombre: string; slug: string }>;
  paises?: unknown; // aceptado por compatibilidad, no se usa
}

const { categorias: categoriasProp } = Astro.props;
const db         = Astro.locals.db;
const categorias = categoriasProp ?? await getCategorias(db);

const tipoBadge: Record<string, string> = {
  crypto: '#1D4ED8',
  forex:  '#15803D',
  metal:  '#B45309',
  stock:  '#374151',
};
const tipoLabel: Record<string, string> = {
  crypto: 'C',
  forex:  'FX',
  metal:  'M',
  stock:  'S',
};

const TICKER_SKELETON = [
  { symbol: 'BTC',     tipo: 'crypto' },
  { symbol: 'ETH',     tipo: 'crypto' },
  { symbol: 'SOL',     tipo: 'crypto' },
  { symbol: 'XRP',     tipo: 'crypto' },
  { symbol: 'ADA',     tipo: 'crypto' },
  { symbol: 'BNB',     tipo: 'crypto' },
  { symbol: 'EUR/USD', tipo: 'forex'  },
  { symbol: 'GBP/USD', tipo: 'forex'  },
  { symbol: 'USD/JPY', tipo: 'forex'  },
  { symbol: 'USD/CHF', tipo: 'forex'  },
  { symbol: 'AUD/USD', tipo: 'forex'  },
  { symbol: 'XAU',     tipo: 'metal'  },
  { symbol: 'XAG',     tipo: 'metal'  },
  { symbol: 'AAPL',    tipo: 'stock'  },
  { symbol: 'MSFT',    tipo: 'stock'  },
  { symbol: 'NVDA',    tipo: 'stock'  },
  { symbol: 'GOOGL',   tipo: 'stock'  },
  { symbol: 'AMZN',    tipo: 'stock'  },
] as const;
---

<header class="fixed top-0 left-0 right-0 w-full z-[100]"
        style="background:#FFFFFF; border-bottom:1px solid #E2DDD8; font-family:'DM Sans',sans-serif; box-shadow:0 1px 4px rgba(0,0,0,0.06);">

  <!-- TOP BAR: ticker de precios -->
  <div style="background:#F5F2EE; border-bottom:1px solid #E2DDD8; height:34px; overflow:hidden;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex items-center">
      <div class="flex-1 overflow-hidden"
           style="mask-image:linear-gradient(to right,transparent,black 40px,black calc(100% - 40px),transparent);">
        <div id="ticker-track" class="ticker-track flex gap-7 whitespace-nowrap w-max">
          {[...TICKER_SKELETON, ...TICKER_SKELETON].map((item) => (
            <span class="ticker-item inline-flex items-center gap-1.5 text-[11px]"
                  data-symbol={item.symbol} data-tipo={item.tipo}>
              <span class="text-[8px] font-bold tracking-widest"
                    style={`color:${tipoBadge[item.tipo]};`}>{tipoLabel[item.tipo]}</span>
              <span class="font-semibold text-[10px] tracking-wide" style="color:#555555;">{item.symbol}</span>
              <span class="ticker-price font-medium animate-pulse" style="color:#AAAAAA;">···</span>
              <span class="ticker-change text-[10px] font-medium" style="color:transparent;"></span>
              <span class="text-[10px]" style="color:#D0C9C0;">·</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN NAV -->
  <div style="background:#FFFFFF;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center gap-4" style="height:60px;">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0 no-underline">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
          <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="none" stroke="#FF8C42" stroke-width="2.5"/>
          <polyline points="8,17 12,12 16,15 20,10" stroke="#FF8C42" stroke-width="2.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-bold leading-none" style="font-size:19px; color:#1A1A1A; font-family:'DM Sans',sans-serif;">
          Inversax<span class="font-semibold text-sm" style="color:#FF8C42;">.com</span>
        </span>
      </a>

      <!-- Divisor desktop -->
      <div class="hidden lg:block h-5 w-px flex-shrink-0" style="background:#E2DDD8;"></div>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-0.5 flex-1">
        <a href="/herramientas"
           class="nav-link text-sm font-semibold px-3 py-1.5 rounded-md no-underline transition-colors duration-200 whitespace-nowrap"
           style="color:#FF8C42;"
           onmouseover="this.style.background='#FFF5EE';"
           onmouseout="this.style.background='';">
          Herramientas
        </a>
        <a href="/herramientas/calculadoras"
           class="nav-link text-sm px-3 py-1.5 rounded-md no-underline transition-colors duration-200 whitespace-nowrap"
           style="color:#555555;"
           onmouseover="this.style.color='#1A1A1A'; this.style.background='#F5F2EE';"
           onmouseout="this.style.color='#555555'; this.style.background='';">
          Calculadoras
        </a>
        <a href="/herramientas/comparar-brokers"
           class="nav-link text-sm px-3 py-1.5 rounded-md no-underline transition-colors duration-200 whitespace-nowrap"
           style="color:#555555;"
           onmouseover="this.style.color='#1A1A1A'; this.style.background='#F5F2EE';"
           onmouseout="this.style.color='#555555'; this.style.background='';">
          Comparar Brokers
        </a>
        <a href="/noticias"
           class="nav-link text-sm px-3 py-1.5 rounded-md no-underline transition-colors duration-200 whitespace-nowrap"
           style="color:#555555;"
           onmouseover="this.style.color='#1A1A1A'; this.style.background='#F5F2EE';"
           onmouseout="this.style.color='#555555'; this.style.background='';">
          Artículos
        </a>
      </nav>

      <!-- Acciones: CTA + búsqueda + menú móvil -->
      <div class="flex items-center gap-2 ml-auto lg:ml-0 flex-shrink-0">
        <a href="/herramientas/calculadoras"
           class="hidden lg:inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg no-underline transition-all duration-200"
           style="background:#FF8C42; color:white;"
           onmouseover="this.style.background='#E87832';"
           onmouseout="this.style.background='#FF8C42';">
          Calcular ahora
        </a>
        <button id="search-toggle"
                class="w-9 h-9 flex items-center justify-center rounded-lg border transition-colors duration-200 cursor-pointer"
                style="background:#F5F2EE; border-color:#E2DDD8; color:#909090;"
                aria-label="Buscar"
                onmouseover="this.style.color='#1A1A1A'; this.style.borderColor='#FF8C42';"
                onmouseout="this.style.color='#909090'; this.style.borderColor='#E2DDD8';">
          <Search size={15} />
        </button>
        <button id="menu-toggle"
                class="lg:hidden w-9 h-9 flex items-center justify-center cursor-pointer border-none"
                style="color:#555555; background:transparent;"
                aria-label="Menú">
          <Menu size={20} />
        </button>
      </div>
    </div>

    <!-- Barra de búsqueda -->
    <div id="search-bar"
         style="max-height:0; transition:max-height 0.25s ease; overflow:hidden; border-top:1px solid #E2DDD8; background:#F5F2EE;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-3" style="color:#909090;">
        <Search size={16} class="flex-shrink-0" />
        <input id="search-input" type="text"
               placeholder="Buscar artículos, criptos, herramientas..."
               class="flex-1 bg-transparent border-none outline-none text-sm"
               style="color:#1A1A1A; font-family:'DM Sans',sans-serif;"
               autocomplete="off" />
        <kbd class="text-[10px] px-1.5 py-0.5 flex-shrink-0"
             style="background:#E2DDD8; border:1px solid #D0C9C0; color:#909090; border-radius:3px;">ESC</kbd>
      </div>
    </div>

    <!-- Resultados de búsqueda -->
    <div id="search-results" class="hidden"
         style="background:#FFFFFF; border-top:1px solid #E2DDD8; box-shadow:0 8px 24px rgba(0,0,0,0.08);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3">
        <div id="search-results-inner" class="flex flex-col gap-1"></div>
        <div id="search-empty" class="hidden text-sm py-4 text-center" style="color:#909090;">
          Sin resultados para esta búsqueda
        </div>
        <div id="search-loading" class="hidden text-sm py-4 text-center" style="color:#909090;">
          Buscando...
        </div>
      </div>
    </div>
  </div>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="lg:hidden overflow-hidden"
       style="max-height:0; transition:max-height 0.4s ease; background:#FFFFFF; border-bottom:1px solid #E2DDD8;">
    <nav class="flex flex-col px-4 py-3 gap-1">
      <a href="/herramientas"
         class="text-sm font-semibold px-3 py-2.5 rounded-md no-underline"
         style="color:#FF8C42;"
         onmouseover="this.style.background='#FFF5EE';"
         onmouseout="this.style.background='';">
        Herramientas
      </a>
      <a href="/herramientas/calculadoras"
         class="text-sm px-3 py-2.5 rounded-md no-underline"
         style="color:#555555;"
         onmouseover="this.style.background='#F5F2EE'; this.style.color='#1A1A1A';"
         onmouseout="this.style.background=''; this.style.color='#555555';">
        Calculadoras financieras
      </a>
      <a href="/herramientas/comparar-brokers"
         class="text-sm px-3 py-2.5 rounded-md no-underline"
         style="color:#555555;"
         onmouseover="this.style.background='#F5F2EE'; this.style.color='#1A1A1A';"
         onmouseout="this.style.background=''; this.style.color='#555555';">
        Comparar Brokers
      </a>
      <a href="/noticias"
         class="text-sm px-3 py-2.5 rounded-md no-underline"
         style="color:#555555;"
         onmouseover="this.style.background='#F5F2EE'; this.style.color='#1A1A1A';"
         onmouseout="this.style.background=''; this.style.color='#555555';">
        Artículos
      </a>
      <div class="pt-2 pb-1">
        <a href="/herramientas/calculadoras"
           class="flex items-center justify-center text-sm font-semibold px-4 py-2.5 rounded-lg no-underline"
           style="background:#FF8C42; color:white;">
          Calcular ahora →
        </a>
      </div>
    </nav>
  </div>

</header>

<style>
  .ticker-track { animation: ticker-scroll 55s linear infinite; }
  .ticker-track:hover { animation-play-state: paused; }
  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
  .ticker-item[data-loaded="false"] { display: none; }
</style>

<script>
  // ── Búsqueda ──────────────────────────────────────────────────
  const searchToggle       = document.getElementById('search-toggle');
  const searchBar          = document.getElementById('search-bar') as HTMLElement;
  const searchInput        = document.getElementById('search-input') as HTMLInputElement;
  const searchResults      = document.getElementById('search-results') as HTMLElement;
  const searchResultsInner = document.getElementById('search-results-inner') as HTMLElement;
  const searchEmpty        = document.getElementById('search-empty') as HTMLElement;
  const searchLoading      = document.getElementById('search-loading') as HTMLElement;

  let searchOpen = false;
  let debounceTimer: ReturnType<typeof setTimeout>;

  function openSearch() {
    searchOpen = true;
    searchBar.style.maxHeight = '56px';
    setTimeout(() => searchInput?.focus(), 50);
  }
  function closeSearch() {
    searchOpen = false;
    searchBar.style.maxHeight = '0px';
    searchResults.classList.add('hidden');
    if (searchInput) searchInput.value = '';
  }

  searchToggle?.addEventListener('click', () => searchOpen ? closeSearch() : openSearch());
  document.addEventListener('click', (e) => {
    const header = document.querySelector('header');
    if (!header?.contains(e.target as Node) && searchOpen) closeSearch();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeSearch(); });

  function formatFechaDiff(fecha: string) {
    const diff  = Date.now() - new Date(fecha).getTime();
    const horas = Math.floor(diff / 3600000);
    if (horas < 1)  return 'Hace unos min';
    if (horas < 24) return `Hace ${horas}h`;
    return `Hace ${Math.floor(horas / 24)}d`;
  }

  async function buscar(q: string) {
    if (q.length < 2) { searchResults.classList.add('hidden'); return; }
    searchLoading.classList.remove('hidden');
    searchEmpty.classList.add('hidden');
    searchResultsInner.innerHTML = '';
    searchResults.classList.remove('hidden');
    try {
      const res  = await fetch(`/api/buscar?q=${encodeURIComponent(q)}`);
      const json = await res.json() as any;
      searchLoading.classList.add('hidden');
      if (!json.ok || json.data.length === 0) {
        searchEmpty.classList.remove('hidden');
        return;
      }
      searchResultsInner.innerHTML = json.data.map((n: any) => `
        <a href="/noticias/${n.slug}"
           class="flex items-center gap-3 px-3 py-2.5 no-underline rounded-md transition-colors duration-150"
           style="border-radius:6px;"
           onmouseover="this.style.background='#F5F2EE';"
           onmouseout="this.style.background='';">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              ${n.categoria ? `<span class="text-[10px] font-bold uppercase tracking-wider" style="color:#FF8C42;">${n.categoria.nombre}</span>` : ''}
              <span class="text-[10px] ml-auto" style="color:#AAAAAA;">${n.creadoEn ? formatFechaDiff(n.creadoEn) : ''}</span>
            </div>
            <p class="text-sm font-medium leading-snug truncate" style="color:#1A1A1A; margin:0;">${n.titulo}</p>
          </div>
        </a>
      `).join('');
    } catch {
      searchLoading.classList.add('hidden');
      searchEmpty.classList.remove('hidden');
    }
  }

  searchInput?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const q = searchInput.value.trim();
    if (q.length < 2) { searchResults.classList.add('hidden'); return; }
    debounceTimer = setTimeout(() => buscar(q), 300);
  });

  // ── Menú móvil ───────────────────────────────────────────────
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu.style.maxHeight !== '0px' && mobileMenu.style.maxHeight !== '';
    mobileMenu.style.maxHeight = isOpen ? '0px' : '400px';
  });

  // ── Active link highlight ────────────────────────────────────
  const path = window.location.pathname;
  document.querySelectorAll<HTMLElement>('header .nav-link').forEach((link) => {
    const href = link.getAttribute('href');
    if (href && href !== '/' && path.startsWith(href)) {
      link.style.color = '#FF8C42';
      link.style.fontWeight = '600';
    }
  });

  // ── TICKER (client-side) ─────────────────────────────────────
  const TICKER_COUNT = { crypto: 6, forex: 5, metal: 2, stock: 5 };

  function fmtPrice(p: number): string {
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  }
  function fmtForex(p: number): string {
    if (!p) return '—';
    if (p >= 100) return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  }

  function patchTicker(items: { symbol: string; price: string; change?: string; up?: boolean }[]) {
    const nodes = document.querySelectorAll<HTMLElement>('#ticker-track .ticker-item');
    items.forEach(({ symbol, price, change, up }) => {
      nodes.forEach((node) => {
        if (node.dataset.symbol?.toUpperCase() !== symbol.toUpperCase()) return;
        const priceEl  = node.querySelector('.ticker-price');
        const changeEl = node.querySelector('.ticker-change');
        if (priceEl) {
          priceEl.textContent = price;
          priceEl.classList.remove('animate-pulse');
          (priceEl as HTMLElement).style.color = '#1A1A1A';
        }
        if (changeEl && change !== undefined) {
          changeEl.textContent = change;
          (changeEl as HTMLElement).style.color = up ? '#15803D' : '#DC2626';
        }
        node.dataset.loaded = 'true';
      });
    });
  }

  function ocultarSinPrecio() {
    document.querySelectorAll<HTMLElement>('#ticker-track .ticker-item').forEach((node) => {
      if (node.dataset.loaded !== 'true') node.dataset.loaded = 'false';
    });
  }

  async function cargarTicker() {
    const [resCripto, resForex, resMetales, resAcciones] = await Promise.allSettled([
      fetch('/api/precios'),
      fetch('/api/forex'),
      fetch('/api/metales'),
      fetch('/api/acciones?limit=10'),
    ]);
    if (resCripto.status === 'fulfilled' && resCripto.value.ok) {
      const data = await resCripto.value.json() as any;
      patchTicker(data.slice(0, TICKER_COUNT.crypto).map((c: any) => ({
        symbol: c.symbol.toUpperCase(),
        price:  fmtPrice(c.price),
        change: `${c.change24 >= 0 ? '+' : ''}${c.change24.toFixed(2)}%`,
        up:     c.change24 >= 0,
      })));
    }
    if (resForex.status === 'fulfilled' && resForex.value.ok) {
      const data  = await resForex.value.json() as any;
      const forex = data.data ?? data;
      patchTicker(forex.slice(0, TICKER_COUNT.forex).map((f: any) => ({
        symbol: f.par,
        price:  fmtForex(f.precio),
      })));
    }
    if (resMetales.status === 'fulfilled' && resMetales.value.ok) {
      const data    = await resMetales.value.json() as any;
      const metales = data.data ?? data;
      patchTicker(metales.slice(0, TICKER_COUNT.metal).map((m: any) => ({
        symbol: m.simbolo,
        price:  `$${m.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
      })));
    }
    if (resAcciones.status === 'fulfilled' && resAcciones.value.ok) {
      const json = await resAcciones.value.json() as any;
      if (json.ok) {
        patchTicker(json.data.filter((a: any) => a.precio > 0).slice(0, TICKER_COUNT.stock).map((a: any) => ({
          symbol: a.ticker,
          price:  `$${a.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
          change: `${a.cambioPct >= 0 ? '+' : ''}${a.cambioPct.toFixed(2)}%`,
          up:     a.alza,
        })));
      }
    }
    ocultarSinPrecio();
  }

  cargarTicker();
  setInterval(cargarTicker, 300_000);
</script>
