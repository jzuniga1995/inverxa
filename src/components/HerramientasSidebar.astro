---
// src/components/HerramientasSidebar.astro
// Uso: <HerramientasSidebar /> en la página de artículo
// Props opcionales: categoría del artículo para highlight futuro
import {
  BarChart2,
  TrendingUp,
  Layers,
  Landmark,
  DollarSign,
  Calculator,
  GitCompare,
  ArrowRight,
  Wrench,
} from 'lucide-astro';

interface Herramienta {
  titulo:   string;
  desc:     string;
  href:     string;
  icon:     string;
  badge?:   string; // etiqueta opcional: "Nuevo", "Live", etc.
}

const herramientas: Herramienta[] = [
  {
    titulo: "Mercados Cripto",
    desc:   "Precios en vivo de las principales criptomonedas.",
    href:   "/herramientas/cripto",
    icon:   "chart",
    badge:  "Live",
  },
  {
    titulo: "Forex",
    desc:   "Tipos de cambio de divisas globales y LATAM.",
    href:   "/herramientas/forex",
    icon:   "forex",
    badge:  "Live",
  },
  {
    titulo: "Metales Preciosos",
    desc:   "Oro, plata, platino y paladio por onza troy.",
    href:   "/herramientas/metales",
    icon:   "layers",
  },
  {
    titulo: "Acciones",
    desc:   "Cotizaciones en tiempo real del mercado estadounidense.",
    href:   "/herramientas/acciones",
    icon:   "acciones",
    badge:  "Live",
  },
  {
    titulo: "Precio del Dólar",
    desc:   "Dólar oficial y paralelo por país.",
    href:   "/herramientas/dolar",
    icon:   "dollar",
  },
  {
    titulo: "Calculadoras de Trading",
    desc:   "Pips, posición, ganancias y margen para Forex.",
    href:   "/herramientas/calculadora-trading",
    icon:   "calc2",
  },
  {
    titulo: "Calculadora Cripto",
    desc:   "Convertí cripto a pesos y calculá ganancias.",
    href:   "/herramientas/calculadora-cripto",
    icon:   "calc",
  },
  {
    titulo: "Comparar Brokers",
    desc:   "Spreads, regulación y plataformas para LATAM.",
    href:   "/herramientas/comparar-brokers",
    icon:   "compare",
  },
];
---

<!-- ─────────────────────────────────────────────────────────
     SIDEBAR DESKTOP (sticky) + SECCIÓN MOBILE (debajo)
     Uso en la página de artículo:

     <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-10">
       <article>...tu contenido...</article>
       <HerramientasSidebar />
     </div>
───────────────────────────────────────────────────────────── -->

<aside
  class="herramientas-sidebar w-full"
  style="font-family: 'DM Sans', sans-serif;"
  aria-label="Herramientas financieras"
>
  <div class="lg:sticky lg:top-6">

    <!-- Header -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <Wrench size={15} style="color: #B91C1C;" />
        <span
          class="font-bold text-[13px] uppercase tracking-wide"
          style="color: #1C1917; font-family: 'DM Sans', sans-serif;"
        >
          Herramientas
        </span>
      </div>
      <a
        href="/herramientas"
        class="text-[11px] no-underline transition-colors duration-200 flex items-center gap-1"
        style="color: #78716C;"
        onmouseover="this.style.color='#B91C1C'"
        onmouseout="this.style.color='#78716C'"
      >
        Ver todas <ArrowRight size={11} />
      </a>
    </div>

    <!-- Lista desktop: compacta, una columna -->
    <div class="hidden lg:flex flex-col overflow-hidden" style="background: #FFFFFF; border: 1px solid #E5E0D8;">
      {herramientas.map((h, i) => (
        <a
          href={h.href}
          class={`herramienta-item group flex items-center gap-3 px-4 py-3.5 no-underline transition-all duration-200 ${i < herramientas.length - 1 ? 'border-b' : ''}`}
          style={i < herramientas.length - 1 ? 'border-color: #E5E0D8;' : ''}
          onmouseover="this.style.background='#F9F7F4'"
          onmouseout="this.style.background=''"
        >
          <!-- Ícono -->
          <div
            class="w-8 h-8 flex items-center justify-center flex-shrink-0 transition-colors duration-200"
            style={`background: ${
              h.icon === 'chart'    ? 'rgba(29,78,216,0.08)'  :
              h.icon === 'forex'   ? 'rgba(21,128,61,0.08)'  :
              h.icon === 'layers'  ? 'rgba(180,83,9,0.08)'   :
              h.icon === 'acciones'? 'rgba(55,65,81,0.08)'   :
              'rgba(120,113,108,0.08)'
            }; color: ${
              h.icon === 'chart'    ? '#1D4ED8' :
              h.icon === 'forex'   ? '#15803D' :
              h.icon === 'layers'  ? '#B45309' :
              h.icon === 'acciones'? '#374151' :
              '#78716C'
            };`}
          >
            {h.icon === "chart"    && <BarChart2   size={14} />}
            {h.icon === "forex"    && <TrendingUp  size={14} />}
            {h.icon === "layers"   && <Layers      size={14} />}
            {h.icon === "acciones" && <Landmark    size={14} />}
            {h.icon === "dollar"   && <DollarSign  size={14} />}
            {h.icon === "calc"     && <Calculator  size={14} />}
            {h.icon === "calc2"    && <Calculator  size={14} />}
            {h.icon === "compare"  && <GitCompare  size={14} />}
          </div>

          <!-- Texto -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span
                class="herramienta-titulo text-[13px] font-semibold leading-tight transition-colors duration-200"
                style="color: #1C1917; font-family: 'DM Sans', sans-serif;"
              >
                {h.titulo}
              </span>
              {h.badge && (
                <span class="text-[9px] font-bold px-1.5 py-0.5 uppercase tracking-wider flex-shrink-0"
                      style="background: #F0FDF4; color: #15803D; border: 1px solid rgba(21,128,61,0.2);">
                  {h.badge}
                </span>
              )}
            </div>
            <p class="text-[11px] leading-snug mt-0.5 truncate" style="color: #78716C;">{h.desc}</p>
          </div>

          <!-- Arrow -->
          <ArrowRight size={12} class="herramienta-arrow flex-shrink-0 transition-colors duration-200 group-hover:translate-x-0.5 transform" style="color: #D6D0C8;" />
        </a>
      ))}
    </div>

    <!-- Grid mobile: 2 columnas, debajo del artículo -->
    <div class="lg:hidden grid grid-cols-2 sm:grid-cols-4 gap-3">
      {herramientas.map((h) => (
        <a
          href={h.href}
          class="group flex flex-col gap-3 p-4 no-underline transition-all duration-200 hover:-translate-y-0.5"
          style="background: #FFFFFF; border: 1px solid #E5E0D8;"
          onmouseover="this.style.borderColor='rgba(185,28,28,0.25)'"
          onmouseout="this.style.borderColor='#E5E0D8'"
        >
          <div class="flex items-center justify-between">
            <div
              class="w-8 h-8 flex items-center justify-center transition-colors duration-200"
              style={`background: ${
                h.icon === 'chart'    ? 'rgba(29,78,216,0.08)'  :
                h.icon === 'forex'   ? 'rgba(21,128,61,0.08)'  :
                h.icon === 'layers'  ? 'rgba(180,83,9,0.08)'   :
                h.icon === 'acciones'? 'rgba(55,65,81,0.08)'   :
                'rgba(120,113,108,0.08)'
              }; color: ${
                h.icon === 'chart'    ? '#1D4ED8' :
                h.icon === 'forex'   ? '#15803D' :
                h.icon === 'layers'  ? '#B45309' :
                h.icon === 'acciones'? '#374151' :
                '#78716C'
              };`}
            >
              {h.icon === "chart"    && <BarChart2   size={14} />}
              {h.icon === "forex"    && <TrendingUp  size={14} />}
              {h.icon === "layers"   && <Layers      size={14} />}
              {h.icon === "acciones" && <Landmark    size={14} />}
              {h.icon === "dollar"   && <DollarSign  size={14} />}
              {h.icon === "calc"     && <Calculator  size={14} />}
              {h.icon === "calc2"    && <Calculator  size={14} />}
              {h.icon === "compare"  && <GitCompare  size={14} />}
            </div>
            {h.badge && (
              <span class="text-[9px] font-bold px-1.5 py-0.5 uppercase tracking-wider"
                    style="background: #F0FDF4; color: #15803D; border: 1px solid rgba(21,128,61,0.2);">
                {h.badge}
              </span>
            )}
          </div>
          <div>
            <span
              class="herramienta-titulo-mobile text-[12px] font-bold leading-snug block transition-colors duration-200"
              style="color: #1C1917; font-family: 'DM Sans', sans-serif;"
            >
              {h.titulo}
            </span>
            <p class="text-[11px] leading-snug mt-0.5 line-clamp-2" style="color: #78716C;">{h.desc}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA banner -->
    <a
      href="/herramientas"
      class="group mt-3 hidden lg:flex items-center justify-between px-4 py-3 no-underline transition-all duration-200"
      style="background: #FEF2F2; border: 1px solid rgba(185,28,28,0.2);"
      onmouseover="this.style.borderColor='rgba(185,28,28,0.45)'; this.style.background='#FEE2E2';"
      onmouseout="this.style.borderColor='rgba(185,28,28,0.2)'; this.style.background='#FEF2F2';"
    >
      <span class="text-[12px] font-semibold" style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
        Explorar todas las herramientas
      </span>
      <ArrowRight size={13} class="group-hover:translate-x-0.5 transform transition-transform duration-200" style="color: #B91C1C;" />
    </a>

  </div>
</aside>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
