---
interface Props {
  chartId: string;
  tvSymbol: string;
  height?: number;
}
const { chartId, tvSymbol, height = 460 } = Astro.props;
---

<!-- Header -->
<div class="px-5 py-4 flex items-center justify-between"
     style="border-bottom: 1px solid #E5E0D8;">
  <h2 class="font-bold text-base" style="color: #1C1917; font-family: 'DM Sans', sans-serif;">Gráfica de precio</h2>
  <div class="flex items-center gap-3">
    <span class="text-xs" style="color: #A8A29E;">TradingView</span>
    {tvSymbol && (
      <button
        data-chart={chartId}
        class="tv-fs-btn transition-colors p-1"
        style="color: #78716C;"
        title="Pantalla completa"
        onmouseover="this.style.color='#1C1917'"
        onmouseout="this.style.color='#78716C'"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
        </svg>
      </button>
    )}
  </div>
</div>

<!-- Chart -->
{tvSymbol ? (
  <div id={chartId} style={`height: ${height}px;`}></div>
) : (
  <div class="flex flex-col items-center justify-center py-16 gap-3">
    <p class="text-sm font-medium" style="color: #A8A29E;">Gráfica no disponible</p>
  </div>
)}

<script define:vars={{ chartId, tvSymbol, height }}>
  // ── TradingView ──
  const container = document.getElementById(chartId);
  if (container && tvSymbol) {
    const s = document.createElement('script');
    s.src = 'https://s3.tradingview.com/tv.js';
    s.onload = () => {
      new TradingView.widget({
        container_id:        chartId,
        symbol:              tvSymbol,
        interval:            'D',
        timezone:            'America/Tegucigalpa',
        theme:               'dark',
        style:               '1',
        locale:              'es',
        toolbar_bg:          '#111318',
        enable_publishing:   false,
        hide_top_toolbar:    false,
        hide_side_toolbar:   false,
        save_image:          false,
        backgroundColor:     '#111318',
        gridColor:           'rgba(255,255,255,0.03)',
        width:               '100%',
        height:              height,
        withdateranges:      true,
        allow_symbol_change: false,
        autosize:            true,
      });
    };
    document.head.appendChild(s);
  }

  // ── Fullscreen ──
  const iconExpand   = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>`;
  const iconCollapse = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>`;

  const btn   = document.querySelector(`[data-chart="${chartId}"]`);
  const chart = document.getElementById(chartId);

  btn?.addEventListener('click', () => {
    document.fullscreenElement ? document.exitFullscreen() : chart?.requestFullscreen();
  });

  document.addEventListener('fullscreenchange', () => {
    const iframe = chart?.querySelector('iframe');
    if (document.fullscreenElement) {
      btn.innerHTML = iconCollapse;
      if (chart) { chart.style.height = '100vh'; chart.style.width = '100vw'; }
      if (iframe) { iframe.style.width = '100%'; iframe.style.height = '100%'; }
    } else {
      btn.innerHTML = iconExpand;
      if (chart) { chart.style.height = `${height}px`; chart.style.width = '100%'; }
      if (iframe) { iframe.style.width = '100%'; iframe.style.height = `${height}px`; }
    }
    setTimeout(() => window.dispatchEvent(new Event('resize')), 100);
  });
</script>
