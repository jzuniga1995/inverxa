---
// Footer.astro — Inversax (naranja, sin sección Por País)
import { ArrowRight, TrendingUp } from 'lucide-astro';
import { getCategorias } from '../db/queries';

const db         = Astro.locals.db;
const categorias = await getCategorias(db);

const herramientas = [
  { label: "Mercados Cripto",       href: "/herramientas/cripto"                    },
  { label: "Forex",                  href: "/herramientas/forex"                     },
  { label: "Metales Preciosos",      href: "/herramientas/metales"                   },
  { label: "Acciones",               href: "/herramientas/acciones"                  },
  { label: "Comparar Brokers",       href: "/herramientas/comparar-brokers"          },
  { label: "Precio del Dólar",       href: "/herramientas/dolar"                     },
  { label: "Calc. de Trading",       href: "/herramientas/calculadora-trading"       },
  { label: "Calculadoras",           href: "/herramientas/calculadoras"              },
];

const calculadoras = [
  { label: "Interés Compuesto",      href: "/herramientas/calculadoras/interes-compuesto"  },
  { label: "Préstamo",               href: "/herramientas/calculadoras/prestamo"           },
  { label: "Hipoteca",               href: "/herramientas/calculadoras/hipoteca"           },
  { label: "ROI de Inversión",       href: "/herramientas/calculadoras/roi"                },
  { label: "Conversión de Divisas",  href: "/herramientas/calculadoras/conversion-divisas" },
  { label: "Ganancias en Cripto",    href: "/herramientas/calculadoras/cripto-ganancias"   },
];

const nosotros = [
  { label: "Acerca de",   href: "/acerca"     },
  { label: "Contacto",    href: "/contacto"   },
  { label: "Aviso Legal", href: "/legal"      },
  { label: "Privacidad",  href: "/privacidad" },
  { label: "Publicidad",  href: "/publicidad" },
];

const socialLinks = [
  {
    href:  "https://www.facebook.com/share/17n2iAeMxV/",
    label: "Facebook",
    svg:   '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
    fill:  true,
  },
  {
    href:  "https://www.instagram.com/inversaxtop",
    label: "Instagram",
    svg:   '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>',
    fill:  false,
  },
  {
    href:  "https://x.com/inversax",
    label: "X (Twitter)",
    svg:   '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>',
    fill:  true,
  },
  {
    href:  "https://t.me/inversax",
    label: "Telegram",
    svg:   '<path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.67l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.958.889z"/>',
    fill:  true,
  },
];
---

<footer style="background:#1A1A1A; font-family:'DM Sans',sans-serif;">

  <!-- CUERPO DEL FOOTER -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">

      <!-- Col 1 (4 cols): Marca + newsletter + redes -->
      <div class="lg:col-span-4 flex flex-col gap-6">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 no-underline w-fit">
          <svg width="26" height="26" viewBox="0 0 28 28" fill="none">
            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="none" stroke="#FF8C42" stroke-width="2"/>
            <polyline points="8,16 12,12 16,15 20,10" stroke="#FF8C42" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-bold text-[20px] leading-none" style="color:#F5F0E8;">
            Inversax<span class="font-normal text-sm" style="color:#FF8C42;">.com</span>
          </span>
        </a>

        <p class="text-sm leading-relaxed" style="color:rgba(245,240,232,0.4); max-width:300px;">
          Calculadoras financieras, herramientas de trading y comparación de brokers en español para inversores latinoamericanos.
        </p>

        <!-- Newsletter -->
        <div class="flex flex-col gap-3 p-5 rounded-xl"
             style="background:rgba(255,140,66,0.08); border:1px solid rgba(255,140,66,0.2);">
          <div>
            <span class="block text-[10px] font-bold uppercase tracking-[0.22em] mb-1"
                  style="color:#FF8C42; font-family:'DM Sans',sans-serif;">Newsletter diario</span>
            <span class="text-xs" style="color:rgba(245,240,232,0.4);">
              Recibe los mejores análisis del día
            </span>
          </div>
          <div class="flex items-center gap-2">
            <input
              id="nl-email"
              type="email"
              placeholder="tu@email.com"
              class="flex-1 border-none outline-none text-sm min-w-0 rounded-lg"
              style="background:rgba(245,240,232,0.08); color:#F5F0E8; padding:10px 14px; font-family:'DM Sans',sans-serif;"
            />
            <button
              id="nl-btn"
              class="flex-shrink-0 cursor-pointer border-none rounded-lg transition-colors duration-200"
              style="background:#FF8C42; color:white; padding:10px 16px;"
              onmouseover="this.style.background='#E87832';"
              onmouseout="this.style.background='#FF8C42';"
            >
              <ArrowRight size={16} />
            </button>
          </div>
          <p id="nl-msg" style="display:none; font-size:12px; margin:0; font-family:'DM Sans',sans-serif;"></p>
        </div>

        <!-- Redes sociales -->
        <div class="flex items-center gap-2">
          {socialLinks.map((r) => (
            <a href={r.href} aria-label={r.label} target="_blank" rel="noopener noreferrer"
               class="w-8 h-8 flex items-center justify-center no-underline rounded-lg transition-colors duration-200"
               style="border:1px solid rgba(245,240,232,0.15); color:rgba(245,240,232,0.4);"
               onmouseover="this.style.color='#FF8C42'; this.style.borderColor='rgba(255,140,66,0.4)';"
               onmouseout="this.style.color='rgba(245,240,232,0.4)'; this.style.borderColor='rgba(245,240,232,0.15)';">
              <svg width="14" height="14" viewBox="0 0 24 24"
                   fill={r.fill ? "currentColor" : "none"}
                   stroke={r.fill ? "none" : "currentColor"}
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   set:html={r.svg} />
            </a>
          ))}
        </div>

      </div>

      <!-- Divisor vertical desktop -->
      <div class="hidden lg:block lg:col-span-1">
        <div class="h-full w-px mx-auto" style="background:rgba(245,240,232,0.06);"></div>
      </div>

      <!-- Col 2: Herramientas -->
      <div class="lg:col-span-2 flex flex-col gap-4">
        <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
              style="color:rgba(245,240,232,0.3); font-family:'DM Sans',sans-serif;">
          Herramientas
        </span>
        <div style="width:20px; height:2px; background:#FF8C42; margin-bottom:4px;"></div>
        <ul class="flex flex-col gap-3 list-none p-0 m-0">
          {herramientas.map((link) => (
            <li>
              <a href={link.href}
                 class="text-sm no-underline transition-colors duration-200"
                 style="color:rgba(245,240,232,0.5);"
                 onmouseover="this.style.color='#FF8C42';"
                 onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Calculadoras -->
      <div class="lg:col-span-2 flex flex-col gap-4">
        <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
              style="color:rgba(245,240,232,0.3); font-family:'DM Sans',sans-serif;">
          Calculadoras
        </span>
        <div style="width:20px; height:2px; background:#FF8C42; margin-bottom:4px;"></div>
        <ul class="flex flex-col gap-3 list-none p-0 m-0">
          {calculadoras.map((link) => (
            <li>
              <a href={link.href}
                 class="text-sm no-underline transition-colors duration-200"
                 style="color:rgba(245,240,232,0.5);"
                 onmouseover="this.style.color='#FF8C42';"
                 onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Artículos + Inversax -->
      <div class="lg:col-span-3 flex flex-col sm:flex-row lg:flex-col gap-8 lg:gap-6">

        <!-- Artículos -->
        <div class="flex flex-col gap-4 flex-1">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
                style="color:rgba(245,240,232,0.3); font-family:'DM Sans',sans-serif;">
            Artículos
          </span>
          <div style="width:20px; height:2px; background:#FF8C42; margin-bottom:4px;"></div>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {categorias.map((cat) => (
              <li>
                <a href={`/${cat.slug}`}
                   class="text-sm no-underline transition-colors duration-200"
                   style="color:rgba(245,240,232,0.5);"
                   onmouseover="this.style.color='#FF8C42';"
                   onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                  {cat.nombre}
                </a>
              </li>
            ))}
            <li class="pt-1" style="border-top:1px solid rgba(245,240,232,0.08);">
              <a href="/noticias"
                 class="text-sm no-underline font-semibold transition-colors duration-200"
                 style="color:#FF8C42;"
                 onmouseover="this.style.color='#FFB07A';"
                 onmouseout="this.style.color='#FF8C42';">
                Ver todos →
              </a>
            </li>
          </ul>
        </div>

        <!-- Inversax -->
        <div class="flex flex-col gap-4 flex-1">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
                style="color:rgba(245,240,232,0.3); font-family:'DM Sans',sans-serif;">
            Inversax
          </span>
          <div style="width:20px; height:2px; background:#FF8C42; margin-bottom:4px;"></div>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {nosotros.map((link) => (
              <li>
                <a href={link.href}
                   class="text-sm no-underline transition-colors duration-200"
                   style="color:rgba(245,240,232,0.5);"
                   onmouseover="this.style.color='#FF8C42';"
                   onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>

  <script>
    const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
    const btn        = document.getElementById('nl-btn')   as HTMLButtonElement | null;
    const msg        = document.getElementById('nl-msg')   as HTMLParagraphElement | null;

    function showMsg(text: string, color: string) {
      if (!msg) return;
      msg.textContent  = text;
      msg.style.color  = color;
      msg.style.display = 'block';
    }

    btn?.addEventListener('click', async () => {
      if (!emailInput || !btn) return;
      const email = emailInput.value.trim();
      if (!email) return;
      btn.disabled      = true;
      btn.style.opacity = '0.6';
      showMsg('Enviando…', 'rgba(245,240,232,0.4)');
      try {
        const res  = await fetch('/api/newsletter', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ email, pais: null }),
        });
        const data = await res.json() as any;
        if (res.ok && data.success) {
          showMsg('¡Listo! Te avisamos cada día.', '#4ADE80');
          emailInput.value = '';
        } else {
          showMsg(data.error ?? 'Algo salió mal.', '#F87171');
          btn.disabled      = false;
          btn.style.opacity = '1';
        }
      } catch {
        showMsg('Error de red.', '#F87171');
        btn.disabled      = false;
        btn.style.opacity = '1';
      }
    });

    emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') btn?.click();
    });
  </script>

  <!-- Franja inferior: copyright + disclaimer -->
  <div style="border-top:1px solid rgba(245,240,232,0.08);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <span class="text-[11px]" style="color:rgba(245,240,232,0.2); font-family:'DM Sans',sans-serif;">
        © {new Date().getFullYear()} Inversax.com — Todos los derechos reservados
      </span>
      <span class="text-[11px] text-center sm:text-right"
            style="color:rgba(245,240,232,0.15); font-family:'DM Sans',sans-serif; max-width:480px;">
        <TrendingUp size={10} class="inline mr-1" style="vertical-align:middle; opacity:0.5;" />
        Contenido informativo. No constituye asesoría financiera. Invertir conlleva riesgos.
      </span>
    </div>
  </div>

</footer>
