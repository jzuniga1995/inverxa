---
// Footer.astro - Inversax
import { ArrowRight, TrendingUp } from 'lucide-astro';
import { getCategorias, getPaises } from '../db/queries';

const db = Astro.locals.db;
const categorias = await getCategorias(db);
const paises     = await getPaises(db);

const paisesLocales = paises.filter(p => p.codigo !== 'global').slice(0, 8);

const herramientas = [
  { label: "Mercados Cripto",   href: "/herramientas/cripto"   },
  { label: "Forex",             href: "/herramientas/forex"    },
  { label: "Metales Preciosos", href: "/herramientas/metales"  },
  { label: "Acciones",          href: "/herramientas/acciones" },
  { label: "Comparar Brokers",           href: "/herramientas/comparar-brokers"},
  { label: "Precio del Dólar",  href: "/herramientas/dolar"    },
  { label: "Calculadoras de Trading", href: "/herramientas/calculadora-trading" },
];


const nosotros = [
  { label: "Acerca de",   href: "/acerca"     },
  { label: "Contacto",    href: "/contacto"   },
  { label: "Aviso Legal", href: "/legal"      },
  { label: "Privacidad",  href: "/privacidad" },
  { label: "Publicidad",  href: "/publicidad" },
];
---

<footer style="background: #1C1917; font-family: 'DM Sans', sans-serif;">

  <!-- ── CUERPO DEL FOOTER ───────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">

      <!-- Col 1 (wide): Marca + tagline + newsletter destacado -->
      <div class="lg:col-span-4 flex flex-col gap-6">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 no-underline w-fit">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" fill="none" stroke="#B91C1C" stroke-width="2"/>
            <polyline points="8,16 12,12 16,15 20,10" stroke="#B91C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-bold text-[22px] leading-none" style="color: #F5F0E8; font-family: 'Playfair Display', serif;">
            Inversax<span class="font-normal text-sm" style="color: #B91C1C;">.com</span>
          </span>
        </a>

        <p class="text-sm leading-relaxed" style="color: rgba(245,240,232,0.45); max-width: 300px;">
          Tu fuente de información financiera en español. Cripto, trading y bolsa actualizado cada día para toda la comunidad hispanohablante.
        </p>

        <!-- Newsletter destacado -->
        <div class="flex flex-col gap-3 p-5" style="background: rgba(245,240,232,0.05); border: 1px solid rgba(245,240,232,0.1);">
          <div>
            <span class="block text-[10px] font-bold uppercase tracking-[0.22em] mb-1"
                  style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">Newsletter diario</span>
            <span class="text-xs" style="color: rgba(245,240,232,0.4);">
              Recibe las noticias más importantes del día
            </span>
          </div>
          <div class="flex items-center gap-2">
            <input
              id="nl-email"
              type="email"
              placeholder="tu@email.com"
              class="flex-1 border-none outline-none text-sm min-w-0"
              style="background: rgba(245,240,232,0.08); color: #F5F0E8; padding: 10px 14px; font-family: 'DM Sans', sans-serif;"
            />
            <button
              id="nl-btn"
              class="flex-shrink-0 cursor-pointer border-none transition-colors duration-200"
              style="background: #B91C1C; color: white; padding: 10px 16px;"
              onmouseover="this.style.background='#991B1B';"
              onmouseout="this.style.background='#B91C1C';"
            >
              <ArrowRight size={16} />
            </button>
          </div>
          <p id="nl-msg" style="display:none; font-size: 12px; margin: 0; font-family: 'DM Sans', sans-serif;"></p>
        </div>

        <!-- Redes sociales -->
        <div class="flex items-center gap-2">
          <a href="https://www.facebook.com/share/17n2iAeMxV/" aria-label="Facebook" target="_blank" rel="noopener noreferrer"
            class="w-8 h-8 flex items-center justify-center no-underline transition-colors duration-200"
            style="border: 1px solid rgba(245,240,232,0.15); color: rgba(245,240,232,0.4);"
            onmouseover="this.style.color='#F5F0E8'; this.style.borderColor='rgba(245,240,232,0.35)';"
            onmouseout="this.style.color='rgba(245,240,232,0.4)'; this.style.borderColor='rgba(245,240,232,0.15)';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/inversaxtop" aria-label="Instagram" target="_blank" rel="noopener noreferrer"
            class="w-8 h-8 flex items-center justify-center no-underline transition-colors duration-200"
            style="border: 1px solid rgba(245,240,232,0.15); color: rgba(245,240,232,0.4);"
            onmouseover="this.style.color='#F5F0E8'; this.style.borderColor='rgba(245,240,232,0.35)';"
            onmouseout="this.style.color='rgba(245,240,232,0.4)'; this.style.borderColor='rgba(245,240,232,0.15)';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://x.com/inversax" aria-label="X" target="_blank" rel="noopener noreferrer"
            class="w-8 h-8 flex items-center justify-center no-underline transition-colors duration-200"
            style="border: 1px solid rgba(245,240,232,0.15); color: rgba(245,240,232,0.4);"
            onmouseover="this.style.color='#F5F0E8'; this.style.borderColor='rgba(245,240,232,0.35)';"
            onmouseout="this.style.color='rgba(245,240,232,0.4)'; this.style.borderColor='rgba(245,240,232,0.15)';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://t.me/inversax" aria-label="Telegram" target="_blank" rel="noopener noreferrer"
            class="w-8 h-8 flex items-center justify-center no-underline transition-colors duration-200"
            style="border: 1px solid rgba(245,240,232,0.15); color: rgba(245,240,232,0.4);"
            onmouseover="this.style.color='#F5F0E8'; this.style.borderColor='rgba(245,240,232,0.35)';"
            onmouseout="this.style.color='rgba(245,240,232,0.4)'; this.style.borderColor='rgba(245,240,232,0.15)';">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.67l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.958.889z"/></svg>
          </a>
        </div>

      </div>

      <!-- Divisor vertical (desktop) -->
      <div class="hidden lg:block lg:col-span-1">
        <div class="h-full w-px mx-auto" style="background: rgba(245,240,232,0.08);"></div>
      </div>

      <!-- Col 2: Noticias -->
      <div class="lg:col-span-2 flex flex-col gap-4">
        <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
              style="color: rgba(245,240,232,0.3); font-family: 'DM Sans', sans-serif;">
          Noticias
        </span>
        <div style="width: 24px; height: 2px; background: #B91C1C; margin-bottom: 4px;"></div>
        <ul class="flex flex-col gap-3 list-none p-0 m-0">
          {categorias.map((cat) => (
            <li>
              <a href={`/${cat.slug}`}
                 class="text-sm no-underline transition-colors duration-200"
                 style="color: rgba(245,240,232,0.5);"
                 onmouseover="this.style.color='#F5F0E8';"
                 onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                {cat.nombre}
              </a>
            </li>
          ))}
          <li class="pt-1" style="border-top: 1px solid rgba(245,240,232,0.08);">
            <a href="/noticias"
               class="text-sm no-underline transition-colors duration-200 font-semibold"
               style="color: #B91C1C;"
               onmouseover="this.style.color='#F87171';"
               onmouseout="this.style.color='#B91C1C';">
              Ver todas →
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Herramientas -->
      <div class="lg:col-span-2 flex flex-col gap-4">
        <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
              style="color: rgba(245,240,232,0.3); font-family: 'DM Sans', sans-serif;">
          Herramientas
        </span>
        <div style="width: 24px; height: 2px; background: #B91C1C; margin-bottom: 4px;"></div>
        <ul class="flex flex-col gap-3 list-none p-0 m-0">
          {herramientas.map((link) => (
            <li>
              <a href={link.href}
                 class="text-sm no-underline transition-colors duration-200"
                 style="color: rgba(245,240,232,0.5);"
                 onmouseover="this.style.color='#F5F0E8';"
                 onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Por País + Nosotros -->
      <div class="lg:col-span-3 flex flex-col sm:flex-row lg:flex-col gap-8 lg:gap-6">
        <!-- Por País -->
        <div class="flex flex-col gap-4 flex-1">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
                style="color: rgba(245,240,232,0.3); font-family: 'DM Sans', sans-serif;">
            Por País
          </span>
          <div style="width: 24px; height: 2px; background: #B91C1C; margin-bottom: 4px;"></div>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {paisesLocales.map((p) => (
              <li>
                <a href={`/pais/${p.codigo}`}
                   class="text-sm no-underline transition-colors duration-200"
                   style="color: rgba(245,240,232,0.5);"
                   onmouseover="this.style.color='#F5F0E8';"
                   onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                  {p.nombre}
                </a>
              </li>
            ))}
            <li class="pt-1" style="border-top: 1px solid rgba(245,240,232,0.08);">
              <a href="/paises"
                 class="text-sm no-underline font-semibold"
                 style="color: #B91C1C;"
                 onmouseover="this.style.color='#F87171';"
                 onmouseout="this.style.color='#B91C1C';">
                Ver todos →
              </a>
            </li>
          </ul>
        </div>
        <!-- Nosotros -->
        <div class="flex flex-col gap-4 flex-1">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
                style="color: rgba(245,240,232,0.3); font-family: 'DM Sans', sans-serif;">
            Nosotros
          </span>
          <div style="width: 24px; height: 2px; background: #B91C1C; margin-bottom: 4px;"></div>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {nosotros.map((link) => (
              <li>
                <a href={link.href}
                   class="text-sm no-underline transition-colors duration-200"
                   style="color: rgba(245,240,232,0.5);"
                   onmouseover="this.style.color='#F5F0E8';"
                   onmouseout="this.style.color='rgba(245,240,232,0.5)';">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>
  </div>

  <!-- ── SCRIPT NEWSLETTER ──────────────────────────────────── -->
  <script>
    const emailInput = document.getElementById('nl-email') as HTMLInputElement | null;
    const btn        = document.getElementById('nl-btn')   as HTMLButtonElement | null;
    const msg        = document.getElementById('nl-msg')   as HTMLParagraphElement | null;

    function getPais(): string | null {
      const desktop = (document.getElementById('country-select') as HTMLSelectElement | null)?.value;
      const mobile  = (document.getElementById('country-select-mobile') as HTMLSelectElement | null)?.value;
      const val     = desktop ?? mobile ?? null;
      return val && val !== 'global' ? val : null;
    }

    function showMsg(text: string, color: string) {
      if (!msg) return;
      msg.textContent = text;
      msg.style.color = color;
      msg.style.display = 'block';
    }

    btn?.addEventListener('click', async () => {
      if (!emailInput || !btn) return;
      const email = emailInput.value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.style.opacity = '0.6';
      showMsg('Enviando…', 'rgba(245,240,232,0.4)');

      try {
        const res  = await fetch('/api/newsletter', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ email, pais: getPais() }),
        });
        const data = await res.json();

        if (res.ok && data.success) {
          showMsg('¡Listo! Te avisamos cada día.', '#4ADE80');
          emailInput.value = '';
        } else {
          showMsg(data.error ?? 'Algo salió mal, intenta de nuevo.', '#F87171');
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      } catch {
        showMsg('Error de red. Intenta de nuevo.', '#F87171');
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    });

    emailInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') btn?.click();
    });
  </script>

  <!-- ── FRANJA INFERIOR: copyright + disclaimer + redes ─────── -->
  <div style="border-top: 1px solid rgba(245,240,232,0.08);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <span class="text-[11px]" style="color: rgba(245,240,232,0.25); font-family: 'DM Sans', sans-serif;">
        © {new Date().getFullYear()} Inversax.com — Todos los derechos reservados
      </span>
      <span class="text-[11px] text-center sm:text-right" style="color: rgba(245,240,232,0.2); font-family: 'DM Sans', sans-serif; max-width: 480px;">
        <TrendingUp size={10} class="inline mr-1" style="vertical-align: middle; opacity: 0.5;" />
        Contenido informativo. No constituye asesoría financiera. Invertir conlleva riesgos.
      </span>
    </div>
  </div>

</footer>
