---

{mostrar && (
  <aside class="bb-section" aria-label="Brokers recomendados por Inversax">
    <div class="bb-wrap">

      <div class="bb-header">
        <div class="bb-label">
          <span class="bb-dot"></span>
          Brokers recomendados por Inversax
        </div>
        <span class="bb-legal">Contiene enlaces de afiliado · Invertir implica riesgos</span>
      </div>

      <div class="bb-grid">
        {brokers.map((b, i) => (
          <a
            href={b.href}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="bb-card"
            style={`--c:${b.color}; --delay:${i * 70}ms`}
          >
            <div class="bb-glow"></div>

            <div class="bb-top">
              <div class="bb-logo-wrap">
                <img
                  src={b.logo ?? `https://icon.horse/icon/${b.domain}`}
                  alt={`Logo ${b.nombre}`}
                  class="bb-logo"
                  width="40"
                  height="40"
                  loading="lazy"
                  onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                />
                <div class="bb-logo-fallback" style={`background:${b.color}18;color:${b.color};`}>
                  {b.nombre.slice(0,2).toUpperCase()}
                </div>
              </div>

              <div class="bb-meta">
                <div class="bb-name-row">
                  <span class="bb-name">{b.nombre}</span>
                  <span class="bb-badge" style={`background:${b.color}18;color:${b.color};border-color:${b.color}35`}>
                    {b.badge}
                  </span>
                </div>
                <span class="bb-tipo">{b.tipo}</span>
              </div>
            </div>

            <p class="bb-desc">{b.descripcion}</p>

            <div class="bb-mid">
              <div class="bb-stars">
                {[1,2,3,4,5].map(s => (
                  <span class={s <= Math.round(b.rating) ? 'bb-star on' : 'bb-star'}>★</span>
                ))}
                <span class="bb-rnum">{b.rating}</span>
              </div>
              <span class="bb-bono">{b.bono}</span>
            </div>

            <div class="bb-cta" style={`background:${b.color};box-shadow:0 4px 18px ${b.color}45`}>
              {b.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </div>

          </a>
        ))}
      </div>

    </div>
  </aside>
)}

<style>
.bb-section {
  background: #0A0B0D;
  border-top:    1px solid rgba(255,255,255,.055);
  border-bottom: 1px solid rgba(255,255,255,.055);
  padding: 1.75rem 1rem;
  font-family: 'DM Sans', sans-serif;
}
.bb-wrap {
  max-width: 72rem;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}
.bb-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: .4rem;
}
.bb-label {
  display: flex;
  align-items: center;
  gap: .45rem;
  font-size: .72rem;
  font-weight: 700;
  color: rgba(255,255,255,.4);
  text-transform: uppercase;
  letter-spacing: .08em;
}
.bb-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #D4A843;
  animation: bbPulse 2s infinite;
  flex-shrink: 0;
}
@keyframes bbPulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:.4; transform:scale(.75); }
}
.bb-legal { font-size:.6rem; color:rgba(255,255,255,.13); }

/* Grid: 1 col mobile → 2 tablet → 3 desktop */
.bb-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: .75rem;
}
@media (min-width: 600px)  { .bb-grid { grid-template-columns: repeat(2,1fr); } }
@media (min-width: 1024px) { .bb-grid { grid-template-columns: repeat(3,1fr); } }

.bb-card {
  position: relative;
  overflow: hidden;
  background: #111318;
  border: 1px solid rgba(255,255,255,.065);
  border-radius: 1rem;
  padding: 1.1rem;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: .8rem;
  transition: border-color .25s, transform .25s;
  animation: bbUp .4s ease both;
  animation-delay: var(--delay, 0ms);
}
.bb-card:hover {
  border-color: color-mix(in srgb, var(--c) 45%, transparent);
  transform: translateY(-3px);
}
@keyframes bbUp {
  from { opacity:0; transform:translateY(12px); }
  to   { opacity:1; transform:translateY(0); }
}
.bb-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at top right, color-mix(in srgb, var(--c) 12%, transparent), transparent 65%);
  pointer-events: none;
  opacity: .7;
  transition: opacity .3s;
}
.bb-card:hover .bb-glow { opacity: 1.3; }

.bb-top {
  display: flex;
  align-items: center;
  gap: .75rem;
  position: relative;
  z-index: 1;
}
.bb-logo-wrap {
  width: 42px; height: 42px;
  border-radius: .65rem;
  overflow: hidden;
  flex-shrink: 0;
  border: 1px solid rgba(255,255,255,.08);
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bb-logo {
  width: 100%; height: 100%;
  object-fit: contain;
  padding: 5px;
}
.bb-logo-fallback {
  display: none;
  width: 100%; height: 100%;
  align-items: center;
  justify-content: center;
  font-size: .65rem;
  font-weight: 800;
  font-family: 'Syne', sans-serif;
}
.bb-meta { display:flex; flex-direction:column; gap:.2rem; min-width:0; }
.bb-name-row { display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; }
.bb-name { font-family:'Syne',sans-serif; font-weight:700; font-size:.95rem; color:#fff; }
.bb-badge {
  font-size:.58rem; font-weight:700; text-transform:uppercase;
  letter-spacing:.06em; padding:.12rem .45rem;
  border-radius:999px; border:1px solid; white-space:nowrap;
}
.bb-tipo { font-size:.68rem; color:rgba(255,255,255,.22); }

.bb-desc {
  font-size:.73rem; color:rgba(255,255,255,.42);
  line-height:1.55; margin:0; position:relative; z-index:1;
}

.bb-mid {
  display:flex; align-items:center;
  justify-content:space-between;
  position:relative; z-index:1;
}
.bb-stars { display:flex; align-items:center; gap:.05rem; }
.bb-star     { font-size:.72rem; color:rgba(255,255,255,.12); }
.bb-star.on  { color:#D4A843; }
.bb-rnum { font-size:.68rem; color:rgba(255,255,255,.28); margin-left:.3rem; }
.bb-bono {
  font-size:.62rem; color:rgba(255,255,255,.22);
  border:1px solid rgba(255,255,255,.08);
  padding:.12rem .5rem; border-radius:999px; white-space:nowrap;
}

.bb-cta {
  display:flex; align-items:center; justify-content:center;
  gap:.4rem; padding:.62rem 1rem; border-radius:.65rem;
  font-size:.78rem; font-weight:700; color:#fff;
  transition:opacity .2s, transform .2s;
  position:relative; z-index:1; margin-top:auto;
}
.bb-card:hover .bb-cta { opacity:.88; transform:scale(.98); }
</style>
