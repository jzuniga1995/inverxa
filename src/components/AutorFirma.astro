---
// src/components/AutorFirma.astro
// Uso: <AutorFirma fecha={articulo.creadoEn} />

import { Twitter, Globe } from 'lucide-astro';

interface Props {
  fecha?: Date | null;
}

const { fecha } = Astro.props;

function formatFecha(f: Date | null | undefined) {
  if (!f) return '';
  return new Intl.DateTimeFormat('es', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(f);
}
---

<div class="flex items-center gap-4 py-5 px-5 sm:px-6 my-8"
     style="background: #F5F1EC; border: 1px solid #E5E0D8; font-family: 'DM Sans', sans-serif;">

  <!-- Avatar -->
  <a href="/autor/jose-zuniga" class="flex-shrink-0 no-underline">
    <div class="w-12 h-12 overflow-hidden transition-colors duration-200"
         style="border: 1px solid #E5E0D8;"
         onmouseover="this.style.borderColor='#B91C1C'"
         onmouseout="this.style.borderColor='#E5E0D8'">
      <img src="/foto-jose.jpg" alt="José Zúñiga" class="w-full h-full object-cover" />
    </div>
  </a>

  <!-- Info -->
  <div class="flex flex-col gap-0.5 flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <a
        href="/autor/jose-zuniga"
        class="font-bold text-sm no-underline transition-colors duration-200"
        style="color: #1C1917; font-family: 'DM Sans', sans-serif;"
        onmouseover="this.style.color='#B91C1C'"
        onmouseout="this.style.color='#1C1917'"
      >
        José Zúniga
      </a>
      <span class="text-[10px] font-bold px-1.5 py-0.5 uppercase tracking-wider"
            style="color: #B91C1C; background: #FEF2F2; border: 1px solid rgba(185,28,28,0.2);">
        Editor
      </span>
    </div>
    <p class="text-xs leading-snug" style="color: #78716C;">
      Desarrollador de software · Finanzas & Cripto · Inversax
    </p>
    {fecha && (
      <p class="text-[10px] mt-0.5" style="color: #A8A29E;">
        Publicado el {formatFecha(fecha)}
      </p>
    )}
  </div>

  <!-- Social (solo desktop) -->
  <div class="hidden sm:flex items-center gap-2 flex-shrink-0">
    <a
      href="https://twitter.com/inversax"
      target="_blank"
      rel="noopener noreferrer"
      class="w-8 h-8 flex items-center justify-center transition-all duration-200 no-underline"
      style="background: #F0EDE7; border: 1px solid #E5E0D8; color: #78716C;"
      onmouseover="this.style.borderColor='rgba(185,28,28,0.3)'; this.style.color='#B91C1C';"
      onmouseout="this.style.borderColor='#E5E0D8'; this.style.color='#78716C';"
    >
      <Twitter size={13} />
    </a>
    <a
      href="https://inversax.com"
      target="_blank"
      rel="noopener noreferrer"
      class="w-8 h-8 flex items-center justify-center transition-all duration-200 no-underline"
      style="background: #F0EDE7; border: 1px solid #E5E0D8; color: #78716C;"
      onmouseover="this.style.borderColor='rgba(185,28,28,0.3)'; this.style.color='#B91C1C';"
      onmouseout="this.style.borderColor='#E5E0D8'; this.style.color='#78716C';"
    >
      <Globe size={13} />
    </a>
  </div>

</div>


