---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NavProgress from '../components/NavProgress.astro';
import BrokerBanner from '../components/BrokerBanner.astro';

interface Props {
  bodyClass?:      string;
  mostrarBrokers?: boolean;
  categorias?:     Array<{ nombre: string; slug: string }>;
  paises?:         unknown; // aceptado por compatibilidad, no se usa
}

const { bodyClass = '', mostrarBrokers = true, categorias } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name='impact-site-verification' content='583936fd-55de-4e95-be9e-bc478ae7ef56'>

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png">

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap.xml" />

  <!-- DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">

  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-E8YH3R6PPW"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-E8YH3R6PPW');
  </script>

  <NavProgress />

  <!-- SEO de cada página -->
  <slot name="head" />
</head>

<body class={`min-h-screen ${bodyClass}`}
      style="background:#F7F7F5; font-family:'DM Sans',sans-serif;">

  <Header categorias={categorias} />

  <!-- pt-[94px] = 34px topbar + 60px nav -->
  <main class="pt-[94px]">
    <slot />
  </main>

  <BrokerBanner mostrar={mostrarBrokers} />
  <Footer />

</body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    scroll-behavior: smooth;
    overflow-x: hidden;
  }
  body {
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  ::-webkit-scrollbar        { width: 6px; }
  ::-webkit-scrollbar-track  { background: #F0EDE9; }
  ::-webkit-scrollbar-thumb  { background: #D0C9C0; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #FF8C42; }

  ::selection {
    background: rgba(255, 140, 66, 0.15);
    color: #1A1A1A;
  }
</style>
