    "inLanguage": "es",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
