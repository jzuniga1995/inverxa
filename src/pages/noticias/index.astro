  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

