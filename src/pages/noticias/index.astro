</slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family: 'DM Sans', sans-serif;">

    <!-- PAGE HEADER -->
    <div class="border-b border-white/[0.07] bg-[#111318]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <h1 class="font-extrabold text-2xl sm:text-4xl text-white mb-2" style="font-family: 'Syne', sans-serif;">
          Últimas Noticias
        </h1>
        <p class="text-white/40 text-sm sm:text-base">
          Cripto, trading y economía actualizado cada día para Latinoamérica
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10">

      <!-- FILTROS DE CATEGORÍA -->
      <div class="flex items-center gap-2 mb-6 sm:mb-8 overflow-x-auto pb-2 scrollbar-hide">
        <Filter size={14} class="text-white/30 flex-shrink-0" />
        <a
          href="/noticias"
          class={`flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-colors duration-200 no-underline ${
            categoriaActiva === 'todas'
              ? 'bg-[#D4A843] text-[#0A0B0D]'
              : 'bg-white/5 border border-white/[0.07] text-white/50 hover:text-white hover:bg-white/10'
          }`}
        >
          Todas
        </a>
        {categorias.map((cat) => (
          <a
           href={`/noticias?categoria=${cat.slug}`}
            class={`flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-colors duration-200 no-underline ${
              categoriaActiva === cat.slug
                ? 'bg-[#D4A843] text-[#0A0B0D]'
                : 'bg-white/5 border border-white/[0.07] text-white/50 hover:text-white hover:bg-white/10'
            }`}
          >
            {cat.nombre}
          </a>
        ))}
      </div>

      <!-- LAYOUT PRINCIPAL -->
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- CONTENIDO -->
        <div class="flex-1 min-w-0">

          {articulosFiltrados.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-24 gap-4 text-center">
              <span class="text-5xl">📰</span>
              <p class="text-white/40 text-sm">No hay artículos en esta categoría todavía.</p>
            </div>
          ) : (
            <div class="flex flex-col gap-5 sm:gap-6">

              <!-- Artículo principal -->
              {principal && (
                <a
                  href={`/noticias/${principal.slug}`}
                  class="group flex flex-col sm:flex-row bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-2xl overflow-hidden no-underline transition-colors duration-300 sm:min-h-[220px]"
                >
                  <div class="w-full sm:w-72 lg:w-80 h-52 sm:h-full flex-shrink-0 bg-[#1A1D24] overflow-hidden">
                    {principal.imagen
                      ? <img src={principal.imagen} alt={principal.titulo} class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" />
                      : <div class="w-full h-full" style="background: linear-gradient(135deg, #1A1D24, #23272F);" />
                    }
                  </div>
                  <div class="flex flex-col gap-3 p-5 sm:p-6 lg:p-7 justify-center">
                    <div class="flex items-center gap-2 flex-wrap">
                      {principal.categoria && (
                        <span class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                          {principal.categoria.nombre}
                        </span>
                      )}
                      <span class="text-white/30 text-xs flex items-center gap-1 ml-auto">
                        <Clock size={11} />
                        {formatFecha(principal.creadoEn)}
                      </span>
                    </div>
                    <h2 class="font-bold text-lg sm:text-xl lg:text-2xl text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug" style="font-family: 'Syne', sans-serif;">
                      {principal.titulo}
                    </h2>
                    {principal.resumen && (
                      <p class="text-white/50 text-sm leading-relaxed line-clamp-2">{principal.resumen}</p>
                    )}
                    <span class="flex items-center gap-1 text-[#D4A843] text-sm font-medium mt-1">
                      Leer más <ArrowRight size={14} />
                    </span>
                  </div>
                </a>
              )}

              <!-- Grid resto -->
              <div id="noticias-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {resto.map((articulo) => (
                  <a
                    href={`/noticias/${articulo.slug}`}
                    class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl overflow-hidden no-underline transition-colors duration-200"
                  >
                    {articulo.imagen
                      ? (
                        <div class="w-full h-36 bg-[#1A1D24] overflow-hidden flex-shrink-0">
                          <img src={articulo.imagen} alt={articulo.titulo} class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" />
                        </div>
                      )
                      : (
                        <div class="w-full h-36 flex-shrink-0" style="background: linear-gradient(135deg, #1A1D24, #23272F);" />
                      )
                    }
                    <div class="flex flex-col gap-2 px-4 pb-4">
                      <div class="flex items-center gap-2 flex-wrap">
                        {articulo.categoria && (
                          <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">
                            {articulo.categoria.nombre}
                          </span>
                        )}
                        <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto">
                          <Clock size={9} />
                          {formatFecha(articulo.creadoEn)}
                        </span>
                      </div>
                      <h3 class="font-bold text-sm text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug line-clamp-2" style="font-family: 'Syne', sans-serif;">
                        {articulo.titulo}
                      </h3>
                      {articulo.resumen && (
                        <p class="text-white/40 text-xs leading-relaxed line-clamp-2">{articulo.resumen}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>

              <!-- BOTÓN CARGAR MÁS -->
              <div id="load-more-wrapper" class={hayMasInicial ? '' : 'hidden'}>
                <button
                  id="btn-cargar-mas"
                  data-offset={LIMIT}
                  data-categoria={categoriaActiva === 'todas' ? '' : categoriaActiva}
                  class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl border border-white/[0.07] hover:border-[#D4A843]/40 text-white/40 hover:text-[#D4A843] text-sm font-medium transition-all duration-200 bg-transparent cursor-pointer"
                >
                  <span id="btn-texto">Cargar más noticias</span>
                  <ArrowRight size={14} id="btn-icon" />
                </button>
              </div>

            </div>
          )}
        </div>

        <!-- SIDEBAR -->
        <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0 flex flex-col gap-4">

          {resto.length > 0 && (
            <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
              <h3 class="font-bold text-sm text-white mb-4" style="font-family: 'Syne', sans-serif;">Más recientes</h3>
              <div class="flex flex-col gap-4">
                {resto.slice(0, 6).map((a) => (
                  <a href={`/noticias/${a.slug}`} class="group flex flex-col gap-1 no-underline">
                    {a.categoria && (
                      <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{a.categoria.nombre}</span>
                    )}
                    <span class="text-white/60 group-hover:text-white text-xs leading-snug line-clamp-2 transition-colors duration-200" style="font-family: 'Syne', sans-serif;">
                      {a.titulo}
                    </span>
                    <span class="text-white/25 text-[10px] flex items-center gap-1">
                      <Clock size={9} /> {formatFecha(a.creadoEn)}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Link a países -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
            <h3 class="font-bold text-sm text-white mb-4" style="font-family: 'Syne', sans-serif;">Por País</h3>
            <p class="text-white/40 text-xs leading-relaxed mb-3">
              Encuentra noticias específicas de tu región.
            </p>
            <a
              href="/paises"
              class="flex items-center justify-between w-full bg-[#D4A843]/10 border border-[#D4A843]/20 hover:border-[#D4A843]/40 text-[#D4A843] text-sm px-4 py-2.5 rounded-xl no-underline transition-all duration-200"
            >
              Ver todos los países
              <ArrowRight size={14} />
            </a>
          </div>

        </aside>

      </div>
    </div>
  </div>
</Layout>

<script>
  const btn      = document.getElementById('btn-cargar-mas') as HTMLButtonElement | null;
  const grid     = document.getElementById('noticias-grid');
  const wrapper  = document.getElementById('load-more-wrapper');
  const btnTexto = document.getElementById('btn-texto');
  const btnIcon  = document.getElementById('btn-icon');

  function formatFecha(fechaStr: string) {
    const fecha = new Date(fechaStr);
    const diff  = Date.now() - fecha.getTime();
    const horas = Math.floor(diff / 1000 / 60 / 60);
    if (horas < 1)  return 'Hace unos minutos';
    if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
    const dias = Math.floor(horas / 24);
    return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
  }

  function crearCard(a: any): string {
    return `
      <a
        href="/noticias/${a.slug}"
        class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl overflow-hidden no-underline transition-colors duration-200"
      >
        ${a.imagen
          ? `<div class="w-full h-36 bg-[#1A1D24] overflow-hidden flex-shrink-0">
               <img src="${a.imagen}" alt="${a.titulo}" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" loading="lazy" />
             </div>`
          : `<div class="w-full h-36 flex-shrink-0" style="background: linear-gradient(135deg, #1A1D24, #23272F);"></div>`
        }
        <div class="flex flex-col gap-2 px-4 pb-4">
          <div class="flex items-center gap-2 flex-wrap">
            ${a.categoria ? `<span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">${a.categoria.nombre}</span>` : ''}
            <span class="text-white/25 text-[10px] ml-auto">${formatFecha(a.creadoEn)}</span>
          </div>
          <h3 class="font-bold text-sm text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug line-clamp-2" style="font-family: 'Syne', sans-serif;">
            ${a.titulo}
          </h3>
          ${a.resumen ? `<p class="text-white/40 text-xs leading-relaxed line-clamp-2">${a.resumen}</p>` : ''}
        </div>
      </a>
    `;
  }

  btn?.addEventListener('click', async () => {
    if (!btn || !grid) return;

    const offset    = parseInt(btn.dataset.offset ?? '12');
    const categoria = btn.dataset.categoria ?? '';

    // Estado cargando
    if (btnTexto) btnTexto.textContent = 'Cargando...';
    btn.disabled = true;

    try {
      const params = new URLSearchParams({ offset: String(offset), limit: '10' });
      if (categoria) params.set('categoria', categoria);

      const res  = await fetch(`/api/noticias?${params}`);
     const json = await res.json() as any;

      if (!json.ok || !json.data.length) {
        if (wrapper) wrapper.classList.add('hidden');
        return;
      }

      // Agregar cards al grid
      json.data.forEach((a: any) => {
        grid.insertAdjacentHTML('beforeend', crearCard(a));
      });

      // Actualizar offset
      btn.dataset.offset = String(offset + json.data.length);

      // Ocultar botón si no hay más
      if (!json.hayMas) {
        if (wrapper) wrapper.classList.add('hidden');
      }

    } catch (e) {
      console.error('[cargar más]', e);
    } finally {
      if (btnTexto) btnTexto.textContent = 'Cargar más noticias';
      btn.disabled = false;
    }
  });
</script>

