---
// src/pages/noticias/index.astro — lista limpia, sin filtros de país/categoría
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulos, getCategorias } from '../../db/queries';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=30');

const LIMIT = 15;
const db    = Astro.locals.db;

const [categorias, todosArticulos] = await Promise.all([
  getCategorias(db),
  getArticulos(db, LIMIT + 1),
]);

const hayMas    = todosArticulos.length > LIMIT;
const articulos = todosArticulos.slice(0, LIMIT);

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 3600000);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<Layout categorias={categorias}>

<slot name="head" slot="head">
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <title>Artículos de Finanzas, Cripto y Bolsa en Español — Inversax</title>
  <meta name="description"    content="Artículos sobre criptomonedas, trading, forex, bolsa y economía para Latinoamérica. Actualizado cada día en español." />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <link rel="canonical"       href="https://inversax.com/noticias" />
  <meta name="keywords"       content="noticias criptomonedas, noticias trading, noticias forex, bolsa de valores latinoamérica, finanzas en español, bitcoin hoy" />

  <meta property="og:site_name"   content="Inversax" />
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content="Artículos de Finanzas, Cripto y Bolsa en Español — Inversax" />
  <meta property="og:description" content="Las últimas noticias de criptomonedas, trading, forex y bolsa para Latinoamérica." />
  <meta property="og:url"         content="https://inversax.com/noticias" />
  <meta property="og:image"       content="https://inversax.com/og-noticias.png" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:site"       content="@inversax" />
  <meta name="twitter:title"      content="Artículos de Finanzas, Cripto y Bolsa — Inversax" />
  <meta name="twitter:image"      content="https://inversax.com/og-noticias.png" />

  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Artículos de Finanzas, Cripto y Bolsa en Español",
    "description": "Artículos sobre criptomonedas, trading, forex y economía para Latinoamérica.",
    "url": "https://inversax.com/noticias",
    "inLanguage": "es",
    "isPartOf": { "@type": "WebSite", "name": "Inversax", "url": "https://inversax.com" }
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",    "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Artículos", "item": "https://inversax.com/noticias" }
    ]
  })}</script>
</slot>

<!-- PAGE HEADER -->
<div style="background:#FFFFFF; border-bottom:1px solid #E2DDD8;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 sm:py-12">
    <span class="text-xs font-bold uppercase tracking-widest mb-3 block"
          style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
      Editorial
    </span>
    <h1 class="font-bold leading-tight mb-2"
        style="font-family:'DM Sans',sans-serif; color:#1A1A1A; font-size:clamp(26px,4vw,42px);">
      Artículos de finanzas e inversión
    </h1>
    <p class="text-sm sm:text-base" style="color:#888888; font-family:'DM Sans',sans-serif;">
      Cripto, trading, forex y economía — actualizado cada día para Latinoamérica
    </p>
  </div>
</div>

<!-- LISTA DE ARTÍCULOS -->
<div style="background:#F7F7F5; min-height:60vh; padding:40px 0;">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    {articulos.length === 0 ? (
      <div class="flex flex-col items-center justify-center py-24 gap-4 text-center rounded-xl"
           style="background:#FFFFFF; border:1px solid #E2DDD8;">
        <p class="text-sm" style="color:#888888; font-family:'DM Sans',sans-serif;">
          No hay artículos disponibles todavía.
        </p>
      </div>
    ) : (
      <div id="articulos-lista" class="flex flex-col gap-0"
           style="background:#FFFFFF; border:1px solid #E2DDD8; border-radius:12px; overflow:hidden;">
        {articulos.map((art, i) => (
          <a href={`/noticias/${art.slug}`}
             class="block no-underline transition-colors duration-150"
             style={`padding:20px 24px; ${i < articulos.length - 1 ? 'border-bottom:1px solid #E2DDD8;' : ''}`}
             onmouseover="this.style.background='#F7F7F5';"
             onmouseout="this.style.background='';">
            <div class="flex items-start gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                  {art.categoria && (
                    <span class="text-[10px] font-bold uppercase tracking-wider flex-shrink-0"
                          style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
                      {art.categoria.nombre}
                    </span>
                  )}
                  <span class="text-[11px]" style="color:#BBBBBB; font-family:'DM Sans',sans-serif;">
                    {formatFecha(art.creadoEn)}
                  </span>
                </div>
                <h2 class="font-semibold leading-snug mb-1"
                    style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:16px;">
                  {art.titulo}
                </h2>
                {art.resumen && (
                  <p class="text-sm leading-relaxed line-clamp-2"
                     style="color:#666666; font-family:'DM Sans',sans-serif;">
                    {art.resumen}
                  </p>
                )}
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   stroke="#CCCCCC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="flex-shrink-0 mt-1">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}

    <!-- CARGAR MÁS -->
    <div id="load-more-wrapper" class={`mt-6 ${hayMas ? '' : 'hidden'}`}>
      <button
        id="btn-cargar-mas"
        data-offset={LIMIT}
        class="w-full flex items-center justify-center gap-2 py-3.5 text-sm font-semibold transition-all duration-200 rounded-xl cursor-pointer border"
        style="background:#FFFFFF; border-color:#E2DDD8; color:#555555; font-family:'DM Sans',sans-serif;"
        onmouseover="this.style.borderColor='#FF8C42'; this.style.color='#FF8C42';"
        onmouseout="this.style.borderColor='#E2DDD8'; this.style.color='#555555';"
      >
        <span id="btn-texto">Cargar más artículos</span>
        <svg id="btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
    </div>

  </div>
</div>

</Layout>

<script>
  const btn      = document.getElementById('btn-cargar-mas') as HTMLButtonElement | null;
  const lista    = document.getElementById('articulos-lista');
  const wrapper  = document.getElementById('load-more-wrapper');
  const btnTexto = document.getElementById('btn-texto');

  function formatFecha(fechaStr: string) {
    const diff  = Date.now() - new Date(fechaStr).getTime();
    const horas = Math.floor(diff / 3600000);
    if (horas < 1)  return 'Hace unos minutos';
    if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
    const dias = Math.floor(horas / 24);
    return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
  }

  function crearFila(art: any, ultimo: boolean): string {
    return `
      <a href="/noticias/${art.slug}"
         class="block no-underline transition-colors duration-150"
         style="padding:20px 24px; ${!ultimo ? 'border-bottom:1px solid #E2DDD8;' : ''}"
         onmouseover="this.style.background='#F7F7F5';"
         onmouseout="this.style.background='';">
        <div style="display:flex; align-items:flex-start; gap:16px;">
          <div style="flex:1; min-width:0;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
              ${art.categoria ? `<span style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#FF8C42; font-family:'DM Sans',sans-serif;">${art.categoria.nombre}</span>` : ''}
              <span style="font-size:11px; color:#BBBBBB; font-family:'DM Sans',sans-serif;">${formatFecha(art.creadoEn)}</span>
            </div>
            <h2 style="font-weight:600; line-height:1.4; margin-bottom:4px; color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:16px;">
              ${art.titulo}
            </h2>
            ${art.resumen ? `<p style="font-size:14px; line-height:1.5; color:#666666; font-family:'DM Sans',sans-serif; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">${art.resumen}</p>` : ''}
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#CCCCCC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </div>
      </a>
    `;
  }

  btn?.addEventListener('click', async () => {
    if (!btn || !lista) return;
    const offset = parseInt(btn.dataset.offset ?? '15');
    if (btnTexto) btnTexto.textContent = 'Cargando...';
    btn.disabled = true;
    try {
      const res  = await fetch(`/api/noticias?offset=${offset}&limit=10`);
      const json = await res.json() as any;
      if (!json.ok || !json.data.length) {
        if (wrapper) wrapper.classList.add('hidden');
        return;
      }
      // Quitar el borde del último existente antes de añadir más
      const lastRow = lista.lastElementChild as HTMLElement | null;
      if (lastRow) lastRow.style.borderBottom = '1px solid #E2DDD8';

      json.data.forEach((art: any, idx: number) => {
        const ultimo = idx === json.data.length - 1 && !json.hayMas;
        lista.insertAdjacentHTML('beforeend', crearFila(art, ultimo));
      });
      btn.dataset.offset = String(offset + json.data.length);
      if (!json.hayMas && wrapper) wrapper.classList.add('hidden');
    } catch (e) {
      console.error('[cargar más]', e);
    } finally {
      if (btnTexto) btnTexto.textContent = 'Cargar más artículos';
      btn.disabled = false;
    }
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
