---
// src/pages/noticias/index.astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulos, getCategorias } from '../../db/queries';
import { Clock, ArrowRight, Filter } from 'lucide-astro';

const LIMIT = 12;

const db              = Astro.locals.db;
const categorias      = await getCategorias(db);
const categoriaActiva = Astro.url.searchParams.get('categoria') ?? 'todas';

const todosArticulos = await getArticulos(db, LIMIT + 1);

const articulosFiltrados = categoriaActiva === 'todas'
  ? todosArticulos
  : todosArticulos.filter(a => a.categoria?.slug === categoriaActiva);

const hayMasInicial  = articulosFiltrados.length > LIMIT;
const articulosInit  = articulosFiltrados.slice(0, LIMIT);
const [principal, ...resto] = articulosInit;

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}

---

<Layout>


<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
