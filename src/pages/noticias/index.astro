---
// src/pages/noticias/index.astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulos, getCategorias } from '../../db/queries';
import { Clock, ArrowRight, Filter } from 'lucide-astro';

const articulos  = await getArticulos(30);
const categorias = await getCategorias();

const categoriaActiva = Astro.url.searchParams.get('categoria') ?? 'todas';
const paisActivo      = Astro.url.searchParams.get('pais') ?? 'global';

// Filtrar por categoría + país (país viene del header)
const articulosFiltrados = articulos.filter(a => {
  const matchCategoria = categoriaActiva === 'todas' || a.categoria?.slug === categoriaActiva;
  const matchPais = paisActivo === 'global'
    ? (a.pais?.codigo === 'global' || !a.pais)
    : (a.pais?.codigo === paisActivo || a.pais?.codigo === 'global');
  return matchCategoria && matchPais;
});

const [principal, ...resto] = articulosFiltrados;

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  return new Intl.RelativeTimeFormat('es', { numeric: 'auto' }).format(
    Math.round((fecha.getTime() - Date.now()) / (1000 * 60 * 60)),
    'hours'
  );
}
---

<Layout>
  <slot name="head" slot="head">
    <title>Noticias — Inversax</title>
    <meta name="description" content="Últimas noticias de cripto, trading, bolsa y economía para Latinoamérica." />
  </slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family: 'DM Sans', sans-serif;">

    <!-- PAGE HEADER -->
    <div class="border-b border-white/[0.07] bg-[#111318]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <h1 class="font-extrabold text-2xl sm:text-4xl text-white mb-2" style="font-family: 'Syne', sans-serif;">
          Últimas Noticias
        </h1>
        <p class="text-white/40 text-sm sm:text-base">
          Cripto, trading y economía actualizado cada día para Latinoamérica
        </p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10">

      <!-- FILTROS DE CATEGORÍA (horizontal) -->
      <div class="flex items-center gap-2 mb-6 sm:mb-8 overflow-x-auto pb-2 scrollbar-hide">
        <Filter size={14} class="text-white/30 flex-shrink-0" />
        <a
          href={`/noticias${paisActivo !== 'global' ? `?pais=${paisActivo}` : ''}`}
          class={`flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-colors duration-200 no-underline ${
            categoriaActiva === 'todas'
              ? 'bg-[#D4A843] text-[#0A0B0D]'
              : 'bg-white/5 border border-white/[0.07] text-white/50 hover:text-white hover:bg-white/10'
          }`}
        >
          Todas
        </a>
        {categorias.map((cat) => (
          <a
            href={`/noticias?categoria=${cat.slug}${paisActivo !== 'global' ? `&pais=${paisActivo}` : ''}`}
            class={`flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium transition-colors duration-200 no-underline ${
              categoriaActiva === cat.slug
                ? 'bg-[#D4A843] text-[#0A0B0D]'
                : 'bg-white/5 border border-white/[0.07] text-white/50 hover:text-white hover:bg-white/10'
            }`}
          >
            {cat.nombre}
          </a>
        ))}
      </div>

      <!-- LAYOUT PRINCIPAL -->
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- CONTENIDO -->
        <div class="flex-1 min-w-0">

          {articulosFiltrados.length === 0 ? (

            <!-- Sin resultados -->
            <div class="flex flex-col items-center justify-center py-24 gap-4 text-center">
              <span class="text-5xl">🌎</span>
              {paisActivo !== 'global' ? (
                <>
                  <p class="text-white/60 text-base font-medium" style="font-family: 'Syne', sans-serif;">
                    Próximamente en esta región
                  </p>
                  <p class="text-white/30 text-sm max-w-xs leading-relaxed">
                    Estamos trabajando para traerte contenido local. Por ahora puedes explorar las noticias globales.
                  </p>
                  <a href="/noticias" class="mt-2 text-[#D4A843] text-sm font-medium hover:underline no-underline">
                    Ver noticias globales →
                  </a>
                </>
              ) : (
                <p class="text-white/40 text-sm">No hay artículos en esta categoría todavía.</p>
              )}
            </div>

          ) : (
            <div class="flex flex-col gap-5 sm:gap-6">

              <!-- Artículo principal destacado -->
              {principal && (
                <a
                  href={`/noticias/${principal.slug}`}
                  class="group flex flex-col sm:flex-row bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-2xl overflow-hidden no-underline transition-colors duration-300"
                >
                  <!-- Imagen -->
                  <div class="w-full sm:w-72 lg:w-80 h-48 sm:h-auto flex-shrink-0 bg-[#1A1D24]">
                    {principal.imagen
                      ? <img src={principal.imagen} alt={principal.titulo} class="w-full h-full object-cover" />
                      : <div class="w-full h-full" style="background: linear-gradient(135deg, #1A1D24, #23272F);" />
                    }
                  </div>
                  <!-- Contenido -->
                  <div class="flex flex-col gap-3 p-5 sm:p-6 lg:p-7 justify-center">
                    <div class="flex items-center gap-2 flex-wrap">
                      {principal.categoria && (
                        <span class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                          {principal.categoria.nombre}
                        </span>
                      )}
                      {principal.pais && principal.pais.codigo !== 'global' && (
                        <span class="text-white/30 text-[10px] border border-white/[0.07] px-2 py-0.5 rounded uppercase">
                          {principal.pais.nombre}
                        </span>
                      )}
                      <span class="text-white/30 text-xs flex items-center gap-1 ml-auto">
                        <Clock size={11} />
                        {formatFecha(principal.creadoEn)}
                      </span>
                    </div>
                    <h2 class="font-bold text-lg sm:text-xl lg:text-2xl text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug" style="font-family: 'Syne', sans-serif;">
                      {principal.titulo}
                    </h2>
                    {principal.resumen && (
                      <p class="text-white/50 text-sm leading-relaxed line-clamp-2">{principal.resumen}</p>
                    )}
                    <span class="flex items-center gap-1 text-[#D4A843] text-sm font-medium mt-1">
                      Leer más <ArrowRight size={14} />
                    </span>
                  </div>
                </a>
              )}

              <!-- Grid resto de artículos -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {resto.map((articulo) => (
                  <a
                    href={`/noticias/${articulo.slug}`}
                    class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-4 sm:p-5 no-underline transition-colors duration-200"
                  >
                    {articulo.imagen && (
                      <div class="w-full h-36 rounded-lg overflow-hidden bg-[#1A1D24]">
                        <img src={articulo.imagen} alt={articulo.titulo} class="w-full h-full object-cover" />
                      </div>
                    )}
                    <div class="flex items-center gap-2 flex-wrap">
                      {articulo.categoria && (
                        <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">
                          {articulo.categoria.nombre}
                        </span>
                      )}
                      {articulo.pais && articulo.pais.codigo !== 'global' && (
                        <span class="text-white/25 text-[10px] border border-white/[0.07] px-1.5 py-0.5 rounded uppercase">
                          {articulo.pais.codigo}
                        </span>
                      )}
                      <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto">
                        <Clock size={9} />
                        {formatFecha(articulo.creadoEn)}
                      </span>
                    </div>
                    <h3 class="font-bold text-sm text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug line-clamp-2" style="font-family: 'Syne', sans-serif;">
                      {articulo.titulo}
                    </h3>
                    {articulo.resumen && (
                      <p class="text-white/40 text-xs leading-relaxed line-clamp-2">{articulo.resumen}</p>
                    )}
                  </a>
                ))}
              </div>

            </div>
          )}
        </div>

        <!-- SIDEBAR -->
        <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0 flex flex-col gap-4">
          {resto.length > 0 && (
            <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
              <h3 class="font-bold text-sm text-white mb-4" style="font-family: 'Syne', sans-serif;">Más recientes</h3>
              <div class="flex flex-col gap-4">
                {resto.slice(0, 6).map((a) => (
                  <a href={`/noticias/${a.slug}`} class="group flex flex-col gap-1 no-underline">
                    {a.categoria && (
                      <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{a.categoria.nombre}</span>
                    )}
                    <span class="text-white/60 group-hover:text-white text-xs leading-snug line-clamp-2 transition-colors duration-200" style="font-family: 'Syne', sans-serif;">
                      {a.titulo}
                    </span>
                    <span class="text-white/25 text-[10px] flex items-center gap-1">
                      <Clock size={9} /> {formatFecha(a.creadoEn)}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>

      </div>
    </div>
  </div>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
