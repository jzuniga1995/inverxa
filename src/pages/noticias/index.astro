    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://inversax.com/noticias?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })}</script>

  <!-- ═══════════════════════════════════════
       JSON-LD — CollectionPage
       Le dice a Google que esta página es un
       índice de artículos, no un artículo suelto
  ═══════════════════════════════════════ -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Noticias de Finanzas, Cripto y Bolsa en Español",
    "description": "Las últimas noticias de criptomonedas, trading, forex, bolsa y economía para Latinoamérica.",
