---
// src/pages/noticias/[slug].astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticuloPorSlug, getArticulosPorCategoria } from '../../db/queries';
import { Clock, ArrowLeft, ArrowRight, Globe } from 'lucide-astro';
import AutorFirma from '../../components/AutorFirma.astro';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/noticias');

const db = Astro.locals.db;
const articulo = await getArticuloPorSlug(db, slug);

if (!articulo) return Astro.redirect('/404');

const filtrados = articulo.categoria?.slug
  ? (await getArticulosPorCategoria(db, articulo.categoria.slug, 4))
      .filter(a => a.slug !== slug)
      .slice(0, 3)
  : [];

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  return new Intl.DateTimeFormat('es', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(fecha);
}

---

<Layout>
---
// REEMPLAZA el bloque <slot name="head"> en src/pages/noticias/[slug].astro
// El resto del archivo (frontmatter, template, styles) queda igual.
// Solo copia este bloque y pégalo en lugar del anterior.
---

<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT / DNS-PREFETCH
       Mejora LCP cargando antes el CDN de imágenes
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
  <title>{articulo.titulo} — Inversax</title>
  <meta name="description"  content={articulo.resumen ?? ''} />
  <meta name="author"       content="José Zúniga" />
  <meta name="robots"       content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"    content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"     href={`https://inversax.com/noticias/${articulo.slug}`} />

  <!-- ═══════════════════════════════════════
       KEYWORDS
       news_keywords es leído específicamente por Google News
  ═══════════════════════════════════════ -->
  <meta name="keywords"      content={[
    articulo.categoria?.nombre,
    'inversiones',
    'finanzas',
    'latinoamérica',
    'mercados financieros',
    articulo.pais?.nombre,
  ].filter(Boolean).join(', ')} />
  <meta name="news_keywords" content={[
    articulo.categoria?.nombre,
    articulo.titulo.split(' ').slice(0, 5).join(' '),
    'Inversax',
  ].filter(Boolean).join(', ')} />

  <!-- ═══════════════════════════════════════
       GEO — ayuda en búsquedas locales LATAM
  ═══════════════════════════════════════ -->
  <meta name="geo.region"      content={articulo.pais?.codigo ?? 'LATAM'} />
  <meta name="geo.placename"   content={articulo.pais?.nombre ?? 'Latinoamérica'} />
  <meta name="language"        content="Spanish" />
  <meta name="content-language" content="es" />

  <!-- ═══════════════════════════════════════
       HREFLANG — cubre todos los mercados que sirves
       Le dice a Google qué variante de español mostrar
       según el país del usuario
  ═══════════════════════════════════════ -->
  {(() => {
    const url = `https://inversax.com/noticias/${articulo.slug}`;
    const locales = [
      'es',        // español genérico
      // América Latina
      'es-MX',     // México
      'es-AR',     // Argentina
      'es-CO',     // Colombia
      'es-CL',     // Chile
      'es-PE',     // Perú
      'es-VE',     // Venezuela
      'es-EC',     // Ecuador
      'es-BO',     // Bolivia
      'es-PY',     // Paraguay
      'es-UY',     // Uruguay
      'es-CR',     // Costa Rica
      'es-PA',     // Panamá
      'es-DO',     // República Dominicana
      'es-SV',     // El Salvador
      'es-HN',     // Honduras
      'es-NI',     // Nicaragua
      'es-GT',     // Guatemala
      'es-CU',     // Cuba
      'es-PR',     // Puerto Rico
      'es-BZ',     // Belice
      // Europa
      'es-ES',     // España
      'es-AD',     // Andorra
      'es-DE',     // Alemania
      'es-FR',     // Francia
      'es-IT',     // Italia
      'es-CH',     // Suiza
      'es-NL',     // Países Bajos
      'es-GB',     // Reino Unido
      'es-PT',     // Portugal
      // Resto del mundo
      'es-US',     // Estados Unidos
      'es-CA',     // Canadá
      'es-AU',     // Australia
      'es-BR',     // Brasil
      'es-PH',     // Filipinas
      'es-GQ',     // Guinea Ecuatorial
      'es-MA',     // Marruecos
    ];
    return locales.map(lang => (
      <link rel="alternate" hreflang={lang} href={url} />
    ));
  })()}
  <link rel="alternate" hreflang="x-default" href={`https://inversax.com/noticias/${articulo.slug}`} />

  <!-- ═══════════════════════════════════════
       OPEN GRAPH
  ═══════════════════════════════════════ -->
  <meta property="og:site_name"   content="Inversax" />
  <meta property="og:locale"      content="es_LA" />
  <meta property="og:locale:alternate" content="es_MX" />
  <meta property="og:locale:alternate" content="es_AR" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:locale:alternate" content="es_ES" />
  <meta property="og:type"        content="article" />
  <meta property="og:title"       content={articulo.titulo} />
  <meta property="og:description" content={articulo.resumen ?? ''} />
  <meta property="og:url"         content={`https://inversax.com/noticias/${articulo.slug}`} />
  {articulo.imagen && <meta property="og:image"        content={articulo.imagen} />}
  {articulo.imagen && <meta property="og:image:width"   content="1200" />}
  {articulo.imagen && <meta property="og:image:height"  content="630" />}
  {articulo.imagen && <meta property="og:image:alt"     content={articulo.titulo} />}
  {articulo.imagen && <meta property="og:image:type"    content="image/png" />}

  <!-- ═══════════════════════════════════════
       ARTICLE META
  ═══════════════════════════════════════ -->
  <meta property="article:published_time" content={articulo.creadoEn?.toISOString() ?? ''} />
  <meta property="article:modified_time"  content={articulo.actualizadoEn?.toISOString() ?? ''} />
  <meta property="article:publisher"      content="https://inversax.com" />
  <meta property="article:author"         content="https://inversax.com/autor/jose-zuniga" />
  {articulo.categoria && <meta property="article:section" content={articulo.categoria.nombre} />}
  {articulo.categoria && <meta property="article:tag"     content={articulo.categoria.nombre} />}
  <meta property="article:tag" content="finanzas" />
  <meta property="article:tag" content="latinoamérica" />

  <!-- ═══════════════════════════════════════
       TWITTER CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content={articulo.titulo} />
  <meta name="twitter:description" content={articulo.resumen ?? ''} />
  {articulo.imagen && <meta name="twitter:image"     content={articulo.imagen} />}
  {articulo.imagen && <meta name="twitter:image:alt" content={articulo.titulo} />}

  <!-- ═══════════════════════════════════════
       JSON-LD — WebSite + SearchAction
       Activa el Sitelinks Searchbox en Google
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://inversax.com/noticias?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — Organization
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Inversax",
    "url": "https://inversax.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://inversax.com/favicon.png",
      "width": 200,
      "height": 60
    },
    "sameAs": [
      "https://twitter.com/inversax",
      "https://inversax.com"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "editorial",
      "email": "contacto@inversax.com",
      "availableLanguage": "Spanish"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — Person (Autor)
       Construye autoridad E-E-A-T del autor
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "José Zúniga",
    "url": "https://inversax.com/autor/jose-zuniga",
    "jobTitle": "Editor y Fundador",
    "worksFor": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "knowsAbout": [
      "Criptomonedas", "Trading", "Forex", "Bolsa de valores",
      "Economía latinoamericana", "Finanzas personales"
    ],
    "sameAs": [
      "https://inversax.com/autor/jose-zuniga"
    ]
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — NewsArticle (Rich Results)
       Versión extendida con wordCount, speakable, keywords
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": articulo.titulo,
    "description": articulo.resumen ?? '',
    "url": `https://inversax.com/noticias/${articulo.slug}`,
    "datePublished": articulo.creadoEn?.toISOString() ?? '',
    "dateModified": articulo.actualizadoEn?.toISOString() ?? '',
    "wordCount": articulo.contenido
      ? articulo.contenido.replace(/<[^>]+>/g, '').split(/\s+/).length
      : undefined,
    "inLanguage": "es",
    "isAccessibleForFree": true,
    "image": articulo.imagen ? {
      "@type": "ImageObject",
      "url": articulo.imagen,
      "width": 1200,
      "height": 630
    } : undefined,
    "thumbnailUrl": articulo.imagen ?? undefined,
    "author": {
      "@type": "Person",
      "name": "José Zúniga",
      "url": "https://inversax.com/autor/jose-zuniga"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://inversax.com/favicon.png",
        "width": 200,
        "height": 60
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://inversax.com/noticias/${articulo.slug}`
    },
    "articleSection": articulo.categoria?.nombre ?? '',
    "keywords": [
      articulo.categoria?.nombre,
      "inversiones",
      "finanzas latinoamérica",
      articulo.pais?.nombre,
    ].filter(Boolean).join(', '),
    // speakable → Google Assistant puede leer el título/resumen en voz
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".article-summary"]
    },
    "copyrightYear": new Date().getFullYear(),
    "copyrightHolder": {
      "@type": "Organization",
      "name": "Inversax"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — BreadcrumbList
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://inversax.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Noticias",
        "item": "https://inversax.com/noticias"
      },
      ...(articulo.categoria ? [
        {
          "@type": "ListItem",
          "position": 3,
          "name": articulo.categoria.nombre,
          "item": `https://inversax.com/${articulo.categoria.slug}`
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": articulo.titulo,
          "item": `https://inversax.com/noticias/${articulo.slug}`
        }
      ] : [
        {
          "@type": "ListItem",
          "position": 3,
          "name": articulo.titulo,
          "item": `https://inversax.com/noticias/${articulo.slug}`
        }
      ])
    ]
  })} />

</slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- ARTÍCULO -->
        <article class="flex-1 min-w-0">

          <!-- Volver -->
          <a href="/noticias" class="inline-flex items-center gap-1.5 text-white/40 hover:text-white text-sm no-underline transition-colors duration-200 mb-6">
            <ArrowLeft size={15} /> Volver a noticias
          </a>

          <!-- Meta -->
          <div class="flex items-center gap-2 flex-wrap mb-4">
            {articulo.categoria && (
              <a
                href={`/noticias?categoria=${articulo.categoria.slug}`}
                class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider no-underline hover:bg-[#E8C060] transition-colors duration-200"
              >
                {articulo.categoria.nombre}
              </a>
            )}
            {articulo.pais && (
              <span class="flex items-center gap-1 text-white/30 text-xs border border-white/[0.07] px-2 py-0.5 rounded">
                <Globe size={10} />
                {articulo.pais.nombre}
              </span>
            )}
            <span class="text-white/30 text-xs flex items-center gap-1 ml-auto">
              <Clock size={11} />
              {formatFecha(articulo.creadoEn)}
            </span>
          </div>

          <!-- Título -->
          <h1 class="font-extrabold text-2xl sm:text-3xl lg:text-4xl text-white leading-tight mb-4" style="font-family: 'Syne', sans-serif;">
            {articulo.titulo}
          </h1>

          <!-- Resumen -->
          {articulo.resumen && (
            <p class="text-white/50 text-base sm:text-lg leading-relaxed border-l-2 border-[#D4A843] pl-4 mb-8 font-light">
              {articulo.resumen}
            </p>
          )}

          <!-- Imagen principal -->
          {articulo.imagen && (
            <div class="w-full h-56 sm:h-80 rounded-2xl overflow-hidden mb-8 bg-[#1A1D24]">
              <img
                src={articulo.imagen}
                alt={articulo.titulo}
                class="w-full h-full object-cover"
              />
            </div>
          )}

          <!-- Contenido del artículo -->
          <div class="article-content text-white/70 leading-relaxed text-base sm:text-[16.5px]" set:html={articulo.contenido} />

          <!-- FIRMA DEL AUTOR ← aquí -->
<AutorFirma fecha={articulo.creadoEn} />

          <!-- Footer del artículo -->
          <div class="flex items-center justify-between mt-10 pt-6 border-t border-white/[0.07] flex-wrap gap-4">
            <span class="text-white/25 text-xs">
              Actualizado: {formatFecha(articulo.actualizadoEn)}
            </span>
            <a href="/noticias" class="inline-flex items-center gap-1.5 text-[#D4A843] text-sm font-medium no-underline hover:text-[#E8C060] transition-colors duration-200">
              <ArrowLeft size={14} /> Ver más noticias
            </a>
          </div>

        </article>

        <!-- SIDEBAR -->
        <aside class="w-full lg:w-72 flex-shrink-0 flex flex-col gap-4">

          <!-- Artículos relacionados -->
          {filtrados.length > 0 && (
            <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
              <h3 class="font-bold text-sm text-white mb-4" style="font-family: 'Syne', sans-serif;">
                Relacionados
              </h3>
              <div class="flex flex-col gap-4">
                {filtrados.map((rel) => (
                  <a href={`/noticias/${rel.slug}`} class="group flex flex-col gap-1.5 no-underline">
                    {rel.imagen && (
                      <div class="w-full h-28 rounded-lg overflow-hidden bg-[#1A1D24]">
                        <img src={rel.imagen} alt={rel.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                      </div>
                    )}
                    {rel.categoria && (
                      <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{rel.categoria.nombre}</span>
                    )}
                    <span class="text-white/60 group-hover:text-white text-xs leading-snug line-clamp-2 transition-colors duration-200" style="font-family: 'Syne', sans-serif;">
                      {rel.titulo}
                    </span>
                    <span class="text-white/25 text-[10px] flex items-center gap-1">
                      <Clock size={9} /> {formatFecha(rel.creadoEn)}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Explorar categorías -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
            <h3 class="font-bold text-sm text-white mb-4" style="font-family: 'Syne', sans-serif;">
              Explorar
            </h3>
            <div class="flex flex-col gap-1">
              {[
                { label: 'Criptomonedas', slug: 'cripto'   },
                { label: 'Trading',       slug: 'trading'  },
                { label: 'Bolsa',         slug: 'bolsa'    },
                { label: 'Economía',      slug: 'economia' },
                { label: 'Forex',         slug: 'forex'    },
              ].map((cat) => (
                <a
                  href={`/noticias?categoria=${cat.slug}`}
                  class="flex items-center justify-between px-3 py-2 rounded-lg text-sm text-white/50 hover:text-white hover:bg-white/5 no-underline transition-colors duration-200"
                >
                  <span>{cat.label}</span>
                  <ArrowRight size={13} />
                </a>
              ))}
            </div>
          </div>

        </aside>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-content h2 {
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #E8EAF0;
    margin: 2rem 0 1rem;
  }

  .article-content h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #E8EAF0;
    margin: 1.5rem 0 0.75rem;
  }

  .article-content h4 {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #E8EAF0;
    margin: 1.25rem 0 0.5rem;
  }

  .article-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .article-content a {
    color: #D4A843;
    text-decoration: underline;
  }

  .article-content a:hover {
    color: #E8C060;
  }

  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-content ul {
    list-style-type: disc;
  }

  .article-content ol {
    list-style-type: decimal;
  }

  .article-content li {
    line-height: 1.7;
  }

  /* Listas anidadas */
  .article-content li ul,
  .article-content li ol {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .article-content blockquote {
    border-left: 3px solid #D4A843;
    padding-left: 1rem;
    color: rgba(232,234,240,0.5);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .article-content strong {
    color: #E8EAF0;
    font-weight: 600;
  }

  .article-content em {
    font-style: italic;
    color: rgba(232,234,240,0.8);
  }

  .article-content img {
    width: 100%;
    border-radius: 12px;
    margin: 1.5rem 0;
  }

  .article-content code {
    background: rgba(255,255,255,0.07);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875rem;
    color: #D4A843;
    font-family: monospace;
  }

  /* Bloque de código */
  .article-content pre {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .article-content pre code {
    background: transparent;
    padding: 0;
    font-size: 0.85rem;
    color: #E8EAF0;
  }

  .article-content hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 2rem 0;
  }

  /* Tablas */
  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .article-content th {
    background: rgba(212,168,67,0.1);
    color: #D4A843;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .article-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.7);
  }

  .article-content tr:hover td {
    background: rgba(255,255,255,0.02);
  }
</style>


