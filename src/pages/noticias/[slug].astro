---
// src/pages/noticias/[slug].astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticuloPorSlug, getArticulosPorCategoria } from '../../db/queries';
import { Clock, ArrowLeft, ArrowRight, Globe } from 'lucide-astro';
import AutorFirma from '../../components/AutorFirma.astro';
import HerramientasSidebar from '../../components/HerramientasSidebar.astro';
import { getCloudinaryUrl } from '../../lib/cloudinary';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/noticias');

const db = Astro.locals.db;
const articulo = await getArticuloPorSlug(db, slug);

if (!articulo) return Astro.redirect('/404');

const filtrados = articulo.categoria?.slug
  ? (await getArticulosPorCategoria(db, articulo.categoria.slug, 4))
      .filter(a => a.slug !== slug)
      .slice(0, 3)
  : [];

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  return new Intl.DateTimeFormat('es', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(fecha);
}
---

<Layout>

<slot name="head" slot="head">

  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <title>{articulo.titulo} — Inversax</title>
  <meta name="description"  content={articulo.resumen ?? ''} />
  <meta name="author"       content="José Zúniga" />
  <meta name="robots"       content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"    content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"     href={`https://inversax.com/noticias/${articulo.slug}`} />

  <meta name="keywords"      content={[
    articulo.categoria?.nombre,
    'inversiones',
    'finanzas',
    'latinoamérica',
    'mercados financieros',
    articulo.pais?.nombre,
  ].filter(Boolean).join(', ')} />
  <meta name="news_keywords" content={[
    articulo.categoria?.nombre,
    articulo.titulo.split(' ').slice(0, 5).join(' '),
    'Inversax',
  ].filter(Boolean).join(', ')} />

  <meta name="geo.region"      content={articulo.pais?.codigo ?? 'LATAM'} />
  <meta name="geo.placename"   content={articulo.pais?.nombre ?? 'Latinoamérica'} />
  <meta name="language"        content="Spanish" />
  <meta name="content-language" content="es" />

  {(() => {
    const url = `https://inversax.com/noticias/${articulo.slug}`;
    const locales = [
      'es','es-MX','es-AR','es-CO','es-CL','es-PE','es-VE','es-EC',
      'es-BO','es-PY','es-UY','es-CR','es-PA','es-DO','es-SV','es-HN',
      'es-NI','es-GT','es-CU','es-PR','es-BZ','es-ES','es-AD','es-DE',
      'es-FR','es-IT','es-CH','es-NL','es-GB','es-PT','es-US','es-CA',
      'es-AU','es-BR','es-PH','es-GQ','es-MA',
    ];
    return locales.map(lang => (
      <link rel="alternate" hreflang={lang} href={url} />
    ));
  })()}
  <link rel="alternate" hreflang="x-default" href={`https://inversax.com/noticias/${articulo.slug}`} />

  <meta property="og:site_name"   content="Inversax" />
  <meta property="og:locale"      content="es_LA" />
  <meta property="og:locale:alternate" content="es_MX" />
  <meta property="og:locale:alternate" content="es_AR" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:locale:alternate" content="es_ES" />
  <meta property="og:type"        content="article" />
  <meta property="og:title"       content={articulo.titulo} />
  <meta property="og:description" content={articulo.resumen ?? ''} />
  <meta property="og:url"         content={`https://inversax.com/noticias/${articulo.slug}`} />
  {articulo.imagen && <meta property="og:image"       content={articulo.imagen} />}
  {articulo.imagen && <meta property="og:image:width"  content="1200" />}
  {articulo.imagen && <meta property="og:image:height" content="630" />}
  {articulo.imagen && <meta property="og:image:alt"    content={articulo.titulo} />}
  {articulo.imagen && <meta property="og:image:type"   content="image/png" />}

  <meta property="article:published_time" content={articulo.creadoEn?.toISOString() ?? ''} />
  <meta property="article:modified_time"  content={articulo.actualizadoEn?.toISOString() ?? ''} />
  <meta property="article:publisher"      content="https://inversax.com" />
  <meta property="article:author"         content="https://inversax.com/autor/jose-zuniga" />
  {articulo.categoria && <meta property="article:section" content={articulo.categoria.nombre} />}
  {articulo.categoria && <meta property="article:tag"     content={articulo.categoria.nombre} />}
  <meta property="article:tag" content="finanzas" />
  <meta property="article:tag" content="latinoamérica" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content={articulo.titulo} />
  <meta name="twitter:description" content={articulo.resumen ?? ''} />
  {articulo.imagen && <meta name="twitter:image"     content={articulo.imagen} />}
  {articulo.imagen && <meta name="twitter:image:alt" content={articulo.titulo} />}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://inversax.com/noticias?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Inversax",
    "url": "https://inversax.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://inversax.com/favicon.png",
      "width": 200,
      "height": 60
    },
    "sameAs": [
      "https://twitter.com/inversax",
      "https://inversax.com"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "editorial",
      "email": "codezun@gmail.com",
      "availableLanguage": "Spanish"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "José Zúniga",
    "url": "https://inversax.com/autor/jose-zuniga",
    "jobTitle": "Editor y Fundador",
    "worksFor": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "knowsAbout": [
      "Criptomonedas", "Trading", "Forex", "Bolsa de valores",
      "Economía latinoamericana", "Finanzas personales"
    ],
    "sameAs": [
      "https://inversax.com/autor/jose-zuniga"
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": articulo.titulo,
    "description": articulo.resumen ?? '',
    "url": `https://inversax.com/noticias/${articulo.slug}`,
    "datePublished": articulo.creadoEn?.toISOString() ?? '',
    "dateModified": articulo.actualizadoEn?.toISOString() ?? '',
    "wordCount": articulo.contenido
      ? articulo.contenido.replace(/<[^>]+>/g, '').split(/\s+/).length
      : undefined,
    "inLanguage": "es",
    "isAccessibleForFree": true,
    "image": articulo.imagen ? {
      "@type": "ImageObject",
      "url": articulo.imagen,
      "width": 1200,
      "height": 630
    } : undefined,
    "thumbnailUrl": articulo.imagen ?? undefined,
    "author": {
      "@type": "Person",
      "name": "José Zúniga",
      "url": "https://inversax.com/autor/jose-zuniga"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://inversax.com/favicon.png",
        "width": 200,
        "height": 60
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://inversax.com/noticias/${articulo.slug}`
    },
    "articleSection": articulo.categoria?.nombre ?? '',
    "keywords": [
      articulo.categoria?.nombre,
      "inversiones",
      "finanzas latinoamérica",
      articulo.pais?.nombre,
    ].filter(Boolean).join(', '),
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".article-summary"]
    },
    "copyrightYear": new Date().getFullYear(),
    "copyrightHolder": {
      "@type": "Organization",
      "name": "Inversax"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://inversax.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Noticias",
        "item": "https://inversax.com/noticias"
      },
      ...(articulo.categoria ? [
        {
          "@type": "ListItem",
          "position": 3,
          "name": articulo.categoria.nombre,
          "item": `https://inversax.com/${articulo.categoria.slug}`
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": articulo.titulo,
          "item": `https://inversax.com/noticias/${articulo.slug}`
        }
      ] : [
        {
          "@type": "ListItem",
          "position": 3,
          "name": articulo.titulo,
          "item": `https://inversax.com/noticias/${articulo.slug}`
        }
      ])
    ]
  })} />

</slot>

  <div style="background:#FAFAF8;min-height:100vh;font-family:'DM Sans',sans-serif;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- ── ARTÍCULO ─────────────────────────────────────── -->
        <article class="flex-1 min-w-0">

          <!-- Volver -->
          <a href="/noticias" class="inline-flex items-center gap-1.5 text-sm no-underline transition-colors duration-200 mb-6" style="color:#78716C;">
            <ArrowLeft size={15} /> Volver a noticias
          </a>

          <!-- Meta -->
          <div class="flex items-center gap-2 flex-wrap mb-4">
            {articulo.categoria && (
              <a
                href={`/noticias?categoria=${articulo.categoria.slug}`}
                class="text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider no-underline transition-colors duration-200"
                style="background:#B91C1C;color:#fff;"
              >
                {articulo.categoria.nombre}
              </a>
            )}
            {articulo.pais && (
              <span class="flex items-center gap-1 text-xs px-2 py-0.5 rounded" style="color:#A8A29E;border:1px solid #E5E0D8;">
                <Globe size={10} />
                {articulo.pais.nombre}
              </span>
            )}
            <span class="text-xs flex items-center gap-1 ml-auto" style="color:#A8A29E;">
              <Clock size={11} />
              {formatFecha(articulo.creadoEn)}
            </span>
          </div>

          <!-- Título -->
          <h1 class="font-extrabold text-2xl sm:text-3xl lg:text-4xl leading-tight mb-4" style="font-family:'Playfair Display',serif;color:#1C1917;">
            {articulo.titulo}
          </h1>

          <!-- Resumen -->
          {articulo.resumen && (
            <p class="article-summary text-base sm:text-lg leading-relaxed pl-4 mb-8 font-light" style="color:#57534E;border-left:3px solid #B91C1C;">
              {articulo.resumen}
            </p>
          )}

          <!-- Imagen principal -->
          {articulo.imagen && (
            <div class="w-full h-56 sm:h-80 rounded-2xl overflow-hidden mb-8" style="background:#F0EDE7;">
              <img
                src={getCloudinaryUrl(articulo.imagen, 900)!}
                alt={articulo.titulo}
                width="900" height="506"
                loading="eager"
                fetchpriority="high"
                class="w-full h-full object-cover"
              />
            </div>
          )}

          <!-- Contenido -->
          <div class="article-content leading-relaxed text-base sm:text-[16.5px]" style="color:#1C1917;" set:html={articulo.contenido} />

          <!-- Firma del autor -->
          <AutorFirma fecha={articulo.creadoEn} />

          <!-- Footer del artículo -->
          <div class="flex items-center justify-between mt-10 pt-6 flex-wrap gap-4" style="border-top:1px solid #E5E0D8;">
            <span class="text-xs" style="color:#A8A29E;">
              Actualizado: {formatFecha(articulo.actualizadoEn)}
            </span>
            <a href="/noticias" class="inline-flex items-center gap-1.5 text-sm font-medium no-underline transition-colors duration-200" style="color:#B91C1C;">
              <ArrowLeft size={14} /> Ver más noticias
            </a>
          </div>

          <!-- ── HERRAMIENTAS MOBILE (debajo del artículo) ── -->
          <!--
            En mobile el sidebar derecho se apila debajo del artículo,
            pero las herramientas son más útiles aquí, justo al cerrar
            la lectura. El componente muestra su versión grid (lg:hidden)
            solo en este bloque mobile dedicado.
          -->
          <div class="mt-10 pt-8 lg:hidden" style="border-top:1px solid #E5E0D8;">
            <HerramientasSidebar />
          </div>

        </article>

        <!-- ── SIDEBAR DERECHO (solo desktop) ─────────────── -->
        <aside class="w-full lg:w-72 flex-shrink-0 flex flex-col gap-4">

          <!-- Artículos relacionados -->
          {filtrados.length > 0 && (
            <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
              <h3 class="font-bold text-sm mb-4" style="color:#1C1917;">
                Relacionados
              </h3>
              <div class="flex flex-col gap-4">
                {filtrados.map((rel) => (
                  <a href={`/noticias/${rel.slug}`} class="group flex flex-col gap-1.5 no-underline">
                    {rel.imagen && (
                      <div class="w-full h-28 rounded-lg overflow-hidden" style="background:#E5E0D8;">
                        <img src={getCloudinaryUrl(rel.imagen, 400)!} alt={rel.titulo} width="400" height="224" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                      </div>
                    )}
                    {rel.categoria && (
                      <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#B91C1C;">{rel.categoria.nombre}</span>
                    )}
                    <span class="text-xs leading-snug line-clamp-2 transition-colors duration-200 group-hover:text-[#B91C1C]" style="color:#1C1917;">
                      {rel.titulo}
                    </span>
                    <span class="text-[10px] flex items-center gap-1" style="color:#A8A29E;">
                      <Clock size={9} /> {formatFecha(rel.creadoEn)}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Explorar categorías -->
          <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
            <h3 class="font-bold text-sm mb-4" style="color:#1C1917;">
              Explorar
            </h3>
            <div class="flex flex-col gap-1">
              {[
                { label: 'Criptomonedas', slug: 'cripto'   },
                { label: 'Trading',       slug: 'trading'  },
                { label: 'Bolsa',         slug: 'bolsa'    },
                { label: 'Economía',      slug: 'economia' },
                { label: 'Forex',         slug: 'forex'    },
              ].map((cat) => (
                <a
                  href={`/noticias?categoria=${cat.slug}`}
                  class="flex items-center justify-between px-3 py-2 rounded-lg text-sm no-underline transition-colors duration-200 hover:bg-[#EDE8E1]"
                  style="color:#57534E;"
                >
                  <span>{cat.label}</span>
                  <ArrowRight size={13} />
                </a>
              ))}
            </div>
          </div>

          <!-- ── HERRAMIENTAS DESKTOP (sidebar sticky) ── -->
          <!--
            El componente internamente tiene hidden lg:flex,
            así que en desktop muestra la lista compacta sticky
            y en mobile no renderiza nada aquí (lo maneja el
            bloque de arriba, dentro del artículo).
          -->
         <div class="hidden lg:block">
  <HerramientasSidebar />
</div>

        </aside>

      </div>
    </div>
  </div>

</Layout>

<style is:global>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-content h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #1C1917;
    margin: 2rem 0 1rem;
  }

  .article-content h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: #1C1917;
    margin: 1.5rem 0 0.75rem;
  }

  .article-content h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 600;
    color: #1C1917;
    margin: 1.25rem 0 0.5rem;
  }

  .article-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .article-content a {
    color: #B91C1C;
    text-decoration: underline;
  }

  .article-content a:hover {
    color: #991B1B;
  }

  .article-content ul,
  .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-content ul { list-style-type: disc; }
  .article-content ol { list-style-type: decimal; }

  .article-content li { line-height: 1.7; }

  .article-content li ul,
  .article-content li ol {
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .article-content blockquote {
    border-left: 3px solid #B91C1C;
    padding-left: 1rem;
    color: #57534E;
    font-style: italic;
    margin: 1.5rem 0;
  }

  .article-content strong {
    color: #1C1917;
    font-weight: 600;
  }

  .article-content em {
    font-style: italic;
    color: #57534E;
  }

  .article-content img {
    width: 100%;
    border-radius: 12px;
    margin: 1.5rem 0;
  }

  .article-content code {
    background: #F0EDE7;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875rem;
    color: #B91C1C;
    font-family: monospace;
  }

  .article-content pre {
    background: #F5F1EC;
    border: 1px solid #E5E0D8;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .article-content pre code {
    background: transparent;
    padding: 0;
    font-size: 0.85rem;
    color: #1C1917;
  }

  .article-content hr {
    border: none;
    border-top: 1px solid #E5E0D8;
    margin: 2rem 0;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  .article-content th {
    background: #F5F1EC;
    color: #78716C;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #E5E0D8;
  }

  .article-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #F0EDE7;
    color: #1C1917;
  }

  .article-content tr:hover td {
    background: #F9F7F4;
  }
</style>

