---
export const prerender = false;
// src/pages/paises.astro
import Layout from '../layouts/Layout.astro';
import { getPaises, getCategorias } from '../db/queries';
import { Globe, ArrowRight, MapPin } from 'lucide-astro';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=600, stale-while-revalidate=60');

const db = Astro.locals.db;
const [todosPaises, categorias] = await Promise.all([
  getPaises(db),
  getCategorias(db),
]);

const regiones = [
  {
    label: "Latinoamérica",
    codigos: ["ar","bo","br","cl","co","cu","ec","mx","py","pe","uy","ve"],
  },
  {
    label: "América Central",
    codigos: ["bz","cr","sv","gt","hn","ni","pa"],
  },
  {
    label: "Caribe",
    codigos: ["do","pr"],
  },
  {
    label: "Norteamérica",
    codigos: ["us","ca"],
  },
  {
    label: "Europa",
    codigos: ["es","ad","de","fr","gb","it","nl","pt","ch"],
  },
  {
    label: "África",
    codigos: ["gq","ma"],
  },
  {
    label: "Oceanía / Asia",
    codigos: ["au","ph"],
  },
];

const regionesConPaises = regiones.map((region) => ({
  ...region,
  paises: region.codigos
    .map((code) => todosPaises.find((p) => p.codigo === code))
    .filter(Boolean),
})).filter((r) => r.paises.length > 0);

const global = todosPaises.find((p) => p.codigo === 'global');

// ── Códigos especiales que FlagCDN no resuelve bien ──
const flagOverrides: Record<string, string> = {
  gb: 'gb',   // Reino Unido → gb
  pr: 'pr',   // Puerto Rico → pr
};

function getFlagCode(codigo: string): string {
  return flagOverrides[codigo] ?? codigo;
}
