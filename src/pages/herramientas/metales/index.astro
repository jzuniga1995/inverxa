---
// src/pages/herramientas/metales/index.astro
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft, Layers, CircleDollarSign, Gem, Hexagon, Cpu } from 'lucide-astro';

type MetalData = {
  nombre: string; simbolo: string; icono: string;
  color: string; precio: number; unidad: string;
  tradingviewSimbolo: string; slug: string;
};

const ICONOS: Record<string, any> = {
  CircleDollarSign,
  Gem,
  Hexagon,
  Cpu,
};

const colorPorSimbolo: Record<string, string> = {
  XAU: '#F59E0B', XAG: '#94A3B8', XPT: '#7DD3FC', XPD: '#C084FC',
};

const infoMetal: Record<string, { descripcion: string; usos: string[] }> = {
  XAU: {
    descripcion: 'El oro es el metal precioso por excelencia, utilizado como reserva de valor y refugio seguro en momentos de incertidumbre económica.',
    usos: ['Reserva de valor', 'Joyería', 'Electrónica', 'Inversión'],
  },
  XAG: {
    descripcion: 'La plata combina su rol como metal precioso con un alto valor industrial, siendo clave en paneles solares y electrónica.',
    usos: ['Paneles solares', 'Electrónica', 'Joyería', 'Fotografía'],
  },
  XPT: {
    descripcion: 'El platino es más raro que el oro y tiene alta demanda industrial, especialmente en la industria automotriz para catalizadores.',
    usos: ['Catalizadores', 'Joyería', 'Industria química', 'Médico'],
  },
  XPD: {
    descripcion: 'El paladio es uno de los metales más escasos del mundo, con uso crítico en convertidores catalíticos de automóviles.',
    usos: ['Convertidores catalíticos', 'Electrónica', 'Química', 'Dental'],
  },
};

const formatMetal = (p: number) =>
  p > 0 ? `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—';

const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

let metales: MetalData[] = [];
let fetchError = false;

try {
  const cached = await KV?.get('cache:metales', 'json') as MetalData[] | null;
  if (cached && cached.length > 0) {
    metales = cached;
  }
} catch (e) {
  fetchError = true;
  console.error('[MetalesIndex]', e);
}
