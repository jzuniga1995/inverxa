                  style="padding: 14px 20px; border-top: 1px solid #F0EDE7;"
                >
                  <div class="flex items-center gap-3 flex-1 min-w-0">
                    <div style={`width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: ${color}15;`}>
                      <span style={`font-size: 10px; font-weight: 700; color: ${color};`}>{m.simbolo.slice(1, 3)}</span>
                    </div>
                    <div class="min-w-0">
                      <div style="font-weight: 700; font-size: 14px; color: #1C1917;" class="truncate">{m.nombre}</div>
                      <div style="color: #A8A29E; font-size: 11px;">{m.simbolo}</div>
                    </div>
                  </div>

                  <div class="flex items-center md:justify-end flex-shrink-0" style="font-weight: 700; font-size: 14px; color: #1C1917;">
                    {formatMetal(m.precio)}
                  </div>

                  <div class="hidden md:flex items-center justify-end" style="color: #78716C; font-size: 12px;">
                    {m.simbolo}/USD
                  </div>

                  <div class="hidden md:flex items-center justify-end" style="color: #A8A29E; font-size: 12px;">
                    fawazahmed0 API
                  </div>
                </a>
              );
            })}
          </div>

          <!-- Nota -->
          <div style="background: #F5F1EC; border-left: 3px solid #D6D0C8; padding: 14px 18px;">
            <p style="color: #57534E; font-size: 13px; line-height: 1.6; margin: 0;">
              <strong style="color: #B45309;">Nota:</strong> Los precios son tasas de referencia en USD por onza troy con actualización diaria.
              Para trading activo de metales, consultá los precios en tiempo real de tu broker o exchange.
            </p>
          </div>

        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .table-cols { grid-template-columns: 1fr 160px 160px 200px; }
  }
  .metal-row:hover { background: #F9F7F4; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
</style>
