---
// src/pages/herramientas/metales/[metal].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft, CircleDollarSign, Gem, Hexagon, Cpu } from 'lucide-astro';
import TVChart from '../../../components/TVChart.astro';
import { fetchMetales } from '../../../lib/metales';

const { metal } = Astro.params;

type MetalData = {
  nombre: string; simbolo: string; icono: string; color: string;
  precio: number; unidad: string; tradingviewSimbolo: string; slug: string;
};

// ── Caché KV (misma clave que usa el cron: 'cache:metales') ───
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

let metalData: MetalData | null = null;
let fetchError = false;

try {
  // 1. Leer desde KV
  let lista = await KV?.get('cache:metales', 'json') as MetalData[] | null;

  // 2. Si KV vacío → llamar lib directamente y guardar
  if (!lista || lista.length === 0) {
    lista = await fetchMetales();
    if (lista.length > 0) {
      await KV?.put('cache:metales', JSON.stringify(lista), { expirationTtl: 3600 });
    }
  }

  // 3. Encontrar el metal solicitado por slug
  metalData = lista?.find(m => m.slug === metal) ?? null;
} catch (e) {
  fetchError = true;
  console.error('[Metal detail]', e);
}

if (!metalData && !fetchError) {
  return Astro.redirect('/herramientas/metales');
}

// ── Helpers ───────────────────────────────────────────────────
const formatMetal = (p: number) =>
  p > 0 ? `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—';

const colorPorSimbolo: Record<string, string> = {
  XAU: '#F59E0B',
  XAG: '#94A3B8',
  XPT: '#7DD3FC',
  XPD: '#C084FC',
};

const infoCompleta: Record<string, {
  descripcion: string;
  historia: string;
  latam: string;
  usos: string[];
  datos: { label: string; valor: string }[];
}> = {
  XAU: {
    descripcion: 'El oro es el metal precioso por excelencia. Durante siglos ha sido utilizado como reserva de valor, medio de intercambio y símbolo de riqueza. Hoy es el principal activo refugio en momentos de incertidumbre económica.',
    historia: 'El patrón oro dominó el sistema monetario mundial hasta 1971, cuando Nixon desvinculó el dólar del oro. Desde entonces su precio fluctúa libremente y tiende a subir en períodos de inflación o crisis.',
    latam: 'Perú y Brasil son grandes productores mundiales de oro. Muchos bancos centrales latinoamericanos mantienen reservas en oro como protección frente a la devaluación de sus monedas.',
    usos: ['Reserva de valor', 'Joyería', 'Electrónica', 'Medicina', 'Inversión (ETF, monedas)'],
    datos: [
      { label: 'Símbolo',                valor: 'XAU' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Pureza máx.',            valor: '24 quilates (999.9)' },
      { label: 'Principales productores', valor: 'China, Australia, Rusia, Perú' },
    ],
  },
  XAG: {
    descripcion: 'La plata es el segundo metal precioso más importante. A diferencia del oro, tiene un valor industrial enorme que representa más del 50% de su demanda total, especialmente en tecnología verde.',
    historia: 'Históricamente más volátil que el oro, la plata fue moneda oficial en muchas civilizaciones. Su relación con el oro (Gold/Silver Ratio) es un indicador clave para traders de metales.',
    latam: 'México y Perú son los dos mayores productores de plata del mundo. La industria minera es uno de los principales motores económicos de ambos países.',
    usos: ['Paneles solares', 'Electrónica', 'Joyería', 'Fotografía', 'Antibacterial'],
    datos: [
      { label: 'Símbolo',                valor: 'XAG' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Conductividad',          valor: 'Mayor que cualquier metal' },
      { label: 'Principales productores', valor: 'México, Perú, China, Chile' },
    ],
  },
  XPT: {
    descripcion: 'El platino es más raro que el oro y se extrae principalmente en Sudáfrica y Rusia. Su alta resistencia a la corrosión y propiedades catalíticas lo hacen indispensable en la industria.',
    historia: 'Fue considerado inútil por los colonizadores españoles en Sudamérica. Hoy es uno de los metales más valiosos del mundo. Su precio suele superar al oro en períodos de expansión industrial.',
    latam: 'Colombia tiene depósitos históricos de platino en el Chocó. El metal tiene alta relevancia para países con industria automotriz en crecimiento.',
    usos: ['Convertidores catalíticos', 'Joyería fina', 'Industria química', 'Implantes médicos', 'Electrodos'],
    datos: [
      { label: 'Símbolo',                valor: 'XPT' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Punto de fusión',        valor: '1.768°C' },
      { label: 'Principales productores', valor: 'Sudáfrica (75%), Rusia' },
    ],
  },
  XPD: {
    descripcion: 'El paladio es el metal más escaso y uno de los más caros del mundo. Su demanda está impulsada casi exclusivamente por la industria automotriz para reducir emisiones contaminantes.',
    historia: 'Descubierto en 1803, fue ignorado por décadas. La regulación anticontaminación global lo convirtió en un metal estratégico en los 2000s. En 2020 su precio superó los $2.800/oz.',
    latam: 'Brasil tiene los únicos depósitos significativos de paladio en Latinoamérica. Su precio impacta directamente el costo de fabricación de automóviles en la región.',
    usos: ['Convertidores catalíticos', 'Electrónica', 'Industria química', 'Odontología'],
    datos: [
      { label: 'Símbolo',                valor: 'XPD' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Extracción',             valor: 'Subproducto del níquel' },
      { label: 'Principales productores', valor: 'Rusia (40%), Sudáfrica (37%)' },
    ],
  },
};

const color     = metalData ? (colorPorSimbolo[metalData.simbolo] ?? '#D4A843') : '#D4A843';
const tvSymbol  = metalData?.tradingviewSimbolo ?? '';
const info      = metalData ? (infoCompleta[metalData.simbolo] ?? null) : null;
const precioFmt = metalData ? formatMetal(metalData.precio) : '—';
---

