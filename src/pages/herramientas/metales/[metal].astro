---
// src/pages/herramientas/metales/[metal].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-astro';
import { fetchMetales } from '../../../lib/metales';

const { metal } = Astro.params;

type MetalData = {
  nombre: string; simbolo: string; icono: string; color: string;
  precio: number; unidad: string; tradingviewSimbolo: string; slug: string;
};

// ── Caché KV (misma clave que usa el cron: 'cache:metales') ───
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

let metalData: MetalData | null = null;
let fetchError = false;

try {
  // 1. Leer desde KV
  let lista = await KV?.get('cache:metales', 'json') as MetalData[] | null;

  // 2. Si KV vacío → llamar lib directamente y guardar
  if (!lista || lista.length === 0) {
    lista = await fetchMetales();
    if (lista.length > 0) {
      await KV?.put('cache:metales', JSON.stringify(lista), { expirationTtl: 3600 });
    }
  }

  // 3. Encontrar el metal solicitado por slug
  metalData = lista?.find(m => m.slug === metal) ?? null;
} catch (e) {
  fetchError = true;
  console.error('[Metal detail]', e);
}

if (!metalData && !fetchError) {
  return Astro.redirect('/herramientas/metales');
}

// ── Helpers ───────────────────────────────────────────────────
const formatMetal = (p: number) =>
  p > 0 ? `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—';

const colorPorSimbolo: Record<string, string> = {
  XAU: '#F59E0B',
  XAG: '#94A3B8',
  XPT: '#7DD3FC',
  XPD: '#C084FC',
};

const infoCompleta: Record<string, {
  descripcion: string;
  historia: string;
  latam: string;
  usos: string[];
  datos: { label: string; valor: string }[];
}> = {
  XAU: {
    descripcion: 'El oro es el metal precioso por excelencia. Durante siglos ha sido utilizado como reserva de valor, medio de intercambio y símbolo de riqueza. Hoy es el principal activo refugio en momentos de incertidumbre económica.',
    historia: 'El patrón oro dominó el sistema monetario mundial hasta 1971, cuando Nixon desvinculó el dólar del oro. Desde entonces su precio fluctúa libremente y tiende a subir en períodos de inflación o crisis.',
    latam: 'Perú y Brasil son grandes productores mundiales de oro. Muchos bancos centrales latinoamericanos mantienen reservas en oro como protección frente a la devaluación de sus monedas.',
    usos: ['Reserva de valor', 'Joyería', 'Electrónica', 'Medicina', 'Inversión (ETF, monedas)'],
    datos: [
      { label: 'Símbolo',                valor: 'XAU' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Pureza máx.',            valor: '24 quilates (999.9)' },
      { label: 'Principales productores', valor: 'China, Australia, Rusia, Perú' },
    ],
  },
  XAG: {
    descripcion: 'La plata es el segundo metal precioso más importante. A diferencia del oro, tiene un valor industrial enorme que representa más del 50% de su demanda total, especialmente en tecnología verde.',
    historia: 'Históricamente más volátil que el oro, la plata fue moneda oficial en muchas civilizaciones. Su relación con el oro (Gold/Silver Ratio) es un indicador clave para traders de metales.',
    latam: 'México y Perú son los dos mayores productores de plata del mundo. La industria minera es uno de los principales motores económicos de ambos países.',
    usos: ['Paneles solares', 'Electrónica', 'Joyería', 'Fotografía', 'Antibacterial'],
    datos: [
      { label: 'Símbolo',                valor: 'XAG' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Conductividad',          valor: 'Mayor que cualquier metal' },
      { label: 'Principales productores', valor: 'México, Perú, China, Chile' },
    ],
  },
  XPT: {
    descripcion: 'El platino es más raro que el oro y se extrae principalmente en Sudáfrica y Rusia. Su alta resistencia a la corrosión y propiedades catalíticas lo hacen indispensable en la industria.',
    historia: 'Fue considerado inútil por los colonizadores españoles en Sudamérica. Hoy es uno de los metales más valiosos del mundo. Su precio suele superar al oro en períodos de expansión industrial.',
    latam: 'Colombia tiene depósitos históricos de platino en el Chocó. El metal tiene alta relevancia para países con industria automotriz en crecimiento.',
    usos: ['Convertidores catalíticos', 'Joyería fina', 'Industria química', 'Implantes médicos', 'Electrodos'],
    datos: [
      { label: 'Símbolo',                valor: 'XPT' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Punto de fusión',        valor: '1.768°C' },
      { label: 'Principales productores', valor: 'Sudáfrica (75%), Rusia' },
    ],
  },
  XPD: {
    descripcion: 'El paladio es el metal más escaso y uno de los más caros del mundo. Su demanda está impulsada casi exclusivamente por la industria automotriz para reducir emisiones contaminantes.',
    historia: 'Descubierto en 1803, fue ignorado por décadas. La regulación anticontaminación global lo convirtió en un metal estratégico en los 2000s. En 2020 su precio superó los $2.800/oz.',
    latam: 'Brasil tiene los únicos depósitos significativos de paladio en Latinoamérica. Su precio impacta directamente el costo de fabricación de automóviles en la región.',
    usos: ['Convertidores catalíticos', 'Electrónica', 'Industria química', 'Odontología'],
    datos: [
      { label: 'Símbolo',                valor: 'XPD' },
      { label: 'Unidad',                 valor: 'Onza troy (31.1g)' },
      { label: 'Extracción',             valor: 'Subproducto del níquel' },
      { label: 'Principales productores', valor: 'Rusia (40%), Sudáfrica (37%)' },
    ],
  },
};

const color     = metalData ? (colorPorSimbolo[metalData.simbolo] ?? '#D4A843') : '#D4A843';
const tvSymbol  = metalData?.tradingviewSimbolo ?? '';
const info      = metalData ? (infoCompleta[metalData.simbolo] ?? null) : null;
const precioFmt = metalData ? formatMetal(metalData.precio) : '—';
---

<Layout>
  <slot name="head" slot="head">
    <title>{metalData?.nombre ?? metal} — Precio en Vivo · Inversax</title>
    <meta name="description" content={`Precio de ${metalData?.nombre} (${metalData?.simbolo}) en tiempo real con gráfica histórica y análisis para inversores en Latinoamérica.`} />
    <link rel="canonical" href={`https://inversax.com/herramientas/metales/${metal}`} />
  </slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family:'DM Sans',sans-serif;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">

      <!-- Breadcrumb -->
      <a href="/herramientas/metales" class="inline-flex items-center gap-2 text-white/30 hover:text-white text-sm mb-6 no-underline transition-colors">
        <ArrowLeft size={15} /> Metales Preciosos
      </a>

      {fetchError || !metalData ? (
        <div class="flex items-center justify-center py-24 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <p class="text-white/30 text-sm">
            No se pudo cargar la información.{' '}
            <a href="/herramientas/metales" class="text-[#F59E0B]">Volver</a>
          </p>
        </div>
      ) : (
        <div class="flex flex-col gap-6">

          <!-- Header: nombre + precio -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[#111318] border border-white/[0.07] rounded-2xl p-5 sm:p-6">
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0"
                style={`background: ${color}15;`}>
                <span class="font-extrabold text-lg" style={`color: ${color};`}>{metalData.simbolo}</span>
              </div>
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <h1 class="text-white font-extrabold text-xl sm:text-2xl" style="font-family:'Syne',sans-serif;">{metalData.nombre}</h1>
                  <span class="text-white/30 text-sm bg-white/5 px-2 py-0.5 rounded">{metalData.simbolo}/USD</span>
                </div>
                <div class="flex items-center gap-3 mt-1 flex-wrap">
                  <span class="text-white font-bold text-2xl sm:text-3xl" style={`font-family:'Syne',sans-serif; color: ${color};`}>{precioFmt}</span>
                  <span class="text-white/30 text-xs">por onza troy</span>
                </div>
              </div>
            </div>
            <div class="text-white/20 text-xs text-right leading-relaxed">
              Fuente: fawazahmed0 API<br/>Actualización diaria
            </div>
          </div>

          <!-- Gráfico TradingView -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden">
            <div class="px-5 py-4 border-b border-white/[0.07] flex items-center justify-between">
              <h2 class="text-white font-bold text-base" style="font-family:'Syne',sans-serif;">Gráfica de precio</h2>
              <span class="text-white/25 text-xs">TradingView</span>
            </div>
            {tvSymbol ? (
              <div id="tv-chart" style="height: 460px;"></div>
            ) : (
              <div class="flex flex-col items-center justify-center py-16 gap-3">
                <div class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center">
                  <span class="font-bold text-white/20">{metalData.simbolo}</span>
                </div>
                <p class="text-white/30 text-sm font-medium">Gráfica no disponible para {metalData.nombre}</p>
                <p class="text-white/20 text-xs text-center max-w-xs">TradingView no tiene datos históricos para este metal en este momento.</p>
              </div>
            )}
          </div>

          <!-- Datos clave -->
          {info && (
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {info.datos.map(({ label, valor }) => (
                <div class="bg-[#111318] border border-white/[0.07] rounded-xl p-4">
                  <div class="text-white/30 text-xs mb-1.5">{label}</div>
                  <div class="text-white font-bold text-sm leading-snug" style="font-family:'Syne',sans-serif;">{valor}</div>
                </div>
              ))}
            </div>
          )}

          <!-- Usos -->
          {info && (
            <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5 sm:p-6">
              <h2 class="text-white font-bold text-base mb-4" style="font-family:'Syne',sans-serif;">Principales usos</h2>
              <div class="flex flex-wrap gap-2">
                {info.usos.map(uso => (
                  <span class="text-sm px-3 py-1.5 rounded-lg border font-medium"
                    style={`background: ${color}10; border-color: ${color}25; color: ${color};`}>
                    {uso}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Descripción + Historia + LATAM -->
          {info && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
                <h3 class="text-white font-bold text-sm mb-3" style="font-family:'Syne',sans-serif;">¿Qué es?</h3>
                <p class="text-white/45 text-sm leading-relaxed">{info.descripcion}</p>
              </div>
              <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
                <h3 class="text-white font-bold text-sm mb-3" style="font-family:'Syne',sans-serif;">Historia y mercado</h3>
                <p class="text-white/45 text-sm leading-relaxed">{info.historia}</p>
              </div>
              <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5"
                style={`border-color: ${color}20;`}>
                <h3 class="font-bold text-sm mb-3" style={`font-family:'Syne',sans-serif; color: ${color};`}>Relevancia en LATAM</h3>
                <p class="text-white/45 text-sm leading-relaxed">{info.latam}</p>
              </div>
            </div>
          )}

          <!-- Nota -->
          <div class="rounded-xl p-4" style={`background: ${color}08; border: 1px solid ${color}15;`}>
            <p class="text-white/40 text-xs leading-relaxed">
              <span class="font-bold" style={`color: ${color};`}>Nota:</span> Los precios mostrados son tasas de referencia con actualización diaria.
              Para trading activo de metales, consultá precios en tiempo real en tu broker. Los precios spot pueden diferir.
            </p>
          </div>

        </div>
      )}
    </div>
  </div>
</Layout>

<!-- TradingView Widget -->
<script define:vars={{ tvSymbol }}>
  const container = document.getElementById('tv-chart');
  if (container && tvSymbol) {
    const script = document.createElement('script');
    script.src = 'https://s3.tradingview.com/tv.js';
    script.onload = () => {
      new TradingView.widget({
        container_id:        'tv-chart',
        symbol:              tvSymbol,
        interval:            'D',
        timezone:            'America/Tegucigalpa',
        theme:               'dark',
        style:               '1',
        locale:              'es',
        toolbar_bg:          '#111318',
        enable_publishing:   false,
        hide_top_toolbar:    false,
        save_image:          false,
        backgroundColor:     '#111318',
        gridColor:           'rgba(255,255,255,0.03)',
        width:               '100%',
        height:              460,
        withdateranges:      true,
        allow_symbol_change: false,
      });
    };
    document.head.appendChild(script);
  }
</script>

