          <!-- Descripción + Historia + LATAM -->
          {info && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div style="border:1px solid #E5E0D8;background:#F5F1EC;padding:20px;">
                <h3 style="font-size:14px;font-weight:700;color:#1C1917;margin:0 0 12px;">¿Qué es?</h3>
                <p style="color:#57534E;font-size:13px;line-height:1.7;margin:0;">{info.descripcion}</p>
              </div>
              <div style="border:1px solid #E5E0D8;background:#F5F1EC;padding:20px;">
                <h3 style="font-size:14px;font-weight:700;color:#1C1917;margin:0 0 12px;">Historia y mercado</h3>
                <p style="color:#57534E;font-size:13px;line-height:1.7;margin:0;">{info.historia}</p>
              </div>
              <div style={`border:1px solid ${color}25;background:${color}05;padding:20px;`}>
                <h3 style={`font-size:14px;font-weight:700;color:${color};margin:0 0 12px;`}>Relevancia en LATAM</h3>
                <p style="color:#57534E;font-size:13px;line-height:1.7;margin:0;">{info.latam}</p>
              </div>
            </div>
          )}

          <!-- Nota -->
          <div style="background:#F5F1EC;border-left:3px solid #D6D0C8;padding:14px 18px;">
            <p style="color:#57534E;font-size:13px;line-height:1.6;margin:0;">
              <strong style={`color:${color};`}>Nota:</strong> Los precios mostrados son tasas de referencia con actualización diaria.
              Para trading activo de metales, consultá precios en tiempo real en tu broker. Los precios spot pueden diferir.
            </p>
          </div>

        </div>
      )}
    </div>
  </div>
</Layout>

