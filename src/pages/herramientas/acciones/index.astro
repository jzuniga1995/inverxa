---
// src/pages/herramientas/acciones/index.astro
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-astro';

type Accion = {
  nombre: string;
  ticker: string;
  slug: string;
  sector: string;
  icono: string;
  color: string;
  tradingviewSimbolo: string;
  precio: number;
  cambioPct: number;
  alza: boolean;
};

let acciones: Accion[] = [];

const fmt = (p: number) => {
  if (!p || p <= 0) return '—';
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};
const fmtC = (c: number) => `${c >= 0 ? '+' : ''}${c.toFixed(2)}%`;

const dominiosPorTicker: Record<string, string> = {
  // ── Tecnología ──
  AAPL:    'apple.com',
  NVDA:    'nvidia.com',
  MSFT:    'microsoft.com',
  META:    'meta.com',
  GOOGL:   'google.com',
  AMD:     'amd.com',
  PLTR:    'palantir.com',
  CRWD:    'crowdstrike.com',

  // ── Alta volatilidad ──
  TSLA:    'tesla.com',
  AMZN:    'amazon.com',
  NFLX:    'netflix.com',
  COIN:    'coinbase.com',
  HOOD:    'robinhood.com',
  SHOP:    'shopify.com',

  // ── ETFs ──
  SPY:     'ssga.com',
  QQQ:     'invesco.com',
  GLD:     'spdrgoldshares.com',

  // ── LATAM ──
  MELI:    'mercadolibre.com',
  EC:      'ecopetrol.com.co',
  PBR:     'petrobras.com.br',
  VALE:    'vale.com',
  GLOB:    'globant.com',
  AMX:     'americamovil.com',

  // ── Finanzas ──
  V:       'visa.com',
  JPM:     'jpmorganchase.com',
  GS:      'goldmansachs.com',
  'BRK-B': 'berkshirehathaway.com',
  PYPL:    'paypal.com',

  // ── Salud ──
  LLY:     'lilly.com',
  JNJ:     'jnj.com',
  PFE:     'pfizer.com',

  // ── Consumo ──
  KO:      'coca-cola.com',
  MCD:     'mcdonalds.com',
  DIS:     'disney.com',
  SBUX:    'starbucks.com',
  NKE:     'nike.com',
  UBER:    'uber.com',

  // ── Energía ──
  XOM:     'exxonmobil.com',
  CVX:     'chevron.com',

  // ── Industria ──
  BA:      'boeing.com',
  CAT:     'caterpillar.com',
};

// ── Lee de KV directamente ──────
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

try {
  const cached = await KV?.get('acciones', 'json') as Accion[] | null;
  if (cached && cached.length > 0) acciones = cached;
} catch (e) {
  console.error('[AccionesIndex]', e);
}
