---
// src/pages/herramientas/acciones/index.astro
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-astro';

type Accion = {
  nombre: string;
  ticker: string;
  slug: string;
  sector: string;
  icono: string;
  color: string;
  tradingviewSimbolo: string;
  precio: number;
  cambioPct: number;
  alza: boolean;
};

let acciones: Accion[] = [];

const fmt = (p: number) => {
  if (!p || p <= 0) return '—';
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};
const fmtC = (c: number) => `${c >= 0 ? '+' : ''}${c.toFixed(2)}%`;

const dominiosPorTicker: Record<string, string> = {
  AAPL:   'apple.com',              MSFT:  'microsoft.com',        GOOGL: 'google.com',
  AMZN:   'amazon.com',             NVDA:  'nvidia.com',            META:  'meta.com',
  TSLA:   'tesla.com',              ORCL:  'oracle.com',            CRM:   'salesforce.com',
  ADBE:   'adobe.com',              INTC:  'intel.com',             AMD:   'amd.com',
  QCOM:   'qualcomm.com',           JPM:   'jpmorganchase.com',     BAC:   'bankofamerica.com',
  GS:     'goldmansachs.com',       MS:    'morganstanley.com',     V:     'visa.com',
  MA:     'mastercard.com',         PYPL:  'paypal.com',            KO:    'coca-cola.com',
  PEP:    'pepsico.com',            MCD:   'mcdonalds.com',         WMT:   'walmart.com',
  NKE:    'nike.com',               SBUX:  'starbucks.com',         NFLX:  'netflix.com',
  DIS:    'disney.com',             UBER:  'uber.com',              BA:    'boeing.com',
  T:      'att.com',                VZ:    'verizon.com',           SPY:   'ssga.com',
  QQQ:    'invesco.com',
  'BRK-B': 'berkshirehathaway.com',
  LYFT:   'lyft.com',               TGT:   'target.com',            HD:    'homedepot.com',
  LOW:    'lowes.com',              CMCSA: 'comcast.com',           SNE:   'sony.com',
  CAT:    'caterpillar.com',        DE:    'deere.com',             IBM:   'ibm.com',
  TXN:    'ti.com',                 INTU:  'intuit.com',            CSCO:  'cisco.com',
  VMW:    'vmware.com',             SAP:   'sap.com',               ADP:   'adp.com',
  C:      'citi.com',
};

// ── Lee de KV directamente (igual que forex/index.astro) ──────
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

try {
  const cached = await KV?.get('acciones', 'json') as Accion[] | null;
  if (cached && cached.length > 0) acciones = cached;
} catch (e) {
  console.error('[AccionesIndex]', e);
}
