---
// src/pages/herramientas/forex/[par].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft, TrendingUp } from 'lucide-astro';
import TVChart from '../../../components/TVChart.astro';
import { obtenerForex } from '../../../lib/forex';

const { par } = Astro.params;

// Convertir slug a formato par: eur-usd → EUR/USD
const parFormateado = par!.replace('-', '/').toUpperCase();

type ForexData = {
  par: string; base: string; cotizada: string;
  banderaBase: string; banderaCotizada: string;
  precio: number; tradingviewSimbolo: string;
  tvDisponible?: boolean;
};

// ── Caché KV (igual que el cron guarda 'cache:forex') ─────────
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;

let parData: (ForexData & { tvDisponible: boolean }) | null = null;
let fetchError = false;

try {
  // 1. Leer lista completa desde KV (la misma clave que usa el cron)
  let lista = await KV?.get('cache:forex', 'json') as ForexData[] | null;

  // 2. Si KV está vacío, llamar lib directamente y guardar en KV
  if (!lista || lista.length === 0) {
    lista = await obtenerForex();
    if (lista.length > 0) {
      await KV?.put('cache:forex', JSON.stringify(lista), { expirationTtl: 3600 });
    }
  }

  // 3. Encontrar el par solicitado
  const found = lista?.find(f => f.par === parFormateado) ?? null;
  if (found) {
    parData = { ...found, tvDisponible: found.tvDisponible ?? false };
  }
} catch (e) {
  fetchError = true;
  console.error('[Forex detail]', e);
}

if (!parData && !fetchError) {
  return Astro.redirect('/herramientas/forex');
}

// ── Helpers ───────────────────────────────────────────────────
const formatForex = (p: number) => {
  if (!p) return '—';
  if (p >= 100) return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
};

const nombrePar: Record<string, string> = {
  'EUR/USD': 'Euro / Dólar Estadounidense',
  'GBP/USD': 'Libra Esterlina / Dólar',
  'USD/JPY': 'Dólar / Yen Japonés',
  'USD/CHF': 'Dólar / Franco Suizo',
  'USD/CAD': 'Dólar / Dólar Canadiense',
  'AUD/USD': 'Dólar Australiano / Dólar',
  'USD/MXN': 'Dólar / Peso Mexicano',
  'USD/COP': 'Dólar / Peso Colombiano',
  'USD/ARS': 'Dólar / Peso Argentino',
  'USD/CLP': 'Dólar / Peso Chileno',
  'USD/PEN': 'Dólar / Sol Peruano',
  'USD/BRL': 'Dólar / Real Brasileño',
  'USD/BOB': 'Dólar / Boliviano',
  'USD/GTQ': 'Dólar / Quetzal Guatemalteco',
  'USD/HNL': 'Dólar / Lempira Hondureño',
  'USD/NIO': 'Dólar / Córdoba Nicaragüense',
  'USD/CRC': 'Dólar / Colón Costarricense',
  'USD/DOP': 'Dólar / Peso Dominicano',
  'USD/PYG': 'Dólar / Guaraní Paraguayo',
  'USD/UYU': 'Dólar / Peso Uruguayo',
  'USD/VES': 'Dólar / Bolívar Venezolano',
  'USD/PAB': 'Dólar / Balboa Panameño',
  'NZD/USD': 'Dólar Neozelandés / Dólar',
  'USD/CNY': 'Dólar / Yuan Chino',
  'USD/CUP': 'Dólar / Peso Cubano',
  'USD/JMD': 'Dólar / Dólar Jamaicano',
  'USD/TTD': 'Dólar / Dólar Trinidad y Tobago',
  'USD/BBD': 'Dólar / Dólar de Barbados',
  'USD/HTG': 'Dólar / Gourde Haitiano',
};

const infoMoneda: Record<string, { nombre: string; descripcion: string }> = {
  USD: { nombre: 'Dólar Estadounidense', descripcion: 'La moneda de reserva mundial, emitida por la Reserva Federal de EE.UU.' },
  EUR: { nombre: 'Euro',                 descripcion: 'Moneda oficial de 20 países de la Unión Europea, segunda más transada del mundo.' },
  GBP: { nombre: 'Libra Esterlina',      descripcion: 'Una de las monedas más antiguas y la cuarta más transada globalmente.' },
  JPY: { nombre: 'Yen Japonés',          descripcion: 'Moneda de Japón, considerada refugio de valor en momentos de incertidumbre global.' },
  CHF: { nombre: 'Franco Suizo',         descripcion: 'Moneda de Suiza, considerada la más estable del mundo por la solidez del sistema financiero helvético.' },
  CAD: { nombre: 'Dólar Canadiense',     descripcion: 'Llamado "Loonie", está fuertemente influenciado por los precios del petróleo.' },
  AUD: { nombre: 'Dólar Australiano',    descripcion: 'Correlacionado con los precios de materias primas como oro y hierro.' },
  MXN: { nombre: 'Peso Mexicano',        descripcion: 'La moneda más transada de Latinoamérica, influenciada por la relación comercial con EE.UU.' },
  COP: { nombre: 'Peso Colombiano',      descripcion: 'Moneda de Colombia, sensible a los precios del petróleo por ser el país un exportador.' },
  ARS: { nombre: 'Peso Argentino',       descripcion: 'Ha sufrido alta inflación históricamente. Existen múltiples tipos de cambio oficiales y paralelos.' },
  CLP: { nombre: 'Peso Chileno',         descripcion: 'Ligado al precio del cobre dado que Chile es el mayor productor mundial.' },
  PEN: { nombre: 'Sol Peruano',          descripcion: 'Considerada una de las monedas más estables de Sudamérica.' },
  BRL: { nombre: 'Real Brasileño',       descripcion: 'Moneda de la mayor economía de Latinoamérica, sensible a factores políticos.' },
  GTQ: { nombre: 'Quetzal Guatemalteco', descripcion: 'Moneda de Guatemala, relativamente estable gracias a las remesas del exterior.' },
  HNL: { nombre: 'Lempira Hondureño',    descripcion: 'Moneda de Honduras, cuyo tipo de cambio es administrado por el Banco Central.' },
};

const tvSymbol     = parData?.tradingviewSimbolo ?? '';
const tvDisponible = parData?.tvDisponible ?? false;
const precioFmt    = parData ? formatForex(parData.precio) : '—';
const nombre       = parData ? (nombrePar[parData.par] ?? parData.par) : parFormateado;
const baseInfo     = parData ? (infoMoneda[parData.base.toUpperCase()]     ?? null) : null;
const cotInfo      = parData ? (infoMoneda[parData.cotizada.toUpperCase()] ?? null) : null;
---

