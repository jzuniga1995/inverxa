              {cotInfo && (
                <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
                  <div class="flex items-center gap-3 mb-3">
                    <img
                      src={`https://flagcdn.com/w40/${parData.banderaCotizada.toLowerCase()}.png`}
                      alt={parData.banderaCotizada}
                      class="w-7 h-7 rounded-full object-cover"
                      onerror="this.style.display='none'"
                    />
                    <div>
                      <div class="text-white/30 text-[10px] uppercase tracking-widest">Moneda cotizada</div>
                      <div class="text-white font-bold text-sm" style="font-family:'Syne',sans-serif;">
                        {cotInfo.nombre} ({parData.cotizada.toUpperCase()})
                      </div>
                    </div>
                  </div>
                  <p class="text-white/40 text-sm leading-relaxed">{cotInfo.descripcion}</p>
                </div>
              )}
            </div>
          )}

          <!-- Nota sobre datos -->
          <div class="bg-[#EC4899]/5 border border-[#EC4899]/10 rounded-xl p-4">
            <p class="text-white/40 text-xs leading-relaxed">
              <span class="text-[#EC4899] font-bold">Nota:</span> Los precios mostrados son tasas de referencia con actualización diaria.
              Para trading activo, consultá los precios en tiempo real de tu broker. Las tasas de cambio oficiales pueden diferir.
            </p>
          </div>

        </div>
      )}
    </div>
  </div>
</Layout>

