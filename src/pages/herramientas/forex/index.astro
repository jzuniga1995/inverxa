---
// src/pages/herramientas/forex/index.astro
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-astro';
import { parseJson } from '../../../lib/utils';
type ForexData = {
  par: string; base: string; cotizada: string;
  banderaBase: string; banderaCotizada: string;
  precio: number; tradingviewSimbolo: string;
};

let pares: ForexData[] = [];
let fetchError = false;

const formatForex = (p: number) => {
  if (!p) return '—';
  if (p >= 100) return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
};

try {
  const res  = await fetch(new URL('/api/forex', Astro.url));
  if (!res.ok) throw new Error(`${res.status}`);
 const json = await parseJson(res);
  if (json.ok) pares = json.data;
} catch (e) {
  fetchError = true;
}

const nombrePar: Record<string, string> = {
  'EUR/USD': 'Euro / Dólar Estadounidense',
  'GBP/USD': 'Libra Esterlina / Dólar',
  'USD/JPY': 'Dólar / Yen Japonés',
  'USD/CHF': 'Dólar / Franco Suizo',
  'USD/CAD': 'Dólar / Dólar Canadiense',
  'AUD/USD': 'Dólar Australiano / Dólar',
  'USD/MXN': 'Dólar / Peso Mexicano',
  'USD/COP': 'Dólar / Peso Colombiano',
  'USD/ARS': 'Dólar / Peso Argentino',
  'USD/CLP': 'Dólar / Peso Chileno',
  'USD/PEN': 'Dólar / Sol Peruano',
  'USD/BRL': 'Dólar / Real Brasileño',
  'USD/BOB': 'Dólar / Boliviano',
  'USD/GTQ': 'Dólar / Quetzal Guatemalteco',
  'USD/HNL': 'Dólar / Lempira Hondureño',
  'USD/NIO': 'Dólar / Córdoba Nicaragüense',
  'USD/CRC': 'Dólar / Colón Costarricense',
  'USD/DOP': 'Dólar / Peso Dominicano',
  'USD/PYG': 'Dólar / Guaraní Paraguayo',
  'USD/UYU': 'Dólar / Peso Uruguayo',
  'USD/VES': 'Dólar / Bolívar Venezolano',
  'USD/PAB': 'Dólar / Balboa Panameño',
  'NZD/USD': 'Dólar Neozelandés / Dólar',
  'USD/CNY': 'Dólar / Yuan Chino',
  'USD/CUP': 'Dólar / Peso Cubano',
  'USD/JMD': 'Dólar / Dólar Jamaicano',
  'USD/TTD': 'Dólar / Dólar Trinidad y Tobago',
  'USD/BBD': 'Dólar / Dólar de Barbados',
  'USD/HTG': 'Dólar / Gourde Haitiano',
};

const paresGlobales = ['EUR/USD','GBP/USD','USD/JPY','USD/CHF','USD/CAD','AUD/USD','NZD/USD','USD/CNY'];
---

<Layout>
  <slot name="head" slot="head">
    <title>Forex — Tipos de Cambio en Tiempo Real | Inversax</title>
    <meta name="description" content="Tipos de cambio de los principales pares de divisas y monedas de Latinoamérica. EUR/USD, USD/MXN, USD/ARS y más." />
    <link rel="canonical" href="https://inversax.com/herramientas/forex" />
  </slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family:'DM Sans',sans-serif;">
    <div class="max-w-5xl mx-auto px-4 py-10">

      <!-- Breadcrumb -->
      <a href="/herramientas" class="inline-flex items-center gap-2 text-white/30 hover:text-white text-sm mb-6 no-underline transition-colors">
        <ArrowLeft size={15} /> Herramientas
      </a>

      <!-- Título -->
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-7">
        <div>
          <h1 class="text-white font-extrabold text-3xl mb-1" style="font-family:'Syne',sans-serif;">
            Forex
          </h1>
          <p class="text-white/30 text-sm">{pares.length} pares de divisas · Actualización diaria</p>
        </div>

        <!-- Buscador -->
        <div class="relative w-full sm:w-52 flex-shrink-0">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-white/30" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input id="forex-search" type="text" placeholder="USD/MXN, Euro..."
            autocomplete="off"
            class="w-full bg-[#111318] text-white text-sm placeholder-white/20 border border-white/10 focus:border-[#EC4899]/50 rounded-xl pl-8 pr-3 py-2 outline-none transition-colors" />
        </div>
      </div>

      <!-- Filtros -->
      <div class="flex gap-2 flex-wrap mb-5">
        <button data-filter="all" class="filter-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-medium border transition-all duration-150"
          style="background:rgba(236,72,153,.1);border-color:rgba(236,72,153,.4);color:#EC4899">
          Todos
        </button>
        <button data-filter="global" class="filter-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-medium border transition-all duration-150"
          style="background:#111318;border-color:rgba(255,255,255,.08);color:rgba(255,255,255,.4)">
          Globales
        </button>
        <button data-filter="latam" class="filter-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-medium border transition-all duration-150"
          style="background:#111318;border-color:rgba(255,255,255,.08);color:rgba(255,255,255,.4)">
          Latinoamérica
        </button>
      </div>

      {fetchError ? (
        <div class="flex items-center justify-center py-24 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <p class="text-white/30 text-sm">No se pudieron cargar los datos. Intenta de nuevo.</p>
        </div>
      ) : (
        <div class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden">

          <!-- Cabecera -->
          <div class="hidden md:grid border-b border-white/[0.07] px-4 py-3"
            style="grid-template-columns: 60px 1fr 160px 140px">
            <div class="text-white/40 text-[11px] font-semibold uppercase tracking-wider">#</div>
            <div class="text-white/40 text-[11px] font-semibold uppercase tracking-wider pl-2">Par</div>
            <div class="text-white/40 text-[11px] font-semibold uppercase tracking-wider text-right">Precio</div>
            <div class="text-white/40 text-[11px] font-semibold uppercase tracking-wider text-right">Descripción</div>
          </div>

          <!-- Filas -->
          <div id="forex-table-body">
            {pares.map((f, i) => {
              const slug  = f.par.replace('/', '-').toLowerCase();
              const CARIBE = ['USD/DOP','USD/CUP','USD/JMD','USD/TTD','USD/BBD','USD/HTG'];
              const isGlobal = paresGlobales.includes(f.par);
              const isCaribe = CARIBE.includes(f.par);
              return (
                <a href={`/herramientas/forex/${slug}`}
                  class="forex-row grid px-4 py-3.5 border-b border-white/[0.04] hover:bg-white/[0.025] transition-colors no-underline"
                  style="grid-template-columns: 60px 1fr 160px 140px"
                  data-par={f.par.toLowerCase()}
                  data-nombre={(nombrePar[f.par] ?? f.par).toLowerCase()}
                  data-region={isGlobal ? 'global' : isCaribe ? 'caribe' : 'latam'}>

                  <div class="flex items-center text-white/20 text-xs" style="font-family:'Syne',sans-serif;">
                    {i + 1}
                  </div>

                  <div class="flex items-center gap-3 pl-2 min-w-0">
                    <!-- Banderas solapadas -->
                    <div class="relative w-9 h-7 flex-shrink-0">
                      <img
                        src={`https://flagcdn.com/w40/${f.banderaBase.toLowerCase()}.png`}
                        alt={f.banderaBase}
                        class="absolute top-0 left-0 w-6 h-6 rounded-full object-cover border-2 border-[#111318]"
                        onerror="this.style.display='none'"
                      />
                      <img
                        src={`https://flagcdn.com/w40/${f.banderaCotizada.toLowerCase()}.png`}
                        alt={f.banderaCotizada}
                        class="absolute bottom-0 right-0 w-6 h-6 rounded-full object-cover border-2 border-[#111318]"
                        onerror="this.style.display='none'"
                      />
                    </div>
                    <div class="min-w-0">
                      <div class="text-white font-bold text-sm" style="font-family:'Syne',sans-serif;">{f.par}</div>
                      <div class="text-white/30 text-[11px] truncate">{nombrePar[f.par] ?? f.par}</div>
                    </div>
                    {isGlobal && (
                      <span class="text-[9px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wide bg-[#EC4899]/10 text-[#EC4899] flex-shrink-0">Global</span>
                    )}
                  </div>

                  <div class="flex items-center justify-end text-white font-semibold text-sm" style="font-family:'Syne',sans-serif;">
                    {formatForex(f.precio)}
                  </div>

                  <div class="hidden md:flex items-center justify-end text-white/30 text-xs truncate pl-2">
                    {f.base.toUpperCase()}/{f.cotizada.toUpperCase()}
                  </div>

                </a>
              );
            })}
          </div>

          <div id="forex-empty" class="hidden items-center justify-center py-14">
            <p class="text-white/25 text-sm">Sin resultados</p>
          </div>

        </div>
      )}

    </div>
  </div>
</Layout>

<style>
  @media (max-width: 767px) {
    .forex-row { grid-template-columns: 50px 1fr 120px !important; }
    .forex-row > div:nth-child(4) { display: none !important; }
  }
  .filter-btn { transition: all .15s; }
</style>

<script>
  const rows    = Array.from(document.querySelectorAll('.forex-row')) as HTMLAnchorElement[];
  const empty   = document.getElementById('forex-empty')!;
  let activeFilter = 'all';
  let query = '';

  function applyFilters() {
    const q = query.trim().toLowerCase();
    let visible = 0;
    rows.forEach(row => {
      const par    = row.dataset.par    || '';
      const nombre = row.dataset.nombre || '';
      const region = row.dataset.region || '';

      const matchSearch = !q || par.includes(q) || nombre.includes(q);
      const matchFilter =
        activeFilter === 'all'    ? true :
        activeFilter === 'global' ? region === 'global' :
        activeFilter === 'latam'  ? region === 'latam' :
        activeFilter === 'caribe' ? region === 'caribe' : true;

      const show = matchSearch && matchFilter;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    empty.classList.toggle('hidden', visible > 0);
    empty.classList.toggle('flex',   visible === 0);
  }

  document.getElementById('forex-search')!.addEventListener('input', function(this: HTMLInputElement) {
    query = this.value;
    applyFilters();
  });

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = (btn as HTMLElement).dataset.filter || 'all';
      document.querySelectorAll('.filter-btn').forEach(b => {
        const el = b as HTMLElement;
        if (el.dataset.filter === activeFilter) {
          el.style.background   = 'rgba(236,72,153,.1)';
          el.style.borderColor  = 'rgba(236,72,153,.4)';
          el.style.color        = '#EC4899';
        } else {
          el.style.background   = '#111318';
          el.style.borderColor  = 'rgba(255,255,255,.08)';
          el.style.color        = 'rgba(255,255,255,.4)';
        }
      });
      applyFilters();
    });
  });
</script>
