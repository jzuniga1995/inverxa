  <link rel="alternate" hreflang="es-CA" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-AU" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-BR" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-PH" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-GQ" href="https://inversax.com/herramientas/calculadora-cripto" />
