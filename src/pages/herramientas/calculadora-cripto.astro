      <button class="tab-btn flex-1 min-w-[120px]" data-tab="convertir">⇄ Convertir</button>
      <button class="tab-btn flex-1 min-w-[120px]" data-tab="ganancias">📈 Ganancias</button>
      <button class="tab-btn flex-1 min-w-[120px]" data-tab="ahorro">🔁 Ahorro DCA</button>
      <button class="tab-btn flex-1 min-w-[120px]" data-tab="comisiones">💸 Comisiones</button>
    </div>

    <!-- ══ CONVERTIR ══ -->
