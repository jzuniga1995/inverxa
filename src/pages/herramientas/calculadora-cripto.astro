  <!-- América Latina -->
  <link rel="alternate" hreflang="es-MX" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-AR" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-CO" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-CL" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-PE" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-VE" href="https://inversax.com/herramientas/calculadora-cripto" />
