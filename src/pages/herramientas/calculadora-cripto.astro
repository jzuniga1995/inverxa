  <link rel="alternate" hreflang="es-AD" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-DE" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-FR" href="https://inversax.com/herramientas/calculadora-cripto" />
