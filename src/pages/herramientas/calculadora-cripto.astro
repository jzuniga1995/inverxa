---
import Layout from '../../layouts/Layout.astro';
import { Calculator, ArrowLeft } from 'lucide-astro';
---

<Layout>

<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
  <title>Calculadora de Criptomonedas — Convertir, Ganancias y Comisiones en Vivo | Inversax</title>
  <meta name="description"    content="Calculadora cripto gratis: convertí Bitcoin, Ethereum y más a pesos, dólares o cualquier moneda LATAM. Calculá ganancias, ahorro DCA y comisiones del exchange con precios en vivo." />
  <meta name="author"         content="José Zúniga" />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"      content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"       href="https://inversax.com/herramientas/calculadora-cripto" />

  <!-- ═══════════════════════════════════════
       KEYWORDS
  ═══════════════════════════════════════ -->
  <meta name="keywords"      content="calculadora bitcoin, calculadora criptomonedas, convertir bitcoin a pesos, convertir ethereum a pesos argentinos, calculadora crypto latino, cuanto vale mi bitcoin, ganancias bitcoin calculadora, DCA cripto calculadora, comisiones exchange calculadora, convertir BTC a MXN, convertir BTC a ARS, convertir BTC a COP, precio bitcoin en pesos, calculadora cripto latam" />
  <meta name="news_keywords" content="calculadora criptomonedas, bitcoin pesos, ethereum pesos, crypto latam, Inversax" />

  <!-- ═══════════════════════════════════════
       GEO
  ═══════════════════════════════════════ -->
  <meta name="geo.region"       content="LATAM" />
  <meta name="geo.placename"    content="Latinoamérica" />
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />
  <meta name="coverage"         content="Worldwide" />
  <meta name="target"           content="all" />
  <meta name="rating"           content="general" />
  <meta name="category"         content="finance, crypto, calculator, investing" />

  <!-- ═══════════════════════════════════════
       HREFLANG — 36 variantes
  ═══════════════════════════════════════ -->
