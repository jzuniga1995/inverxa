  <link rel="alternate" hreflang="es-CH" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-NL" href="https://inversax.com/herramientas/calculadora-cripto" />
  <link rel="alternate" hreflang="es-GB" href="https://inversax.com/herramientas/calculadora-cripto" />
