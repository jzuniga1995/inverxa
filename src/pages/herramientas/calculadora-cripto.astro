  <!-- ═══════════════════════════════════════
       OPEN GRAPH
  ═══════════════════════════════════════ -->
  <meta property="og:site_name"        content="Inversax" />
  <meta property="og:locale"           content="es_LA" />
  <meta property="og:locale:alternate" content="es_MX" />
  <meta property="og:locale:alternate" content="es_AR" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:locale:alternate" content="es_ES" />
  <meta property="og:type"             content="website" />
  <meta property="og:title"            content="Calculadora Cripto Gratis — Convertir, Ganancias y Comisiones | Inversax" />
  <meta property="og:description"      content="Convertí Bitcoin, Ethereum y más a pesos, dólares o cualquier moneda LATAM. Calculá ganancias, ahorro DCA y comisiones con precios en vivo." />
  <meta property="og:url"              content="https://inversax.com/herramientas/calculadora-cripto" />
  <meta property="og:image"            content="https://inversax.com/og/herramientas/calculadora-cripto.png" />
