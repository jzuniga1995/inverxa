              <div class="stat-cell">
                <div class="stat-label">Vale hoy</div>
                <div id="gan-actual" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Ganancia / Pérdida</div>
                <div id="gan-neta" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Precio de recuperación</div>
                <div id="gan-breakeven" class="stat-val">—</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ══ AHORRO PERIÓDICO ══ -->
    <div class="panel hidden" id="tab-ahorro">
      <div class="card">

        <div class="info-banner mb-6">
          <span class="text-amber-400 flex-shrink-0 text-base">💡</span>
          <span class="text-white/50 text-sm leading-relaxed">El <strong class="text-white/80">ahorro periódico (DCA)</strong> consiste en comprar una cantidad fija de cripto cada semana o mes sin importar el precio. Promediás el costo y reducís el riesgo.</span>
        </div>

        <div id="ahorro-live" class="hidden items-center gap-3 live-badge mb-6">
          <img id="ahorro-img" src="" alt="" class="w-7 h-7 rounded-full ring-1 ring-white/10" />
          <span id="ahorro-cname" class="text-white/50 text-xs font-medium"></span>
          <span id="ahorro-cprice" class="text-emerald-400 font-bold ml-auto font-mono text-sm"></span>
          <span id="ahorro-cchg" class="text-xs font-mono px-2 py-0.5 rounded-full"></span>
        </div>

        <div class="mb-5">
          <label class="field-label">Criptomoneda</label>
          <select id="ahorro-coin" class="field-select"><option>Cargando...</option></select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label class="field-label">Monto por compra <span class="normal-case text-white/25 font-normal">(USD)</span></label>
            <input type="number" id="ahorro-monto" placeholder="ej: 50" min="0" step="any" class="field-input" />
          </div>
          <div>
            <label class="field-label">Frecuencia</label>
            <select id="ahorro-freq" class="field-select">
              <option value="weekly">Cada semana</option>
              <option value="monthly" selected>Cada mes</option>
              <option value="quarterly">Cada 3 meses</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label class="field-label">¿Cuántas veces compraste?</label>
            <input type="number" id="ahorro-periodos" value="12" min="1" max="240" class="field-input" />
          </div>
          <div>
            <label class="field-label">Precio promedio pagado <span class="normal-case text-white/25 font-normal">(USD)</span></label>
            <input type="number" id="ahorro-avg" placeholder="ej: 45000" min="0" step="any" class="field-input" />
          </div>
        </div>

        <div id="ahorro-error" class="hidden error-box mb-4">
          Completá monto, períodos y precio promedio para calcular.
        </div>

        <div id="result-ahorro" class="hidden result-box mt-4">
          <div class="result-header flex items-center">
            <span>Resumen de tu ahorro</span>
            <span id="ahorro-pill" class="ml-auto text-[10px] font-bold px-2.5 py-1 rounded-full"></span>
          </div>
          <div class="p-5">
            <div id="ahorro-pct" class="result-val">—</div>
            <div id="ahorro-sub" class="result-sub mb-5"></div>
            <div class="stats-grid mb-5">
              <div class="stat-cell">
                <div class="stat-label">Total invertido</div>
                <div id="ahorro-total-inv" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Cripto acumulada</div>
                <div id="ahorro-total-cripto" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Vale hoy</div>
                <div id="ahorro-valor-hoy" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Ganancia total</div>
                <div id="ahorro-ganancia" class="stat-val">—</div>
              </div>
            </div>
            <div class="border border-white/[0.07] rounded-xl overflow-hidden">
              <div class="max-h-64 overflow-y-auto">
                <table class="w-full text-xs font-mono border-collapse">
                  <thead>
                    <tr class="bg-[#161b22] text-white/30 uppercase text-[10px] tracking-wider sticky top-0">
                      <th class="px-4 py-2.5 text-left border-b border-white/[0.07]">#</th>
                      <th class="px-4 py-2.5 text-left border-b border-white/[0.07]">Invertido</th>
                      <th class="px-4 py-2.5 text-left border-b border-white/[0.07]">Cripto</th>
                      <th class="px-4 py-2.5 text-left border-b border-white/[0.07] hidden sm:table-cell">Acumulado</th>
                      <th class="px-4 py-2.5 text-left border-b border-white/[0.07]">Valor</th>
                    </tr>
                  </thead>
                  <tbody id="ahorro-tbody" class="divide-y divide-white/[0.05]"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ══ COMISIONES ══ -->
    <div class="panel hidden" id="tab-comisiones">
      <div class="card">

        <div class="info-banner mb-6">
          <span class="text-amber-400 flex-shrink-0 text-base">💡</span>
          <span class="text-white/50 text-sm leading-relaxed">La <strong class="text-white/80">comisión</strong> es el porcentaje que cobra el exchange. Binance 0.1%, Kraken 0.26%, Coinbase hasta 1.49%. Calculá cuánto te queda realmente.</span>
        </div>

        <div id="com-live" class="hidden items-center gap-3 live-badge mb-6">
          <img id="com-img" src="" alt="" class="w-7 h-7 rounded-full ring-1 ring-white/10" />
          <span id="com-cname" class="text-white/50 text-xs font-medium"></span>
          <span id="com-cprice" class="text-emerald-400 font-bold ml-auto font-mono text-sm"></span>
          <span id="com-cchg" class="text-xs font-mono px-2 py-0.5 rounded-full"></span>
        </div>

        <div class="mb-5">
          <label class="field-label">Criptomoneda</label>
          <select id="com-coin" class="field-select"><option>Cargando...</option></select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
          <div>
            <label class="field-label">Cantidad a operar</label>
            <input type="number" id="com-cant" placeholder="ej: 0.1" min="0" step="any" class="field-input" />
          </div>
          <div>
            <label class="field-label">Comisión del exchange <span class="normal-case text-white/25 font-normal">(%)</span></label>
            <input type="number" id="com-pct" value="0.1" min="0" step="0.01" class="field-input" />
          </div>
        </div>

        <div class="mb-5">
          <label class="field-label">Tipo de operación</label>
          <select id="com-tipo" class="field-select">
            <option value="compra">Solo compra</option>
            <option value="venta">Solo venta</option>
            <option value="ambas">Compra y venta (comisión doble)</option>
          </select>
        </div>

        <div id="com-error" class="hidden error-box mb-4">
          Ingresá la cantidad para calcular.
        </div>

        <div id="result-comisiones" class="hidden result-box mt-4">
          <div class="result-header">Lo que realmente pagás</div>
          <div class="p-5">
            <div id="com-neto" class="result-val">—</div>
            <div id="com-sub" class="result-sub mb-5"></div>
            <div class="stats-grid">
              <div class="stat-cell">
                <div class="stat-label">Valor total de la operación</div>
                <div id="com-bruto" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Total en comisiones</div>
                <div id="com-fee-usd" class="stat-val text-red-400">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Comisión en cripto</div>
                <div id="com-fee-cripto" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">% del capital que se va</div>
                <div id="com-pct-real" class="stat-val text-red-400">—</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</main>
</Layout>

<script>
  const CODIGO_MAP: Record<string,string> = {
    ar:'ars',mx:'mxn',co:'cop',hn:'hnl',br:'brl',
    cl:'clp',pe:'pen',uy:'uyu',py:'pyg',bo:'bob',
    cr:'crc',gt:'gtq',ni:'nio',do:'dop',ve:'ves',
  };
  const FIAT_SIM: Record<string,string> = {
    usd:'$',eur:'€',mxn:'$',ars:'$',cop:'$',hnl:'L',
    brl:'R$',clp:'$',pen:'S/',uyu:'$',pyg:'₲',bob:'Bs',
    crc:'₡',gtq:'Q',nio:'C$',dop:'$',ves:'Bs.S',
  };
  const FIAT_NAME: Record<string,string> = {
    usd:'USD',eur:'EUR',mxn:'MXN',ars:'ARS',cop:'COP',hnl:'HNL',
    brl:'BRL',clp:'CLP',pen:'PEN',uyu:'UYU',pyg:'PYG',bob:'BOB',
    crc:'CRC',gtq:'GTQ',nio:'NIO',dop:'DOP',ves:'VES',
  };
  const FIAT_RATES: Record<string,number> = { usd:1, eur:0.92 };
  let coins: any[] = [];

  const gc  = (id: string) => coins.find((c:any) => c.id === id);
  const el  = (id: string): any => document.getElementById(id);
  const set = (id: string, v: string) => { const e = el(id); if(e) e.textContent = v; };
  const showBlock = (id: string, v: boolean) => { const e = el(id); if(e) e.classList.toggle('hidden',!v); };

  function fUSD(n: number): string {
    if (!isFinite(n)) return '—';
    if (Math.abs(n) >= 1e9) return '$'+(n/1e9).toFixed(2)+'B';
    if (Math.abs(n) >= 1e6) return '$'+(n/1e6).toFixed(2)+'M';
    return '$'+n.toLocaleString('es-419',{minimumFractionDigits:2,maximumFractionDigits:2});
  }
  function fFiat(n: number, key: string): string {
    if (!isFinite(n)) return '—';
    const s = FIAT_SIM[key]||'$', nm = FIAT_NAME[key]||key.toUpperCase();
    if (Math.abs(n) >= 1e9) return s+(n/1e9).toFixed(2)+'B '+nm;
    if (Math.abs(n) >= 1e6) return s+(n/1e6).toFixed(2)+'M '+nm;
    const d = Math.abs(n)<10?4:2;
    return s+n.toLocaleString('es-419',{minimumFractionDigits:d,maximumFractionDigits:d})+' '+nm;
  }
  function fCripto(n: number, sym: string): string {
    if (!isFinite(n)) return '—';
    const d = n<0.0001?8:n<0.01?6:n<1?4:2;
    return n.toLocaleString('es-419',{minimumFractionDigits:d,maximumFractionDigits:d})+' '+sym.toUpperCase();
  }
  function fPct(n: number): string { return (n>=0?'+':'')+n.toFixed(2)+'%'; }

  function badge(pfx: string, coin: any) {
    if (!coin) return;
    const wrap = el(pfx+'-live');
    const img  = el(pfx+'-img');
    if (img) { img.src = coin.image||''; img.alt = coin.symbol; }
    set(pfx+'-cname', coin.name);
    set(pfx+'-cprice', fUSD(coin.price));
    const chg = el(pfx+'-cchg');
    if (chg) {
      const c = coin.change24||0;
      chg.textContent = fPct(c);
      chg.className = 'text-xs font-mono px-2 py-0.5 rounded-full '
        + (c>=0 ? 'bg-emerald-400/10 text-emerald-400' : 'bg-red-400/10 text-red-400');
    }
    if (wrap) { wrap.classList.remove('hidden'); wrap.classList.add('flex'); }
  }

  async function loadDolar() {
    try {
      const r = await fetch('/api/dolar');
      const j: any = await r.json();
      if (!j.ok) return;
      j.data.forEach((p: any) => {
        const k = CODIGO_MAP[p.codigo];
        if (!k) return;
        const of = p.variantes.find((v: any) => !v.esParalelo) || p.variantes[0];
        if (of?.venta) FIAT_RATES[k] = of.venta;
      });
    } catch(e) { console.warn('[dolar]', e); }
  }

  async function loadCoins() {
    try {
      const r = await fetch('/api/precios');
      coins   = await r.json();
      populateSelects();
      bindAll();
    } catch(e) { console.error('[precios]', e); }
  }

  function populateSelects() {
    ['conv-from','conv-to-cripto','gan-coin','ahorro-coin','com-coin'].forEach(id => {
      const s = el(id);
      if (!s) return;
      s.innerHTML = coins.map((c:any) =>
        `<option value="${c.id}">${c.symbol.toUpperCase()} — ${c.name}</option>`
      ).join('');
    });
    const f = coins[0];
    if (f) {
      badge('conv',f); badge('gan',f); badge('ahorro',f); badge('com',f);
      const gn = el('gan-now');
      if (gn) gn.value = String(f.price);
      const cs = el('conv-suffix'); if (cs) cs.textContent = f.symbol.toUpperCase();
    }
  }

  function bindAll() {

    // ── TABS — una sola clase, manejada 100% por JS ──────────────
    const allTabs   = document.querySelectorAll<HTMLElement>('.tab-btn');
    const allPanels = document.querySelectorAll<HTMLElement>('.panel');

    function activateTab(btn: HTMLElement) {
      // 1. Limpiar TODOS los botones
      allTabs.forEach(b => b.classList.remove('tab-is-active'));
      // 2. Ocultar TODOS los paneles
      allPanels.forEach(p => p.classList.add('hidden'));
      // 3. Activar el botón clickeado
      btn.classList.add('tab-is-active');
      // 4. Mostrar el panel correspondiente
      el('tab-' + btn.dataset.tab)?.classList.remove('hidden');
    }

    allTabs.forEach(btn => btn.addEventListener('click', () => activateTab(btn)));

    // Activar el primero al cargar (sin depender de HTML)
    if (allTabs[0]) activateTab(allTabs[0]);

    // ── CONVERTIR ──
    function calcConv() {
      const amt  = parseFloat(el('conv-amount').value);
      const from = el('conv-from').value;
      const to   = el('conv-to').value;
      const coin = gc(from);
      if (!coin || !amt || amt <= 0) { showBlock('result-convertir', false); return; }
      badge('conv', coin);
      const cs = el('conv-suffix'); if (cs) cs.textContent = coin.symbol.toUpperCase();
      const usd = amt * coin.price;

      if (to === 'cripto') {
        const tc = gc(el('conv-to-cripto').value);
        if (!tc) return;
        set('conv-result-val', fCripto(usd/tc.price, tc.symbol));
        set('conv-result-sub', `${amt} ${coin.symbol.toUpperCase()} = ${fUSD(usd)}`);
        set('conv-unit', fUSD(coin.price)+' USD');
        set('conv-tasa', `1 ${tc.symbol.toUpperCase()} = ${fUSD(tc.price)}`);
      } else {
        const rate = FIAT_RATES[to]||1;
        set('conv-result-val', fFiat(usd * rate, to));
        set('conv-result-sub', `${amt} ${coin.symbol.toUpperCase()} × ${fFiat(coin.price * rate, to)} por unidad`);
        set('conv-unit', fFiat(coin.price * rate, to));
        set('conv-tasa', `1 USD = ${FIAT_SIM[to]||'$'}${rate.toLocaleString('es-419',{maximumFractionDigits:4})} ${FIAT_NAME[to]||''}`);
      }
      showBlock('result-convertir', true);
    }

    el('conv-from')?.addEventListener('change', () => { badge('conv', gc(el('conv-from').value)); calcConv(); });
    el('conv-amount')?.addEventListener('input', calcConv);
    el('conv-to')?.addEventListener('change', () => {
      const isC = el('conv-to').value === 'cripto';
      el('conv-cripto-wrap')?.classList.toggle('hidden', !isC);
      calcConv();
    });
    el('conv-to-cripto')?.addEventListener('change', calcConv);

    // ── GANANCIAS ──
    function calcGan() {
      const coin = gc(el('gan-coin').value);
      const buy  = parseFloat(el('gan-buy').value);
      const qty  = parseFloat(el('gan-qty').value);
      const now  = parseFloat(el('gan-now').value);
      const ok   = !!(coin && buy > 0 && qty > 0 && now > 0);
      const touched = !!(el('gan-buy').value || el('gan-qty').value);
      el('gan-error')?.classList.toggle('hidden', !(!ok && touched));
      if (!ok) { showBlock('result-ganancias', false); return; }

      const inv = buy*qty, act = now*qty, net = act-inv;
      const pct = ((now-buy)/buy)*100, gain = net >= 0;

      set('gan-pct', fPct(pct));
      const gp = el('gan-pct');
      if (gp) gp.className = 'result-val '+(gain?'text-emerald-400':'text-red-400');
      set('gan-sub', gain ? `Ganaste ${fUSD(net)} con esta inversión ✓` : `Perdiste ${fUSD(Math.abs(net))} con esta inversión`);

      const pill = el('gan-pill');
      if (pill) {
        pill.textContent = gain?'▲ GANANCIA':'▼ PÉRDIDA';
        pill.className = gain
          ? 'ml-auto text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-400/10 text-emerald-400'
          : 'ml-auto text-[10px] font-bold px-2.5 py-1 rounded-full bg-red-400/10 text-red-400';
      }
      set('gan-invertido', fUSD(inv));
      set('gan-actual', fUSD(act));
      const ne = el('gan-neta');
      if (ne) { ne.textContent = (gain?'+':'')+fUSD(net); ne.className = 'stat-val '+(gain?'text-emerald-400':'text-red-400'); }
      set('gan-breakeven', fUSD(buy));
      showBlock('result-ganancias', true);
    }

    el('gan-coin')?.addEventListener('change', () => {
      const c = gc(el('gan-coin').value);
      if (c) { badge('gan',c); el('gan-now').value = String(c.price); }
      calcGan();
    });
    ['gan-buy','gan-qty','gan-now'].forEach(id => el(id)?.addEventListener('input', calcGan));

    // ── AHORRO ──
    function calcAhorro() {
      const coin  = gc(el('ahorro-coin').value);
      const monto = parseFloat(el('ahorro-monto').value);
      const pers  = parseInt(el('ahorro-periodos').value);
      const avg   = parseFloat(el('ahorro-avg').value);
      const ok    = !!(coin && monto > 0 && pers > 0 && avg > 0);
      const touched = !!(el('ahorro-monto').value || el('ahorro-avg').value);
      el('ahorro-error')?.classList.toggle('hidden', !(!ok && touched));
      if (!ok) { showBlock('result-ahorro', false); return; }

      const totInv = monto*pers, totC = totInv/avg, valHoy = totC*coin.price;
      const gan = valHoy-totInv, gain = gan>=0, pct = (gan/totInv)*100;
      const freqEl = el('ahorro-freq');
      const freqLabel = freqEl.options[freqEl.selectedIndex].text.toLowerCase();

      set('ahorro-pct', fPct(pct));
      const ap = el('ahorro-pct');
      if (ap) ap.className = 'result-val '+(gain?'text-emerald-400':'text-red-400');
      set('ahorro-sub', `Si invertiste ${fUSD(monto)} ${freqLabel} durante ${pers} ${pers===1?'vez':'veces'}`);

      const pill = el('ahorro-pill');
      if (pill) {
        pill.textContent = gain?'▲ EN GANANCIA':'▼ EN PÉRDIDA';
        pill.className = gain
          ? 'ml-auto text-[10px] font-bold px-2.5 py-1 rounded-full bg-emerald-400/10 text-emerald-400'
          : 'ml-auto text-[10px] font-bold px-2.5 py-1 rounded-full bg-red-400/10 text-red-400';
      }

      set('ahorro-total-inv', fUSD(totInv));
      set('ahorro-total-cripto', fCripto(totC, coin.symbol));
      set('ahorro-valor-hoy', fUSD(valHoy));
      const ge = el('ahorro-ganancia');
      if (ge) { ge.textContent=(gain?'+':'')+fUSD(gan); ge.className='stat-val '+(gain?'text-emerald-400':'text-red-400'); }

      let rows = '', ac = 0;
      for (let i=1; i<=pers; i++) {
        const pc = monto/avg; ac += pc;
        rows += `<tr class="hover:bg-white/[0.02] transition-colors">
          <td class="px-4 py-2.5 text-white/40">${i}</td>
          <td class="px-4 py-2.5 text-white/80">${fUSD(monto)}</td>
          <td class="px-4 py-2.5 text-white/80">${fCripto(pc, coin.symbol)}</td>
          <td class="px-4 py-2.5 text-white/80 hidden sm:table-cell">${fCripto(ac, coin.symbol)}</td>
          <td class="px-4 py-2.5 text-emerald-400/80">${fUSD(ac*avg)}</td>
        </tr>`;
      }
      const tb = el('ahorro-tbody'); if (tb) tb.innerHTML = rows;
      showBlock('result-ahorro', true);
    }

    el('ahorro-coin')?.addEventListener('change', () => { badge('ahorro', gc(el('ahorro-coin').value)); calcAhorro(); });
    ['ahorro-monto','ahorro-periodos','ahorro-avg','ahorro-freq'].forEach(id => {
      el(id)?.addEventListener('input', calcAhorro);
      el(id)?.addEventListener('change', calcAhorro);
    });

    // ── COMISIONES ──
    function calcCom() {
      const coin = gc(el('com-coin').value);
      const cant = parseFloat(el('com-cant').value);
      const pct  = parseFloat(el('com-pct').value);
      const tipo = el('com-tipo').value;
      const ok   = !!(coin && cant > 0 && pct >= 0);
      el('com-error')?.classList.toggle('hidden', !(ok === false && !!el('com-cant').value));
      if (!ok) { showBlock('result-comisiones', false); return; }

      const bruto = cant*coin.price, mult = tipo==='ambas'?2:1;
      const fee = bruto*(pct/100)*mult, neto = bruto-fee, feeC = fee/coin.price, pctR = (fee/bruto)*100;

      set('com-neto', fUSD(neto));
      set('com-sub', tipo==='ambas'
        ? 'Lo que recibís después de comisión de compra + venta'
        : `Lo que recibís después de la comisión de ${tipo}`);
      set('com-bruto', fUSD(bruto));
      set('com-fee-usd', '−'+fUSD(fee));
      set('com-fee-cripto', fCripto(feeC, coin.symbol));
      set('com-pct-real', pctR.toFixed(4)+'%');
      showBlock('result-comisiones', true);
    }

    el('com-coin')?.addEventListener('change', () => { badge('com', gc(el('com-coin').value)); calcCom(); });
    ['com-cant','com-pct','com-tipo'].forEach(id => {
      el(id)?.addEventListener('input', calcCom);
      el(id)?.addEventListener('change', calcCom);
    });
  }

  await Promise.all([loadDolar(), loadCoins()]);
</script>

