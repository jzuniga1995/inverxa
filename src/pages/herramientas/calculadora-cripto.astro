  <meta property="og:image:height"     content="630" />
  <meta property="og:image:alt"        content="Calculadora de Criptomonedas — Inversax" />
  <meta property="og:image:type"       content="image/png" />

  <!-- ═══════════════════════════════════════
       TWITTER CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content="Calculadora Cripto — Convertir, Ganancias y Comisiones | Inversax" />
  <meta name="twitter:description" content="Convertí crypto a pesos, calculá ganancias, DCA y comisiones del exchange. Precios en vivo para toda Latinoamérica." />
  <meta name="twitter:image"       content="https://inversax.com/og/herramientas/calculadora-cripto.png" />
  <meta name="twitter:image:alt"   content="Calculadora de Criptomonedas — Inversax" />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebSite + SearchAction
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://inversax.com/noticias?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebPage
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Calculadora de Criptomonedas — Convertir, Ganancias y Comisiones | Inversax",
    "description": "Calculadora cripto gratis con precios en vivo. Convertí Bitcoin, Ethereum y más a pesos o dólares. Calculá ganancias, ahorro DCA y comisiones del exchange.",
    "url": "https://inversax.com/herramientas/calculadora-cripto",
    "inLanguage": "es",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://inversax.com/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    "about": [
      { "@type": "Thing", "name": "Criptomonedas" },
      { "@type": "Thing", "name": "Bitcoin" },
      { "@type": "Thing", "name": "Calculadora financiera" },
      { "@type": "Thing", "name": "DCA investing" },
      { "@type": "Thing", "name": "Comisiones exchange" }
    ]
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — BreadcrumbList
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",            "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Herramientas",      "item": "https://inversax.com/herramientas" },
      { "@type": "ListItem", "position": 3, "name": "Calculadora Cripto","item": "https://inversax.com/herramientas/calculadora-cripto" }
    ]
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — SoftwareApplication
       Le dice a Google que es una herramienta interactiva gratuita
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Calculadora de Criptomonedas Inversax",
    "url": "https://inversax.com/herramientas/calculadora-cripto",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Herramienta gratuita para convertir criptomonedas a monedas LATAM, calcular ganancias/pérdidas, simular ahorro DCA y estimar comisiones de exchanges con precios en tiempo real.",
    "featureList": [
      "Convertidor cripto a más de 17 monedas LATAM",
      "Calculadora de ganancias y pérdidas",
      "Simulador de ahorro periódico DCA",
      "Calculadora de comisiones de exchange",
      "Precios en tiempo real"
    ],
    "inLanguage": "es",
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — FAQPage
       Rich results para búsquedas de calculadora cripto
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cómo convertir Bitcoin a pesos argentinos, mexicanos o colombianos?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Con la calculadora cripto de Inversax podés convertir Bitcoin y más de 100 criptomonedas a pesos argentinos (ARS), mexicanos (MXN), colombianos (COP), lempiras (HNL) y otras 17 monedas de Latinoamérica usando precios en vivo."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué es el DCA en criptomonedas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El DCA (Dollar Cost Averaging) o ahorro periódico es una estrategia que consiste en invertir una cantidad fija de dinero en cripto de forma regular (semanal o mensual), sin importar el precio. Esto reduce el riesgo de comprar todo en el peor momento y promedia el costo de entrada a largo plazo."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto cobra Binance, Kraken y Coinbase de comisión?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Binance cobra un 0.1% por operación, Kraken entre 0.16% y 0.26% dependiendo del volumen, y Coinbase hasta un 1.49% en compras directas. Con la calculadora de comisiones de Inversax podés ver exactamente cuánto pagás y cuánto te queda neto."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo calcular las ganancias o pérdidas de una inversión en cripto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ingresá el precio al que compraste, la cantidad de cripto y el precio actual. La calculadora de Inversax te muestra el porcentaje de ganancia o pérdida, el valor actual de tu inversión, la ganancia o pérdida en USD y el precio de recuperación (breakeven)."
        }
      },
      {
        "@type": "Question",
        "name": "¿Los precios de la calculadora son en tiempo real?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí, la calculadora cripto de Inversax usa precios en vivo obtenidos directamente desde la API. Las tasas de cambio de monedas LATAM también se actualizan diariamente para reflejar el tipo de cambio oficial de cada país."
        }
      }
    ]
  })} />

</slot>

<main class="min-h-screen bg-[#0A0B0D] pt-24 sm:pt-28 pb-24 px-4 sm:px-6" style="font-family: 'DM Sans', sans-serif;">
  <div class="max-w-3xl mx-auto">

    <!-- Back -->
    <a href="/herramientas" class="inline-flex items-center gap-2 text-white/30 hover:text-white/70 text-sm mb-6 sm:mb-8 no-underline transition-colors group">
      <ArrowLeft size={14} class="group-hover:-translate-x-0.5 transition-transform" /> Herramientas
    </a>

    <!-- Header -->
    <div class="mb-7 sm:mb-10">
      <div class="flex items-center gap-3 sm:gap-4 mb-2">
        <div class="w-10 h-10 sm:w-11 sm:h-11 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(0,214,143,0.15), rgba(0,214,143,0.05)); border: 1px solid rgba(0,214,143,0.2);">
          <Calculator size={18} class="text-emerald-400" />
        </div>
        <div>
          <h1 class="font-extrabold text-xl sm:text-3xl text-white leading-tight" style="font-family: 'Syne', sans-serif;">
            Calculadora Cripto
          </h1>
          <p class="text-white/40 text-xs sm:text-sm mt-0.5">Precios en vivo · Para toda Latinoamérica</p>
        </div>
      </div>
    </div>

    <!-- TABS -->
    <div class="flex gap-1 bg-[#111318] border border-white/[0.07] rounded-2xl p-1.5 mb-6 sm:mb-7 overflow-x-auto scrollbar-hide">
      <button class="tab-btn flex-1 min-w-[90px] sm:min-w-[120px]" data-tab="convertir">⇄ Convertir</button>
      <button class="tab-btn flex-1 min-w-[90px] sm:min-w-[120px]" data-tab="ganancias">Ganancias</button>
      <button class="tab-btn flex-1 min-w-[90px] sm:min-w-[120px]" data-tab="ahorro">DCA</button>
      <button class="tab-btn flex-1 min-w-[90px] sm:min-w-[120px]" data-tab="comisiones">Comisiones</button>
    </div>

    <!-- ══ CONVERTIR ══ -->
    <div class="panel hidden" id="tab-convertir">
      <div class="card">

        <div id="conv-live" class="hidden items-center gap-2 sm:gap-3 live-badge mb-5 sm:mb-6">
          <img id="conv-img" src="" alt="" class="w-6 h-6 sm:w-7 sm:h-7 rounded-full ring-1 ring-white/10 flex-shrink-0" />
          <span id="conv-cname" class="text-white/50 text-xs font-medium truncate"></span>
          <span id="conv-cprice" class="text-emerald-400 font-bold ml-auto font-mono text-xs sm:text-sm flex-shrink-0"></span>
          <span id="conv-cchg" class="text-xs font-mono px-1.5 sm:px-2 py-0.5 rounded-full flex-shrink-0"></span>
        </div>

        <div class="mb-4 sm:mb-5">
          <label class="field-label">Cantidad a convertir</label>
          <div class="relative">
            <input type="number" id="conv-amount" value="1" min="0" step="any" class="field-input pr-16" />
            <span id="conv-suffix" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 text-xs font-mono font-bold pointer-events-none">BTC</span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-4 sm:mb-5">
          <div>
            <label class="field-label">Criptomoneda</label>
            <select id="conv-from" class="field-select"><option>Cargando...</option></select>
          </div>
          <div>
            <label class="field-label">Convertir a</label>
            <select id="conv-to" class="field-select">
              <option value="usd">🇺🇸 Dólar — USD</option>
              <option value="eur">🇪🇺 Euro — EUR</option>
              <option value="ars">🇦🇷 Peso Argentino — ARS</option>
              <option value="mxn">🇲🇽 Peso Mexicano — MXN</option>
              <option value="cop">🇨🇴 Peso Colombiano — COP</option>
              <option value="hnl">🇭🇳 Lempira — HNL</option>
              <option value="brl">🇧🇷 Real Brasileño — BRL</option>
              <option value="clp">🇨🇱 Peso Chileno — CLP</option>
              <option value="pen">🇵🇪 Sol Peruano — PEN</option>
              <option value="uyu">🇺🇾 Peso Uruguayo — UYU</option>
              <option value="pyg">🇵🇾 Guaraní — PYG</option>
              <option value="bob">🇧🇴 Boliviano — BOB</option>
              <option value="crc">🇨🇷 Colón — CRC</option>
              <option value="gtq">🇬🇹 Quetzal — GTQ</option>
              <option value="nio">🇳🇮 Córdoba — NIO</option>
              <option value="dop">🇩🇴 Peso Dominicano — DOP</option>
              <option value="ves">🇻🇪 Bolívar — VES</option>
              <option value="cripto">⚡ Otra criptomoneda</option>
            </select>
          </div>
        </div>

        <div id="conv-cripto-wrap" class="hidden mb-4 sm:mb-5">
          <label class="field-label">Criptomoneda destino</label>
          <select id="conv-to-cripto" class="field-select"><option>Cargando...</option></select>
        </div>

        <div id="result-convertir" class="hidden result-box mt-4">
          <div class="result-header">Resultado</div>
          <div class="p-4 sm:p-5">
            <div id="conv-result-val" class="result-val">—</div>
            <div id="conv-result-sub" class="result-sub mb-4 sm:mb-5"></div>
            <div class="stats-grid">
              <div class="stat-cell">
                <div class="stat-label">Precio unitario</div>
                <div id="conv-unit" class="stat-val">—</div>
              </div>
              <div class="stat-cell">
                <div class="stat-label">Tasa usada</div>
                <div id="conv-tasa" class="stat-val">—</div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <div class="how-to-section">
        <h2 class="how-to-title">¿Cómo usar el convertidor?</h2>
        <ol class="how-to-steps">
          <li>
            <span class="how-to-num">1</span>
            <div>
              <strong class="how-to-step-title">Elegí la criptomoneda origen</strong>
              <p class="how-to-step-desc">Seleccioná la cripto que querés convertir (BTC, ETH, SOL, etc.). El precio se carga automáticamente en vivo.</p>
            </div>
          </li>
          <li>
            <span class="how-to-num">2</span>
            <div>
              <strong class="how-to-step-title">Ingresá la cantidad</strong>
              <p class="how-to-step-desc">Escribí cuántas unidades querés convertir. Podés usar decimales, por ejemplo <code class="how-to-code">0.005</code> BTC.</p>
            </div>
          </li>
          <li>
            <span class="how-to-num">3</span>
            <div>
              <strong class="how-to-step-title">Elegí la moneda destino</strong>
              <p class="how-to-step-desc">Podés convertir a más de 17 monedas LATAM o a otra criptomoneda seleccionando <em>⚡ Otra criptomoneda</em>.</p>
            </div>
          </li>
        </ol>
        <div class="how-to-note">
          Las tasas de cambio de monedas locales (HNL, ARS, MXN…) se actualizan diariamente desde fuentes oficiales de cada país.
        </div>
      </div>
    </div>

    <!-- ══ GANANCIAS ══ -->
    <div class="panel hidden" id="tab-ganancias">
      <div class="card">

        <div id="gan-live" class="hidden items-center gap-2 sm:gap-3 live-badge mb-5 sm:mb-6">
          <img id="gan-img" src="" alt="" class="w-6 h-6 sm:w-7 sm:h-7 rounded-full ring-1 ring-white/10 flex-shrink-0" />
