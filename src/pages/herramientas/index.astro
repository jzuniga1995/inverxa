---
// src/pages/herramientas/index.astro
import Layout from '../../layouts/Layout.astro';
import { ArrowRight, Calculator, DollarSign, BarChart2, Shield, TrendingUp, Layers, Landmark } from 'lucide-astro';

const herramientas = [
  {
    icon: 'chart',
    nombre: 'Mercados Cripto',
    descripcion: 'Precios en tiempo real, gráficos TradingView y análisis técnico de las principales criptomonedas.',
    href: '/herramientas/cripto',
    disponible: true,
    badge: 'En vivo',
    color: '#F59E0B',
  },
  {
    icon: 'forex',
    nombre: 'Forex',
    descripcion: 'Tipos de cambio en tiempo real de los principales pares de divisas globales y monedas de Latinoamérica.',
    href: '/herramientas/forex',
    disponible: true,
    badge: 'En vivo',
    color: '#EC4899',
  },
  {
    icon: 'layers',
    nombre: 'Metales Preciosos',
    descripcion: 'Precios actualizados de oro, plata, platino y paladio por onza troy con gráficas en vivo.',
    href: '/herramientas/metales',
    disponible: true,
    badge: 'En vivo',
    color: '#F59E0B',
  },
  {
    icon: 'acciones',
    nombre: 'Acciones',
    descripcion: 'Cotizaciones en tiempo real de las principales empresas del mercado estadounidense.',
    href: '/herramientas/acciones',
    disponible: true,
    badge: 'En vivo',
    color: '#10B981',
  },
  {
    icon: 'dollar',
    nombre: 'Precio del Dólar',
    descripcion: 'Precio del dólar oficial y paralelo (blue en Argentina) en todos los países de Latinoamérica.',
    href: '/herramientas/dolar',
    disponible: true,
    badge: 'En vivo',
    color: '#D4A843',
  },
  {
    icon: 'calculator',
    nombre: 'Calculadora Cripto',
    descripcion: 'Convertí y calculá ganancias entre criptomonedas y monedas fiat al instante.',
    href: '#',
    disponible: false,
    badge: 'Próximamente',
    color: '#D4A843',
  },
  {
    icon: 'shield',
    nombre: 'Comparar Brokers',
    descripcion: 'Compará comisiones, regulaciones y características de los principales brokers para Latinoamérica.',
    href: '#',
    disponible: false,
    badge: 'Próximamente',
    color: '#D4A843',
  },
];
---

<Layout>
<slot name="head" slot="head">

  <title>Herramientas Financieras Gratis — Cripto, Forex, Bolsa y Metales en Vivo | Inversax</title>
  <meta name="description" content="Precios en tiempo real de criptomonedas, forex, acciones y metales preciosos. Herramientas financieras gratuitas para inversores y traders en Latinoamérica." />
  <meta name="keywords" content="herramientas financieras latam, precio bitcoin tiempo real, forex en vivo, precio oro hoy, acciones en tiempo real, precio dolar latinoamerica, herramientas trading gratis" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="author" content="Inversax" />
  <link rel="canonical" href="https://inversax.com/herramientas" />

  <meta property="og:site_name"    content="Inversax" />
  <meta property="og:locale"       content="es_LA" />
  <meta property="og:type"         content="website" />
  <meta property="og:title"        content="Herramientas Financieras Gratis — Cripto, Forex, Bolsa y Metales en Vivo | Inversax" />
  <meta property="og:description"  content="Precios en tiempo real de cripto, forex, acciones y metales. Gratis para toda Latinoamérica." />
  <meta property="og:url"          content="https://inversax.com/herramientas" />
  <meta property="og:image"        content="https://inversax.com/og/herramientas.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"    content="Herramientas Financieras — Inversax" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:title"       content="Herramientas Financieras Gratis — Cripto, Forex, Bolsa | Inversax" />
  <meta name="twitter:description" content="Precios en tiempo real de cripto, forex, acciones y metales para Latinoamérica. Gratis." />
  <meta name="twitter:image"       content="https://inversax.com/og/herramientas.png" />

  <meta name="language" content="Spanish" />
  <meta name="content-language" content="es" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Herramientas Financieras — Inversax",
    "description": "Precios en tiempo real de cripto, forex, acciones y metales. Gratis para Latinoamérica.",
    "url": "https://inversax.com/herramientas",
    "inLanguage": "es",
    "isPartOf": { "@type": "WebSite", "name": "Inversax", "url": "https://inversax.com" },
    "publisher": {
      "@type": "Organization", "name": "Inversax", "url": "https://inversax.com",
      "logo": { "@type": "ImageObject", "url": "https://inversax.com/favicon.png" }
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",       "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Herramientas", "item": "https://inversax.com/herramientas" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Herramientas financieras de Inversax",
    "url": "https://inversax.com/herramientas",
    "numberOfItems": 5,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Mercados Cripto — Precios en vivo",        "url": "https://inversax.com/herramientas/cripto"   },
      { "@type": "ListItem", "position": 2, "name": "Forex — Tipos de cambio en tiempo real",   "url": "https://inversax.com/herramientas/forex"    },
      { "@type": "ListItem", "position": 3, "name": "Metales Preciosos — Precio del oro y plata","url": "https://inversax.com/herramientas/metales"  },
      { "@type": "ListItem", "position": 4, "name": "Acciones — Cotizaciones en tiempo real",   "url": "https://inversax.com/herramientas/acciones" },
      { "@type": "ListItem", "position": 5, "name": "Precio del Dólar en Latinoamérica",        "url": "https://inversax.com/herramientas/dolar"    }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Herramientas de mercado en vivo — Inversax",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "url": "https://inversax.com/herramientas",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Precios en tiempo real de cripto, forex, metales y acciones para Latinoamérica.",
    "inLanguage": "es"
  })} />

</slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family: 'DM Sans', sans-serif;">

    <!-- PAGE HEADER -->
    <div class="border-b border-white/[0.07] bg-[#111318]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <h1 class="font-extrabold text-2xl sm:text-4xl text-white mb-2" style="font-family: 'Syne', sans-serif;">
          Herramientas
        </h1>
        <p class="text-white/40 text-sm sm:text-base">
          Precios en vivo, gráficas y recursos financieros para inversores en Latinoamérica
        </p>
      </div>
    </div>

    <!-- GRID -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">

        {herramientas.map((h) => (
          <div class={`relative flex flex-col gap-4 bg-[#111318] border rounded-2xl p-6 transition-all duration-200 ${
            h.disponible
              ? 'border-white/[0.07] hover:border-white/20 cursor-pointer group hover:-translate-y-0.5'
              : 'border-white/[0.04] opacity-50'
          }`}>

            <!-- Icono + Badge -->
            <div class="flex items-start justify-between">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                style={h.disponible ? `background: ${h.color}15;` : 'background: rgba(255,255,255,0.05);'}>
                {h.icon === 'calculator' && <Calculator  size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'dollar'     && <DollarSign  size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'chart'      && <BarChart2   size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'forex'      && <TrendingUp  size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'layers'     && <Layers      size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'acciones'   && <Landmark    size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
                {h.icon === 'shield'     && <Shield      size={20} class={h.disponible ? '' : 'text-white/30'} style={h.disponible ? `color: ${h.color}` : ''} />}
              </div>
              <span class="text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider"
                style={h.disponible
                  ? `background: ${h.color}15; color: ${h.color};`
                  : 'background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3);'
                }>
                {h.badge}
              </span>
            </div>

            <!-- Texto -->
            <div class="flex flex-col gap-2 flex-1">
              <h2 class={`font-bold text-base leading-snug transition-colors duration-200 ${
                h.disponible ? 'text-white group-hover:text-[#D4A843]' : 'text-white/40'
              }`} style="font-family: 'Syne', sans-serif;">
                {h.nombre}
              </h2>
              <p class="text-white/35 text-sm leading-relaxed">
                {h.descripcion}
              </p>
            </div>

            <!-- CTA -->
            {h.disponible ? (
              <span class="flex items-center gap-1.5 text-sm font-medium no-underline mt-auto" style={`color: ${h.color};`}>
                Abrir herramienta <ArrowRight size={14} />
              </span>
            ) : (
              <span class="text-white/20 text-xs mt-auto">En desarrollo</span>
            )}

            <!-- Overlay clickeable -->
            {h.disponible && (
              <a href={h.href} class="absolute inset-0 rounded-2xl no-underline" aria-label={h.nombre} />
            )}

          </div>
        ))}

      </div>
    </div>

  </div>
</Layout>
