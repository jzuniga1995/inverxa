<script>
  // Carga datos en vivo para las cards de herramientas
  const fmtPrice = (p: number) => {
    if (!p) return '···';
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  };
  const fmtForex = (p: number) => {
    if (!p) return '···';
    return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  };

  async function cargarDatos() {
    const [resCripto, resForex, resMetales] = await Promise.allSettled([
      fetch('/api/precios'),
      fetch('/api/forex'),
      fetch('/api/metales'),
    ]);

    if (resCripto.status === 'fulfilled' && resCripto.value.ok) {
      const data = await resCripto.value.json() as any[];
      const btc = data.find((c: any) => c.id === 'bitcoin');
      if (btc) {
        document.querySelectorAll<HTMLElement>('[data-live="btc-price"]').forEach(el => {
          el.textContent = fmtPrice(btc.price);
          el.classList.remove('animate-pulse');
        });
      }
    }
    if (resForex.status === 'fulfilled' && resForex.value.ok) {
      const json = await resForex.value.json() as any;
      const forex = json.data ?? json;
      const eurusd = forex.find((f: any) => f.par === 'EUR/USD');
      if (eurusd) {
        document.querySelectorAll<HTMLElement>('[data-live="eurusd-rate"]').forEach(el => {
          el.textContent = fmtForex(eurusd.precio);
          el.classList.remove('animate-pulse');
        });
      }
    }
    if (resMetales.status === 'fulfilled' && resMetales.value.ok) {
      const json = await resMetales.value.json() as any;
      const metales = json.data ?? json;
      const oro = metales.find((m: any) => m.slug === 'oro' || m.simbolo === 'XAU');
      if (oro && oro.precio > 0) {
        document.querySelectorAll<HTMLElement>('[data-live="gold-price"]').forEach(el => {
          el.textContent = `$${oro.precio.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
          el.classList.remove('animate-pulse');
        });
      }
    }
  }

  cargarDatos();
</script>
