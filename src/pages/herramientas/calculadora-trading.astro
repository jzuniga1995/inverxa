  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Cuánto vale un pip en EUR/USD?", "acceptedAnswer": { "@type": "Answer", "text": "En EUR/USD, 1 pip equivale a 0.0001. Con un lote estándar (100,000 unidades) cada pip vale $10 USD. Con un mini lote (10,000 unidades) vale $1 USD, y con un micro lote (1,000 unidades) vale $0.10 USD." } },
      { "@type": "Question", "name": "¿Cómo calcular el tamaño de posición en Forex?", "acceptedAnswer": { "@type": "Answer", "text": "El tamaño de posición se calcula con la fórmula: Lotes = (Capital × % Riesgo) ÷ (Stop Loss en pips × Valor por pip). Ejemplo: con $1,000, 2% de riesgo y 20 pips de stop en EUR/USD: $20 ÷ $10/pip = 0.2 lotes." } },
      { "@type": "Question", "name": "¿Qué es el margen requerido en Forex y cómo se calcula?", "acceptedAnswer": { "@type": "Answer", "text": "El margen requerido es el dinero que el broker bloquea para abrir una posición. Se calcula como: Margen = (Lotes × 100,000 × Precio) ÷ Apalancamiento." } },
      { "@type": "Question", "name": "¿Cuánto debo arriesgar por operación en Forex?", "acceptedAnswer": { "@type": "Answer", "text": "Los traders profesionales recomiendan arriesgar entre el 1% y el 2% del capital por operación. Con $1,000 de cuenta eso es entre $10 y $20 por trade." } },
      { "@type": "Question", "name": "¿Cuál es la diferencia entre un lote estándar, mini lote y micro lote?", "acceptedAnswer": { "@type": "Answer", "text": "Un lote estándar equivale a 100,000 unidades. Un mini lote son 10,000 unidades (0.1 lotes) y un micro lote son 1,000 unidades (0.01 lotes)." } },
      { "@type": "Question", "name": "¿Qué brokers tienen mayor apalancamiento para traders de Latinoamérica?", "acceptedAnswer": { "@type": "Answer", "text": "Para traders de Latinoamérica: Exness ofrece hasta 1:2000 de apalancamiento, XM hasta 1:1000, y Pepperstone hasta 1:400." } },
      { "@type": "Question", "name": "¿Cómo calcular las ganancias o pérdidas en Forex?", "acceptedAnswer": { "@type": "Answer", "text": "Resultado = (Precio de salida - Precio de entrada) ÷ Tamaño de pip × Valor del pip × Lotes. En una compra de EUR/USD a 1.0850 con salida en 1.0900 con 1 lote: 50 pips × $10/pip = $500 USD bruto." } },
      { "@type": "Question", "name": "¿Cómo calcular los pips en pares con JPY como USD/JPY?", "acceptedAnswer": { "@type": "Answer", "text": "Para pares con el Yen japonés (USD/JPY, EUR/JPY, GBP/JPY), 1 pip equivale a 0.01 en lugar de 0.0001. La calculadora de Inversax ajusta esto automáticamente." } },
      { "@type": "Question", "name": "¿Qué es un margin call y cómo evitarlo?", "acceptedAnswer": { "@type": "Answer", "text": "Un margin call ocurre cuando las pérdidas consumen el margen libre y el broker cierra tus posiciones automáticamente. Se evita usando apalancamiento bajo y manteniendo margen libre mayor al 100%." } },
      { "@type": "Question", "name": "¿Funciona la calculadora para pares LATAM como USD/HNL o USD/MXN?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. La calculadora incluye USD/HNL, USD/MXN, USD/BRL, USD/COP, USD/ARS, USD/CLP y USD/PEN, ideal para traders que operan con divisas de su propio país." } }
    ]
