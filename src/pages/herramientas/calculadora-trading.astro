  }
  .calc-btn:hover { opacity: 0.88; }
  .calc-btn:active { transform: scale(0.98); }

  /* RESULTADO */
  .resultado-box {
    margin-top: 1.5rem;
    background: #0A0B0D;
    border: 1px solid #23272F;
    border-radius: 12px;
    padding: 1.25rem;
  }
  .resultado-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  @media (max-width: 480px) { .resultado-grid { grid-template-columns: 1fr; } }

  .resultado-item {
    background: #13151A;
    border: 1px solid #23272F;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .resultado-item.highlight { border-color: #D4A843; }

  .resultado-label {
    font-size: 0.72rem;
    color: #6B7280;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .resultado-valor {
    font-size: 1.05rem;
    font-weight: 700;
    color: #E8EAF0;
    font-family: 'Syne', sans-serif;
  }
  .resultado-nota {
    font-size: 0.8rem;
    color: #6B7280;
    line-height: 1.5;
  }
  .ganancia { color: #22c55e !important; }
  .perdida  { color: #ef4444 !important; }
</style>

<script>
// @ts-nocheck

  // TABS
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.calc-panel').forEach(p => p.classList.remove('active'));
      (btn as HTMLElement).classList.add('active');
      document.getElementById('tab-' + (btn as HTMLElement).dataset.tab)?.classList.add('active');
    });
  });

  // HELPERS
  const fmt = (n: number, dec = 2) =>
    n.toLocaleString('es-MX', { minimumFractionDigits: dec, maximumFractionDigits: dec });

  const approxPrices: Record<string, number> = {
    'USD/JPY': 150, 'USD/CHF': 0.91, 'USD/CAD': 1.36,
    'USD/MXN': 17,  'USD/BRL': 5.1,  'USD/CLP': 900,
    'USD/COP': 4000,'USD/PEN': 3.7,  'USD/ARS': 1000,
    'USD/HNL': 24.8,'EUR/GBP': 0.86, 'EUR/JPY': 162,
    'GBP/JPY': 190, 'EUR/AUD': 1.65, 'NZD/USD': 0.61,
  };

  function pipVal(par: string, pipSize: number, lotSize: number, price: number) {
    return par.endsWith('USD') ? pipSize * lotSize : (pipSize / price) * lotSize;
  }

  // PIPS
  document.getElementById('btn-pips')?.addEventListener('click', () => {
    const parEl   = document.getElementById('pip-par') as HTMLSelectElement;
    const par     = parEl.value;
    const pipSize = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const loteTipo= parseFloat((document.getElementById('pip-lote-tipo') as HTMLSelectElement).value);
    const lotes   = parseFloat((document.getElementById('pip-lotes') as HTMLInputElement).value) || 1;
    const pips    = parseFloat((document.getElementById('pip-cantidad') as HTMLInputElement).value) || 10;
    const lotSize = loteTipo * lotes;
    const price   = approxPrices[par] ?? 1.085;
    const vPip    = pipVal(par, pipSize, lotSize, price);

    document.getElementById('r-pip-valor')!.textContent = '$' + fmt(vPip);
    document.getElementById('r-pip-total')!.textContent = '$' + fmt(vPip * pips);
    document.getElementById('r-pip-par')!.textContent   = par;
    document.getElementById('r-pip-size')!.textContent  = fmt(lotSize, 0) + ' unidades';
    document.getElementById('r-pip-n')!.textContent     = String(pips);
    (document.getElementById('resultado-pips') as HTMLElement).style.display = 'block';
  });

  // POSICIÓN
  document.getElementById('btn-posicion')?.addEventListener('click', () => {
    const capital   = parseFloat((document.getElementById('pos-capital') as HTMLInputElement).value) || 1000;
    const riesgoPct = parseFloat((document.getElementById('pos-riesgo') as HTMLInputElement).value) || 2;
    const parEl     = document.getElementById('pos-par') as HTMLSelectElement;
    const par       = parEl.value;
    const pipSize   = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const slPips    = parseFloat((document.getElementById('pos-sl') as HTMLInputElement).value) || 20;
    const entrada   = parseFloat((document.getElementById('pos-entrada') as HTMLInputElement).value) || 1.085;
    const riesgoUSD = capital * (riesgoPct / 100);
    const pvStd     = pipVal(par, pipSize, 100000, approxPrices[par] ?? entrada);
    const lotesStd  = riesgoUSD / (slPips * pvStd);

    document.getElementById('r-pos-lotes')!.textContent      = fmt(lotesStd, 2) + ' lotes';
    document.getElementById('r-pos-mini')!.textContent       = fmt(lotesStd * 10, 1) + ' mini lotes';
    document.getElementById('r-pos-riesgo-usd')!.textContent = '$' + fmt(riesgoUSD);
    document.getElementById('r-pos-unidades')!.textContent   = fmt(Math.round(lotesStd * 100000), 0);
    document.getElementById('r-pos-sl')!.textContent         = slPips + ' pips';
    document.getElementById('r-pos-precio-sl')!.textContent  = fmt(entrada - slPips * pipSize, 5);
    (document.getElementById('resultado-posicion') as HTMLElement).style.display = 'block';
  });

  // GANANCIAS
  document.getElementById('btn-ganancias')?.addEventListener('click', () => {
    const parEl    = document.getElementById('gan-par') as HTMLSelectElement;
    const par      = parEl.value;
    const pipSize  = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const dir      = (document.getElementById('gan-direccion') as HTMLSelectElement).value;
    const lotes    = parseFloat((document.getElementById('gan-lotes') as HTMLInputElement).value) || 1;
    const entrada  = parseFloat((document.getElementById('gan-entrada') as HTMLInputElement).value);
    const salida   = parseFloat((document.getElementById('gan-salida') as HTMLInputElement).value);
    const comision = parseFloat((document.getElementById('gan-comision') as HTMLInputElement).value) || 0;
    const lotSize  = lotes * 100000;
    const diff     = dir === 'buy' ? salida - entrada : entrada - salida;
    const pipsRec  = diff / pipSize;
    const pv       = pipVal(par, pipSize, lotSize, approxPrices[par] ?? entrada);
    const bruto    = pipsRec * pv;
    const neto     = bruto - comision;

    const netoEl = document.getElementById('r-gan-neto')!;
    netoEl.textContent = (neto >= 0 ? '+' : '') + '$' + fmt(Math.abs(neto)) + ' USD';
    netoEl.className = 'resultado-valor ' + (neto >= 0 ? 'ganancia' : 'perdida');
    (document.getElementById('r-gan-box-neto') as HTMLElement).style.borderColor = neto >= 0 ? '#22c55e' : '#ef4444';

    document.getElementById('r-gan-bruto')!.textContent     = (bruto >= 0 ? '+' : '') + '$' + fmt(Math.abs(bruto)) + ' USD';
    document.getElementById('r-gan-pips')!.textContent      = fmt(Math.abs(pipsRec), 1) + ' pips';
    document.getElementById('r-gan-pip-valor')!.textContent = '$' + fmt(pv / lotes, 2) + '/pip';
    document.getElementById('r-gan-comision')!.textContent  = '$' + fmt(comision);
    document.getElementById('r-gan-pct')!.textContent       = (neto >= 0 ? '+' : '') + fmt((neto / 1000) * 100, 2) + '%';
    (document.getElementById('resultado-ganancias') as HTMLElement).style.display = 'block';
  });

  // MARGEN
  document.getElementById('btn-margen')?.addEventListener('click', () => {
    const lotes  = parseFloat((document.getElementById('mar-lotes') as HTMLInputElement).value) || 1;
    const precio = parseFloat((document.getElementById('mar-precio') as HTMLInputElement).value) || 1.085;
    const apal   = parseFloat((document.getElementById('mar-apal') as HTMLSelectElement).value);
    const valPos = lotes * 100000 * precio;
    const margen = valPos / apal;

    document.getElementById('r-mar-margen')!.textContent = '$' + fmt(margen);
    document.getElementById('r-mar-valor')!.textContent  = '$' + fmt(valPos);
    document.getElementById('r-mar-apal')!.textContent   = '1:' + apal;
    document.getElementById('r-mar-libre')!.textContent  = '$' + fmt(Math.max(1000 - margen, 0));
    (document.getElementById('resultado-margen') as HTMLElement).style.display = 'block';
  });
</script>
