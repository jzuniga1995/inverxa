  @media (max-width: 480px) {
    .seo-table-row { grid-template-columns: 1fr 1fr; font-size: 0.75rem; }
    .seo-table-row span:last-child { display: none; }
  }
</style>

<script>
// @ts-nocheck

  // TABS
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.calc-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
    });
  });

  // ─────────────────────────────────────────
  // HELPERS
  // ─────────────────────────────────────────
  const fmt = (n, dec = 2) =>
    n.toLocaleString('es-MX', { minimumFractionDigits: dec, maximumFractionDigits: dec });

  // Precios aproximados para pares donde USD NO es la divisa cotizada
  const approxPrices = {
    'USD/JPY': 150,   'USD/CHF': 0.91,  'USD/CAD': 1.36,
    'USD/MXN': 17.5,  'USD/BRL': 5.1,   'USD/CLP': 920,
    'USD/COP': 4000,  'USD/PEN': 3.75,  'USD/ARS': 1050,
    'USD/HNL': 24.8,  'EUR/GBP': 0.86,  'EUR/JPY': 162,
    'GBP/JPY': 190,   'EUR/AUD': 1.65,  'NZD/USD': 0.61,
  };

  /**
   * Calcula el valor en USD de 1 pip para un tamaño de posición dado.
   *
   * Casos:
   *  1. Par termina en USD (EUR/USD, GBP/USD, AUD/USD, NZD/USD):
   *     pipValue = pipSize × lotSize
   *     Ej: EUR/USD lote std → 0.0001 × 100,000 = $10 USD ✅
   *
   *  2. USD es la divisa BASE (USD/JPY, USD/CHF, USD/CAD, USD/MXN, USD/HNL...):
   *     pipValue = (pipSize × lotSize) / price
   *     Ej: USD/JPY a 150 → (0.01 × 100,000) / 150 = $6.67 USD ✅
   *     Ej: USD/CHF a 0.91 → (0.0001 × 100,000) / 0.91 = $10.99 USD ✅
   *
   *  3. Crosses sin USD (EUR/GBP, EUR/JPY, GBP/JPY):
   *     Aproximación: (pipSize × lotSize) / price
   *     (resultado en USD aproximado, suficiente para gestión de riesgo)
   */
  function pipVal(par, pipSize, lotSize, price) {
    if (par.endsWith('USD')) {
      // Caso 1: USD es divisa cotizada → pip directo en USD
      return pipSize * lotSize;
    } else {
      // Caso 2 y 3: USD es divisa base o cross → dividir por precio
      return (pipSize * lotSize) / price;
    }
  }

  function getPrice(par, fallback) {
    return approxPrices[par] ?? fallback ?? 1.085;
  }

  // ─────────────────────────────────────────
  // CALCULADORA: PIPS
  // ─────────────────────────────────────────
  document.getElementById('btn-pips')?.addEventListener('click', () => {
    const parEl    = document.getElementById('pip-par');
    const par      = parEl.value;
    const pipSize  = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const loteTipo = parseFloat(document.getElementById('pip-lote-tipo').value);
    const lotes    = parseFloat(document.getElementById('pip-lotes').value) || 1;
    const pips     = parseFloat(document.getElementById('pip-cantidad').value) || 10;
    const lotSize  = loteTipo * lotes;
    const price    = getPrice(par, 1.085);
    const vPip     = pipVal(par, pipSize, lotSize, price);

    document.getElementById('r-pip-valor').textContent = '$' + fmt(vPip);
    document.getElementById('r-pip-total').textContent = '$' + fmt(vPip * pips);
    document.getElementById('r-pip-par').textContent   = par;
    document.getElementById('r-pip-size').textContent  = fmt(lotSize, 0) + ' unidades';
    document.getElementById('r-pip-n').textContent     = String(pips);
    document.getElementById('resultado-pips').style.display = 'block';
  });

  // ─────────────────────────────────────────
  // CALCULADORA: TAMAÑO DE POSICIÓN
  // ─────────────────────────────────────────
  document.getElementById('btn-posicion')?.addEventListener('click', () => {
    const capital   = parseFloat(document.getElementById('pos-capital').value) || 1000;
    const riesgoPct = parseFloat(document.getElementById('pos-riesgo').value) || 2;
    const parEl     = document.getElementById('pos-par');
    const par       = parEl.value;
    const pipSize   = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const slPips    = parseFloat(document.getElementById('pos-sl').value) || 20;
    const entrada   = parseFloat(document.getElementById('pos-entrada').value) || 1.085;
    const price     = getPrice(par, entrada);

    const riesgoUSD = capital * (riesgoPct / 100);
    // Valor de 1 pip con 1 lote estándar (100,000 unidades)
    const pvStd     = pipVal(par, pipSize, 100000, price);
    const lotesStd  = riesgoUSD / (slPips * pvStd);

    document.getElementById('r-pos-lotes').textContent      = fmt(lotesStd, 2) + ' lotes';
    document.getElementById('r-pos-mini').textContent       = fmt(lotesStd * 10, 1) + ' mini lotes';
    document.getElementById('r-pos-riesgo-usd').textContent = '$' + fmt(riesgoUSD);
    document.getElementById('r-pos-unidades').textContent   = fmt(Math.round(lotesStd * 100000), 0);
    document.getElementById('r-pos-sl').textContent         = slPips + ' pips';
    // Nivel de stop para Buy (precio de entrada − stop loss en precio)
    const decimals = pipSize === 0.01 ? 3 : 5;
    document.getElementById('r-pos-precio-sl').textContent  = fmt(entrada - slPips * pipSize, decimals);
    document.getElementById('resultado-posicion').style.display = 'block';
  });

  // ─────────────────────────────────────────
  // CALCULADORA: GANANCIAS / PÉRDIDAS
  // ─────────────────────────────────────────
  document.getElementById('btn-ganancias')?.addEventListener('click', () => {
    const parEl    = document.getElementById('gan-par');
    const par      = parEl.value;
    const pipSize  = parseFloat(parEl.selectedOptions[0].dataset.pip ?? '0.0001');
    const dir      = document.getElementById('gan-direccion').value;
    const lotes    = parseFloat(document.getElementById('gan-lotes').value) || 1;
    const entrada  = parseFloat(document.getElementById('gan-entrada').value);
    const salida   = parseFloat(document.getElementById('gan-salida').value);
    const comision = parseFloat(document.getElementById('gan-comision').value) || 0;

    const lotSize  = lotes * 100000;
    const price    = getPrice(par, entrada);
    // Diferencia de precio según dirección
    const diff     = dir === 'buy' ? salida - entrada : entrada - salida;
    const pipsRec  = diff / pipSize;
    const pv       = pipVal(par, pipSize, lotSize, price);
    const bruto    = pipsRec * pv;
    const neto     = bruto - comision;

    const netoEl = document.getElementById('r-gan-neto');
    netoEl.textContent = (neto >= 0 ? '+' : '') + '$' + fmt(Math.abs(neto)) + ' USD';
    netoEl.className   = 'resultado-valor ' + (neto >= 0 ? 'ganancia' : 'perdida');
    document.getElementById('r-gan-box-neto').style.borderColor = neto >= 0 ? '#22c55e' : '#ef4444';

    document.getElementById('r-gan-bruto').textContent     = (bruto >= 0 ? '+' : '') + '$' + fmt(Math.abs(bruto)) + ' USD';
    document.getElementById('r-gan-pips').textContent      = fmt(Math.abs(pipsRec), 1) + ' pips';
    // Valor por pip dividido por lotes para mostrar valor por pip de 1 lote
    document.getElementById('r-gan-pip-valor').textContent = '$' + fmt(pv / lotes, 2) + '/pip';
    document.getElementById('r-gan-comision').textContent  = '$' + fmt(comision);
    document.getElementById('r-gan-pct').textContent       = (neto >= 0 ? '+' : '') + fmt((neto / 1000) * 100, 2) + '%';
    document.getElementById('resultado-ganancias').style.display = 'block';
  });

  // ─────────────────────────────────────────
  // CALCULADORA: MARGEN
  // ─────────────────────────────────────────
  document.getElementById('btn-margen')?.addEventListener('click', () => {
    const lotes  = parseFloat(document.getElementById('mar-lotes').value) || 1;
    const precio = parseFloat(document.getElementById('mar-precio').value) || 1.085;
    const apal   = parseFloat(document.getElementById('mar-apal').value);
    const par    = document.getElementById('mar-par').value;

    // Para pares donde USD es la base (USD/JPY, USD/CHF, etc.),
    // el valor nocional en USD es simplemente lotes × 100,000
    // Para pares donde USD es la cotizada (EUR/USD), se multiplica por el precio
    let valPos;
    if (par.startsWith('USD')) {
      // USD es base: valor en USD = lotes × 100,000 (no depende del precio)
      valPos = lotes * 100000;
    } else {
      // USD es cotizada: valor en USD = lotes × 100,000 × precio
      valPos = lotes * 100000 * precio;
    }

    const margen = valPos / apal;

    document.getElementById('r-mar-margen').textContent = '$' + fmt(margen);
    document.getElementById('r-mar-valor').textContent  = '$' + fmt(valPos);
    document.getElementById('r-mar-apal').textContent   = '1:' + apal;
    document.getElementById('r-mar-libre').textContent  = '$' + fmt(Math.max(1000 - margen, 0));
    document.getElementById('resultado-margen').style.display = 'block';
  });
</script>

</Layout>

