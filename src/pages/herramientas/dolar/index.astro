---
export const prerender = true;
// src/pages/herramientas/dolar/index.astro
import Layout from '../../../layouts/Layout.astro';
import { DollarSign, RefreshCw, Globe, ArrowLeft } from 'lucide-astro';
---

<Layout>

<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
  <title>Precio del Dólar Hoy en Latinoamérica — Oficial, Blue y Paralelo | Inversax</title>
  <meta name="description"    content="Precio del dólar hoy en Argentina, Venezuela, México, Colombia y toda Latinoamérica. Dólar blue, oficial, MEP, CCL y paralelo actualizados cada 15 minutos." />
  <meta name="author"         content="José Zúniga" />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"      content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"       href="https://inversax.com/herramientas/dolar" />

  <!-- ═══════════════════════════════════════
       KEYWORDS
  ═══════════════════════════════════════ -->
  <meta name="keywords"      content="precio dolar hoy, dolar blue hoy, dolar paralelo, tipo de cambio latinoamerica, dolar oficial argentina, dolar venezuela, dolar mexico hoy, dolar colombia hoy, dolar mep, dolar ccl, dolar blue argentina hoy" />
  <meta name="news_keywords" content="precio dólar hoy, dólar blue, dólar paralelo, tipo de cambio, Inversax" />

  <!-- ═══════════════════════════════════════
       GEO
  ═══════════════════════════════════════ -->
  <meta name="geo.region"       content="LATAM" />
  <meta name="geo.placename"    content="Latinoamérica" />
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />
  <meta name="coverage"         content="Worldwide" />
  <meta name="target"           content="all" />

  <!-- ═══════════════════════════════════════
       HREFLANG
  ═══════════════════════════════════════ -->
  <link rel="alternate" hreflang="es"    href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-MX" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-AR" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-CO" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-CL" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-PE" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-VE" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-EC" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-BO" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-PY" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-UY" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-CR" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-PA" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-DO" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-SV" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-HN" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-NI" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-GT" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-CU" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-PR" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-BZ" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-ES" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="es-US" href="https://inversax.com/herramientas/dolar" />
  <link rel="alternate" hreflang="x-default" href="https://inversax.com/herramientas/dolar" />

  <!-- ═══════════════════════════════════════
       OPEN GRAPH
  ═══════════════════════════════════════ -->
  <meta property="og:site_name"   content="Inversax" />
  <meta property="og:locale"      content="es_LA" />
  <meta property="og:locale:alternate" content="es_MX" />
  <meta property="og:locale:alternate" content="es_AR" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:locale:alternate" content="es_ES" />
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content="Precio del Dólar Hoy en Latinoamérica — Oficial, Blue y Paralelo | Inversax" />
  <meta property="og:description" content="Dólar blue, oficial, MEP y paralelo en Argentina, Venezuela, México, Colombia y más. Actualizado cada 15 minutos." />
  <meta property="og:url"         content="https://inversax.com/herramientas/dolar" />
  <meta property="og:image"       content="https://inversax.com/og/herramientas/dolar.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"   content="Precio del Dólar hoy en Latinoamérica — Inversax" />
  <meta property="og:image:type"  content="image/png" />

  <!-- ═══════════════════════════════════════
       TWITTER CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content="Precio del Dólar Hoy — Oficial, Blue y Paralelo en LATAM | Inversax" />
  <meta name="twitter:description" content="Dólar blue, oficial y paralelo en toda Latinoamérica. Actualizado cada 15 minutos." />
  <meta name="twitter:image"       content="https://inversax.com/og/herramientas/dolar.png" />
  <meta name="twitter:image:alt"   content="Precio del Dólar hoy en Latinoamérica — Inversax" />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebSite + SearchAction
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://inversax.com/noticias?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebPage
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Precio del Dólar Hoy en Latinoamérica — Inversax",
    "description": "Dólar oficial, blue y paralelo en toda Latinoamérica. Actualizado cada 15 minutos.",
    "url": "https://inversax.com/herramientas/dolar",
    "inLanguage": "es",
    "isPartOf": { "@type": "WebSite", "name": "Inversax", "url": "https://inversax.com" },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": { "@type": "ImageObject", "url": "https://inversax.com/favicon.png", "width": 512, "height": 512 }
    },
    "about": { "@type": "Thing", "name": "Tipo de cambio del dólar estadounidense" }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — BreadcrumbList
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",           "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Herramientas",     "item": "https://inversax.com/herramientas" },
      { "@type": "ListItem", "position": 3, "name": "Precio del Dólar", "item": "https://inversax.com/herramientas/dolar" }
    ]
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — FAQPage
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuál es el precio del dólar blue hoy en Argentina?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El dólar blue en Argentina se actualiza cada 15 minutos en Inversax. Es el tipo de cambio informal que opera fuera del sistema bancario oficial."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué diferencia hay entre el dólar oficial y el dólar paralelo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El dólar oficial es el tipo de cambio fijado por el banco central. El paralelo o blue es el precio en el mercado informal, generalmente más alto en países con controles cambiarios como Argentina o Venezuela."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cada cuánto se actualiza el precio del dólar en Inversax?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Los precios se actualizan automáticamente cada 15 minutos. También puedes forzar actualización manual con el botón Actualizar."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué es el dólar MEP y el CCL en Argentina?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El dólar MEP y CCL son tipos de cambio financieros legales en Argentina que se obtienen comprando y vendiendo bonos en bolsa. Son alternativas legales al dólar blue."
        }
      }
    ]
  })} />

</slot>

  <main class="min-h-screen pt-28 pb-20 px-4 sm:px-6" style="background: #FAFAF8; font-family: 'DM Sans', sans-serif;">
    <div class="max-w-5xl mx-auto">

      <a href="/herramientas" class="inline-flex items-center gap-2 text-sm mb-6 no-underline" style="color: #A8A29E;">
        <ArrowLeft size={15} /> Herramientas
      </a>

      <!-- Encabezado -->
      <div class="mb-10" style="border-bottom: 1px solid #E5E0D8; padding-bottom: 24px;">
        <h1 style="font-family: 'Playfair Display', serif; font-size: clamp(24px, 3.5vw, 36px); font-weight: 700; color: #1C1917; margin: 0 0 6px;">
          Precio del Dólar
        </h1>
        <p style="color: #78716C; font-size: 14px; margin: 0 0 16px;">Oficial, blue y paralelo en Latinoamérica</p>

        <!-- Meta info + botón actualizar -->
        <div class="flex items-center justify-between flex-wrap gap-3">
          <div class="flex items-center gap-4 flex-wrap">
            <span class="flex items-center gap-1.5 text-xs" style="color: #78716C;">
              <span class="w-1.5 h-1.5 rounded-full inline-block" style="background: #15803D;"></span>
              Actualizado cada 15 minutos
            </span>
            <span id="ultima-actualizacion" class="text-xs" style="color: #A8A29E;"></span>
          </div>
          <button
            id="btn-actualizar"
            class="flex items-center gap-1.5 text-xs cursor-pointer"
            style="color: #57534E; border: 1px solid #D6D0C8; padding: 6px 12px; background: #FAFAF8;"
          >
            <RefreshCw size={12} />
            Actualizar
          </button>
        </div>
      </div>

      <!-- Grid de países — skeleton inicial, se llena client-side -->
      <div id="paises-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 items-start">

        <!-- Skeletons mientras cargan los datos -->
        {[...Array(6)].map(() => (
          <div style="border: 1px solid #E5E0D8; overflow: hidden;">
            <div class="flex items-center gap-3 px-4 py-3.5" style="border-bottom: 1px solid #E5E0D8;">
              <div class="w-6 h-4 rounded-sm animate-pulse flex-shrink-0" style="background: #E5E0D8;"></div>
              <div class="flex-1 flex flex-col gap-1.5">
                <div class="w-24 h-3 rounded animate-pulse" style="background: #E5E0D8;"></div>
                <div class="w-16 h-2.5 rounded animate-pulse" style="background: #E5E0D8;"></div>
              </div>
            </div>
            <div>
              {[...Array(3)].map(() => (
                <div class="flex items-center justify-between px-4 py-3" style="border-top: 1px solid #F0EDE7;">
                  <div class="w-20 h-4 rounded animate-pulse" style="background: #E5E0D8;"></div>
                  <div class="w-16 h-4 rounded animate-pulse" style="background: #E5E0D8;"></div>
                </div>
              ))}
            </div>
          </div>
        ))}

      </div>

      <!-- Nota informativa -->
      <p class="text-xs text-center mt-8" style="color: #A8A29E;">
        Los precios paralelos son referenciales. Las fuentes utilizadas son bluelytics.com.ar y dolarapi.com.
        Los tipos de cambio oficiales provienen de fawazahmed0/currency-api.
      </p>

    </div>
  </main>
</Layout>

<script>
  const btnActualizar = document.getElementById('btn-actualizar');
  const grid          = document.getElementById('paises-grid') as HTMLElement;
  const ultimaAct     = document.getElementById('ultima-actualizacion');
  const icon          = btnActualizar?.querySelector('svg') as HTMLElement | null;

  const fmtNum = (n: number | null) => {
    if (n === null || n === undefined) return '—';
    if (n >= 100) return n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return n.toLocaleString('es-AR', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  };

  function renderGrid(data: any[]) {
    grid.innerHTML = data.map((pais: any) => {
      const hayParalelo = pais.variantes.some((v: any) => v.esParalelo);
      return `
      <a
        href="/herramientas/dolar/${pais.bandera}"
        style="display:block; border: 1px solid #E5E0D8; overflow: hidden; text-decoration: none; background: #fff;"
      >
        <div style="display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid #E5E0D8;">
          <img
            src="https://flagcdn.com/w40/${pais.bandera}.png"
            alt="${pais.pais}"
            style="width:24px; height:16px; object-fit:cover; flex-shrink:0;"
            onerror="this.style.display='none'"
          />
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; font-size:14px; color:#1C1917;">${pais.pais}</div>
            <div style="font-size:11px; color:#A8A29E;">${pais.moneda} · ${pais.simbolo}</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#A8A29E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div>
          ${pais.variantes.map((v: any) => `
            <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 16px; border-top:1px solid #F0EDE7;">
              <div style="display:flex; align-items:center; gap:8px; min-width:0;">
                ${hayParalelo ? `
                  <span style="font-size:10px; font-weight:700; padding:2px 6px; flex-shrink:0; ${
                    v.esParalelo
                      ? 'background:#FEF2F2; color:#B91C1C;'
                      : 'background:#F0FDF4; color:#15803D;'
                  }">
                    ${v.esParalelo ? 'PARALELO' : 'OFICIAL'}
                  </span>
                ` : ''}
                <span style="color:#78716C; font-size:12px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${v.nombre}</span>
              </div>
              <div style="display:flex; align-items:center; gap:12px; flex-shrink:0; margin-left:8px;">
                ${v.compra !== null ? `
                  <div style="text-align:right;">
                    <div style="font-size:10px; color:#A8A29E; line-height:1; margin-bottom:2px;">Compra</div>
                    <div style="font-size:12px; color:#57534E; font-weight:500;">${fmtNum(v.compra)}</div>
                  </div>
                ` : ''}
                <div style="text-align:right;">
                  ${v.compra !== null ? `<div style="font-size:10px; color:#A8A29E; line-height:1; margin-bottom:2px;">Venta</div>` : ''}
                  <div style="font-weight:700; font-size:14px; color:#1C1917;">${fmtNum(v.venta)}</div>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      </a>`;
    }).join('');
  }

  async function cargarDatos() {
    btnActualizar?.setAttribute('disabled', 'true');
    if (icon) icon.style.animation = 'spin 1s linear infinite';

    try {
      const res  = await fetch('/api/dolar');
      const json = await res.json() as any;

      if (!json.ok || !json.data?.length) {
        grid.innerHTML = `
          <div style="grid-column:1/-1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:80px 20px; border:1px solid #E5E0D8;">
            <p style="color:#A8A29E; font-size:14px;">Error al cargar los datos. Intenta de nuevo.</p>
          </div>`;
        return;
      }

      renderGrid(json.data);

      if (ultimaAct) {
        ultimaAct.textContent = new Date().toLocaleString('es-ES', {
          day: '2-digit', month: '2-digit', year: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
      }
    } catch (e) {
      console.error('[dolar index]', e);
    } finally {
      btnActualizar?.removeAttribute('disabled');
      if (icon) icon.style.animation = '';
    }
  }

  cargarDatos();
  btnActualizar?.addEventListener('click', cargarDatos);
  setInterval(cargarDatos, 1000 * 60 * 15);
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
</style>
