const fmtNum = (n: number | null) => {
  if (n === null || n === undefined) return '—';
  if (n >= 100) return n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return n.toLocaleString('es-AR', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
};

const tituloPage  = pais.tieneParalelo
  ? `Dólar hoy en ${pais.nombre} — Oficial, Blue y Paralelo | Inversax`
  : `Dólar hoy en ${pais.nombre} — Tipo de Cambio Oficial | Inversax`;

const canonicalUrl = `https://inversax.com/herramientas/dolar/${codigo}`;
---

<Layout>

<slot name="head" slot="head">

  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <title>{tituloPage}</title>
  <meta name="description"    content={pais.descripcionSeo} />
  <meta name="author"         content="José Zúniga" />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"      content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"       href={canonicalUrl} />

  <meta name="keywords"      content={`precio dolar hoy ${pais.nombre.toLowerCase()}, dolar ${pais.simbolo.toLowerCase()}, tipo de cambio ${pais.nombre.toLowerCase()}, ${pais.tieneParalelo ? `dolar blue ${pais.nombre.toLowerCase()}, dolar paralelo ${pais.nombre.toLowerCase()}, ` : ''}dolar oficial ${pais.nombre.toLowerCase()}, inversax ${pais.nombre.toLowerCase()}`} />
  <meta name="news_keywords" content={`dólar ${pais.nombre}, tipo de cambio, ${pais.simbolo}, Inversax`} />

  <meta name="geo.region"       content={codigo!.toUpperCase()} />
  <meta name="geo.placename"    content={pais.nombre} />
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />

  <link rel="alternate" hreflang="es"                             href={canonicalUrl} />
  <link rel="alternate" hreflang={`es-${codigo!.toUpperCase()}`}  href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default"                      href={canonicalUrl} />

  <meta property="og:site_name"   content="Inversax" />
  <meta property="og:locale"      content="es_LA" />
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={tituloPage} />
  <meta property="og:description" content={pais.descripcionSeo} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:image"       content={`https://inversax.com/og/herramientas/dolar-${codigo}.png`} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"   content={`Precio del Dólar en ${pais.nombre} — Inversax`} />
  <meta property="og:image:type"  content="image/png" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content={tituloPage} />
  <meta name="twitter:description" content={pais.descripcionSeo} />
  <meta name="twitter:image"       content={`https://inversax.com/og/herramientas/dolar-${codigo}.png`} />
  <meta name="twitter:image:alt"   content={`Precio del Dólar en ${pais.nombre} — Inversax`} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://inversax.com/noticias?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": tituloPage,
    "description": pais.descripcionSeo,
    "url": canonicalUrl,
    "inLanguage": "es",
    "isPartOf": { "@type": "WebSite", "name": "Inversax", "url": "https://inversax.com" },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": { "@type": "ImageObject", "url": "https://inversax.com/favicon.png", "width": 512, "height": 512 }
    },
    "about": { "@type": "Place", "name": pais.nombre, "addressCountry": codigo!.toUpperCase() }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",           "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Herramientas",     "item": "https://inversax.com/herramientas" },
      { "@type": "ListItem", "position": 3, "name": "Precio del Dólar", "item": "https://inversax.com/herramientas/dolar" },
      { "@type": "ListItem", "position": 4, "name": pais.nombre,        "item": canonicalUrl }
    ]
  })} />

  {pais.tieneParalelo && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `¿Cuál es el precio del dólar blue hoy en ${pais.nombre}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `El dólar paralelo en ${pais.nombre} se actualiza cada 15 minutos en Inversax. Representa el tipo de cambio informal fuera del sistema bancario oficial.`
          }
        },
        {
          "@type": "Question",
          "name": `¿Cuánto vale el dólar oficial hoy en ${pais.nombre}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `El dólar oficial en ${pais.nombre} es el tipo de cambio fijado por el banco central. Inversax lo actualiza cada 15 minutos automáticamente.`
          }
        },
        {
          "@type": "Question",
          "name": `¿Cada cuánto se actualiza el tipo de cambio en Inversax?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los precios se actualizan automáticamente cada 15 minutos. También podés forzar una actualización manual con el botón Actualizar."
          }
        }
      ]
    })} />
  )}

  <!-- JSON-LD: DefinedTermSet con el léxico local — ayuda a Google a entender terminología específica -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    "name": `Léxico cambiario en ${pais.nombre}`,
    "inLanguage": "es",
    "hasDefinedTerm": pais.contenidoSeo.lexico.map(item => ({
      "@type": "DefinedTerm",
      "name": item.termino,
      "description": item.definicion,
      "inDefinedTermSet": `https://inversax.com/herramientas/dolar/${codigo}`
    }))
  })} />

</slot>

  <main
    class="min-h-screen bg-[#0A0B0D] pt-28 pb-20 px-4 sm:px-6"
    style="font-family: 'DM Sans', sans-serif;"
    data-codigo={codigo}
  >
    <div class="max-w-2xl mx-auto">

      <!-- Back -->
      <a
        href="/herramientas/dolar"
        class="inline-flex items-center gap-2 text-white/30 hover:text-white text-sm mb-6 no-underline transition-colors"
      >
        <ArrowLeft size={15} /> Precio del Dólar
      </a>

      <!-- ── Header ── -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(212,168,67,0.15);">
            <img
              src={`https://flagcdn.com/w40/${pais.bandera}.png`}
              alt={pais.nombre}
              class="w-6 h-4 object-cover rounded-sm"
            />
          </div>
          <div>
            <h1
              class="font-extrabold text-2xl sm:text-3xl text-white leading-tight"
              style="font-family: 'Syne', sans-serif;"
            >
              Dólar en {pais.nombre}
            </h1>
            <p class="text-white/40 text-sm">{pais.moneda} · {pais.simbolo}</p>
          </div>
        </div>

        <div class="flex items-center justify-between flex-wrap gap-3">
          <div class="flex items-center gap-4 flex-wrap">
            <span class="flex items-center gap-1.5 text-xs text-white/30">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
              Actualizado cada 15 minutos
            </span>
            <span id="ultima-actualizacion" class="text-xs text-white/20"></span>
          </div>
          <button
            id="btn-actualizar"
            class="flex items-center gap-1.5 text-xs text-white/40 hover:text-white border border-white/[0.07] hover:border-white/20 px-3 py-1.5 rounded-lg transition-colors duration-200 cursor-pointer bg-transparent"
          >
            <RefreshCw size={12} />
            Actualizar
          </button>
        </div>
      </div>

      <!-- ── Tabla de variantes ── -->
      <div
        id="variantes-container"
        class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden mb-10"
        data-tiene-paralelo={pais.tieneParalelo ? 'true' : 'false'}
      >
        {errorCarga || variantes.length === 0 ? (
          <div class="divide-y divide-white/[0.05]">
            {[...Array(2)].map(() => (
              <div class="flex items-center justify-between px-3 sm:px-5 py-3 sm:py-4">
                <div class="flex items-center gap-2">
                  <div class="w-14 h-4 bg-white/5 rounded animate-pulse"></div>
                  <div class="w-24 h-3 bg-white/5 rounded animate-pulse"></div>
                </div>
                <div class="flex items-center gap-3 sm:gap-4">
                  <div class="w-12 sm:w-16 h-4 bg-white/5 rounded animate-pulse"></div>
                  <div class="w-12 sm:w-16 h-5 bg-white/5 rounded animate-pulse"></div>
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div>
            {(() => {
              // Detectar si la API realmente devolvió variantes paralelas
              const hayParalelo = variantes.some((v: any) => v.esParalelo);
              return variantes.map((v: any, i: number) => (
              <div class={`flex flex-col px-4 sm:px-6 py-4 sm:py-5 gap-3 ${i < variantes.length - 1 ? 'border-b border-white/[0.05]' : ''}`}>
                <div class="flex items-center gap-2">
                  {hayParalelo && (
                    <span class={`text-[10px] font-bold px-1.5 py-0.5 rounded ${
                      v.esParalelo
                        ? 'bg-[#D4A843]/10 text-[#D4A843]'
                        : 'bg-emerald-400/10 text-emerald-400'
                    }`}>
                      {v.esParalelo ? 'PARALELO' : 'OFICIAL'}
                    </span>
                  )}
                  <span class="text-white/40 text-xs">{v.nombre}</span>
                </div>
                <!-- Precio: etiquetas Compra/Venta solo si ambas existen -->
                <div class="flex items-end justify-center gap-6 py-2">
                  {v.compra !== null && (
                    <div class="text-center">
                      <div class="text-[10px] text-white/25 mb-1">Compra</div>
                      <div class="font-bold text-2xl sm:text-3xl text-white/50" style="font-family: 'Syne', sans-serif;">
                        {fmtNum(v.compra)}
                      </div>
                    </div>
                  )}
                  <div class="text-center">
                    {v.compra !== null && (
                      <div class="text-[10px] text-white/25 mb-1">Venta</div>
                    )}
                    <div class={`font-extrabold text-3xl sm:text-4xl ${v.esParalelo ? 'text-[#D4A843]' : 'text-white'}`} style="font-family: 'Syne', sans-serif;">
                      {fmtNum(v.venta)}
                    </div>
                  </div>
                </div>
              </div>
            ));
            })()}
          </div>
        )}
      </div>

      <!-- ═══════════════════════════════════════════════════════
           CONTENIDO SEO EDITORIAL
           Texto humanizado, extenso y con léxico local.
           Google lo indexa; los usuarios que quieran contexto
           lo leen; el resto simplemente lo omite.
      ═══════════════════════════════════════════════════════ -->

      <!-- Intro -->
      <section class="mb-8">
        <h2
          class="font-bold text-base sm:text-lg text-white mb-3"
          style="font-family: 'Syne', sans-serif;"
        >
          El dólar en {pais.nombre}: contexto y realidad
        </h2>
        <p class="text-white/50 text-sm leading-relaxed">
          {pais.contenidoSeo.intro}
        </p>
      </section>

      <!-- Léxico local -->
      <section class="mb-8">
        <h2
          class="font-bold text-base sm:text-lg text-white mb-4"
          style="font-family: 'Syne', sans-serif;"
        >
          Términos que se usan en {pais.nombre}
        </h2>
        <div class="flex flex-col gap-3">
          {pais.contenidoSeo.lexico.map((item) => (
            <div class="bg-[#111318] border border-white/[0.05] rounded-xl px-4 sm:px-5 py-3 sm:py-4">
              <p class="text-sm font-semibold text-white mb-1" style="font-family: 'Syne', sans-serif;">
                {item.termino}
              </p>
              <p class="text-white/45 text-xs leading-relaxed">{item.definicion}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Contexto económico -->
      <section class="mb-8">
        <h2
          class="font-bold text-base sm:text-lg text-white mb-3"
          style="font-family: 'Syne', sans-serif;"
        >
          Situación actual del tipo de cambio
        </h2>
        <p class="text-white/50 text-sm leading-relaxed">
          {pais.contenidoSeo.contexto}
        </p>
      </section>

      <!-- Consejo práctico -->
      <section class="mb-10">
        <div class="bg-[#111318] border border-[#D4A843]/15 rounded-2xl px-4 sm:px-5 py-4 sm:py-5">
          <p class="text-[#D4A843] text-xs font-bold uppercase tracking-widest mb-2">Consejo práctico</p>
          <p class="text-white/50 text-sm leading-relaxed">{pais.contenidoSeo.consejo}</p>
        </div>
      </section>

      <!-- Nota de fuentes -->
      <p class="text-white/15 text-xs text-center mb-8">
        Los precios paralelos son referenciales. Fuentes: bluelytics.com.ar, dolarapi.com y fawazahmed0/currency-api.
      </p>

      <!-- Link de vuelta -->
      <div class="pt-6 border-t border-white/[0.05]">
        <p class="text-white/25 text-xs mb-3">Ver otros países</p>
        <a
          href="/herramientas/dolar"
          class="inline-flex items-center gap-2 text-[#D4A843] text-sm font-medium hover:underline no-underline"
        >
          ← Todos los países en Latinoamérica
        </a>
      </div>

    </div>
  </main>

</Layout>

<script>
  const fmtNum = (n: number | null): string => {
    if (n === null || n === undefined) return '—';
    if (n >= 100) return n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return n.toLocaleString('es-AR', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  };

  const main       = document.querySelector('main[data-codigo]') as HTMLElement;
  const CODIGO     = main?.dataset.codigo ?? '';
  const container  = document.getElementById('variantes-container') as HTMLElement;
  const TIENE_PARALELO = container?.dataset.tieneParalelo === 'true';
  const ultimaAct  = document.getElementById('ultima-actualizacion');
  const btnAct     = document.getElementById('btn-actualizar');
  const icon       = btnAct?.querySelector('svg') as HTMLElement | null;

  function renderVariantes(variantes: any[]) {
    if (!variantes.length) return;
    const hayParalelo = variantes.some((v: any) => v.esParalelo);
    container.innerHTML = `
      <div>
        ${variantes.map((v: any, i: number) => `
          <div class="flex flex-col px-4 sm:px-6 py-4 sm:py-5 gap-3 ${i < variantes.length - 1 ? 'border-b border-white/[0.05]' : ''}">
            <div class="flex items-center gap-2">
              ${hayParalelo ? `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded ${v.esParalelo ? 'bg-[#D4A843]/10 text-[#D4A843]' : 'bg-emerald-400/10 text-emerald-400'}">${v.esParalelo ? 'PARALELO' : 'OFICIAL'}</span>` : ''}
              <span class="text-white/40 text-xs">${v.nombre}</span>
            </div>
            <div class="flex items-end justify-center gap-6 py-2">
              ${v.compra !== null ? `
                <div class="text-center">
                  <div class="text-[10px] text-white/25 mb-1">Compra</div>
                  <div class="font-bold text-2xl sm:text-3xl text-white/50" style="font-family: 'Syne', sans-serif;">${fmtNum(v.compra)}</div>
                </div>
              ` : ''}
              <div class="text-center">
                ${v.compra !== null ? `<div class="text-[10px] text-white/25 mb-1">Venta</div>` : ''}
                <div class="font-extrabold text-3xl sm:text-4xl ${v.esParalelo ? 'text-[#D4A843]' : 'text-white'}" style="font-family: 'Syne', sans-serif;">${fmtNum(v.venta)}</div>
              </div>
            </div>
          </div>
        `).join('')}
      </div>`;
  }

  async function cargarDatos() {
    btnAct?.setAttribute('disabled', 'true');
    if (icon) icon.style.animation = 'spin 1s linear infinite';
    try {
      const res      = await fetch('/api/dolar');
      const json     = await res.json() as any;
      if (!json.ok || !json.data?.length) return;
      const paisData = json.data.find((p: any) => p.bandera === CODIGO || p.codigo === CODIGO);
      if (paisData?.variantes?.length) {
        renderVariantes(paisData.variantes);
        if (ultimaAct) {
          ultimaAct.textContent = new Date().toLocaleString('es-ES', {
            day: '2-digit', month: '2-digit', year: 'numeric',
            hour: '2-digit', minute: '2-digit',
          });
        }
      }
    } catch (e) {
      console.error('[dolar/[codigo]]', e);
    } finally {
      btnAct?.removeAttribute('disabled');
      if (icon) icon.style.animation = '';
    }
  }

  // Si SSR no trajo datos, cargar en cliente
  const hayDatosSSR = container.querySelector('.divide-y') !== null &&
                      !container.querySelector('.animate-pulse');
  if (!hayDatosSSR) cargarDatos();

  btnAct?.addEventListener('click', cargarDatos);
  setInterval(cargarDatos, 1000 * 60 * 15);
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
</style>


