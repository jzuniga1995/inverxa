<script>
(function () {
  const BROKERS = JSON.parse(document.getElementById('cmp-data')!.textContent!) as any[];

  const selector = document.getElementById('cmp-selector')!;
  const tableEl  = document.getElementById('cmp-table')!;
  const counter  = document.getElementById('cmp-counter')!;
  const hint     = document.getElementById('cmp-hint')!;

  let selected: string[] = [];

  const isMobile = () => window.innerWidth < 640;

  const IC: Record<string, string> = {
    BarChart2:    `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>`,
    Wallet:       `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>`,
    TrendingDown: `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/></svg>`,
    CreditCard:   `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>`,
    ShieldCheck:  `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`,
    Monitor:      `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>`,
    Zap:          `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>`,
    Clock:        `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    Star:         `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>`,
    Users:        `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    Arrow:        `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`,
  };

  const ROWS = [
    { key: 'tipo',           label: 'Tipo de broker',   icon: 'BarChart2'    },
    { key: 'deposito',       label: 'Depósito mínimo',  icon: 'Wallet'       },
    { key: 'spread',         label: 'Spread',           icon: 'TrendingDown' },
    { key: 'cuentas',        label: 'Tipos de cuenta',  icon: 'CreditCard'   },
    { key: 'regulacion',     label: 'Regulación',       icon: 'ShieldCheck'  },
    { key: 'plataformas',    label: 'Plataformas',      icon: 'Monitor'      },
    { key: 'instrumentos',   label: 'Instrumentos',     icon: 'BarChart2'    },
    { key: 'apalancamiento', label: 'Apalancamiento',   icon: 'Zap'          },
    { key: 'inactividad',    label: 'Com. inactividad', icon: 'Clock'        },
    { key: 'rating',         label: 'Rating Inversax',  icon: 'Star'         },
    { key: 'ideal',          label: 'Ideal para',       icon: 'Users'        },
  ];

  function stars(r: number) {
    let s = '';
    for (let i = 1; i <= 5; i++) {
      s += `<span style="color:${i <= Math.round(r) ? '#D4A843' : 'rgba(255,255,255,0.1)'};font-size:.75rem;">★</span>`;
    }
    return `<span style="display:flex;align-items:center;gap:2px;">${s}<span style="font-size:.72rem;color:rgba(255,255,255,.3);margin-left:4px;">${r}</span></span>`;
  }

  function cellVal(b: any, key: string) {
    const v = b[key];
    if (key === 'rating') return stars(v);
    if (Array.isArray(v)) return v.map(x => `<span class="cmp-tag">${x}</span>`).join('');
    return `<span>${v}</span>`;
  }

  function toggle(id: string) {
    const idx = selected.indexOf(id);
    if (idx > -1) selected.splice(idx, 1);
    else {
      if (selected.length >= 3) return;
      selected.push(id);
    }
    render();
  }

  function renderMobile(sel: any[]) {
    let html = `<div style="display:flex;flex-direction:column;gap:.5rem;opacity:0;transform:translateY(8px);transition:opacity .3s,transform .3s;" id="cmp-tbl">`;

    html += `<div style="display:grid;grid-template-columns:${sel.map(() => '1fr').join(' ')};gap:.5rem;margin-bottom:.25rem;">`;
    sel.forEach(b => {
      html += `
      <div style="background:color-mix(in srgb,${b.color} 8%,#111318);border:1px solid color-mix(in srgb,${b.color} 30%,transparent);
           border-radius:.85rem;padding:.75rem;display:flex;flex-direction:column;align-items:center;gap:.4rem;text-align:center;">
        <div style="width:36px;height:36px;border-radius:.5rem;overflow:hidden;background:#fff;border:1px solid rgba(255,255,255,.1);
             display:flex;align-items:center;justify-content:center;">
          <img src="${b.logo ?? `https://icon.horse/icon/${b.domain}`}" alt="${b.nombre}"
               style="width:100%;height:100%;object-fit:contain;padding:3px;"
               onerror="this.style.display='none'" loading="lazy"/>
        </div>
        <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:.82rem;color:#fff;">${b.nombre}</span>
        <span style="font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;
               padding:.1rem .35rem;border-radius:999px;background:${b.color}22;color:${b.color};border:1px solid ${b.color}44;
               white-space:nowrap;">${b.badge}</span>
      </div>`;
    });
    html += `</div>`;

    ROWS.forEach((row, ri) => {
      const stripe = ri % 2 !== 0 ? 'rgba(255,255,255,.016)' : 'transparent';
      html += `
      <div style="border:1px solid rgba(255,255,255,.055);border-radius:.75rem;overflow:hidden;">
        <div style="padding:.45rem .75rem;background:rgba(255,255,255,.025);display:flex;align-items:center;gap:.4rem;
             border-bottom:1px solid rgba(255,255,255,.04);">
          <span style="color:rgba(255,255,255,.25);">${IC[row.icon]}</span>
          <span style="font-size:.62rem;font-weight:600;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:.06em;">${row.label}</span>
        </div>
        <div style="display:grid;grid-template-columns:${sel.map(() => '1fr').join(' ')};background:${stripe};">`;
      sel.forEach((b, bi) => {
        const borderR = bi < sel.length - 1 ? 'border-right:1px solid rgba(255,255,255,.04);' : '';
        html += `
          <div style="padding:.55rem .65rem;font-size:.75rem;color:rgba(255,255,255,.72);
               display:flex;align-items:center;flex-wrap:wrap;gap:.25rem;${borderR}">
            ${cellVal(b, row.key)}
          </div>`;
      });
      html += `</div></div>`;
    });

    html += `<div style="display:grid;grid-template-columns:${sel.map(() => '1fr').join(' ')};gap:.5rem;margin-top:.25rem;">`;
    sel.forEach(b => {
      html += `
      <a href="${b.href}" target="_blank" rel="noopener noreferrer nofollow"
         class="cmp-cta-btn"
         style="display:flex;align-items:center;justify-content:center;gap:.35rem;
                padding:.6rem .5rem;border-radius:.7rem;font-size:.72rem;font-weight:700;
                color:#fff;text-decoration:none;background:${b.color};
                box-shadow:0 4px 14px ${b.color}44;white-space:nowrap;">
        ${b.cta} ${IC.Arrow}
      </a>`;
    });
    html += `</div></div>`;

    return html;
  }

  function renderDesktop(sel: any[]) {
    const cols = sel.length;
    const cell = (extra = '') =>
      `display:flex;align-items:flex-start;flex-wrap:wrap;gap:.3rem;
       border-bottom:1px solid rgba(255,255,255,.04);
       border-right:1px solid rgba(255,255,255,.04);padding:.75rem 1rem;${extra}`;

    let html = `
    <div id="cmp-tbl" style="display:grid;grid-template-columns:160px repeat(${cols},1fr);
      border:1px solid rgba(255,255,255,.065);border-radius:1rem;overflow:hidden;
      min-width:${320 + cols * 240}px;opacity:0;transform:translateY(8px);
      transition:opacity .3s ease,transform .3s ease;">`;

    html += `<div style="${cell('background:rgba(255,255,255,.014);border-right:1px solid rgba(255,255,255,.045);align-items:center;')}"></div>`;
    sel.forEach(b => {
      html += `
      <div style="padding:1.1rem 1rem;background:color-mix(in srgb,${b.color} 6%,#0A0B0D);
           border-bottom:2px solid color-mix(in srgb,${b.color} 40%,transparent);
           border-right:1px solid rgba(255,255,255,.04);">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.55rem;">
          <div style="width:40px;height:40px;border-radius:.5rem;overflow:hidden;background:#fff;
               border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <img src="${b.logo ?? `https://icon.horse/icon/${b.domain}`}" alt="${b.nombre}"
                 style="width:100%;height:100%;object-fit:contain;padding:4px;"
                 onerror="this.style.display='none'" loading="lazy"/>
          </div>
          <div>
            <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;color:#fff;">${b.nombre}</div>
            <span style="display:inline-block;font-size:.58rem;font-weight:700;text-transform:uppercase;
                   letter-spacing:.06em;padding:.1rem .4rem;border-radius:999px;
                   background:${b.color}22;color:${b.color};border:1px solid ${b.color}44;
                   white-space:nowrap;margin-top:2px;">${b.badge}</span>
          </div>
        </div>
        <p style="font-size:.72rem;color:rgba(255,255,255,.38);line-height:1.55;margin:0;">${b.descripcion}</p>
      </div>`;
    });

    ROWS.forEach((row, ri) => {
      const stripe = ri % 2 !== 0 ? 'background:rgba(255,255,255,.016);' : '';
      html += `
      <div style="${cell('background:rgba(255,255,255,.014);border-right:1px solid rgba(255,255,255,.045);')}">
        <span style="color:rgba(255,255,255,.2);flex-shrink:0;margin-top:1px;">${IC[row.icon]}</span>
        <span style="font-size:.67rem;font-weight:600;color:rgba(255,255,255,.25);text-transform:uppercase;
               letter-spacing:.06em;line-height:1.4;">${row.label}</span>
      </div>`;
      sel.forEach(b => {
        html += `<div style="${cell(stripe)}font-size:.8rem;color:rgba(255,255,255,.72);align-items:center;">${cellVal(b, row.key)}</div>`;
      });
    });

    html += `<div style="padding:.9rem 1rem;background:rgba(0,0,0,.2);border-right:1px solid rgba(255,255,255,.045);"></div>`;
    sel.forEach(b => {
      html += `
      <div style="padding:.9rem 1rem;background:rgba(0,0,0,.2);border-right:1px solid rgba(255,255,255,.04);
           display:flex;align-items:center;justify-content:center;">
        <a href="${b.href}" target="_blank" rel="noopener noreferrer nofollow" class="cmp-cta-btn"
           style="display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1.1rem;border-radius:.6rem;
                  font-size:.78rem;font-weight:700;color:#fff;text-decoration:none;
                  background:${b.color};box-shadow:0 4px 18px ${b.color}44;white-space:nowrap;">
          ${b.cta} ${IC.Arrow}
        </a>
      </div>`;
    });

    html += `</div>`;
    return html;
  }

  function render() {
    const cards = document.getElementById('cmp-cards');
    if (cards) cards.style.display = selected.length >= 2 ? 'none' : 'grid';

    selector.querySelectorAll<HTMLButtonElement>('.cmp-pill').forEach(pill => {
      const id     = pill.dataset.id!;
      const active = selected.includes(id);
      const full   = selected.length >= 3 && !active;
      pill.setAttribute('aria-pressed', active ? 'true' : 'false');
      pill.style.borderColor   = active ? `color-mix(in srgb, var(--c) 65%, transparent)` : 'rgba(255,255,255,0.07)';
      pill.style.background    = active ? `color-mix(in srgb, var(--c) 12%, #111318)` : '#111318';
      pill.style.opacity       = full ? '0.3' : '1';
      pill.style.pointerEvents = full ? 'none' : 'auto';
      const check = pill.querySelector<HTMLElement>('.cmp-check');
      if (check) check.style.opacity = active ? '1' : '0';
    });

    counter.textContent = String(selected.length);

    if (selected.length < 2) {
      tableEl.innerHTML = '';
      tableEl.style.overflowX = 'visible';
      hint.style.opacity = '1';
      return;
    }

    hint.style.opacity = '0.4';
    const sel = selected.map(id => BROKERS.find(b => b.id === id)!);

    if (isMobile()) {
      tableEl.style.overflowX = 'visible';
      tableEl.innerHTML = renderMobile(sel);
    } else {
      tableEl.style.overflowX = 'auto';
      tableEl.innerHTML = renderDesktop(sel);
    }

    requestAnimationFrame(() => {
      const t = document.getElementById('cmp-tbl');
      if (t) { t.style.opacity = '1'; t.style.transform = 'translateY(0)'; }
    });
  }

  selector.addEventListener('click', e => {
    const pill = (e.target as Element).closest<HTMLButtonElement>('.cmp-pill');
    if (pill) toggle(pill.dataset.id!);
  });

  tableEl.addEventListener('mouseover', e => {
    const btn = (e.target as Element).closest<HTMLElement>('.cmp-cta-btn');
    if (btn) { btn.style.opacity = '.82'; btn.style.transform = 'translateY(-2px)'; }
  });
  tableEl.addEventListener('mouseout', e => {
    const btn = (e.target as Element).closest<HTMLElement>('.cmp-cta-btn');
    if (btn) { btn.style.opacity = '1'; btn.style.transform = 'translateY(0)'; }
  });

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { if (selected.length >= 2) render(); }, 200);
  });

  render();
})();
</script>

<style>
  @keyframes cmpPulse {
    0%, 100% { opacity: 1;  transform: scale(1); }
    50%       { opacity: .4; transform: scale(.75); }
  }
  .cmp-pulse { animation: cmpPulse 2s infinite; }

  .cmp-tag {
    display: inline-block;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 999px;
    padding: .06rem .4rem;
    font-size: .65rem;
    color: rgba(255,255,255,.5);
    white-space: nowrap;
  }

  .cmp-cta-btn { transition: opacity .2s, transform .15s; }

  @media (hover: none) {
    .cmp-cta-btn:hover { opacity: 1 !important; transform: none !important; }
  }
</style>

