               onerror="this.style.display='none'" loading="lazy"/>
        </div>
        <span style="font-family:'DM Sans',sans-serif;font-weight:800;font-size:.82rem;color:#1C1917;">${b.nombre}</span>
        <span style="font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;
               padding:.1rem .35rem;border-radius:999px;background:${b.color}22;color:${b.color};border:1px solid ${b.color}44;
               white-space:nowrap;">${b.badge}</span>
      </div>`;
    });
    html += `</div>`;
    ROWS.forEach((row, ri) => {
      const stripe = ri % 2 !== 0 ? '#F9F7F4' : 'transparent';
      html += `
      <div style="border:1px solid #E5E0D8;border-radius:.75rem;overflow:hidden;">
        <div style="padding:.45rem .75rem;background:#F5F1EC;display:flex;align-items:center;gap:.4rem;
             border-bottom:1px solid #E5E0D8;">
          <span style="color:#A8A29E;">${IC[row.icon]}</span>
          <span style="font-size:.62rem;font-weight:600;color:#78716C;text-transform:uppercase;letter-spacing:.06em;">${row.label}</span>
        </div>
        <div style="display:grid;grid-template-columns:${sel.map(() => '1fr').join(' ')};background:${stripe};">`;
      sel.forEach((b, bi) => {
        const borderR = bi < sel.length - 1 ? 'border-right:1px solid #F0EDE7;' : '';
        html += `
          <div style="padding:.55rem .65rem;font-size:.75rem;color:#1C1917;
               display:flex;align-items:center;flex-wrap:wrap;gap:.25rem;${borderR}">
            ${cellVal(b, row.key)}
          </div>`;
      });
      html += `</div></div>`;
    });
    html += `<div style="display:grid;grid-template-columns:${sel.map(() => '1fr').join(' ')};gap:.5rem;margin-top:.25rem;">`;
    sel.forEach(b => {
      html += `
      <a href="${b.href}" target="_blank" rel="noopener noreferrer nofollow"
         class="cmp-cta-btn"
         style="display:flex;align-items:center;justify-content:center;gap:.35rem;
                padding:.6rem .5rem;border-radius:.7rem;font-size:.72rem;font-weight:700;
                color:#fff;text-decoration:none;background:${b.color};
                box-shadow:0 4px 14px ${b.color}44;white-space:nowrap;">
        ${b.cta} ${IC.Arrow}
      </a>`;
    });
    html += `</div></div>`;
    return html;
  }

  function renderDesktop(sel) {
    const cols = sel.length;
    const cell = (extra = '') =>
      `display:flex;align-items:flex-start;flex-wrap:wrap;gap:.3rem;
       border-bottom:1px solid #F0EDE7;
       border-right:1px solid #F0EDE7;padding:.75rem 1rem;${extra}`;

    let html = `
    <div id="cmp-tbl" style="display:grid;grid-template-columns:160px repeat(${cols},1fr);
      border:1px solid #E5E0D8;border-radius:1rem;overflow:hidden;
      min-width:${320 + cols * 240}px;opacity:0;transform:translateY(8px);
      transition:opacity .3s ease,transform .3s ease;">`;

    html += `<div style="${cell('background:#F5F1EC;border-right:1px solid #E5E0D8;align-items:center;')}"></div>`;
    sel.forEach(b => {
      html += `
      <div style="padding:1.1rem 1rem;background:color-mix(in srgb,${b.color} 6%,#FAFAF8);
           border-bottom:2px solid color-mix(in srgb,${b.color} 40%,transparent);
           border-right:1px solid #F0EDE7;">
        <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.55rem;">
          <div style="width:40px;height:40px;border-radius:.5rem;overflow:hidden;background:#fff;
               border:1px solid #E5E0D8;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <img src="${b.logo ?? `https://icon.horse/icon/${b.domain}`}" alt="${b.nombre}"
                 style="width:100%;height:100%;object-fit:contain;padding:4px;"
                 onerror="this.style.display='none'" loading="lazy"/>
          </div>
          <div>
            <div style="font-family:'DM Sans',sans-serif;font-weight:800;font-size:.95rem;color:#1C1917;">${b.nombre}</div>
            <span style="display:inline-block;font-size:.58rem;font-weight:700;text-transform:uppercase;
                   letter-spacing:.06em;padding:.1rem .4rem;border-radius:999px;
                   background:${b.color}22;color:${b.color};border:1px solid ${b.color}44;
                   white-space:nowrap;margin-top:2px;">${b.badge}</span>
          </div>
        </div>
        <p style="font-size:.72rem;color:#78716C;line-height:1.55;margin:0;">${b.descripcion}</p>
      </div>`;
    });

    ROWS.forEach((row, ri) => {
      const stripe = ri % 2 !== 0 ? 'background:#F9F7F4;' : '';
      html += `
      <div style="${cell('background:#F5F1EC;border-right:1px solid #E5E0D8;')}">
        <span style="color:#A8A29E;flex-shrink:0;margin-top:1px;">${IC[row.icon]}</span>
        <span style="font-size:.67rem;font-weight:600;color:#78716C;text-transform:uppercase;
               letter-spacing:.06em;line-height:1.4;">${row.label}</span>
      </div>`;
      sel.forEach(b => {
        html += `<div style="${cell(stripe)}font-size:.8rem;color:#1C1917;align-items:center;">${cellVal(b, row.key)}</div>`;
      });
    });

    html += `<div style="padding:.9rem 1rem;background:#F5F1EC;border-right:1px solid #E5E0D8;"></div>`;
    sel.forEach(b => {
      html += `
      <div style="padding:.9rem 1rem;background:#F5F1EC;border-right:1px solid #F0EDE7;
           display:flex;align-items:center;justify-content:center;">
        <a href="${b.href}" target="_blank" rel="noopener noreferrer nofollow" class="cmp-cta-btn"
           style="display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1.1rem;border-radius:.6rem;
                  font-size:.78rem;font-weight:700;color:#fff;text-decoration:none;
                  background:${b.color};box-shadow:0 4px 18px ${b.color}44;white-space:nowrap;">
          ${b.cta} ${IC.Arrow}
        </a>
      </div>`;
    });
    html += `</div>`;
    return html;
  }

  function render() {
    const cards = document.getElementById('cmp-cards');
    if (cards) cards.style.display = selected.length >= 2 ? 'none' : 'grid';

    selector.querySelectorAll('.cmp-pill').forEach(pill => {
      const id     = pill.dataset.id;
      const active = selected.includes(id);
      const full   = selected.length >= 3 && !active;
      pill.setAttribute('aria-pressed', active ? 'true' : 'false');
      pill.style.borderColor   = active ? `color-mix(in srgb, var(--c) 65%, transparent)` : '#D6D0C8';
      pill.style.background    = active ? `color-mix(in srgb, var(--c) 12%, #FAFAF8)` : '#F5F1EC';
      pill.style.opacity       = full ? '0.3' : '1';
      pill.style.pointerEvents = full ? 'none' : 'auto';
      const check = pill.querySelector('.cmp-check');
      if (check) check.style.opacity = active ? '1' : '0';
    });

    counter.textContent = String(selected.length);

    if (selected.length < 2) {
      tableEl.innerHTML = '';
      tableEl.style.overflowX = 'visible';
      hint.style.opacity = '1';
      return;
    }

    hint.style.opacity = '0.4';
    const sel = selected.map(id => BROKERS.find(b => b.id === id));

    if (isMobile()) {
      tableEl.style.overflowX = 'visible';
      tableEl.innerHTML = renderMobile(sel);
    } else {
      tableEl.style.overflowX = 'auto';
      tableEl.innerHTML = renderDesktop(sel);
    }

    requestAnimationFrame(() => {
      const t = document.getElementById('cmp-tbl');
      if (t) { t.style.opacity = '1'; t.style.transform = 'translateY(0)'; }
    });
  }

  selector.addEventListener('click', e => {
    const pill = e.target.closest('.cmp-pill');
    if (pill) toggle(pill.dataset.id);
  });

  tableEl.addEventListener('mouseover', e => {
    const btn = e.target.closest('.cmp-cta-btn');
    if (btn) { btn.style.opacity = '.82'; btn.style.transform = 'translateY(-2px)'; }
  });
  tableEl.addEventListener('mouseout', e => {
    const btn = e.target.closest('.cmp-cta-btn');
    if (btn) { btn.style.opacity = '1'; btn.style.transform = 'translateY(0)'; }
  });

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => { if (selected.length >= 2) render(); }, 200);
  });

  render();
})();
</script>

<style>
  @keyframes cmpPulse {
    0%, 100% { opacity: 1;  transform: scale(1); }
    50%       { opacity: .4; transform: scale(.75); }
  }
  .cmp-pulse { animation: cmpPulse 2s infinite; }

  .cmp-tag {
    display: inline-block;
    background: #F0EDE7;
    border: 1px solid #E5E0D8;
    border-radius: 999px;
    padding: .06rem .4rem;
    font-size: .65rem;
    color: #78716C;
    white-space: nowrap;
  }

  .cmp-cta-btn { transition: opacity .2s, transform .15s; }

  @media (hover: none) {
    .cmp-cta-btn:hover { opacity: 1 !important; transform: none !important; }
  }

  /* ── SEO EDITORIAL ── */
  .cmp-seo-card {
    background: #F5F1EC;
    border: 1px solid #E5E0D8;
    border-radius: 1rem;
    padding: 1.5rem 1.75rem;
  }
  @media (max-width: 580px) {
    .cmp-seo-card { padding: 1.1rem; }
  }

  .cmp-seo-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1C1917;
    margin-bottom: .75rem;
  }

  .cmp-seo-card p {
    font-size: .875rem;
    color: #57534E;
    line-height: 1.75;
    margin-bottom: .65rem;
  }
  .cmp-seo-card p:last-child { margin-bottom: 0; }
  .cmp-seo-card strong { color: #1C1917; }

  /* tabla SEO */
  .cmp-seo-table {
    margin: .85rem 0;
    border: 1px solid #E5E0D8;
    border-radius: .65rem;
    overflow: hidden;
  }
  .cmp-seo-row {
    display: grid;
    grid-template-columns: 1fr 1.4fr 2fr;
    padding: .5rem .85rem;
    font-size: .78rem;
    color: #57534E;
    border-bottom: 1px solid #F0EDE7;
    gap: .5rem;
    align-items: center;
  }
  .cmp-seo-row:last-child { border-bottom: none; }
  .cmp-seo-header {
    background: #EDE8E1;
    color: #78716C;
    font-size: .67rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  @media (max-width: 520px) {
    .cmp-seo-row { grid-template-columns: 1fr 1fr; font-size: .73rem; }
    .cmp-seo-row span:last-child { display: none; }
  }
</style>

