  <link rel="alternate" hreflang="es-AR" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-CO" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-CL" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-PE" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-VE" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-EC" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-BO" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-PY" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-UY" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-CR" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-PA" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-DO" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-SV" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-HN" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-NI" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-GT" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-CU" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-PR" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-BZ" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <!-- Europa -->
  <link rel="alternate" hreflang="es-ES" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-AD" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-DE" href={`https://inversax.com/herramientas/cripto/${id}`} />
  <link rel="alternate" hreflang="es-FR" href={`https://inversax.com/herramientas/cripto/${id}`} />
