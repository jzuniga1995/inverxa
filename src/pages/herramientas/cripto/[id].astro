---
// src/pages/herramientas/cripto/[id].astro
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { ArrowLeft, TrendingUp, TrendingDown, ExternalLink } from 'lucide-astro';

const { id } = Astro.params;

type CoinDetail = {
  id: string;
  symbol: string;
  name: string;
  image: { large: string };
  market_cap_rank: number;
  market_data: {
    current_price: { usd: number };
    price_change_percentage_24h: number;
    price_change_percentage_7d: number;
    price_change_percentage_30d: number;
    market_cap: { usd: number };
    total_volume: { usd: number };
    circulating_supply: number;
    total_supply: number;
    ath: { usd: number };
    atl: { usd: number };
  };
  description: { es: string; en: string };
  links: {
    homepage: string[];
    blockchain_site: string[];
    repos_url: { github: string[] };
  };
};

// ── Helpers de formato ────────────────────────────────────────
const fmt = (p: number) => {
  if (!p) return '—';
  if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
  if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  if (p >= 0.01) return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 6, maximumFractionDigits: 6 })}`;
};
const fmtLarge = (n: number) => {
  if (!n) return '—';
  if (n >= 1e12) return `$${(n/1e12).toFixed(2)}T`;
  if (n >= 1e9)  return `$${(n/1e9).toFixed(2)}B`;
  if (n >= 1e6)  return `$${(n/1e6).toFixed(1)}M`;
  return `$${n.toLocaleString('en-US')}`;
};
const fmtChg    = (c: number) => c != null ? `${c >= 0 ? '+' : ''}${c.toFixed(2)}%` : '—';
const fmtSupply = (n: number) => n ? n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : '—';

// ── Fetch con caché KV (10 minutos) ──────────────────────────
// globalThis._coinCache NO funciona en Cloudflare Workers:
// cada request puede ir a una instancia diferente del worker.
// KV es el caché correcto en este entorno.
const env      = (Astro.locals.runtime?.env as any);
const KV       = env?.INVERSA_KV as KVNamespace | undefined;
const KEY      = env?.COINGECKO_API_KEY as string | undefined;
const cacheKey = `coin:${id}`;

let coin: CoinDetail | null = null;
let fetchError = false;

try {
  // 1. Intentar leer desde KV
  const cached = await KV?.get(cacheKey, 'json') as CoinDetail | null;

  if (cached) {
    // Caché válida — no toca CoinGecko
    coin = cached;
  } else {
    // Caché vacía o expirada — llama a CoinGecko
    const res = await fetch(
      `https://api.coingecko.com/api/v3/coins/${id}?localization=true&tickers=false&market_data=true&community_data=false&developer_data=false`,
      { headers: { 'Accept': 'application/json', ...(KEY ? { 'x-cg-demo-api-key': KEY } : {}) } }
    );
    if (!res.ok) throw new Error(`CoinGecko ${res.status}`);
    coin = await res.json() as CoinDetail;

    // Guarda en KV con TTL de 10 minutos
    await KV?.put(cacheKey, JSON.stringify(coin), { expirationTtl: 600 });
  }
} catch (e) {
  fetchError = true;
  console.error('[CoinDetail]', e);
}

if (!coin && !fetchError) {
  return Astro.redirect('/herramientas/cripto');
}

const price     = coin?.market_data?.current_price?.usd ?? 0;
const chg24     = coin?.market_data?.price_change_percentage_24h ?? 0;
const isUp      = chg24 >= 0;
const symbol    = coin?.symbol?.toUpperCase() ?? '';
const tvSymbol  = `BINANCE:${symbol}USDT`;
const desc      = coin?.description?.es || coin?.description?.en || '';
const descClean = desc.replace(/<[^>]*>/g, '').slice(0, 400);
---

<Layout>
  <slot name="head" slot="head">
    <title>{coin?.name ?? id} — Precio en Vivo · Inversax</title>
    <meta name="description" content={`Precio de ${coin?.name} en tiempo real, gráfica, capitalización y datos del mercado.`} />
  </slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family:'DM Sans',sans-serif;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">

      <!-- Back -->
      <a href="/herramientas/cripto" class="inline-flex items-center gap-2 text-white/30 hover:text-white text-sm mb-6 no-underline transition-colors">
        <ArrowLeft size={15} /> Volver a Criptomonedas
      </a>

      {fetchError || !coin ? (
        <div class="flex items-center justify-center py-24 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <p class="text-white/30 text-sm">
            No se pudo cargar la información.{' '}
            <a href="/herramientas/cripto" class="text-[#D4A843]">Volver</a>
          </p>
        </div>
      ) : (
        <div class="flex flex-col gap-6">

          <!-- Header: logo + precio + cambio -->
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 bg-[#111318] border border-white/[0.07] rounded-2xl p-5 sm:p-6">
            <div class="flex items-center gap-4">
              <img src={coin.image.large} alt={coin.name} class="w-12 h-12 rounded-full" />
              <div>
                <div class="flex items-center gap-2 flex-wrap">
                  <h1 class="text-white font-extrabold text-xl sm:text-2xl" style="font-family:'Syne',sans-serif;">{coin.name}</h1>
                  <span class="text-white/30 text-sm font-medium bg-white/5 px-2 py-0.5 rounded">{symbol}</span>
                  {coin.market_cap_rank && (
                    <span class="text-[#D4A843] text-xs font-bold bg-[#D4A843]/10 px-2 py-0.5 rounded border border-[#D4A843]/20">
                      #{coin.market_cap_rank}
                    </span>
                  )}
                </div>
                <div class="flex items-center gap-3 mt-1 flex-wrap">
                  <span class="text-white font-bold text-2xl sm:text-3xl" style="font-family:'Syne',sans-serif;">{fmt(price)}</span>
                  <span class={`flex items-center gap-1 text-sm font-bold ${isUp ? 'text-emerald-400' : 'text-red-400'}`}>
                    {isUp ? <TrendingUp size={14}/> : <TrendingDown size={14}/>}
                    {fmtChg(chg24)} hoy
                  </span>
                </div>
              </div>
            </div>

            <!-- Links externos -->
            <div class="flex gap-2 flex-wrap">
              {coin.links?.homepage?.[0] && (
                <a href={coin.links.homepage[0]} target="_blank" rel="noopener noreferrer nofollow"
                   class="flex items-center gap-1.5 text-xs text-white/40 hover:text-white bg-white/5 border border-white/[0.07] hover:border-white/20 px-3 py-1.5 rounded-lg no-underline transition-all">
                  <ExternalLink size={11}/> Web oficial
                </a>
              )}
              {coin.links?.repos_url?.github?.[0] && (
                <a href={coin.links.repos_url.github[0]} target="_blank" rel="noopener noreferrer nofollow"
                   class="flex items-center gap-1.5 text-xs text-white/40 hover:text-white bg-white/5 border border-white/[0.07] hover:border-white/20 px-3 py-1.5 rounded-lg no-underline transition-all">
                  <ExternalLink size={11}/> GitHub
                </a>
              )}
            </div>
          </div>

          <!-- Cambios por período -->
          <div class="grid grid-cols-3 gap-3">
            {[
              { label: '24 horas', val: coin.market_data.price_change_percentage_24h  },
              { label: '7 días',   val: coin.market_data.price_change_percentage_7d   },
              { label: '30 días',  val: coin.market_data.price_change_percentage_30d  },
            ].map(({ label, val }) => (
              <div class="bg-[#111318] border border-white/[0.07] rounded-xl p-4 text-center">
                <div class="text-white/30 text-xs mb-1">{label}</div>
                <div class={`font-bold text-lg ${val >= 0 ? 'text-emerald-400' : 'text-red-400'}`} style="font-family:'Syne',sans-serif;">
                  {fmtChg(val)}
                </div>
              </div>
            ))}
          </div>

          <!-- Gráfico TradingView -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden">
            <div class="px-5 py-4 border-b border-white/[0.07] flex items-center justify-between">
              <h2 class="text-white font-bold text-base" style="font-family:'Syne',sans-serif;">Gráfica de precio</h2>
              <span class="text-white/25 text-xs">TradingView</span>
            </div>
            <div id="tv-chart" style="height: 460px;"></div>
          </div>

          <!-- Stats de mercado -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              { label: 'Cap. de Mercado',  val: fmtLarge(coin.market_data.market_cap.usd)    },
              { label: 'Volumen 24h',      val: fmtLarge(coin.market_data.total_volume.usd)  },
              { label: 'Máximo histórico', val: fmt(coin.market_data.ath.usd)                },
              { label: 'Mínimo histórico', val: fmt(coin.market_data.atl.usd)                },
            ].map(({ label, val }) => (
              <div class="bg-[#111318] border border-white/[0.07] rounded-xl p-4">
                <div class="text-white/30 text-xs mb-1.5">{label}</div>
                <div class="text-white font-bold text-base" style="font-family:'Syne',sans-serif;">{val}</div>
              </div>
            ))}
          </div>

          <!-- Suministro -->
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-[#111318] border border-white/[0.07] rounded-xl p-4">
              <div class="text-white/30 text-xs mb-1.5">Suministro circulante</div>
              <div class="text-white font-bold text-base" style="font-family:'Syne',sans-serif;">
                {fmtSupply(coin.market_data.circulating_supply)}
                <span class="text-white/30 text-sm font-normal"> {symbol}</span>
              </div>
            </div>
            <div class="bg-[#111318] border border-white/[0.07] rounded-xl p-4">
              <div class="text-white/30 text-xs mb-1.5">Suministro total</div>
              <div class="text-white font-bold text-base" style="font-family:'Syne',sans-serif;">
                {coin.market_data.total_supply ? fmtSupply(coin.market_data.total_supply) : '∞'}
                <span class="text-white/30 text-sm font-normal"> {symbol}</span>
              </div>
            </div>
          </div>

          <!-- Descripción -->
          {descClean && (
            <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5 sm:p-6">
              <h2 class="text-white font-bold text-base mb-3" style="font-family:'Syne',sans-serif;">¿Qué es {coin.name}?</h2>
              <p class="text-white/50 text-sm leading-relaxed">{descClean}{desc.length > 400 ? '...' : ''}</p>
            </div>
          )}

        </div>
      )}
    </div>
  </div>
</Layout>

<!-- TradingView Widget -->
<script define:vars={{ tvSymbol }}>
  const container = document.getElementById('tv-chart');
  if (container) {
    const script = document.createElement('script');
    script.src = 'https://s3.tradingview.com/tv.js';
    script.onload = () => {
      new TradingView.widget({
        container_id:        'tv-chart',
        symbol:              tvSymbol,
        interval:            'D',
        timezone:            'America/Tegucigalpa',
        theme:               'dark',
        style:               '1',
        locale:              'es',
        toolbar_bg:          '#111318',
        enable_publishing:   false,
        hide_top_toolbar:    false,
        hide_legend:         false,
        save_image:          false,
        backgroundColor:     '#111318',
        gridColor:           'rgba(255,255,255,0.03)',
        width:               '100%',
        height:              460,
        withdateranges:      true,
        allow_symbol_change: false,
        studies:             [],
      });
    };
    document.head.appendChild(script);
  }
</script>

