---
// src/pages/herramientas/cripto/[id].astro
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import TVChart from '../../../components/TVChart.astro';
import { ArrowLeft, TrendingUp, TrendingDown, ExternalLink } from 'lucide-astro';

const { id } = Astro.params;

type CoinDetail = {
  id: string;
  symbol: string;
  name: string;
  image: { large: string };
  market_cap_rank: number;
  market_data: {
    current_price: { usd: number };
    price_change_percentage_24h: number;
    price_change_percentage_7d: number;
    price_change_percentage_30d: number;
    market_cap: { usd: number };
    total_volume: { usd: number };
    circulating_supply: number;
    total_supply: number;
    ath: { usd: number };
    atl: { usd: number };
  };
  description: { es: string; en: string };
  links: {
    homepage: string[];
    blockchain_site: string[];
    repos_url: { github: string[] };
  };
};

// ── Helpers de formato ────────────────────────────────────────
const fmt = (p: number) => {
  if (!p) return '—';
  if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
  if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  if (p >= 0.01) return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 6, maximumFractionDigits: 6 })}`;
};
const fmtLarge = (n: number) => {
  if (!n) return '—';
  if (n >= 1e12) return `$${(n/1e12).toFixed(2)}T`;
  if (n >= 1e9)  return `$${(n/1e9).toFixed(2)}B`;
  if (n >= 1e6)  return `$${(n/1e6).toFixed(1)}M`;
  return `$${n.toLocaleString('en-US')}`;
};
const fmtChg    = (c: number) => c != null ? `${c >= 0 ? '+' : ''}${c.toFixed(2)}%` : '—';
const fmtSupply = (n: number) => n ? n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : '—';

// ── Fetch con caché KV ────────────────────────────────────────
const env = (Astro.locals.runtime?.env as any);
const KV  = env?.INVERSA_KV as KVNamespace | undefined;
const KEY = env?.COINGECKO_API_KEY as string | undefined;

let coin: CoinDetail | null = null;
let fetchError = false;

try {
  // 1. Leer del objeto agrupado que escribe el cron
  const topCoins = await KV?.get('cache:top-coins', 'json') as Record<string, CoinDetail> | null;
  const cached = topCoins?.[id as string] ?? null;

  if (cached) {
    coin = cached;
  } else {
    // 2. Fallback: llamar CoinGecko directamente (sin escribir en KV)
    const res = await fetch(
      `https://api.coingecko.com/api/v3/coins/${id}?localization=true&tickers=false&market_data=true&community_data=false&developer_data=false`,
      { headers: { 'Accept': 'application/json', ...(KEY ? { 'x-cg-demo-api-key': KEY } : {}) } }
    );
    if (!res.ok) throw new Error(`CoinGecko ${res.status}`);
    coin = await res.json() as CoinDetail;
    // ⚠️ Sin KV.put — el cron es el único que escribe
  }
} catch (e) {
  fetchError = true;
  console.error('[CoinDetail]', e);
}

if (!coin && !fetchError) {
  return Astro.redirect('/herramientas/cripto');
}

const price     = coin?.market_data?.current_price?.usd ?? 0;
const chg24     = coin?.market_data?.price_change_percentage_24h ?? 0;
const isUp      = chg24 >= 0;
const symbol    = coin?.symbol?.toUpperCase() ?? '';
const tvSymbol  = `BINANCE:${symbol}USDT`;
const desc      = coin?.description?.es || coin?.description?.en || '';
const descClean = desc.replace(/<[^>]*>/g, '').slice(0, 400);
---

<Layout>


<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
  <title>{coin?.name ?? id} — {fmt(price)} hoy · Precio en Vivo | Inversax</title>
  <meta name="description"    content={`Precio de ${coin?.name ?? id} (${symbol}) hoy: ${fmt(price)}. Variación 24h: ${fmtChg(chg24)}. Gráfica en tiempo real, capitalización de mercado y datos actualizados para inversores en Latinoamérica.`} />
  <meta name="author"         content="José Zúniga" />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"      content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"       href={`https://inversax.com/herramientas/cripto/${id}`} />

  <!-- ═══════════════════════════════════════
       KEYWORDS
  ═══════════════════════════════════════ -->
  <meta name="keywords"      content={`${coin?.name?.toLowerCase()} precio, ${symbol.toLowerCase()} precio hoy, ${symbol.toLowerCase()} usd, precio ${coin?.name?.toLowerCase()} tiempo real, ${symbol.toLowerCase()} cripto, cuanto vale ${symbol.toLowerCase()}, ${symbol.toLowerCase()} latinoamerica`} />
  <meta name="news_keywords" content={`${coin?.name}, ${symbol}, precio ${symbol} hoy, criptomonedas, Inversax`} />

  <!-- ═══════════════════════════════════════
       GEO
  ═══════════════════════════════════════ -->
  <meta name="geo.region"       content="LATAM" />
  <meta name="geo.placename"    content="Latinoamérica" />
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />
  <meta name="coverage"         content="Worldwide" />
  <meta name="target"           content="all" />

  <!-- ═══════════════════════════════════════
       HREFLANG — página global, aplican los 36
  ═══════════════════════════════════════ -->
