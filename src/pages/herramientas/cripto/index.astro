  }
  .seo-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #1C1917;
    margin-bottom: 0.875rem;
  }
  .seo-section p {
    font-size: 0.875rem;
    color: #57534E;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  .seo-section p:last-child { margin-bottom: 0; }
  .seo-section strong { color: #1C1917; }
  .seo-section a { color: #B91C1C; }

  /* ── SEO TABLE ── */
  .seo-table {
    margin: 0.875rem 0;
    border: 1px solid #E5E0D8;
    border-radius: 0.875rem;
    overflow: hidden;
  }
  .seo-table-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 0.55rem 0.875rem;
    font-size: 0.8rem;
    color: #57534E;
    border-bottom: 1px solid #E5E0D8;
    gap: 0.5rem;
    font-family: 'DM Mono', 'Courier New', monospace;
  }
  .seo-table-row:last-child { border-bottom: none; }
  .seo-table-row.seo-table-header {
    background: #E5E0D8;
    color: #78716C;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: 'DM Sans', sans-serif;
  }

  @media (max-width: 540px) {
    .seo-table-row { grid-template-columns: 1fr 1fr; font-size: 0.73rem; }
    .seo-table-row span:nth-child(3),
    .seo-table-row span:nth-child(4) { display: none; }
    .seo-section { padding: 1.25rem; }
  }
</style>

<script>
  const rows     = Array.from(document.querySelectorAll('.coin-row')) as HTMLAnchorElement[];
  const empty    = document.getElementById('empty-state')!;
  let   activeFilter = 'all';
  let   activeSort   = { key: 'cap', dir: -1 };
  let   query        = '';

  function applyFilters() {
    const q = query.trim().toLowerCase();
    let visible = 0;

    rows.forEach(row => {
      const name   = row.dataset.name   || '';
      const symbol = row.dataset.symbol || '';
      const chg24  = parseFloat(row.dataset.chg24 || '0');
      const rank   = parseInt(row.dataset.rank   || '0');

      const matchSearch = !q || name.includes(q) || symbol.includes(q);
      const matchFilter =
        activeFilter === 'all'     ? true :
        activeFilter === 'gainers' ? chg24 > 0 :
        activeFilter === 'losers'  ? chg24 < 0 :
        activeFilter === 'top10'   ? rank <= 10 : true;

      const show = matchSearch && matchFilter;
      row.classList.toggle('hidden-row', !show);
      if (show) visible++;
    });

    empty.classList.toggle('hidden', visible > 0);
    empty.classList.toggle('flex', visible === 0);
  }

  function applySort() {
    const body   = document.getElementById('table-body')!;
    const sorted = [...rows].sort((a, b) => {
      const km: Record<string, string> = {
        price: 'price', change24: 'chg24', change7: 'chg7', cap: 'cap', volume: 'vol'
      };
      const attr = km[activeSort.key] || 'cap';
      const va = parseFloat(a.dataset[attr] || '0');
      const vb = parseFloat(b.dataset[attr] || '0');
      return (va - vb) * activeSort.dir;
    });
    sorted.forEach(r => body.appendChild(r));
  }

  function update() { applySort(); applyFilters(); }

  document.getElementById('search')!.addEventListener('input', function(this: HTMLInputElement) {
    query = this.value;
    applyFilters();
  });

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = (btn as HTMLElement).dataset.filter || 'all';
      document.querySelectorAll('.filter-btn').forEach(b => {
        const el = b as HTMLElement;
        if (el.dataset.filter === activeFilter) {
          el.style.background = 'rgba(29,78,216,0.1)';
          el.style.borderColor = 'rgba(29,78,216,0.4)';
          el.style.color = '#1D4ED8';
        } else {
          el.style.background = '#F5F1EC';
          el.style.borderColor = '#D6D0C8';
          el.style.color = '#57534E';
        }
      });
      applyFilters();
    });
  });

  document.querySelectorAll('.sort-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = (btn as HTMLElement).dataset.sort || 'cap';
      activeSort = activeSort.key === key
        ? { key, dir: activeSort.dir * -1 }
        : { key, dir: -1 };

      document.querySelectorAll('.sort-btn').forEach(b => {
        b.classList.remove('active');
        const arrow = b.querySelector('.sort-arrow');
        if (arrow) arrow.textContent = '↕';
      });
      btn.classList.add('active');
      const arrow = btn.querySelector('.sort-arrow');
      if (arrow) arrow.textContent = activeSort.dir === -1 ? '↓' : '↑';

      update();
    });
  });
</script>

</Layout>

