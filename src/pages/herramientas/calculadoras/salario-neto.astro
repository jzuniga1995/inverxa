<script is:inline>
const PAISES = {
  CO: {
    label: 'Salario bruto mensual (COP)',
    default: 3000000,
    moneda: 'COP',
    deducciones: [
      { nombre: 'Salud (empleado)', pct: 4 },
      { nombre: 'Pensión (empleado)', pct: 4 },
    ],
    retencion: (salario) => {
      const uvt = 47065;
      const uvtMen = salario / uvt;
      if (uvtMen <= 95) return 0;
      if (uvtMen <= 150) return (salario - 95 * uvt) * 0.19;
      if (uvtMen <= 360) return (salario - 150 * uvt) * 0.28 + 55 * uvt * 0.19;
      return (salario - 360 * uvt) * 0.33 + 210 * uvt * 0.28 + 55 * uvt * 0.19;
    }
  },
  MX: {
    label: 'Salario bruto mensual (MXN)',
    default: 15000,
    moneda: 'MXN',
    deducciones: [
      { nombre: 'IMSS (cuotas obrero)', pct: 2.5 },
    ],
    retencion: (salario) => {
      if (salario <= 746.04 * 30) return salario * 0.0192;
      if (salario <= 6333.7 * 30) return (salario - 746.04 * 30) * 0.064 + 746.04 * 30 * 0.0192;
      if (salario <= 11116 * 30) return (salario - 6333.7 * 30) * 0.1088 + ((6333.7 - 746.04) * 30 * 0.064) + 746.04 * 30 * 0.0192;
      return salario * 0.20;
    }
  },
  PE: {
    label: 'Salario bruto mensual (PEN)',
    default: 2500,
    moneda: 'PEN',
    deducciones: [
      { nombre: 'AFP (pensión)', pct: 10 },
      { nombre: 'Seguro de riesgo AFP', pct: 1.35 },
    ],
    retencion: (salario) => {
      const anual = salario * 12;
      const uit = 5150;
      const exento = 7 * uit;
      if (anual <= exento) return 0;
      const base = anual - exento;
      if (base <= 5 * uit) return (base * 0.08) / 12;
      if (base <= 20 * uit) return ((5 * uit * 0.08 + (base - 5 * uit) * 0.14)) / 12;
      return ((5 * uit * 0.08 + 15 * uit * 0.14 + (base - 20 * uit) * 0.17)) / 12;
    }
  },
  CL: {
    label: 'Salario bruto mensual (CLP)',
    default: 800000,
    moneda: 'CLP',
    deducciones: [
      { nombre: 'AFP (pensión)', pct: 10 },
      { nombre: 'Salud (Fonasa/Isapre)', pct: 7 },
    ],
    retencion: (salario) => {
      if (salario <= 852658) return 0;
      if (salario <= 1893688) return (salario - 852658) * 0.04;
      if (salario <= 3155472) return (salario - 1893688) * 0.08 + (1893688 - 852658) * 0.04;
      return salario * 0.15;
    }
  },
  US: {
    label: 'Salario bruto mensual (USD)',
    default: 5000,
    moneda: 'USD',
    deducciones: [
      { nombre: 'Social Security (6.2%)', pct: 6.2 },
      { nombre: 'Medicare (1.45%)', pct: 1.45 },
    ],
    retencion: (salario) => {
      const anual = salario * 12;
      if (anual <= 11600) return 0;
      if (anual <= 47150) return ((anual - 11600) * 0.12 + 0) / 12;
      if (anual <= 100525) return ((anual - 47150) * 0.22 + (47150 - 11600) * 0.12) / 12;
      if (anual <= 191950) return ((anual - 100525) * 0.24 + (100525 - 47150) * 0.22 + (47150 - 11600) * 0.12) / 12;
      return (anual * 0.32) / 12;
    }
  }
};

function fmtMoney(n, moneda) {
  if (moneda === 'USD') return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  return n.toLocaleString('es-CO', { maximumFractionDigits: 0 }) + ' ' + moneda;
}

function calcSalario() {
  const pais = document.getElementById('salPais').value;
  const config = PAISES[pais];
  const bruto = parseFloat(document.getElementById('salBruto').value) || 0;
  document.getElementById('salario-label').textContent = config.label.split(' (')[0];

  let totalDeduc = 0;
  const lista = document.getElementById('deducciones-lista');
  lista.innerHTML = '';

  config.deducciones.forEach(d => {
    const monto = bruto * d.pct / 100;
    totalDeduc += monto;
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; justify-content:space-between; font-size:13px; padding:4px 0;';
    row.innerHTML = `<span style="color:#57534E; font-family:'DM Sans',sans-serif;">${d.nombre}</span><span style="color:#B91C1C; font-family:'DM Sans',sans-serif; font-weight:600;">-${fmtMoney(monto, config.moneda)}</span>`;
    lista.appendChild(row);
  });

  const ret = config.retencion(bruto);
  if (ret > 0) {
    totalDeduc += ret;
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; justify-content:space-between; font-size:13px; padding:4px 0;';
    row.innerHTML = `<span style="color:#57534E; font-family:'DM Sans',sans-serif;">Impuesto / Retención</span><span style="color:#B91C1C; font-family:'DM Sans',sans-serif; font-weight:600;">-${fmtMoney(ret, config.moneda)}</span>`;
    lista.appendChild(row);
  }

  const neto = bruto - totalDeduc;
  const pct = bruto > 0 ? ((neto / bruto) * 100).toFixed(1) : 100;

  document.getElementById('sal-neto').textContent = fmtMoney(neto, config.moneda);
  document.getElementById('sal-pct').textContent = `${pct}% del salario bruto`;
  document.getElementById('sal-deduc').textContent = fmtMoney(totalDeduc, config.moneda);
  document.getElementById('sal-anual').textContent = fmtMoney(neto * 12, config.moneda);
  document.getElementById('sal-dia').textContent = fmtMoney(neto / 30, config.moneda);
  document.getElementById('sal-hora').textContent = fmtMoney(neto / 160, config.moneda);
}

function actualizarDefault() {
  const pais = document.getElementById('salPais').value;
  document.getElementById('salBruto').value = PAISES[pais].default;
  calcSalario();
}

document.getElementById('salPais').addEventListener('change', actualizarDefault);
document.addEventListener('DOMContentLoaded', calcSalario);
</script>
</Layout>
