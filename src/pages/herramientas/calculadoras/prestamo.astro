<script is:inline>
let chartP = null;

function fmt(n) {
  return '$' + Math.abs(n).toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function calcularPrestamo() {
  const P = parseFloat(document.getElementById('monto').value) || 0;
  const tasaAnual = parseFloat(document.getElementById('tasaP').value) || 0;
  let plazo = parseFloat(document.getElementById('plazo').value) || 1;
  const unidad = document.getElementById('unidadPlazo').value;
  const n = unidad === 'anos' ? Math.round(plazo * 12) : Math.round(plazo);
  const r = tasaAnual / 100 / 12;

  let cuota;
  if (r === 0) {
    cuota = P / n;
  } else {
    cuota = P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  }

  const totalPagado = cuota * n;
  const totalIntereses = totalPagado - P;
  const costo = P > 0 ? (totalIntereses / P * 100).toFixed(1) : '0';
  const tasaMen = (tasaAnual / 12).toFixed(4);

  document.getElementById('pres-cuota').textContent = fmt(cuota);
  document.getElementById('pres-total').textContent = fmt(totalPagado);
  document.getElementById('pres-intereses').textContent = fmt(totalIntereses);
  document.getElementById('pres-costo').textContent = costo + '%';
  document.getElementById('pres-tasamen').textContent = (tasaAnual / 12).toFixed(3) + '%';

  // Tabla de amortización
  const tbody = document.getElementById('tabla-body');
  tbody.innerHTML = '';
  let saldo = P;
  const dataCap = [], dataInt = [], labels = [];
  let capAnual = 0, intAnual = 0;

  for (let i = 1; i <= n; i++) {
    const interes = saldo * r;
    const capital = cuota - interes;
    saldo = Math.max(0, saldo - capital);
    capAnual += capital;
    intAnual += interes;

    const tr = document.createElement('tr');
    tr.style.cssText = 'border-bottom:1px solid #F0EDE7;';
    tr.innerHTML = `
      <td style="padding:8px 16px; color:#78716C; font-size:12px;">${i}</td>
      <td style="padding:8px 16px; text-align:right; color:#1C1917; font-weight:600; font-size:13px;">${fmt(cuota)}</td>
      <td style="padding:8px 16px; text-align:right; color:#15803D; font-size:13px;">${fmt(capital)}</td>
      <td style="padding:8px 16px; text-align:right; color:#B91C1C; font-size:13px;">${fmt(interes)}</td>
      <td style="padding:8px 16px; text-align:right; color:#57534E; font-size:13px;">${fmt(saldo)}</td>
    `;
    tbody.appendChild(tr);

    if (i % 12 === 0 || i === n) {
      labels.push(`Año ${Math.ceil(i / 12)}`);
      dataCap.push(Math.round(capAnual));
      dataInt.push(Math.round(intAnual));
      capAnual = 0; intAnual = 0;
    }
  }

  document.getElementById('tabla-info').textContent = `${n} períodos · ${fmt(cuota)}/mes`;

  const ctx = document.getElementById('chart-prestamo').getContext('2d');
  if (chartP) chartP.destroy();
  chartP = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [
        { label: 'Capital', data: dataCap, backgroundColor: '#15803D' },
        { label: 'Intereses', data: dataInt, backgroundColor: '#B91C1C' },
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { labels: { font: { family: "'DM Sans', sans-serif", size: 12 }, color: '#57534E' } } },
      scales: {
        x: { stacked: true, ticks: { font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C' }, grid: { display: false } },
        y: { stacked: true, ticks: { callback: v => '$' + (v/1000).toFixed(0) + 'k', font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C' }, grid: { color: '#F0EDE7' } }
      }
    }
  });
}

document.addEventListener('DOMContentLoaded', calcularPrestamo);
</script>
</Layout>
