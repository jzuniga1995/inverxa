<script is:inline>
let chartHip = null;
function fmt(n) { return '$' + Math.round(n).toLocaleString('es-CO'); }

function calcHipoteca() {
  const valor = parseFloat(document.getElementById('hValor').value) || 0;
  const pctEng = parseFloat(document.getElementById('hEnganche').value) || 0;
  const tasa = parseFloat(document.getElementById('hTasa').value) || 0;
  const plazo = parseFloat(document.getElementById('hPlazo').value) || 1;

  const enganche = valor * pctEng / 100;
  const P = valor - enganche;
  const n = plazo * 12;
  const r = tasa / 100 / 12;

  let cuota;
  if (r === 0) { cuota = P / n; } else {
    cuota = P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  }
  const total = cuota * n + enganche;
  const intereses = cuota * n - P;
  const costo = valor > 0 ? (total / valor).toFixed(2) : '1';

  document.getElementById('hip-cuota').textContent = fmt(cuota);
  document.getElementById('hip-prestamo').textContent = `Préstamo: ${fmt(P)} · ${plazo} años`;
  document.getElementById('hip-enganche').textContent = fmt(enganche);
  document.getElementById('hip-total').textContent = fmt(total);
  document.getElementById('hip-intereses').textContent = fmt(intereses);
  document.getElementById('hip-costo').textContent = `×${costo}`;

  const ctx = document.getElementById('chart-hip').getContext('2d');
  if (chartHip) chartHip.destroy();
  chartHip = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Capital del préstamo', 'Intereses', 'Enganche'],
      datasets: [{ data: [Math.round(P), Math.round(intereses), Math.round(enganche)], backgroundColor: ['#15803D', '#B91C1C', '#F0EDE7'], borderWidth: 2, borderColor: '#fff' }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom', labels: { font: { family: "'DM Sans', sans-serif", size: 12 }, color: '#57534E', padding: 12 } },
        tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${fmt(ctx.raw)}` } }
      }
    }
  });
}
document.addEventListener('DOMContentLoaded', calcHipoteca);
</script>
</Layout>
