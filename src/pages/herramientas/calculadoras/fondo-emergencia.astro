<div style="background:#FAFAF8; border-bottom:2px solid #1C1917;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="flex items-center gap-1.5 text-xs mb-4" style="color:#A8A29E; font-family:'DM Sans',sans-serif;">
      <a href="/" style="color:#A8A29E; text-decoration:none;" onmouseover="this.style.color='#B91C1C';" onmouseout="this.style.color='#A8A29E';">Inicio</a>
      <span>›</span>
      <a href="/herramientas/calculadoras" style="color:#A8A29E; text-decoration:none;" onmouseover="this.style.color='#B91C1C';" onmouseout="this.style.color='#A8A29E';">Calculadoras</a>
      <span>›</span>
      <span style="color:#1C1917; font-weight:600;">Fondo de Emergencia</span>
    </div>
    <h1 class="font-bold leading-tight mb-2" style="font-family:'Playfair Display',serif; color:#1C1917; font-size:clamp(26px,4vw,44px);">
      Calculadora de Fondo de Emergencia
    </h1>
