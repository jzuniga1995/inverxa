          {[
            { id:'feVivienda', label:'Vivienda (arriendo/hipoteca)', val:1200 },
            { id:'feAlim', label:'Alimentación', val:400 },
            { id:'feServ', label:'Servicios (luz, agua, internet)', val:150 },
            { id:'feTransp', label:'Transporte', val:120 },
            { id:'feSalud', label:'Salud y seguros', val:100 },
            { id:'feDeudas', label:'Cuotas mínimas de deudas', val:200 },
            { id:'feOtros', label:'Otros gastos esenciales', val:100 },
          ].map(f => (
            <div>
              <label style="font-size:12px; font-weight:600; color:#57534E; font-family:'DM Sans',sans-serif; text-transform:uppercase; letter-spacing:0.08em;">{f.label}</label>
              <input id={f.id} type="number" value={f.val} min="0" step="10"
                style="width:100%; margin-top:6px; padding:10px 12px; border:1px solid #E5E0D8; background:#FAFAF8; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:15px; outline:none;"
                onfocus="this.style.borderColor='#15803D';" onblur="this.style.borderColor='#E5E0D8';" oninput="calcFondo();" />
            </div>
          ))}
          <div>
            <label style="font-size:12px; font-weight:600; color:#57534E; font-family:'DM Sans',sans-serif; text-transform:uppercase; letter-spacing:0.08em;">Meses de cobertura</label>
            <select id="feMeses"
              style="width:100%; margin-top:6px; padding:10px 12px; border:1px solid #E5E0D8; background:#FAFAF8; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:15px; outline:none;"
              onfocus="this.style.borderColor='#15803D';" onblur="this.style.borderColor='#E5E0D8';" onchange="calcFondo();">
              <option value="3">3 meses (trabajo estable)</option>
              <option value="6" selected>6 meses (recomendado)</option>
              <option value="9">9 meses (independientes)</option>
              <option value="12">12 meses (mayor seguridad)</option>
            </select>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div style="background:#15803D; padding:24px;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.15em; color:rgba(255,255,255,0.65); font-family:'DM Sans',sans-serif; margin-bottom:8px;">Meta del fondo de emergencia</p>
          <p id="fe-meta" style="font-size:36px; font-weight:800; color:#fff; font-family:'Playfair Display',serif; line-height:1.1;">$0</p>
          <p id="fe-sub" style="font-size:13px; color:rgba(255,255,255,0.7); font-family:'DM Sans',sans-serif; margin-top:6px;"></p>
        </div>

        <div style="background:#F5F1EC; border:1px solid #E5E0D8; padding:20px;">
          <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:12px;">¿Cuánto tiempo para alcanzar la meta?</p>
          <div style="display:flex; gap:8px; align-items:center; margin-bottom:8px;">
            <input id="feAhorroCap" type="number" value="200" min="1"
              style="flex:1; padding:10px 12px; border:1px solid #E5E0D8; background:#fff; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:15px; outline:none;"
              onfocus="this.style.borderColor='#15803D';" onblur="this.style.borderColor='#E5E0D8';" oninput="calcFondo();" />
            <span style="font-size:13px; color:#57534E; font-family:'DM Sans',sans-serif; white-space:nowrap;">/ mes</span>
          </div>
          <div style="background:#fff; border:1px solid #E5E0D8; padding:14px;">
            <p style="font-size:10px; text-transform:uppercase; letter-spacing:0.1em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:4px;">Tiempo estimado</p>
            <p id="fe-tiempo" style="font-size:24px; font-weight:700; color:#15803D; font-family:'DM Sans',sans-serif;">0 meses</p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div style="background:#F5F1EC; border:1px solid #E5E0D8; padding:16px;">
            <p style="font-size:10px; text-transform:uppercase; letter-spacing:0.12em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:4px;">Gastos mensuales</p>
            <p id="fe-gastos" style="font-size:18px; font-weight:700; color:#1C1917; font-family:'DM Sans',sans-serif;">$0</p>
          </div>
          <div style="background:#F5F1EC; border:1px solid #E5E0D8; padding:16px;">
            <p style="font-size:10px; text-transform:uppercase; letter-spacing:0.12em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:4px;">Días cubiertos</p>
            <p id="fe-dias" style="font-size:18px; font-weight:700; color:#15803D; font-family:'DM Sans',sans-serif;">0</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div style="background:#F5F1EC; border:1px solid #E5E0D8; padding:28px; margin-top:24px;">
      <div style="display:flex; align-items:flex-start; gap:12px; margin-bottom:16px;">
        <div style="width:3px; height:32px; background:#15803D; flex-shrink:0; margin-top:2px;"></div>
        <div>
          <p style="font-size:10px; text-transform:uppercase; letter-spacing:0.15em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:4px;">Una vez tengas el fondo</p>
          <p style="font-size:18px; font-weight:700; color:#1C1917; font-family:'Playfair Display',serif; line-height:1.3;">Con tu fondo de emergencia listo, empieza a invertir el excedente.</p>
        </div>
      </div>
      <p style="font-size:14px; color:#57534E; font-family:'DM Sans',sans-serif; margin-bottom:20px;">El fondo de emergencia es la base. Una vez lo tengas, el dinero extra debería trabajar en inversiones. Estos brokers te permiten empezar con poco.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px, 1fr)); gap:10px; margin-bottom:16px;">
        <a href="https://geolink.xtb.com/I0QSx" target="_blank" rel="noopener noreferrer nofollow"
           style="display:flex; align-items:center; justify-content:space-between; background:#fff; border:1px solid #E5E0D8; padding:14px 16px; text-decoration:none;"
           onmouseover="this.style.borderColor='#15803D';" onmouseout="this.style.borderColor='#E5E0D8';">
          <div><p style="font-weight:700; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:14px; margin-bottom:2px;">XTB</p><p style="font-size:11px; color:#78716C; font-family:'DM Sans',sans-serif;">Sin mínimo · ETFs</p></div>
          <span style="font-size:12px; color:#15803D; font-weight:700; font-family:'DM Sans',sans-serif;">Abrir →</span>
        </a>
        <a href="https://pepperstone.sjv.io/c/7061517/3194997/21941" target="_blank" rel="noopener noreferrer nofollow"
           style="display:flex; align-items:center; justify-content:space-between; background:#fff; border:1px solid #E5E0D8; padding:14px 16px; text-decoration:none;"
           onmouseover="this.style.borderColor='#15803D';" onmouseout="this.style.borderColor='#E5E0D8';">
          <div><p style="font-weight:700; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:14px; margin-bottom:2px;">Pepperstone</p><p style="font-size:11px; color:#78716C; font-family:'DM Sans',sans-serif;">Sin mínimo · 4.7★</p></div>
          <span style="font-size:12px; color:#15803D; font-weight:700; font-family:'DM Sans',sans-serif;">Abrir →</span>
        </a>
      </div>
      <p style="font-size:11px; color:#A8A29E; font-family:'DM Sans',sans-serif; margin-bottom:10px;">* Contiene enlaces de afiliado. Invertir implica riesgos.</p>
      <a href="/herramientas/comparar-brokers" style="font-size:13px; font-weight:600; color:#B91C1C; font-family:'DM Sans',sans-serif; text-decoration:none;">Ver comparativa completa →</a>
    </div>

    <div style="background:#fff; border:1px solid #E5E0D8; padding:32px; margin-top:24px;">
      <h2 style="font-family:'Playfair Display',serif; color:#1C1917; font-size:22px; font-weight:700; margin-bottom:16px;">Por qué el fondo de emergencia es la base de todo plan financiero</h2>
      <div style="color:#57534E; font-family:'DM Sans',sans-serif; font-size:15px; line-height:1.75;">
        <p style="margin-bottom:14px;">El <strong style="color:#1C1917;">fondo de emergencia</strong> es el primer pilar de cualquier estrategia financiera sólida. Sin él, cualquier imprevisto — una enfermedad, el despido, una reparación urgente — te obliga a endeudarte o liquidar inversiones en el peor momento.</p>
        <p style="margin-bottom:14px;">La regla de oro es tener entre 3 y 6 meses de gastos esenciales en efectivo o activos muy líquidos. No en acciones (podrían bajar justo cuando más los necesitas), no en CDT (pueden tener penalización por retiro anticipado), sino en una cuenta de ahorros con buena tasa o en fondos de mercado monetario.</p>
        <p style="margin-bottom:14px;">Para un trabajador asalariado con empleo estable en Colombia, México o Perú, 3 meses puede ser suficiente. Pero si eres freelance, consultor independiente o tienes una empresa propia, el período de búsqueda de nuevos ingresos puede ser más largo, y 6-12 meses de fondo es más prudente.</p>
        <p style="margin-bottom:14px;">En Latinoamérica, donde los sistemas de desempleo son débiles o inexistentes (a diferencia de países europeos con seguro de desempleo robusto), el fondo de emergencia cumple también el rol que en otros contextos cumple el estado: te protege mientras buscas nuevas oportunidades.</p>
        <p>Una vez tengas el fondo de emergencia completo, el dinero adicional que generes mes a mes debería destinarse a inversiones que generen rendimientos. El fondo de emergencia no es una inversión — es un seguro. No esperes que crezca mucho; su valor está en la tranquilidad y protección que proporciona.</p>
      </div>
    </div>

    <div style="background:#F5F1EC; border:1px solid #E5E0D8; padding:32px; margin-top:16px;">
      <h2 style="font-family:'Playfair Display',serif; color:#1C1917; font-size:20px; font-weight:700; margin-bottom:20px;">Preguntas frecuentes</h2>
      <div class="flex flex-col gap-5">
        {[
          { q: '¿Cuánto dinero debo tener en mi fondo de emergencia?', a: 'Entre 3 y 6 meses de gastos esenciales. Con trabajo estable, 3 meses es aceptable. Como independiente o con ingresos variables, apunta a 6-12 meses.' },
          { q: '¿Dónde guardar el fondo de emergencia?', a: 'En una cuenta de ahorros con buena tasa, CDTs a corto plazo con liquidez, CETES (México), o fondos de money market. Prioriza liquidez y seguridad sobre rentabilidad.' },
          { q: '¿El fondo de emergencia debe incluir el arriendo?', a: 'Sí. Debe cubrir todos los gastos esenciales: vivienda, alimentación, servicios, transporte, salud y pagos mínimos de deudas. Todo lo que necesitas para sobrevivir sin ingresos.' },
          { q: '¿Cuánto tiempo tarda en formarse el fondo?', a: 'Si ahorras el 20% de tu salario neto mensualmente para el fondo, en 12-18 meses puedes tener 3 meses de gastos. Con el 30%, llega en 9-12 meses.' },
        ].map((faq) => (
          <div style="border-bottom:1px solid #E5E0D8; padding-bottom:16px;">
            <p style="font-weight:700; color:#1C1917; font-family:'DM Sans',sans-serif; font-size:15px; margin-bottom:6px;">{faq.q}</p>
            <p style="color:#57534E; font-family:'DM Sans',sans-serif; font-size:14px; line-height:1.6;">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>

    <div style="padding:20px 0; margin-top:8px;">
      <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.12em; color:#A8A29E; font-family:'DM Sans',sans-serif; margin-bottom:12px;">Calculadoras relacionadas</p>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        {[
          { href:'/herramientas/calculadoras/salario-neto', label:'Salario neto' },
          { href:'/herramientas/calculadoras/prestamo', label:'Préstamo y amortización' },
          { href:'/herramientas/calculadoras/pago-deuda', label:'Pago de deuda' },
          { href:'/herramientas/calculadoras/interes-compuesto', label:'Interés compuesto' },
        ].map(l => (
          <a href={l.href} style="font-size:13px; color:#B91C1C; font-family:'DM Sans',sans-serif; text-decoration:none; background:#FEF2F2; padding:4px 10px; border-radius:2px;" onmouseover="this.style.background='#FECACA';" onmouseout="this.style.background='#FEF2F2';">
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
function fmt(n) { return '$' + Math.round(n).toLocaleString('es-CO'); }
function calcFondo() {
  const ids = ['feVivienda','feAlim','feServ','feTransp','feSalud','feDeudas','feOtros'];
  const gastos = ids.reduce((acc, id) => acc + (parseFloat(document.getElementById(id).value) || 0), 0);
  const meses = parseFloat(document.getElementById('feMeses').value) || 6;
  const ahorro = parseFloat(document.getElementById('feAhorroCap').value) || 1;
  const meta = gastos * meses;
  const tiempoMeses = ahorro > 0 ? Math.ceil(meta / ahorro) : 0;
  const dias = meses * 30;

  document.getElementById('fe-meta').textContent = fmt(meta);
  document.getElementById('fe-sub').textContent = `${meses} meses de gastos esenciales`;
  document.getElementById('fe-gastos').textContent = fmt(gastos);
  document.getElementById('fe-dias').textContent = dias + ' días';

  const years = Math.floor(tiempoMeses / 12);
  const mesesR = tiempoMeses % 12;
  let texto = '';
  if (years > 0) texto = `${years} año${years > 1 ? 's' : ''} y ${mesesR} mes${mesesR !== 1 ? 'es' : ''}`;
  else texto = `${tiempoMeses} mes${tiempoMeses !== 1 ? 'es' : ''}`;
  document.getElementById('fe-tiempo').textContent = texto;
}
document.addEventListener('DOMContentLoaded', calcFondo);
</script>
</Layout>
