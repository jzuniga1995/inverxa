<script is:inline>
function fmt(n) { return '$' + Math.round(n).toLocaleString('es-CO'); }
function calcMeses(saldo, tasa, pago) {
  const r = tasa / 100 / 12;
  if (r === 0) return Math.ceil(saldo / pago);
  if (pago <= saldo * r) return Infinity;
  return Math.ceil(Math.log(pago / (pago - saldo * r)) / Math.log(1 + r));
}
function calcTotalPagado(saldo, tasa, pago) {
  const r = tasa / 100 / 12;
  const n = calcMeses(saldo, tasa, pago);
  if (!isFinite(n)) return Infinity;
  return pago * n;
}

function calcDeuda() {
  const saldo = parseFloat(document.getElementById('pdSaldo').value) || 0;
  const tasa = parseFloat(document.getElementById('pdTasa').value) || 0;
  const pago = parseFloat(document.getElementById('pdPago').value) || 0;
  const extra = parseFloat(document.getElementById('pdExtra').value) || 0;
  const pagoExtra = pago + extra;

  const mesesSin = calcMeses(saldo, tasa, pago);
  const mesesCon = calcMeses(saldo, tasa, pagoExtra);
  const totalSin = calcTotalPagado(saldo, tasa, pago);
  const totalCon = calcTotalPagado(saldo, tasa, pagoExtra);

  function fmtMeses(m) {
    if (!isFinite(m)) return '∞ (pago insuficiente)';
    const y = Math.floor(m / 12), mo = m % 12;
    if (y === 0) return `${mo} mes${mo !== 1 ? 'es' : ''}`;
    return `${y} año${y > 1 ? 's' : ''} y ${mo} mes${mo !== 1 ? 'es' : ''}`;
  }

  document.getElementById('pd-tiempo').textContent = fmtMeses(mesesCon);
  document.getElementById('pd-tiempoExtra').textContent = `Sin pago extra: ${fmtMeses(mesesSin)}`;
  document.getElementById('pd-sinTotal').textContent = isFinite(totalSin) ? fmt(totalSin) : '∞';
  document.getElementById('pd-conTotal').textContent = isFinite(totalCon) ? fmt(totalCon) : '∞';
  document.getElementById('pd-ahorro').textContent = (isFinite(totalSin) && isFinite(totalCon)) ? fmt(totalSin - totalCon) : '$0';
  document.getElementById('pd-mesesAhor').textContent = (isFinite(mesesSin) && isFinite(mesesCon)) ? `${Math.max(0, mesesSin - mesesCon)} meses` : '0';
}
document.addEventListener('DOMContentLoaded', calcDeuda);
</script>
</Layout>
