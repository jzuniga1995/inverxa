<div style="background:#FAFAF8; border-bottom:2px solid #1C1917;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="flex items-center gap-1.5 text-xs mb-4" style="color:#A8A29E; font-family:'DM Sans',sans-serif;">
