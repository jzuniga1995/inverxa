      <span>›</span>
      <a href="/herramientas/calculadoras" style="color:#A8A29E; text-decoration:none;" onmouseover="this.style.color='#B91C1C';" onmouseout="this.style.color='#A8A29E';">Calculadoras</a>
      <span>›</span>
      <span style="color:#1C1917; font-weight:600;">Inflación</span>
