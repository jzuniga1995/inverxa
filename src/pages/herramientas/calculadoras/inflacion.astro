</div>

<section style="background:#FAFAF8;" class="px-4 sm:px-6 py-10">
  <div class="max-w-5xl mx-auto">

    <!-- Tasas de referencia por país -->
    <div style="background:#fff; border:1px solid #E5E0D8; padding:20px; margin-bottom:20px;">
      <p style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:#78716C; font-family:'DM Sans',sans-serif; margin-bottom:12px;">Tasas de inflación de referencia 2024-2025</p>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        {[
          { p:'Colombia', t:'5.5', c:'CO' }, { p:'México', t:'4.5', c:'MX' }, { p:'Perú', t:'3.5', c:'PE' },
          { p:'Chile', t:'4.0', c:'CL' }, { p:'Argentina', t:'120+', c:'AR' }, { p:'USA', t:'3.0', c:'US' },
          { p:'España', t:'3.5', c:'ES' }, { p:'Ecuador', t:'2.5', c:'EC' },
        ].map(p => (
          <button onclick={`document.getElementById('infTasa').value='${p.t === '120+' ? '120' : p.t}'; calcInflacion();`}
