<script is:inline>
// Tasas de referencia en USD (1 USD = X moneda)
const TASAS_USD = {
  USD: 1,
  EUR: 0.92,
  COP: 4050,
  MXN: 17.2,
  PEN: 3.75,
  CLP: 940,
  ARS: 1050,
  BRL: 5.0,
  GBP: 0.79,
  JPY: 149,
};

const NOMBRES = {
  USD: 'Dólar USA', EUR: 'Euro', COP: 'Peso COP', MXN: 'Peso MXN',
  PEN: 'Sol', CLP: 'Peso CLP', ARS: 'Peso ARS', BRL: 'Real', GBP: 'Libra', JPY: 'Yen'
};

function fmtDivisa(n, moneda) {
  if (n >= 1000000) return (n / 1000000).toFixed(3) + 'M ' + moneda;
  if (n >= 1000) return n.toLocaleString('es-CO', { maximumFractionDigits: 2 }) + ' ' + moneda;
  return n.toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 4 }) + ' ' + moneda;
}

function convertir(cantidad, de, a) {
  const enUSD = cantidad / TASAS_USD[de];
  return enUSD * TASAS_USD[a];
}

function convertirDivisas() {
  const cantidad = parseFloat(document.getElementById('divCantidad').value) || 0;
  const de = document.getElementById('divDe').value;
  const a = document.getElementById('divA').value;
  const resultado = convertir(cantidad, de, a);
  const tasa = convertir(1, de, a);

  document.getElementById('div-resultado').textContent = fmtDivisa(resultado, a);
  document.getElementById('div-tasa').textContent = `1 ${de} = ${fmtDivisa(tasa, a)} (referencia)`;

  const tabla = document.getElementById('tabla-conv');
  tabla.innerHTML = '';
  const comunes = [1, 10, 100, 500, 1000, 5000];
  comunes.forEach(v => {
    const r = convertir(v, 'USD', a !== 'USD' ? a : de !== 'USD' ? de : 'COP');
    const monDest = a !== 'USD' ? a : de !== 'USD' ? de : 'COP';
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; justify-content:space-between; font-size:13px; padding:4px 0; border-bottom:1px solid #F0EDE7;';
    row.innerHTML = `<span style="color:#57534E; font-family:'DM Sans',sans-serif;">$${v} USD</span><span style="color:#15803D; font-family:'DM Sans',sans-serif; font-weight:600;">${fmtDivisa(r, monDest)}</span>`;
    tabla.appendChild(row);
  });
}

function invertirPar() {
  const de = document.getElementById('divDe').value;
  const a = document.getElementById('divA').value;
  document.getElementById('divDe').value = a;
  document.getElementById('divA').value = de;
  convertirDivisas();
}

document.addEventListener('DOMContentLoaded', convertirDivisas);
</script>
</Layout>
