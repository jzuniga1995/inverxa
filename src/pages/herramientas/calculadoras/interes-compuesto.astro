<script is:inline>
let chartIC = null;

function fmt(n) {
  return '$' + Math.round(n).toLocaleString('es-CO');
}

function calcular() {
  const capital = parseFloat(document.getElementById('capital').value) || 0;
  const aporte  = parseFloat(document.getElementById('aporte').value)  || 0;
  const tasa    = parseFloat(document.getElementById('tasa').value)    || 0;
  const anos    = parseFloat(document.getElementById('anos').value)    || 1;
  const freq    = parseInt(document.getElementById('freq').value)      || 12;

  const r = tasa / 100 / freq;
  const n = freq * anos;

  const valorCapital = capital * Math.pow(1 + r, n);
  const valorAportes = aporte * (Math.pow(1 + r, n) - 1) / r;
  const total = valorCapital + (r > 0 ? valorAportes : aporte * n);
  const capitalInvertido = capital + aporte * 12 * anos;
  const intereses = total - capitalInvertido;
  const mult = capitalInvertido > 0 ? (total / capitalInvertido).toFixed(1) : '—';
  const pct = capitalInvertido > 0 ? ((total / capitalInvertido - 1) * 100).toFixed(1) : '0';
  const r72 = tasa > 0 ? (72 / tasa).toFixed(1) + ' años' : '—';

  document.getElementById('res-total').textContent = fmt(total);
  document.getElementById('res-capital').textContent = fmt(capitalInvertido);
  document.getElementById('res-intereses').textContent = fmt(intereses);
  document.getElementById('res-mult').textContent = `× ${mult} tu dinero`;
  document.getElementById('res-r72').textContent = r72;
  document.getElementById('res-pct').textContent = pct + '%';

  // Datos para gráfica por año
  const labels = [], dataCap = [], dataInt = [];
  for (let a = 0; a <= anos; a++) {
    const nn = freq * a;
    const vCap = capital * Math.pow(1 + r, nn);
    const vAp = r > 0 ? aporte * (Math.pow(1 + r, nn) - 1) / r : aporte * nn;
    const tot = vCap + vAp;
    const inv = capital + aporte * 12 * a;
    labels.push(a === 0 ? 'Inicio' : `Año ${a}`);
    dataCap.push(Math.round(inv));
    dataInt.push(Math.round(tot));
  }

  const ctx = document.getElementById('chart-ic').getContext('2d');
  if (chartIC) chartIC.destroy();
  chartIC = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Capital invertido', data: dataCap, borderColor: '#E5E0D8', backgroundColor: 'rgba(229,224,216,0.3)', fill: true, tension: 0.3, pointRadius: 2 },
        { label: 'Valor total', data: dataInt, borderColor: '#1D4ED8', backgroundColor: 'rgba(29,78,216,0.15)', fill: true, tension: 0.3, pointRadius: 2 },
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { labels: { font: { family: "'DM Sans', sans-serif", size: 12 }, color: '#57534E' } } },
      scales: {
        y: { ticks: { callback: v => '$' + (v/1000).toFixed(0) + 'k', font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C' }, grid: { color: '#F0EDE7' } },
        x: { ticks: { font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C', maxTicksLimit: 10 }, grid: { display: false } }
      }
    }
  });
}

document.addEventListener('DOMContentLoaded', calcular);
</script>
</Layout>
