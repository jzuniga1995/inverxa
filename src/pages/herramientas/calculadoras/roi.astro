  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es el ROI?", "acceptedAnswer": { "@type": "Answer", "text": "ROI (Return on Investment) es el retorno sobre la inversión: la ganancia o pérdida neta expresada como porcentaje del capital invertido. Fórmula: ROI = (Valor Final - Inversión Inicial) / Inversión Inicial × 100." } },
