              onfocus="this.style.borderColor='#0891B2';" onblur="this.style.borderColor='#E5E0D8';" oninput="calcRent();" />
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-4">
        <div style="background:#0891B2; padding:24px;">
          <p style="font-size:11px; text-transform:uppercase; letter-spacing:0.15em; color:rgba(255,255,255,0.65); font-family:'DM Sans',sans-serif; margin-bottom:8px;">Valor final</p>
