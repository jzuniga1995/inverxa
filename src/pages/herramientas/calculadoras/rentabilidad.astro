    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }, "inLanguage": "es"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es el CAGR?", "acceptedAnswer": { "@type": "Answer", "text": "CAGR (Compound Annual Growth Rate) es la tasa de crecimiento anual compuesta. Representa el rendimiento anual constante que habría producido el mismo resultado final. Es la forma más precisa de comparar inversiones de diferentes duraciones." } },
      { "@type": "Question", "name": "¿Cuál es un buen rendimiento anual para una inversión?", "acceptedAnswer": { "@type": "Answer", "text": "El S&P 500 ha promediado ~10% anual nominal históricamente. Un portafolio diversificado puede aspirar a 7%-10% anual. Rendimientos superiores al 15% anual sostenido son muy difíciles de mantener y generalmente implican mayor riesgo." } },
