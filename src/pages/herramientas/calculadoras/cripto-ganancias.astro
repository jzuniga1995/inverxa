<script is:inline>
  function fmt(n) {
    return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
  }
  function fmtPct(n) {
    return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  }

  function calcular() {
    const pc  = parseFloat(document.getElementById('precio-compra').value) || 0;
    const pv  = parseFloat(document.getElementById('precio-venta').value)  || 0;
    const qty = parseFloat(document.getElementById('cantidad').value)      || 0;
    const fee = parseFloat(document.getElementById('fee').value)           || 0;
    const tax = parseFloat(document.getElementById('impuesto').value)      || 0;

    const feeRate = fee / 100;
    const taxRate = tax / 100;

    const inversionBruta = pc * qty;
    const feeCompra      = inversionBruta * feeRate;
    const inversionTotal = inversionBruta + feeCompra;

    const valorVentaBruto = pv * qty;
    const feeVenta        = valorVentaBruto * feeRate;
    const valorVentaNeto  = valorVentaBruto - feeVenta;

    const gananciaBruta = valorVentaBruto - inversionBruta;
    const gananciaNeta  = valorVentaNeto  - inversionTotal;
    const impuestoMonto = gananciaNeta > 0 ? gananciaNeta * taxRate : 0;
    const gananciaFinal = gananciaNeta - impuestoMonto;

    const roiBruto = pc > 0 ? ((pv - pc) / pc) * 100 : 0;
    const roiNeto  = inversionTotal > 0 ? (gananciaNeta / inversionTotal) * 100 : 0;

    const breakeven = pc > 0 ? (pc * (1 + feeRate)) / (1 - feeRate) : 0;
    const multiplicador = inversionTotal > 0 ? (valorVentaNeto / inversionTotal) : 0;
    const varPrecio = pc > 0 ? ((pv - pc) / pc) * 100 : 0;

    const isGain = gananciaFinal >= 0;
    const color  = isGain ? '#15803D' : '#B91C1C';

    document.getElementById('resultado-principal').style.background = color;
    document.getElementById('ganancia-neta').textContent = fmt(gananciaFinal);
    document.getElementById('ganancia-label').textContent = isGain ? 'ganancia neta después de fees e impuestos' : 'pérdida neta después de fees';

    document.getElementById('roi-bruto').textContent = fmtPct(roiBruto);
    document.getElementById('roi-bruto').style.color = roiBruto >= 0 ? '#15803D' : '#B91C1C';
    document.getElementById('roi-neto').textContent = fmtPct(roiNeto);
    document.getElementById('roi-neto').style.color = roiNeto >= 0 ? '#15803D' : '#B91C1C';

    document.getElementById('inversion-total').textContent = fmt(inversionTotal);
    document.getElementById('valor-venta').textContent     = fmt(valorVentaNeto);
    document.getElementById('fee-compra').textContent      = fmt(feeCompra);
    document.getElementById('fee-venta').textContent       = fmt(feeVenta);
    document.getElementById('ganancia-bruta').textContent  = fmt(gananciaBruta);
    document.getElementById('ganancia-bruta').style.color  = gananciaBruta >= 0 ? '#15803D' : '#B91C1C';
    document.getElementById('impuesto-monto').textContent  = fmt(impuestoMonto);
    document.getElementById('ganancia-final-row').textContent = fmt(gananciaFinal);
    document.getElementById('ganancia-final-row').style.color = color;

    document.getElementById('breakeven').textContent = fmt(breakeven);
    document.getElementById('breakeven').style.color = breakeven <= pv ? '#15803D' : '#B91C1C';

    document.getElementById('multiplicador').textContent = multiplicador.toFixed(2) + '×';
    document.getElementById('variacion-precio').textContent = fmtPct(varPrecio);
    document.getElementById('variacion-precio').style.color = varPrecio >= 0 ? '#15803D' : '#B91C1C';
  }

  document.getElementById('calcular-btn').addEventListener('click', calcular);
  document.querySelectorAll('.fee-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('fee').value = btn.dataset.fee;
    });
  });
  ['precio-compra','precio-venta','cantidad','fee','impuesto'].forEach(id => {
    document.getElementById(id).addEventListener('input', calcular);
  });

  calcular();
</script>
