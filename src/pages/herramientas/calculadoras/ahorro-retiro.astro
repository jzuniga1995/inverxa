<script is:inline>
let chartRetiro = null;
function fmt(n) { return '$' + Math.round(n).toLocaleString('es-CO'); }

function calcRetiro() {
  const edadA = parseFloat(document.getElementById('edadActual').value) || 30;
  const edadR = parseFloat(document.getElementById('edadRetiro').value) || 65;
  const ahorroAct = parseFloat(document.getElementById('ahorroActual').value) || 0;
  const ahorroMen = parseFloat(document.getElementById('ahorroMen').value) || 0;
  const rend = parseFloat(document.getElementById('rendRetiro').value) || 7;
  const anos = Math.max(0, edadR - edadA);
  const r = rend / 100 / 12;
  const n = anos * 12;
  const cap = ahorroAct * Math.pow(1 + r, n);
  const aportes = r > 0 ? ahorroMen * (Math.pow(1 + r, n) - 1) / r : ahorroMen * n;
  const total = cap + aportes;
  const aportado = ahorroAct + ahorroMen * n;
  const rendimientos = total - aportado;
  const rentaMen = total * 0.04 / 12;

  document.getElementById('ret-total').textContent = fmt(total);
  document.getElementById('ret-anos').textContent = `En ${anos} años · ${edadR} años`;
  document.getElementById('ret-aportado').textContent = fmt(aportado);
  document.getElementById('ret-rendim').textContent = fmt(rendimientos);
  document.getElementById('ret-renta').textContent = fmt(rentaMen) + '/mes';
  document.getElementById('ret-plazo').textContent = anos + ' años';

  const labels = [], dataCap = [], dataTot = [];
  for (let a = 0; a <= anos; a++) {
    const nn = a * 12;
    const c = ahorroAct * Math.pow(1 + r, nn);
    const ap = r > 0 ? ahorroMen * (Math.pow(1 + r, nn) - 1) / r : ahorroMen * nn;
    labels.push(edadA + a);
    dataCap.push(Math.round(ahorroAct + ahorroMen * nn));
    dataTot.push(Math.round(c + ap));
  }

  const ctx = document.getElementById('chart-retiro').getContext('2d');
  if (chartRetiro) chartRetiro.destroy();
  chartRetiro = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Total aportado', data: dataCap, borderColor: '#E5E0D8', backgroundColor: 'rgba(229,224,216,0.3)', fill: true, tension: 0.3, pointRadius: 0 },
        { label: 'Fondo proyectado', data: dataTot, borderColor: '#7C3AED', backgroundColor: 'rgba(124,58,237,0.12)', fill: true, tension: 0.3, pointRadius: 0 },
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { labels: { font: { family: "'DM Sans', sans-serif", size: 12 }, color: '#57534E' } } },
      scales: {
        y: { ticks: { callback: v => '$' + (v >= 1000000 ? (v/1000000).toFixed(1) + 'M' : (v/1000).toFixed(0) + 'k'), font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C' }, grid: { color: '#F0EDE7' } },
        x: { title: { display: true, text: 'Edad', font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#A8A29E' }, ticks: { font: { family: "'DM Sans', sans-serif", size: 11 }, color: '#78716C', maxTicksLimit: 10 }, grid: { display: false } }
      }
    }
  });
}
document.addEventListener('DOMContentLoaded', calcRetiro);
</script>
</Layout>
