---
// src/pages/herramientas/dolar.astro
import Layout from '../../layouts/Layout.astro';
import { DollarSign, RefreshCw, Globe } from 'lucide-astro';

// ── Sin fetch en SSR ──────────────────────────────────────────
// Los datos del dólar cargan client-side al montar la página
// para no bloquear el TTFB. El botón "Actualizar" y el
// auto-refresh cada 15 min siguen funcionando igual.
---

<Layout>
  <slot name="head" slot="head">
    <title>Precio del Dólar hoy — Oficial, Blue y Paralelo en LATAM | Inversax</title>
    <meta name="description" content="Precio del dólar hoy en Argentina, Venezuela y Latinoamérica. Dólar blue, oficial, MEP, CCL y tipos de cambio actualizados." />
  </slot>

  <main class="min-h-screen bg-[#0A0B0D] pt-28 pb-20 px-4 sm:px-6" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-5xl mx-auto">

      <!-- Encabezado -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(212,168,67,0.15);">
            <DollarSign size={20} class="text-[#D4A843]" />
          </div>
          <div>
            <h1 class="font-extrabold text-2xl sm:text-3xl text-white leading-tight" style="font-family: 'Syne', sans-serif;">
              Precio del Dólar
            </h1>
            <p class="text-white/40 text-sm">Oficial, blue y paralelo en Latinoamérica</p>
          </div>
        </div>

        <!-- Meta info + botón actualizar -->
        <div class="flex items-center justify-between flex-wrap gap-3">
          <div class="flex items-center gap-4 flex-wrap">
            <span class="flex items-center gap-1.5 text-xs text-white/30">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>
              Actualizado cada 15 minutos
            </span>
            <span id="ultima-actualizacion" class="text-xs text-white/20"></span>
          </div>
          <button
            id="btn-actualizar"
            class="flex items-center gap-1.5 text-xs text-white/40 hover:text-white border border-white/[0.07] hover:border-white/20 px-3 py-1.5 rounded-lg transition-colors duration-200 cursor-pointer bg-transparent"
          >
            <RefreshCw size={12} />
            Actualizar
          </button>
        </div>
      </div>

      <!-- Leyenda badges -->
      <div class="flex items-center gap-4 mb-6 flex-wrap">
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-400/10 text-emerald-400">OFICIAL</span>
          Tipo de cambio oficial del banco central
        </span>
        <span class="flex items-center gap-1.5 text-xs text-white/40">
          <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-[#D4A843]/10 text-[#D4A843]">PARALELO</span>
          Mercado informal o alternativo
        </span>
      </div>

      <!-- Grid de países — skeleton inicial, se llena client-side -->
      <div id="paises-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 items-start">

        <!-- Skeletons mientras cargan los datos -->
        {[...Array(6)].map(() => (
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden">
            <div class="flex items-center gap-3 px-4 py-3.5 border-b border-white/[0.07]">
              <div class="w-6 h-4 rounded-sm bg-white/5 animate-pulse flex-shrink-0"></div>
              <div class="flex-1 flex flex-col gap-1.5">
                <div class="w-24 h-3 bg-white/5 rounded animate-pulse"></div>
                <div class="w-16 h-2.5 bg-white/5 rounded animate-pulse"></div>
              </div>
            </div>
            <div class="divide-y divide-white/[0.05]">
              {[...Array(3)].map(() => (
                <div class="flex items-center justify-between px-4 py-3">
                  <div class="w-20 h-4 bg-white/5 rounded animate-pulse"></div>
                  <div class="w-16 h-4 bg-white/5 rounded animate-pulse"></div>
                </div>
              ))}
            </div>
          </div>
        ))}

      </div>

      <!-- Nota informativa -->
      <p class="text-white/15 text-xs text-center mt-8">
        Los precios paralelos son referenciales. Las fuentes utilizadas son bluelytics.com.ar y dolarapi.com.
        Los tipos de cambio oficiales provienen de fawazahmed0/currency-api.
      </p>

    </div>
  </main>
</Layout>

<script>
  const btnActualizar = document.getElementById('btn-actualizar');
  const grid          = document.getElementById('paises-grid') as HTMLElement;
  const ultimaAct     = document.getElementById('ultima-actualizacion');
  const icon          = btnActualizar?.querySelector('svg') as HTMLElement | null;

  const fmtNum = (n: number | null) => {
    if (n === null || n === undefined) return '—';
    if (n >= 100) return n.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return n.toLocaleString('es-AR', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  };

  function renderGrid(data: any[]) {
    grid.innerHTML = data.map((pais: any) => `
      <div class="bg-[#111318] border border-white/[0.07] hover:border-white/15 rounded-2xl overflow-hidden transition-colors duration-200">
        <div class="flex items-center gap-3 px-4 py-3.5 border-b border-white/[0.07]">
          <img
            src="https://flagcdn.com/w40/${pais.bandera}.png"
            alt="${pais.pais}"
            class="w-6 h-4 object-cover rounded-sm flex-shrink-0"
            onerror="this.style.display='none'"
          />
          <div class="flex-1 min-w-0">
            <div class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">${pais.pais}</div>
            <div class="text-[11px] text-white/35">${pais.moneda} · ${pais.simbolo}</div>
          </div>
        </div>
        <div class="divide-y divide-white/[0.05]">
          ${pais.variantes.map((v: any) => `
            <div class="flex items-center justify-between px-4 py-3 hover:bg-white/[0.02] transition-colors duration-150">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded flex-shrink-0 ${
                  v.esParalelo
                    ? 'bg-[#D4A843]/10 text-[#D4A843]'
                    : 'bg-emerald-400/10 text-emerald-400'
                }">
                  ${v.esParalelo ? 'PARALELO' : 'OFICIAL'}
                </span>
                <span class="text-white/60 text-xs truncate">${v.nombre}</span>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0 ml-2">
                ${v.compra !== null ? `
                  <div class="text-right">
                    <div class="text-[10px] text-white/25 leading-none mb-0.5">Compra</div>
                    <div class="text-xs text-white/60 font-medium">${fmtNum(v.compra)}</div>
                  </div>
                ` : ''}
                <div class="text-right">
                  <div class="text-[10px] text-white/25 leading-none mb-0.5">Venta</div>
                  <div class="font-bold text-sm text-white" style="font-family: 'Syne', sans-serif;">${fmtNum(v.venta)}</div>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      </div>
    `).join('');
  }

  async function cargarDatos() {
    btnActualizar?.setAttribute('disabled', 'true');
    if (icon) icon.style.animation = 'spin 1s linear infinite';

    try {
      const res  = await fetch('/api/dolar');
      const json = await res.json() as any;

      if (!json.ok || !json.data?.length) {
        // Error: mostrar mensaje en lugar del skeleton
        grid.innerHTML = `
          <div class="col-span-full flex flex-col items-center justify-center py-20 bg-[#111318] border border-white/[0.07] rounded-2xl">
            <p class="text-white/30 text-sm">Error al cargar los datos. Intenta de nuevo.</p>
          </div>`;
        return;
      }

      renderGrid(json.data);

      if (ultimaAct) {
        ultimaAct.textContent = new Date().toLocaleString('es-ES', {
          day: '2-digit', month: '2-digit', year: 'numeric',
          hour: '2-digit', minute: '2-digit',
        });
      }
    } catch (e) {
      console.error('[dolar page]', e);
    } finally {
      btnActualizar?.removeAttribute('disabled');
      if (icon) icon.style.animation = '';
    }
  }

  // Carga inmediata al montar + botón + auto-refresh
  cargarDatos();
  btnActualizar?.addEventListener('click', cargarDatos);
  setInterval(cargarDatos, 1000 * 60 * 15);
</script>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .animate-pulse { animation: pulse 1.5s ease-in-out infinite; }
</style>

