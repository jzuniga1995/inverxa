---
export const prerender = true;
// src/pages/terminos-condiciones.astro
import Layout from '../layouts/Layout.astro';
import { FileText, ArrowRight, Scale, BookOpen, Ban, AlertTriangle, Globe, RefreshCw, Mail, ChevronRight, ShieldCheck } from 'lucide-astro';

const ultimaActualizacion = "26 de febrero de 2025";
const sitioWeb = "https://inversax.com";
const correoContacto = "codezun@gmail.com";

const secciones = [
  { id: "aceptacion",     titulo: "Aceptación de los Términos"        },
  { id: "servicios",      titulo: "Descripción de los Servicios"      },
  { id: "uso-permitido",  titulo: "Uso Permitido"                     },
  { id: "prohibiciones",  titulo: "Conductas Prohibidas"              },
  { id: "contenido",      titulo: "Propiedad Intelectual"             },
  { id: "disclaimer",     titulo: "Descargo de Responsabilidad"       },
  { id: "afiliados",      titulo: "Divulgación de Afiliados"          },
  { id: "publicidad",     titulo: "Publicidad de Terceros"            },
  { id: "enlaces",        titulo: "Enlaces a Sitios Externos"         },
  { id: "modificaciones", titulo: "Modificaciones al Servicio"        },
  { id: "ley",            titulo: "Ley Aplicable"                     },
  { id: "contacto",       titulo: "Contacto"                          },
];
---

<Layout>
  <slot name="head" slot="head">
    <title>Aviso Legal — Inversax</title>
    <meta name="description" content="Aviso legal de Inversax. Conoce tus derechos y responsabilidades al usar nuestra plataforma financiera." />
    <link rel="canonical" href={`${sitioWeb}/legal`} />
  </slot>

  <!-- HEADER EDITORIAL -->
  <div style="background: #FAFAF8; border-bottom: 1px solid #E5E0D8;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <div class="flex items-center gap-2 text-sm mb-6" style="color: #A8A29E;">
        <a href="/" class="no-underline hover:underline" style="color: #A8A29E;">Inicio</a>
        <span>›</span>
        <span style="color: #57534E;">Aviso Legal</span>
      </div>
      <h1 style="font-family: 'Playfair Display', serif; font-size: clamp(28px, 4vw, 42px); font-weight: 700; color: #1C1917; line-height: 1.2; margin: 0 0 12px;">
        Aviso Legal
      </h1>
      <p style="color: #78716C; font-size: 14px; margin: 0;">
        Última actualización: <span style="color: #57534E; font-weight: 600;">{ultimaActualizacion}</span>
      </p>
    </div>
  </div>

  <!-- CONTENIDO PRINCIPAL -->
  <div style="background: #FAFAF8; min-height: 60vh;">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">

      <!-- Intro -->
      <p style="color: #57534E; font-size: 15px; line-height: 1.8; margin-bottom: 40px;">
        Bienvenido a <strong style="color: #1C1917;">Inversax</strong>. Al acceder o utilizar nuestro sitio web en <a href={sitioWeb} class="no-underline" style="color: #B91C1C;">{sitioWeb}</a> y cualquiera de nuestros servicios asociados, aceptas quedar vinculado por estos Términos y Condiciones de Uso. Si no estás de acuerdo con alguno de estos términos, te pedimos que no utilices nuestros servicios.
      </p>

      <!-- 1. Aceptación -->
      <div id="aceptacion" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">1. Aceptación de los Términos</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Al acceder a Inversax, confirmas que tienes al menos 18 años de edad o la mayoría de edad legal en tu país de residencia, que tienes capacidad legal para aceptar estos términos, y que utilizarás el servicio de conformidad con todas las leyes aplicables.</p>
          <p style="margin: 0;">El uso continuado de la plataforma tras cualquier modificación de estos términos constituye la aceptación de los nuevos términos. Te recomendamos revisar esta página periódicamente.</p>
        </div>
      </div>

      <!-- 2. Servicios -->
      <div id="servicios" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">2. Descripción de los Servicios</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Inversax es una plataforma de información financiera que ofrece los siguientes servicios:</p>
          <ul style="margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 6px;">
            {[
              "Noticias y análisis financieros",
              "Precios de criptomonedas en tiempo real",
              "Cotizaciones de acciones, forex e índices",
              "Tipo de cambio del dólar por país",
              "Herramientas y calculadoras financieras",
              "Cobertura financiera por país en LATAM y el mundo",
            ].map((item) => (
              <li style="padding-left: 4px;">{item}</li>
            ))}
          </ul>
          <p style="margin: 0;">Nos reservamos el derecho de modificar, suspender o discontinuar cualquier parte de los servicios en cualquier momento, con o sin previo aviso.</p>
        </div>
      </div>

      <!-- 3. Uso permitido -->
      <div id="uso-permitido" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">3. Uso Permitido</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Inversax te otorga una licencia limitada, no exclusiva e intransferible para acceder y utilizar el sitio de forma personal y no comercial. Esto incluye:</p>
          <ul style="margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 6px;">
            {[
              "Consultar noticias, precios y herramientas para uso personal",
              "Compartir enlaces a nuestro contenido con atribución",
              "Utilizar nuestras calculadoras y herramientas para tomar decisiones informadas",
            ].map((item) => (
              <li style="padding-left: 4px;">{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- 4. Prohibiciones -->
      <div id="prohibiciones" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">4. Conductas Prohibidas</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Queda estrictamente prohibido:</p>
          <ul style="margin: 0; padding-left: 20px; display: flex; flex-direction: column; gap: 6px;">
            {[
              "Copiar, reproducir o redistribuir nuestro contenido sin autorización escrita",
              "Usar robots, scrapers o herramientas automatizadas para extraer datos del sitio",
              "Intentar acceder a áreas restringidas o sistemas internos de Inversax",
              "Publicar contenido falso, engañoso o que viole derechos de terceros",
              "Utilizar el sitio para actividades ilegales o fraudulentas",
              "Interferir con el funcionamiento normal del sitio o sus servidores",
              "Suplantar la identidad de Inversax o de cualquier persona o entidad",
              "Usar el contenido del sitio con fines comerciales sin autorización previa",
            ].map((item) => (
              <li style="padding-left: 4px;">{item}</li>
            ))}
          </ul>
          <p style="margin: 0;">El incumplimiento de estas normas puede resultar en la suspensión del acceso al sitio y acciones legales si corresponde.</p>
        </div>
      </div>

      <!-- 5. Propiedad Intelectual -->
      <div id="contenido" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">5. Propiedad Intelectual</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Todo el contenido disponible en Inversax, incluyendo pero no limitado a textos, artículos, gráficos, logotipos, íconos, imágenes, clips de audio, descargas digitales y compilaciones de datos, es propiedad de Inversax o de sus proveedores de contenido, y está protegido por las leyes de propiedad intelectual aplicables.</p>
          <p style="margin: 0;">La marca <strong style="color: #1C1917;">Inversax</strong>, su logotipo y todos los nombres de productos y servicios relacionados son marcas comerciales de Inversax. No puedes usar estas marcas sin el consentimiento previo y por escrito de Inversax.</p>
          <div style="background: #F5F1EC; border-left: 3px solid #E5E0D8; padding: 16px 20px;">
            <p style="margin: 0; font-size: 14px; color: #57534E;">
              <strong style="color: #1C1917;">Citas y referencias:</strong> Puedes citar fragmentos breves de nuestro contenido siempre que se incluya un enlace de atribución visible hacia la fuente original en Inversax.
            </p>
          </div>
        </div>
      </div>

      <!-- 6. Disclaimer -->
      <div id="disclaimer" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">6. Descargo de Responsabilidad</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 16px;">
          <div style="background: #FEF2F2; border-left: 3px solid #B91C1C; padding: 16px 20px;">
            <p style="margin: 0 0 8px; font-weight: 700; color: #B91C1C; font-size: 14px;">No somos asesores financieros</p>
            <p style="margin: 0; font-size: 14px; color: #57534E; line-height: 1.7;">Todo el contenido publicado en Inversax tiene carácter exclusivamente informativo y educativo. Nada de lo publicado en este sitio constituye asesoramiento financiero, de inversión, tributario o legal. No somos una entidad regulada ni autorizada para prestar servicios de asesoramiento financiero.</p>
          </div>
          <p style="margin: 0;">Los mercados financieros y las criptomonedas son instrumentos de alto riesgo. Los precios y datos mostrados pueden tener retrasos y no deben utilizarse como única base para tomar decisiones de inversión. Inversax no se hace responsable de pérdidas económicas derivadas del uso de la información publicada en este sitio.</p>
          <p style="margin: 0;">Siempre consulta con un profesional financiero certificado antes de tomar cualquier decisión de inversión.</p>
        </div>
      </div>

      <!-- 7. Afiliados -->
      <div id="afiliados" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">7. Divulgación de Afiliados</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 16px;">
          <p style="margin: 0;">Inversax participa en programas de marketing de afiliados con plataformas financieras, exchanges de criptomonedas y brokers de inversión. Algunos de los enlaces publicados en nuestro contenido son enlaces de afiliado.</p>
          <div style="background: #F5F1EC; border-left: 3px solid #E5E0D8; padding: 16px 20px;">
            <p style="margin: 0; font-size: 14px; color: #57534E;">
              <strong style="color: #1C1917;">Transparencia:</strong> Cuando hagas clic en un enlace de afiliado y realices una acción como registrarte o depositar fondos, Inversax puede recibir una compensación económica. Esto nunca representa un costo adicional para ti. Todos los enlaces de afiliado están identificados claramente con las etiquetas <strong>"Publicidad"</strong> o <strong>"Patrocinado"</strong>.
            </p>
          </div>
          <p style="margin: 0;">Nuestra política editorial es independiente de estas relaciones comerciales. Solo recomendamos plataformas que consideramos legítimas, aunque te instamos a investigar por tu cuenta antes de usar cualquier servicio financiero.</p>
        </div>
      </div>

      <!-- 8. Publicidad -->
      <div id="publicidad" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">8. Publicidad de Terceros</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Inversax muestra anuncios de terceros a través de redes publicitarias como Google AdSense. Estos anunciantes pueden utilizar cookies y tecnologías de seguimiento para personalizar los anuncios que ves.</p>
          <p style="margin: 0;">Inversax no es responsable del contenido de los anuncios de terceros ni de las prácticas de privacidad de los anunciantes. El hecho de que un anuncio aparezca en Inversax no implica ningún tipo de respaldo o recomendación de nuestra parte.</p>
        </div>
      </div>

      <!-- 9. Enlaces externos -->
      <div id="enlaces" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">9. Enlaces a Sitios Externos</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Nuestro sitio puede contener enlaces a sitios web de terceros. Estos enlaces se proporcionan únicamente como referencia informativa. Inversax no tiene control sobre el contenido de esos sitios y no asume ninguna responsabilidad por su contenido, políticas de privacidad o prácticas.</p>
          <p style="margin: 0;">El acceso a sitios de terceros es bajo tu propio riesgo. Te recomendamos leer los términos y condiciones y políticas de privacidad de cualquier sitio externo que visites.</p>
        </div>
      </div>

      <!-- 10. Modificaciones -->
      <div id="modificaciones" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">10. Modificaciones al Servicio y Términos</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Inversax se reserva el derecho de modificar estos Términos y Condiciones en cualquier momento. Los cambios entrarán en vigor en el momento de su publicación en esta página. La fecha de última actualización al inicio del documento reflejará siempre la versión vigente.</p>
          <p style="margin: 0;">Asimismo, podemos modificar, suspender o discontinuar cualquier aspecto del servicio, incluyendo la disponibilidad de funciones, bases de datos o contenido, sin previo aviso ni responsabilidad alguna.</p>
        </div>
      </div>

      <!-- 11. Ley aplicable -->
      <div id="ley" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">11. Ley Aplicable y Jurisdicción</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 12px;">
          <p style="margin: 0;">Estos Términos y Condiciones se rigen e interpretan de conformidad con las leyes aplicables del país de operación de Inversax. Cualquier disputa que surja en relación con estos términos se someterá a la jurisdicción de los tribunales competentes.</p>
          <p style="margin: 0;">Si alguna disposición de estos términos fuera declarada inválida o inaplicable por un tribunal competente, las disposiciones restantes continuarán en pleno vigor y efecto.</p>
        </div>
      </div>

      <!-- 12. Contacto -->
      <div id="contacto" class="scroll-mt-6" style="border-top: 1px solid #E5E0D8; padding-top: 32px; margin-bottom: 32px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; color: #1C1917; margin: 0 0 16px;">12. Contacto</h2>
        <div style="color: #57534E; font-size: 15px; line-height: 1.8; display: flex; flex-direction: column; gap: 16px;">
          <p style="margin: 0;">Si tienes preguntas, inquietudes o comentarios sobre estos Términos y Condiciones, puedes contactarnos a través de:</p>
          <div style="background: #F5F1EC; border: 1px solid #E5E0D8; padding: 20px; display: flex; flex-direction: column; gap: 10px;">
            <a href={`mailto:${correoContacto}`} class="no-underline" style="color: #B91C1C; font-size: 14px;">{correoContacto}</a>
            <a href={sitioWeb} class="no-underline" style="color: #B91C1C; font-size: 14px;">{sitioWeb}</a>
          </div>
        </div>
      </div>

      <!-- Aviso final -->
      <div style="background: #FEF2F2; border-left: 3px solid #B91C1C; padding: 20px 24px; margin-bottom: 32px;">
        <p style="margin: 0 0 8px; font-weight: 700; color: #B91C1C; font-size: 14px;">Recuerda siempre</p>
        <p style="margin: 0; color: #57534E; font-size: 14px; line-height: 1.7;">
          Invertir en criptomonedas, acciones u otros activos financieros conlleva riesgos significativos incluyendo la pérdida total del capital invertido. Toda la información en Inversax es de carácter informativo únicamente. Nunca inviertas dinero que no puedas permitirte perder.
        </p>
      </div>

      <!-- Links a otras políticas -->
      <div style="border-top: 1px solid #E5E0D8; padding-top: 24px;">
        <p style="color: #A8A29E; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; margin: 0 0 16px;">Documentos relacionados</p>
        <a href="/privacidad" class="no-underline" style="display: inline-flex; align-items: center; gap: 8px; color: #B91C1C; font-size: 14px; font-weight: 600;">
          Políticas de Privacidad <ArrowRight size={14} />
        </a>
      </div>

    </div>
  </div>
</Layout>
