---
// src/pages/pais/[codigo].astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulosPorPais, getCategorias, getPaises } from '../../db/queries';
import { ArrowRight, Clock, MapPin, Filter } from 'lucide-astro';

const { codigo } = Astro.params;
if (!codigo) return Astro.redirect('/paises');

const db          = Astro.locals.db;
const todosPaises = await getPaises(db);
const paisActual  = todosPaises.find((p) => p.codigo === codigo && p.codigo !== 'global');
if (!paisActual) return Astro.redirect('/paises');

const categoriaParam = Astro.url.searchParams.get('categoria') ?? 'todas';

const [articulos, categorias] = await Promise.all([
  getArticulosPorPais(db, codigo, 50),
  getCategorias(db),
]);

const articulosFiltrados = categoriaParam === 'todas'
  ? articulos
  : articulos.filter((a) => a.categoria?.slug === categoriaParam);

const [principal, ...resto] = articulosFiltrados;

const regiones: Record<string, string> = {
  ar: 'Latinoamérica', bo: 'Latinoamérica', br: 'Latinoamérica',
  cl: 'Latinoamérica', co: 'Latinoamérica', cu: 'Latinoamérica',
  ec: 'Latinoamérica', mx: 'Latinoamérica', py: 'Latinoamérica',
  pe: 'Latinoamérica', uy: 'Latinoamérica', ve: 'Latinoamérica',
  bz: 'América Central', cr: 'América Central', sv: 'América Central',
  gt: 'América Central', hn: 'América Central', ni: 'América Central', pa: 'América Central',
  do: 'Caribe', pr: 'Caribe',
  us: 'Norteamérica', ca: 'Norteamérica',
  es: 'Europa', ad: 'Europa', de: 'Europa', fr: 'Europa',
  gb: 'Europa', it: 'Europa', nl: 'Europa', pt: 'Europa', ch: 'Europa',
  gq: 'África', ma: 'África',
  au: 'Oceanía / Asia', ph: 'Oceanía / Asia',
};

const region = regiones[codigo] ?? 'Internacional';

// ── Descripciones SEO por país ──────────────────────────────────────────────
const descripcionesPais: Record<string, string> = {
  ar: 'Dólar blue, Merval, Cedears, AFIP e inflación en Argentina. Todo sobre la economía argentina explicado para el ciudadano de a pie, actualizado cada día.',
  mx: 'Tipo de cambio peso-dólar, CETES, BMV, SAT, Banxico e inflación en México. Información financiera actualizada para el inversionista mexicano.',
  co: 'Peso colombiano, Banrep, DIAN, Bolsa de Valores de Colombia, CDTs e inflación. Todo lo que necesitas para invertir desde Colombia.',
  pe: 'Sol peruano, BVL, SUNAT, AFP e inflación en Perú. Noticias financieras y herramientas para el inversionista peruano.',
  hn: 'Lempira, BCH, SAR, remesas e inversiones en Honduras. Finanzas personales y economía hondureña explicada sin tecnicismos.',
  cl: 'Peso chileno, BCCh, CMF, AFP y bolsa en Chile. Noticias de economía e inversiones actualizadas para el chileno de a pie.',
  ve: 'Bolívar, dólar paralelo, economía venezolana y criptomonedas como refugio de valor. Actualizado cada día para Venezuela.',
  ec: 'Economía dolarizada, BCE, SRI e inversiones en Ecuador. Todo sobre finanzas personales y mercados para el ecuatoriano.',
  bo: 'Boliviano, BCB, impuestos y finanzas personales en Bolivia. Noticias económicas actualizadas para el boliviano.',
  py: 'Guaraní, BCP, SET e inversiones en Paraguay. Economía y finanzas personales para el paraguayo.',
  uy: 'Peso uruguayo, BCU, IRPF e inversiones en Uruguay. Finanzas personales y mercados para el uruguayo.',
  cr: 'Colón costarricense, BCCR, Hacienda e inversiones en Costa Rica. Economía y finanzas personales actualizadas.',
  gt: 'Quetzal, Banguat, SAT e inversiones en Guatemala. Finanzas personales y economía guatemalteca.',
  sv: 'Bitcoin como moneda legal, economía dolarizada y finanzas en El Salvador. Actualizado para el salvadoreño.',
  pa: 'Economía dolarizada, MEF e inversiones en Panamá. Centro financiero de Latinoamérica explicado.',
  do: 'Peso dominicano, BCRD, DGII e inversiones en República Dominicana. Finanzas y economía dominicana.',
  cu: 'Economía cubana, peso cubano y finanzas personales en Cuba. Actualizado con contexto regional.',
  ni: 'Córdoba nicaragüense, BCN e inversiones en Nicaragua. Economía y finanzas personales actualizadas.',
  bz: 'Dólar de Belice, economía y finanzas personales. Cobertura financiera para Belice en español.',
  pr: 'Economía de Puerto Rico, finanzas personales y mercados en dólares. Actualizado para Puerto Rico.',
  us: 'Mercados financieros de EE.UU., Fed, S&P 500, Nasdaq y economía americana. Explicado en español para la comunidad latina.',
  ca: 'Dólar canadiense, Banco de Canadá y mercados en Canadá. Finanzas en español para la comunidad hispanohablante en Canadá.',
  es: 'Euro, Banco de España, IBEX 35, Hacienda e inversiones en España. Finanzas personales y mercados para el español.',
  de: 'Euro, Bundesbank, DAX y economía alemana. Finanzas en español para hispanohablantes en Alemania.',
  fr: 'Euro, Banco de Francia, CAC 40 y economía francesa. Finanzas en español para hispanohablantes en Francia.',
  gb: 'Libra esterlina, Banco de Inglaterra, FTSE 100 y economía del Reino Unido en español.',
  it: 'Euro, Banco de Italia, FTSE MIB y economía italiana. Finanzas en español para hispanohablantes en Italia.',
  nl: 'Euro, economía neerlandesa y mercados europeos. Finanzas en español para Países Bajos.',
  pt: 'Euro, Banco de Portugal, PSI 20 e inversiones en Portugal. Finanzas en español.',
  ch: 'Franco suizo, SNB y economía suiza. Centro financiero europeo explicado en español.',
  ad: 'Finanzas, economía e inversiones en Andorra en español. Paraíso fiscal europeo explicado.',
  ma: 'Dírham marroquí, finanzas e inversiones en Marruecos. Cobertura en español.',
  gq: 'Franco CFA, economía y finanzas en Guinea Ecuatorial. El único país hispanohablante de África.',
  au: 'Dólar australiano, RBA, ASX y economía australiana. Finanzas en español para hispanohablantes en Australia.',
  ph: 'Peso filipino, BSP y economía de Filipinas. Finanzas en español para la comunidad hispanohablante en Filipinas.',
};

const descripcion = descripcionesPais[codigo] ??
  `Finanzas, cripto, trading y economía en ${paisActual.nombre}. Noticias actualizadas cada día para inversores y traders en ${region}.`;

// ── Flag helper ──────────────────────────────────────────────────────────────
function getFlagCode(cod: string): string {
  const overrides: Record<string, string> = { gb: 'gb', pr: 'pr' };
  return overrides[cod] ?? cod;
}

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<Layout categorias={categorias} paises={todosPaises}>

<slot name="head" slot="head">

  <!-- ═══════════════════════════════════════
       PRECONNECT
  ═══════════════════════════════════════ -->
  <link rel="preconnect" href="https://res.cloudinary.com" />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://flagcdn.com" />
  <link rel="dns-prefetch" href="https://flagcdn.com" />

  <!-- ═══════════════════════════════════════
       BASIC SEO
  ═══════════════════════════════════════ -->
  <title>Finanzas en {paisActual.nombre} — Cripto, Bolsa y Trading | Inversax</title>
  <meta name="description" content={descripcion} />
  <meta name="author"         content="José Zúniga" />
  <meta name="robots"         content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="googlebot"      content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="googlebot-news" content="index, follow" />
  <link rel="canonical"       href={`https://inversax.com/pais/${codigo}`} />

  <!-- ═══════════════════════════════════════
       KEYWORDS
  ═══════════════════════════════════════ -->
  <meta name="keywords" content={`finanzas ${paisActual.nombre}, cripto ${paisActual.nombre}, trading ${paisActual.nombre}, bolsa ${paisActual.nombre}, inversiones ${paisActual.nombre}, forex ${paisActual.nombre}, economía ${paisActual.nombre}, noticias financieras ${paisActual.nombre}`} />
  <meta name="news_keywords" content={`${paisActual.nombre}, finanzas, cripto, trading, Inversax`} />

  <!-- ═══════════════════════════════════════
       GEO
  ═══════════════════════════════════════ -->
  <meta name="geo.region"       content={codigo.toUpperCase()} />
  <meta name="geo.placename"    content={paisActual.nombre} />
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />

  <!-- ═══════════════════════════════════════
       HREFLANG
  ═══════════════════════════════════════ -->
  <link rel="alternate" hreflang="es"                           href={`https://inversax.com/pais/${codigo}`} />
  <link rel="alternate" hreflang={`es-${codigo.toUpperCase()}`} href={`https://inversax.com/pais/${codigo}`} />
  <link rel="alternate" hreflang="x-default"                    href={`https://inversax.com/pais/${codigo}`} />

  <!-- ═══════════════════════════════════════
       OPEN GRAPH
  ═══════════════════════════════════════ -->
  <meta property="og:site_name"        content="Inversax" />
  <meta property="og:locale"           content="es_LA" />
  <meta property="og:locale:alternate" content="es_MX" />
  <meta property="og:locale:alternate" content="es_AR" />
  <meta property="og:locale:alternate" content="es_CO" />
  <meta property="og:locale:alternate" content="es_ES" />
  <meta property="og:type"             content="website" />
  <meta property="og:title"            content={`Finanzas en ${paisActual.nombre} — Cripto, Bolsa y Trading | Inversax`} />
  <meta property="og:description"      content={descripcion} />
  <meta property="og:url"              content={`https://inversax.com/pais/${codigo}`} />
  <meta property="og:image"            content={`https://inversax.com/og/pais/${codigo}.png`} />
  <meta property="og:image:width"      content="1200" />
  <meta property="og:image:height"     content="630" />
  <meta property="og:image:alt"        content={`Finanzas en ${paisActual.nombre} — Inversax`} />
  <meta property="og:image:type"       content="image/png" />

  <!-- ═══════════════════════════════════════
       TWITTER CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:creator"     content="@inversax" />
  <meta name="twitter:title"       content={`Finanzas en ${paisActual.nombre} — Cripto, Bolsa y Trading | Inversax`} />
  <meta name="twitter:description" content={descripcion} />
  <meta name="twitter:image"       content={`https://inversax.com/og/pais/${codigo}.png`} />
  <meta name="twitter:image:alt"   content={`Finanzas en ${paisActual.nombre} — Inversax`} />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebSite + SearchAction
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Noticias de cripto, trading, forex y bolsa en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://inversax.com/noticias?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebPage con Place
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `Finanzas en ${paisActual.nombre} — Inversax`,
    "description": descripcion,
    "url": `https://inversax.com/pais/${codigo}`,
    "inLanguage": "es",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://inversax.com/favicon.png",
        "width": 200,
        "height": 60
      }
    },
    "about": {
      "@type": "Place",
      "name": paisActual.nombre,
      "addressCountry": codigo.toUpperCase()
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — CollectionPage
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Noticias financieras en ${paisActual.nombre}`,
    "description": descripcion,
    "url": `https://inversax.com/pais/${codigo}`,
    "inLanguage": "es",
    "publisher": {
      "@type": "Organization",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
    "about": {
      "@type": "Thing",
      "name": `Finanzas en ${paisActual.nombre}`
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — BreadcrumbList
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio",         "item": "https://inversax.com" },
      { "@type": "ListItem", "position": 2, "name": "Países",         "item": "https://inversax.com/paises" },
      { "@type": "ListItem", "position": 3, "name": region,           "item": "https://inversax.com/paises" },
      { "@type": "ListItem", "position": 4, "name": paisActual.nombre,"item": `https://inversax.com/pais/${codigo}` }
    ]
  })} />

</slot>

  <div style="background:#FAFAF8;min-height:100vh;font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm mb-8 flex-wrap" style="color:#A8A29E;">
        <a href="/" class="hover:text-[#1C1917] transition-colors duration-200 no-underline">Inicio</a>
        <ArrowRight size={13} />
        <a href="/paises" class="hover:text-[#1C1917] transition-colors duration-200 no-underline">Países</a>
        <ArrowRight size={13} />
        <span class="text-xs" style="color:#A8A29E;">{region}</span>
        <ArrowRight size={13} />
        <span style="color:#1C1917;">{paisActual.nombre}</span>
      </div>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-3">
          <!-- ✅ BANDERA REAL EN HEADER -->
          <img
            src={`https://flagcdn.com/w40/${getFlagCode(codigo)}.png`}
            alt={`Bandera de ${paisActual.nombre}`}
            width="40"
            height="28"
            loading="eager"
            class="rounded-md object-cover flex-shrink-0"
            style="width:40px;height:28px;"
          />
          <div>
            <span class="text-xs uppercase tracking-widest" style="color:#A8A29E;">{region}</span>
            <h1 class="font-extrabold text-2xl sm:text-3xl leading-tight" style="color:#1C1917;font-family:'Playfair Display',serif;">
              {paisActual.nombre}
            </h1>
          </div>
        </div>
        <!-- ✅ DESCRIPCIÓN SEO ESPECÍFICA POR PAÍS -->
        <p class="text-sm max-w-xl leading-relaxed" style="color:#78716C;">
          {descripcion}
        </p>
      </div>

      <!-- Filtro por categoría -->
      <div class="flex items-center gap-2 overflow-x-auto pb-2 mb-10 scrollbar-hide">
        <Filter size={14} class="flex-shrink-0" style="color:#A8A29E;" />
        <a
          href={`/pais/${codigo}`}
          class="flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium no-underline transition-all duration-200"
          style={categoriaParam === 'todas'
            ? 'background:#B91C1C;color:#fff;'
            : 'background:#F5F1EC;border:1px solid #D6D0C8;color:#57534E;'}
        >
          Todas
        </a>
        {categorias.map((cat) => (
          <a
            href={`/pais/${codigo}?categoria=${cat.slug}`}
            class="flex-shrink-0 px-4 py-1.5 rounded-full text-xs font-medium no-underline transition-all duration-200"
            style={categoriaParam === cat.slug
              ? 'background:#B91C1C;color:#fff;'
              : 'background:#F5F1EC;border:1px solid #D6D0C8;color:#57534E;'}
          >
            {cat.nombre}
          </a>
        ))}
      </div>

      <!-- Sin artículos -->
      {articulosFiltrados.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-24 rounded-2xl gap-4 text-center" style="background:#F5F1EC;border:1px solid #E5E0D8;">
          <MapPin size={32} style="color:#C7BFB5;" />
          <p class="text-base font-medium" style="color:#57534E;font-family:'DM Sans',sans-serif;">
            Próximamente en {paisActual.nombre}
          </p>
          <p class="text-sm max-w-xs leading-relaxed" style="color:#A8A29E;">
            Estamos trabajando para traerte contenido local. Por ahora podés explorar las noticias globales.
          </p>
          <a href="/noticias" class="mt-2 text-sm font-medium hover:underline no-underline" style="color:#B91C1C;">
            Ver noticias globales →
          </a>
        </div>

      ) : (
        <div class="flex flex-col lg:flex-row gap-8">

          <!-- CONTENIDO -->
          <div class="flex-1 min-w-0 flex flex-col gap-6">

            <!-- Artículo principal -->
            {principal && (
              <a
                href={`/noticias/${principal.slug}`}
                class="group rounded-2xl overflow-hidden no-underline flex flex-col sm:flex-row sm:min-h-[220px] transition-colors duration-300"
                style="background:#fff;border:1px solid #E5E0D8;"
              >
                <div class="w-full sm:w-72 lg:w-80 h-52 sm:h-full flex-shrink-0 overflow-hidden" style="background:#F0EDE7;">
                  {principal.imagen
                    ? <img src={principal.imagen} alt={principal.titulo} class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" />
                    : <div class="w-full h-full" style="background: linear-gradient(135deg, #F0EDE7, #E5E0D8);" />
                  }
                </div>
                <div class="flex flex-col justify-center gap-3 p-6">
                  <div class="flex items-center gap-2 flex-wrap">
                    {principal.categoria && (
                      <span class="text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider" style="color:#B91C1C;background:#FEF2F2;">
                        {principal.categoria.nombre}
                      </span>
                    )}
                    <span class="text-xs flex items-center gap-1 ml-auto" style="color:#A8A29E;">
                      <Clock size={11} /> {formatFecha(principal.creadoEn)}
                    </span>
                  </div>
                  <h2 class="font-bold text-xl leading-snug group-hover:text-[#B91C1C] transition-colors duration-200" style="color:#1C1917;font-family:'Playfair Display',serif;">
                    {principal.titulo}
                  </h2>
                  {principal.resumen && (
                    <p class="text-sm leading-relaxed line-clamp-2" style="color:#78716C;">{principal.resumen}</p>
                  )}
                  <span class="flex items-center gap-1.5 text-sm font-medium mt-1" style="color:#B91C1C;">
                    Leer artículo <ArrowRight size={14} />
                  </span>
                </div>
              </a>
            )}

            <!-- Grid resto -->
            {resto.length > 0 && (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {resto.map((art) => (
                  <a
                    href={`/noticias/${art.slug}`}
                    class="group flex flex-col rounded-2xl overflow-hidden no-underline transition-colors duration-200"
                    style="background:#fff;border:1px solid #E5E0D8;"
                  >
                    {art.imagen
                      ? (
                        <div class="w-full h-44 overflow-hidden flex-shrink-0" style="background:#F0EDE7;">
                          <img src={art.imagen} alt={art.titulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        </div>
                      ) : (
                        <div class="w-full h-44 flex-shrink-0" style="background: linear-gradient(135deg, #F0EDE7, #E5E0D8);"></div>
                      )
                    }
                    <div class="flex flex-col gap-2 p-4 flex-1">
                      <div class="flex items-center gap-2 flex-wrap">
                        {art.categoria && (
                          <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#B91C1C;background:#FEF2F2;padding:1px 6px;border-radius:3px;">
                            {art.categoria.nombre}
                          </span>
                        )}
                        <span class="text-[10px] flex items-center gap-0.5 ml-auto" style="color:#A8A29E;">
                          <Clock size={9} /> {formatFecha(art.creadoEn)}
                        </span>
                      </div>
                      <h3 class="font-bold text-sm leading-snug group-hover:text-[#B91C1C] transition-colors duration-200 line-clamp-3" style="color:#1C1917;font-family:'Playfair Display',serif;">
                        {art.titulo}
                      </h3>
                      {art.resumen && (
                        <p class="text-xs leading-relaxed line-clamp-2 mt-auto pt-1" style="color:#78716C;">{art.resumen}</p>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            )}

          </div>

          <!-- SIDEBAR — países de la región con banderas -->
          <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0">
            <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
              <h3 class="font-bold text-sm mb-4" style="color:#1C1917;font-family:'DM Sans',sans-serif;">
                {region}
              </h3>
              <div class="flex flex-col gap-1">
                {todosPaises
                  .filter((p) => p.codigo !== 'global' && p.codigo !== codigo && regiones[p.codigo] === region)
                  .slice(0, 8)
                  .map((p) => (
                    <!-- ✅ BANDERAS EN SIDEBAR -->
                    <a
                      href={`/pais/${p.codigo}`}
                      class="flex items-center justify-between px-3 py-2 rounded-lg text-sm no-underline transition-colors duration-200 hover:bg-[#E8E3DC]"
                      style="color:#57534E;"
                    >
                      <span class="flex items-center gap-2">
                        <img
                          src={`https://flagcdn.com/w40/${getFlagCode(p.codigo)}.png`}
                          alt={`Bandera de ${p.nombre}`}
                          width="20"
                          height="14"
                          loading="lazy"
                          class="rounded-sm object-cover flex-shrink-0"
                          style="width:20px;height:14px;"
                        />
                        {p.nombre}
                      </span>
                      <ArrowRight size={13} />
                    </a>
                  ))
                }
                <a
                  href="/paises"
                  class="flex items-center justify-between px-3 py-2 rounded-lg text-xs no-underline transition-colors duration-200 mt-1 pt-3 hover:bg-[#E8E3DC]"
                  style="color:#B91C1C;border-top:1px solid #E5E0D8;"
                >
                  Ver todos los países
                  <ArrowRight size={12} />
                </a>
              </div>
            </div>
          </aside>

        </div>
      )}

    </div>
  </div>
</Layout>

