---
// src/pages/autor/jose-zuniga.astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulos } from '../../db/queries';
import { Clock, ArrowRight, Globe, Twitter, Github, Linkedin } from 'lucide-astro';

const db = Astro.locals.db;
const todosArticulos = await getArticulos(db, 24);

// Filtra solo artículos globales (misma lógica que /noticias)
const articulos = todosArticulos.filter(a => !a.pais || a.pais.codigo === 'global');

const autor = {
  nombre:    'José Zúniga',
  rol:       'Fundador & Editor',
  slug:      'jose-zuniga',
  bio:       'Desarrollador de software con una pasión profunda por los mercados financieros, las criptomonedas y la economía latinoamericana. Creé Inversax con el objetivo de llevar información financiera clara, accesible y de calidad a toda la región. Cada artículo que encuentras aquí pasa por mi revisión editorial antes de publicarse.',
  bioExtra:  'Combino mi background técnico con años de seguimiento activo de mercados para asegurar que el contenido no solo sea preciso, sino también útil para quienes están comenzando a invertir o quieren profundizar sus conocimientos.',
  skills:    ['Desarrollo de Software', 'Análisis de Mercados', 'Criptomonedas', 'Trading', 'Economía LatAm', 'Finanzas Personales'],
  social: {
    twitter:  'https://twitter.com/inversax',
    linkedin: null,
    github:   null,
    web:      'https://inversax.com',
  },
};

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<Layout>
  <slot name="head" slot="head">
    <title>{autor.nombre} — Editor en Inversax</title>
    <meta name="description" content={`${autor.nombre} es el fundador y editor de Inversax. Desarrollador de software apasionado por las finanzas y la economía latinoamericana.`} />
    <link rel="canonical" href={`https://inversax.com/autor/${autor.slug}`} />
    <meta property="og:title"       content={`${autor.nombre} — Editor en Inversax`} />
    <meta property="og:description" content={autor.bio} />
    <meta property="og:type"        content="profile" />
    <meta property="og:url"         content={`https://inversax.com/autor/${autor.slug}`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": autor.nombre,
      "url": `https://inversax.com/autor/${autor.slug}`,
      "jobTitle": autor.rol,
      "worksFor": {
        "@type": "Organization",
        "name": "Inversax",
        "url": "https://inversax.com"
      },
      "description": autor.bio,
      "sameAs": [
        autor.social.twitter,
        autor.social.web,
      ].filter(Boolean)
    })} />
  </slot>

  <div class="bg-[#0A0B0D] min-h-screen" style="font-family: 'DM Sans', sans-serif;">

    <!-- HERO DEL AUTOR -->
    <div class="border-b border-white/[0.07] bg-[#111318]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-7">

          <!-- Avatar -->
          <div class="relative flex-shrink-0">
            <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl border border-[#D4A843]/20 overflow-hidden">
              <img src="/foto-jose.jpg" alt="José Zúñiga" class="w-full h-full object-cover" />
            </div>
            <!-- Badge verificado -->
            <span class="absolute -bottom-2 -right-2 bg-[#D4A843] text-[#0A0B0D] text-[9px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wider">
              Editor
            </span>
          </div>

          <!-- Info -->
          <div class="flex flex-col gap-3 text-center sm:text-left">
            <div>
              <h1 class="font-extrabold text-2xl sm:text-3xl text-white" style="font-family: 'Syne', sans-serif;">
                {autor.nombre}
              </h1>
              <p class="text-[#D4A843] text-sm font-medium mt-0.5">{autor.rol} · Inversax</p>
            </div>

            <p class="text-white/50 text-sm leading-relaxed max-w-xl">{autor.bio}</p>

            <!-- Skills chips -->
            <div class="flex flex-wrap gap-2 justify-center sm:justify-start">
              {autor.skills.map(s => (
                <span class="bg-white/5 border border-white/[0.07] text-white/40 text-[10px] px-2.5 py-1 rounded-full">
                  {s}
                </span>
              ))}
            </div>

            <!-- Social links -->
            <div class="flex items-center gap-3 justify-center sm:justify-start">
              {autor.social.twitter && (
                <a href={autor.social.twitter} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-white/40 hover:text-[#D4A843] text-xs no-underline transition-colors duration-200">
                  <Twitter size={13} /> Twitter / X
                </a>
              )}
              {autor.social.web && (
                <a href={autor.social.web} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-white/40 hover:text-[#D4A843] text-xs no-underline transition-colors duration-200">
                  <Globe size={13} /> inversax.com
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- ARTÍCULOS -->
        <div class="flex-1 min-w-0">
          <h2 class="font-bold text-base text-white mb-6" style="font-family: 'Syne', sans-serif;">
            Artículos publicados
          </h2>

          {articulos.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-24 gap-4 text-center">
              <span class="text-5xl">📰</span>
              <p class="text-white/40 text-sm">No hay artículos publicados todavía.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {articulos.map((articulo) => (
                <a
                  href={`/noticias/${articulo.slug}`}
                  class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl overflow-hidden no-underline transition-colors duration-200"
                >
                  {articulo.imagen
                    ? (
                      <div class="w-full h-36 bg-[#1A1D24] overflow-hidden flex-shrink-0">
                        <img src={articulo.imagen} alt={articulo.titulo} class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                      </div>
                    )
                    : (
                      <div class="w-full h-36 flex-shrink-0" style="background: linear-gradient(135deg, #1A1D24, #23272F);" />
                    )
                  }
                  <div class="flex flex-col gap-2 px-4 pb-4">
                    <div class="flex items-center gap-2 flex-wrap">
                      {articulo.categoria && (
                        <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">
                          {articulo.categoria.nombre}
                        </span>
                      )}
                      <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto">
                        <Clock size={9} />
                        {formatFecha(articulo.creadoEn)}
                      </span>
                    </div>
                    <h3 class="font-bold text-sm text-white group-hover:text-[#D4A843] transition-colors duration-200 leading-snug line-clamp-2" style="font-family: 'Syne', sans-serif;">
                      {articulo.titulo}
                    </h3>
                    {articulo.resumen && (
                      <p class="text-white/40 text-xs leading-relaxed line-clamp-2">{articulo.resumen}</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>

        <!-- SIDEBAR -->
        <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0 flex flex-col gap-4">

          <!-- Sobre el editor -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
            <h3 class="font-bold text-sm text-white mb-3" style="font-family: 'Syne', sans-serif;">Sobre el editor</h3>
            <p class="text-white/40 text-xs leading-relaxed">{autor.bioExtra}</p>
          </div>

          <!-- Metodología -->
          <div class="bg-[#111318] border border-white/[0.07] rounded-2xl p-5">
            <h3 class="font-bold text-sm text-white mb-3" style="font-family: 'Syne', sans-serif;">Metodología editorial</h3>
            <div class="flex flex-col gap-3">
              {[
                { icon: '🔍', label: 'Investigación', desc: 'Cada tema se verifica con múltiples fuentes antes de redactarse.' },
                { icon: '✏️', label: 'Revisión humana', desc: 'Todo el contenido pasa por edición y corrección manual.' },
                { icon: '🖼️', label: 'Imagen propia', desc: 'Las imágenes de cada artículo son generadas y curadas por el editor.' },
              ].map(item => (
                <div class="flex gap-3 items-start">
                  <span class="text-base flex-shrink-0 mt-0.5">{item.icon}</span>
                  <div>
                    <p class="text-white/70 text-xs font-medium">{item.label}</p>
                    <p class="text-white/30 text-[11px] leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <a
            href="/noticias"
            class="flex items-center justify-between w-full bg-[#D4A843]/10 border border-[#D4A843]/20 hover:border-[#D4A843]/40 text-[#D4A843] text-sm px-4 py-3 rounded-xl no-underline transition-all duration-200"
          >
            Ver todas las noticias
            <ArrowRight size={14} />
          </a>

        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
