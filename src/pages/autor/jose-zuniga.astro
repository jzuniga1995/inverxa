---
// src/pages/autor/jose-zuniga.astro
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getArticulos } from '../../db/queries';
import { Clock, ArrowRight, Globe, Twitter } from 'lucide-astro';

const db = Astro.locals.db;
const articulos = await getArticulos(db, 24);

const autor = {
  nombre:    'José Zúniga',
  rol:       'Fundador & Editor',
  slug:      'jose-zuniga',
  bio:       'Desarrollador de software con una pasión profunda por los mercados financieros, las criptomonedas y la economía latinoamericana. Creé Inversax con el objetivo de llevar información financiera clara, accesible y de calidad a toda la región. Cada artículo que encuentras aquí pasa por mi revisión editorial antes de publicarse.',
  bioExtra:  'Combino mi background técnico con años de seguimiento activo de mercados para asegurar que el contenido no solo sea preciso, sino también útil para quienes están comenzando a invertir o quieren profundizar sus conocimientos.',
  skills:    ['Desarrollo de Software', 'Análisis de Mercados', 'Criptomonedas', 'Trading', 'Economía LatAm', 'Finanzas Personales'],
  social: {
    twitter: 'https://twitter.com/inversax',
    web:     'https://inversax.com',
  },
};

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<Layout>
  <slot name="head" slot="head">
    <title>{autor.nombre} — Editor en Inversax</title>
    <meta name="description" content={`${autor.nombre} es el fundador y editor de Inversax. Desarrollador de software apasionado por las finanzas y la economía latinoamericana.`} />
    <link rel="canonical" href={`https://inversax.com/autor/${autor.slug}`} />
    <meta property="og:title"       content={`${autor.nombre} — Editor en Inversax`} />
    <meta property="og:description" content={autor.bio} />
    <meta property="og:type"        content="profile" />
    <meta property="og:url"         content={`https://inversax.com/autor/${autor.slug}`} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": autor.nombre,
      "url": `https://inversax.com/autor/${autor.slug}`,
      "jobTitle": autor.rol,
      "worksFor": { "@type": "Organization", "name": "Inversax", "url": "https://inversax.com" },
      "description": autor.bio,
      "sameAs": [autor.social.twitter, autor.social.web].filter(Boolean)
    })} />
  </slot>

  <div style="background:#FAFAF8;min-height:100vh;font-family:'DM Sans',sans-serif;">

    <!-- HERO -->
    <div style="border-bottom:1px solid #E5E0D8;background:#fff;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-7">

          <div class="relative flex-shrink-0">
            <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-2xl overflow-hidden" style="border:1px solid #E5E0D8;">
              <img src="/foto-jose.jpg" alt="José Zúniga" class="w-full h-full object-cover" />
            </div>
            <span class="absolute -bottom-2 -right-2 text-[9px] font-bold px-1.5 py-0.5 rounded uppercase tracking-wider" style="background:#B91C1C;color:#fff;">
              Editor
            </span>
          </div>

          <div class="flex flex-col gap-3 text-center sm:text-left">
            <div>
              <h1 class="font-extrabold text-2xl sm:text-3xl" style="font-family:'Playfair Display',serif;color:#1C1917;">
                {autor.nombre}
              </h1>
              <p class="text-sm font-medium mt-0.5" style="color:#B91C1C;">{autor.rol} · Inversax</p>
            </div>
            <p class="text-sm leading-relaxed max-w-xl" style="color:#57534E;">{autor.bio}</p>
            <div class="flex flex-wrap gap-2 justify-center sm:justify-start">
              {autor.skills.map((s) => {
                return (
                  <span class="text-[10px] px-2.5 py-1 rounded-full" style="background:#F0EDE7;border:1px solid #E5E0D8;color:#78716C;">
                    {s}
                  </span>
                );
              })}
            </div>
            <div class="flex items-center gap-3 justify-center sm:justify-start">
              {autor.social.twitter && (
                <a href={autor.social.twitter} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-xs no-underline transition-colors duration-200" style="color:#78716C;">
                  <Twitter size={13} /> Twitter / X
                </a>
              )}
              {autor.social.web && (
                <a href={autor.social.web} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-xs no-underline transition-colors duration-200" style="color:#78716C;">
                  <Globe size={13} /> inversax.com
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <div class="flex flex-col lg:flex-row gap-10">

        <!-- ARTÍCULOS -->
        <div class="flex-1 min-w-0">
          <h2 class="font-bold text-base mb-6" style="font-family:'Playfair Display',serif;color:#1C1917;">
            Artículos publicados
          </h2>

          {articulos.length === 0 ? (
            <div class="flex flex-col items-center justify-center py-24 gap-4 text-center">
              <span class="text-5xl">📰</span>
              <p class="text-sm" style="color:#78716C;">No hay artículos publicados todavía.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {articulos.map((articulo) => {
                return (
                  <a
                    href={`/noticias/${articulo.slug}`}
                    class="group flex flex-col gap-3 rounded-xl overflow-hidden no-underline transition-colors duration-200"
                    style="background:#fff;border:1px solid #E5E0D8;"
                  >
                    {articulo.imagen ? (
                      <div class="w-full h-36 overflow-hidden flex-shrink-0" style="background:#F0EDE7;">
                        <img src={articulo.imagen} alt={articulo.titulo} class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                      </div>
                    ) : (
                      <div class="w-full h-36 flex-shrink-0" style="background:linear-gradient(135deg,#F0EDE7,#E5E0D8);" />
                    )}
                    <div class="flex flex-col gap-2 px-4 pb-4">
                      <div class="flex items-center gap-2 flex-wrap">
                        {articulo.categoria && (
                          <span class="text-[10px] font-bold uppercase tracking-wider" style="color:#B91C1C;">
                            {articulo.categoria.nombre}
                          </span>
                        )}
                        {articulo.pais && articulo.pais.codigo !== 'global' && (
                          <span class="text-[10px] px-1.5 py-0.5 rounded uppercase" style="color:#A8A29E;border:1px solid #E5E0D8;">
                            {articulo.pais.nombre}
                          </span>
                        )}
                        <span class="text-[10px] flex items-center gap-0.5 ml-auto" style="color:#A8A29E;">
                          <Clock size={9} />
                          {formatFecha(articulo.creadoEn)}
                        </span>
                      </div>
                      <h3 class="font-bold text-sm group-hover:text-[#B91C1C] transition-colors duration-200 leading-snug line-clamp-2" style="color:#1C1917;">
                        {articulo.titulo}
                      </h3>
                      {articulo.resumen && (
                        <p class="text-xs leading-relaxed line-clamp-2" style="color:#78716C;">{articulo.resumen}</p>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </div>

        <!-- SIDEBAR -->
        <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0 flex flex-col gap-4">

          <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
            <h3 class="font-bold text-sm mb-3" style="color:#1C1917;">Sobre el editor</h3>
            <p class="text-xs leading-relaxed" style="color:#78716C;">{autor.bioExtra}</p>
          </div>

          <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
            <h3 class="font-bold text-sm mb-3" style="color:#1C1917;">Metodología editorial</h3>
            <div class="flex flex-col gap-3">
              {[
                { icon: '🔍', label: 'Investigación',   desc: 'Cada tema se verifica con múltiples fuentes antes de redactarse.' },
                { icon: '✏️', label: 'Revisión humana', desc: 'Todo el contenido pasa por edición y corrección manual.' },
                { icon: '🖼️', label: 'Imagen propia',   desc: 'Las imágenes de cada artículo son generadas y curadas por el editor.' },
              ].map((item) => {
                return (
                  <div class="flex gap-3 items-start">
                    <span class="text-base flex-shrink-0 mt-0.5">{item.icon}</span>
                    <div>
                      <p class="text-xs font-medium" style="color:#1C1917;">{item.label}</p>
                      <p class="text-[11px] leading-relaxed" style="color:#A8A29E;">{item.desc}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <div class="rounded-2xl p-5" style="background:#F5F1EC;border:1px solid #E5E0D8;">
            <h3 class="font-bold text-xs mb-2 uppercase tracking-wider" style="color:#A8A29E;">Aviso legal</h3>
            <p class="text-[11px] leading-relaxed" style="color:#A8A29E;">
              El contenido de Inversax es informativo y no constituye asesoramiento financiero. Siempre consultá un profesional antes de invertir.
            </p>
          </div>

          <a
            href="/noticias"
            class="flex items-center justify-between w-full text-sm px-4 py-3 rounded-xl no-underline transition-all duration-200"
            style="background:rgba(185,28,28,0.08);border:1px solid rgba(185,28,28,0.2);color:#B91C1C;"
          >
            Ver todas las noticias
            <ArrowRight size={14} />
          </a>

        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

