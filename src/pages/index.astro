               style="border-top: 1px solid rgba(245,240,232,0.1);"
               class="lg:border-t-0">
            <div>
              <span class="block text-[10px] font-bold uppercase tracking-[0.22em] mb-3"
                    style="color: rgba(245,240,232,0.35); font-family: 'DM Sans', sans-serif;">
