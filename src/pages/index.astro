  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"    content="Inversax — Cripto, Trading y Finanzas en Español" />

  <!-- ═══════════════════════════════════════
       TWITTER CARD
  ═══════════════════════════════════════ -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:title"       content="Inversax — Cripto, Trading y Finanzas en Español" />
  <meta name="twitter:description" content="Precios en vivo, noticias y herramientas de cripto, forex, bolsa y metales para Latinoamérica." />
  <meta name="twitter:image"       content="https://inversax.com/og/home.png" />
  <meta name="twitter:image:alt"   content="Inversax — Finanzas en Español" />

  <!-- ═══════════════════════════════════════
       EXTRA SEO
  ═══════════════════════════════════════ -->
  <meta name="language"         content="Spanish" />
  <meta name="content-language" content="es" />
  <meta name="coverage"         content="Worldwide" />
  <meta name="target"           content="all" />
  <meta name="rating"           content="general" />
  <meta name="category"         content="finance, crypto, trading, investing" />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebSite + SearchAction
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "alternateName": "Inversax.com",
    "description": "Noticias, precios en vivo y herramientas de cripto, forex, bolsa y metales en español para Latinoamérica.",
    "url": "https://inversax.com",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://inversax.com/noticias?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — Organization
  ═══════════════════════════════════════ -->
