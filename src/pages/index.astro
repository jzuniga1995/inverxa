---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { TrendingUp, TrendingDown, ArrowRight, Calculator, DollarSign, BarChart2, Clock, Flame, BookOpen, Star, ExternalLink, Layers, Landmark } from 'lucide-astro';
import { getArticulos, getArticulosDestacados, getCategorias, getArticulosPorCategoria } from '../db/queries';

const [todasNoticias, destacados, categorias] = await Promise.all([
  getArticulos(20),
  getArticulosDestacados(3),
  getCategorias(),
]);

const noticiaPrincipal    = destacados[0] ?? todasNoticias[0] ?? null;
const noticiasSecundarias = todasNoticias
  .filter(n => n.slug !== noticiaPrincipal?.slug)
  .slice(0, 7);

// ── NOTICIAS POR CATEGORÍA ────────────────────────────────────
const noticiasPorCategoriaArr = await Promise.all(
  categorias.map(cat => getArticulosPorCategoria(cat.slug, 4))
);
const noticiasPorCategoria: Record<string, Awaited<ReturnType<typeof getArticulosPorCategoria>>> = {};
categorias.forEach((cat, i) => {
  noticiasPorCategoria[cat.slug] = noticiasPorCategoriaArr[i];
});
const primeraConNoticias = categorias.find(c => (noticiasPorCategoria[c.slug]?.length ?? 0) > 0);

// ── PRECIOS CRIPTO ────────────────────────────────────────────
const HOME_IDS = ['bitcoin', 'ethereum', 'binancecoin', 'solana', 'ripple', 'cardano'];
type Precio = { id: string; symbol: string; name: string; image: string; price: string; change: string; cap: string; up: boolean; };

let precios: Precio[] = [];
let preciosError = false;

const formatCap = (n: number) => {
  if (!n) return '—';
  if (n >= 1e12) return `$${(n / 1e12).toFixed(2)}T`;
  if (n >= 1e9)  return `$${(n / 1e9).toFixed(0)}B`;
  return `$${(n / 1e6).toFixed(0)}M`;
};
const formatPrice = (p: number) => {
  if (!p) return '—';
  if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
  if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
};
const formatForex = (p: number) => {
  if (!p) return '—';
  if (p >= 100)  return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
};

try {
  const res  = await fetch(new URL('/api/precios', Astro.url));
  if (!res.ok) throw new Error(`/api/precios ${res.status}`);
  const data = await res.json();
  precios = data
    .filter((c: any) => HOME_IDS.includes(c.id))
    .map((c: any) => ({
      id: c.id, symbol: c.symbol, name: c.name, image: c.image,
      price:  formatPrice(c.price),
      change: `${c.change24 >= 0 ? '+' : ''}${c.change24.toFixed(2)}%`,
      cap:    formatCap(c.marketCap),
      up:     c.change24 >= 0,
    }));
} catch (e) {
  preciosError = true;
  precios = [
    { id: 'bitcoin',     symbol: 'BTC', name: 'Bitcoin',  image: '', price: '—', change: '—', cap: '—', up: true },
    { id: 'ethereum',    symbol: 'ETH', name: 'Ethereum', image: '', price: '—', change: '—', cap: '—', up: true },
    { id: 'binancecoin', symbol: 'BNB', name: 'BNB',      image: '', price: '—', change: '—', cap: '—', up: true },
    { id: 'solana',      symbol: 'SOL', name: 'Solana',   image: '', price: '—', change: '—', cap: '—', up: true },
    { id: 'ripple',      symbol: 'XRP', name: 'XRP',      image: '', price: '—', change: '—', cap: '—', up: true },
    { id: 'cardano',     symbol: 'ADA', name: 'Cardano',  image: '', price: '—', change: '—', cap: '—', up: true },
  ];
}

// ── FOREX ─────────────────────────────────────────────────────
type ForexRow = { par: string; base: string; cotizada: string; banderaBase: string; banderaCotizada: string; precio: number; precioFmt: string; tradingviewSimbolo: string; };
let forexData: ForexRow[] = [];

try {
  const res  = await fetch(new URL('/api/forex?limit=6', Astro.url));
  if (!res.ok) throw new Error(`/api/forex ${res.status}`);
  const json = await res.json();
  if (json.ok) {
    forexData = json.data.map((f: any) => ({
      ...f,
      precioFmt: formatForex(f.precio),
    }));
  }
} catch (e) {
  console.error('[Home] forex error:', e);
}

const nombreForex: Record<string, string> = {
  'EUR/USD': 'Euro / Dólar',
  'GBP/USD': 'Libra / Dólar',
  'USD/JPY': 'Dólar / Yen',
  'USD/MXN': 'Dólar / Peso Mexicano',
  'USD/ARS': 'Dólar / Peso Argentino',
  'USD/COP': 'Dólar / Peso Colombiano',
  'USD/CLP': 'Dólar / Peso Chileno',
  'USD/BRL': 'Dólar / Real Brasileño',
  'USD/PEN': 'Dólar / Sol Peruano',
};

// ── METALES ───────────────────────────────────────────────────
type MetalRow = { nombre: string; simbolo: string; icono: string; color: string; precio: number; unidad: string; precioFmt: string; tradingviewSimbolo: string; slug: string; };
let metalesData: MetalRow[] = [];

try {
  const res  = await fetch(new URL('/api/metales?limit=4', Astro.url));
  if (!res.ok) throw new Error(`/api/metales ${res.status}`);
  const json = await res.json();
  if (json.ok) {
    metalesData = json.data.map((m: any) => ({
      ...m,
      precioFmt: `$${m.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
    }));
  }
} catch (e) {
  console.error('[Home] metales error:', e);
}

// ── ACCIONES ──────────────────────────────────────────────────
type AccionRow = { nombre: string; ticker: string; slug: string; sector: string; icono: string; color: string; tradingviewSimbolo: string; precio: number; cambioPct: number; alza: boolean; precioFmt: string; cambioPctFmt: string; };
let accionesData: AccionRow[] = [];

try {
  const res  = await fetch(new URL('/api/acciones?limit=6', Astro.url));
  if (!res.ok) throw new Error(`/api/acciones ${res.status}`);
  const json = await res.json();
  if (json.ok) {
    accionesData = json.data.map((a: any) => ({
      ...a,
      precioFmt:    a.precio > 0 ? `$${a.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—',
      cambioPctFmt: a.precio > 0 ? `${a.cambioPct >= 0 ? '+' : ''}${a.cambioPct.toFixed(2)}%` : '—',
    }));
  }
} catch (e) {
  console.error('[Home] acciones error:', e);
}

// ── LOGOS ACCIONES ────────────────────────────────────────────
const dominiosPorTicker: Record<string, string> = {
  AAPL:  'apple.com',        MSFT:  'microsoft.com', GOOGL: 'google.com',
  AMZN:  'amazon.com',       NVDA:  'nvidia.com',    META:  'meta.com',
  TSLA:  'tesla.com',        JPM:   'jpmorganchase.com', BAC: 'bankofamerica.com',
  GS:    'goldmansachs.com', XOM:   'exxonmobil.com',CVX:  'chevron.com',
  KO:    'coca-cola.com',    MCD:   'mcdonalds.com', SPY:  'ssga.com', QQQ: 'invesco.com',
};

// ── HERRAMIENTAS ─────────────────────────────────────────────
// FIX: 5 herramientas disponibles, sin calculadora (pendiente)
const herramientas = [
  { titulo: "Mercados Cripto",   desc: "Precios en vivo y gráficas de las principales criptomonedas.", href: "/herramientas/cripto",   icon: "chart"    },
  { titulo: "Forex",             desc: "Tipos de cambio de divisas globales y monedas LATAM.",          href: "/herramientas/forex",    icon: "forex"    },
  { titulo: "Metales Preciosos", desc: "Precios de oro, plata, platino y paladio por onza troy.",       href: "/herramientas/metales",  icon: "layers"   },
  { titulo: "Acciones",          desc: "Cotizaciones en tiempo real del mercado estadounidense.",        href: "/herramientas/acciones", icon: "acciones" },
  { titulo: "Precio del Dólar",  desc: "Dólar oficial y paralelo (blue en Argentina) por país.",        href: "/herramientas/dolar",    icon: "dollar"   },
];

// ── CONCEPTO DEL DÍA ─────────────────────────────────────────
const conceptos = [
  { termino: "Bitcoin (BTC)",           categoria: "Cripto",    definicion: "La primera criptomoneda descentralizada del mundo, creada en 2009 por Satoshi Nakamoto. Opera sin bancos ni gobiernos usando tecnología blockchain.", ejemplo: "Si hubieras invertido $100 en Bitcoin en 2010, hoy tendrías millones." },
  { termino: "Blockchain",              categoria: "Cripto",    definicion: "Registro digital distribuido e inmutable donde se almacenan transacciones en bloques encadenados. Nadie puede modificar los datos sin consenso de la red.", ejemplo: "Cuando envías Bitcoin, la transacción queda grabada para siempre en la blockchain." },
  { termino: "Halving",                 categoria: "Cripto",    definicion: "Evento que ocurre cada ~4 años y reduce a la mitad la recompensa que reciben los mineros de Bitcoin. Históricamente dispara el precio por la menor oferta.", ejemplo: "El halving de 2024 redujo la recompensa de 6.25 BTC a 3.125 BTC por bloque." },
  { termino: "Spread",                  categoria: "Trading",   definicion: "Diferencia entre el precio de compra (ask) y el precio de venta (bid) de un activo. Es el costo implícito de cada operación en muchos brokers.", ejemplo: "Si el EUR/USD tiene un spread de 2 pips, pagas eso solo por abrir la operación." },
  { termino: "Apalancamiento",          categoria: "Trading",   definicion: "Permite operar con más dinero del que tienes depositado. Un apalancamiento 1:10 significa que con $100 controlas $1,000 en el mercado.", ejemplo: "Con apalancamiento 1:100 y $500, puedes abrir una posición de $50,000 en forex." },
  { termino: "Stop Loss",               categoria: "Trading",   definicion: "Orden automática que cierra tu posición al alcanzar un precio determinado, limitando tus pérdidas. Es la herramienta de gestión de riesgo más básica.", ejemplo: "Compras BTC a $95,000 y pones un stop loss en $90,000 para no perder más del 5%." },
  { termino: "ETF",                     categoria: "Bolsa",     definicion: "Fondo cotizado en bolsa que replica el rendimiento de un índice, sector o activo. Permite diversificar comprando un solo instrumento.", ejemplo: "El ETF SPY replica el S&P 500, dándote exposición a las 500 empresas más grandes de EE.UU." },
  { termino: "Capitalización bursátil", categoria: "Bolsa",     definicion: "Valor total de mercado de una empresa, calculado multiplicando el precio de la acción por el número de acciones en circulación.", ejemplo: "Apple tiene una capitalización de más de $3 billones, siendo la empresa más valiosa del mundo." },
  { termino: "Inflación",               categoria: "Economía",  definicion: "Aumento sostenido del nivel general de precios con el tiempo, que reduce el poder adquisitivo del dinero. Se mide con el IPC.", ejemplo: "Con una inflación del 10%, lo que hoy cuesta $100 costará $110 el próximo año." },
  { termino: "Staking",                 categoria: "Cripto",    definicion: "Proceso de bloquear criptomonedas en una red para validar transacciones y obtener recompensas. Similar a un depósito a plazo fijo.", ejemplo: "Al hacer staking de ETH puedes ganar entre 3% y 5% anual en recompensas." },
  { termino: "DeFi",                    categoria: "Cripto",    definicion: "Finanzas descentralizadas: servicios financieros (préstamos, trading, ahorro) que funcionan en blockchain sin bancos ni intermediarios.", ejemplo: "En Uniswap puedes intercambiar tokens directamente sin crear cuenta ni verificar identidad." },
  { termino: "Soporte y Resistencia",   categoria: "Trading",   definicion: "Niveles de precio donde históricamente el mercado ha rebotado (soporte) o frenado su subida (resistencia). Claves en análisis técnico.", ejemplo: "Si Bitcoin rebota tres veces en $90,000, ese nivel es un soporte fuerte." },
  { termino: "Par de divisas",          categoria: "Forex",     definicion: "Cotización de dos monedas entre sí. El EUR/USD indica cuántos dólares cuesta un euro. La primera moneda es la base, la segunda es la cotizada.", ejemplo: "EUR/USD = 1.08 significa que 1 euro vale 1.08 dólares." },
  { termino: "Vela japonesa",           categoria: "Trading",   definicion: "Representación gráfica del precio que muestra apertura, cierre, máximo y mínimo en un período. Verde significa subida, roja significa bajada.", ejemplo: "Una vela verde con cuerpo largo indica que los compradores dominaron toda la sesión." },
  { termino: "Altcoin",                 categoria: "Cripto",    definicion: "Cualquier criptomoneda que no sea Bitcoin. El término viene de 'alternative coin'. Ethereum, Solana y XRP son ejemplos populares.", ejemplo: "Ethereum es la altcoin más grande del mercado por capitalización." },
  { termino: "Diversificación",         categoria: "Inversión", definicion: "Estrategia de distribuir el capital en diferentes activos para reducir el riesgo. Si uno cae, los otros pueden compensar las pérdidas.", ejemplo: "En lugar de poner todo en Bitcoin, distribuyes 40% en BTC, 30% en ETH y 30% en acciones." },
  { termino: "Liquidez",                categoria: "Mercados",  definicion: "Facilidad con la que un activo puede comprarse o venderse sin afectar significativamente su precio. Mayor volumen = mayor liquidez.", ejemplo: "Bitcoin tiene alta liquidez; una NFT rara puede tener muy poca y tardas semanas en venderla." },
  { termino: "Whale",                   categoria: "Cripto",    definicion: "Término para referirse a inversores que poseen grandes cantidades de una criptomoneda y cuyas compras o ventas pueden mover el mercado.", ejemplo: "Cuando una wallet mueve 10,000 BTC, el mercado entra en alerta por el posible impacto." },
  { termino: "IPO",                     categoria: "Bolsa",     definicion: "Oferta Pública Inicial: primera vez que una empresa vende acciones al público en bolsa. Es como la empresa 'debuta' en el mercado.", ejemplo: "Cuando Airbnb hizo su IPO en 2020, las acciones subieron un 113% el primer día." },
  { termino: "Bull Market",             categoria: "Mercados",  definicion: "Período prolongado de tendencia alcista en los mercados financieros. Se considera bull market cuando los precios suben más del 20% desde mínimos.", ejemplo: "El bull market de Bitcoin en 2020-2021 llevó el precio de $10,000 a casi $70,000." },
  { termino: "Bear Market",             categoria: "Mercados",  definicion: "Período prolongado de caída de precios, generalmente del 20% o más desde máximos recientes. Puede durar meses o años.", ejemplo: "El bear market cripto de 2022 hizo caer a Bitcoin de $69,000 a menos de $16,000." },
  { termino: "HODL",                    categoria: "Cripto",    definicion: "Estrategia de mantener criptomonedas a largo plazo sin vender, independientemente de la volatilidad. Nació de un error tipográfico de 'hold'.", ejemplo: "Los HODLers que compraron BTC en 2017 y aguantaron el crash de 2018 obtuvieron grandes ganancias." },
];
const ahora       = new Date();
const diaDelAno   = Math.floor((ahora.getTime() - new Date(ahora.getFullYear(), 0, 0).getTime()) / 86400000);
const conceptoHoy = conceptos[diaDelAno % conceptos.length];

// ── BROKERS ───────────────────────────────────────────────────
const brokers = [
  { nombre: "Binance",     tipo: "Exchange Cripto",       descripcion: "El exchange de criptomonedas más grande del mundo por volumen. Ideal para operar con cientos de altcoins y futuros cripto.",                         activos: ["BTC", "ETH", "BNB", "+350 más"],                 rating: 4.8, comision: "0.1% por operación",      ideal: "Traders cripto",        href: "https://www.binance.com",      color: "#F0B90B" },
  { nombre: "XM",          tipo: "Broker Forex & CFD",    descripcion: "Broker global con 15 años en el mercado y fuerte presencia en Latinoamérica. Soporte completo en español y más de 1,000 instrumentos.",             activos: ["Forex", "Cripto", "Acciones", "Índices"],        rating: 4.6, comision: "Desde 0 pips",            ideal: "Traders Forex",         href: "https://www.xm.com",          color: "#E84142" },
  { nombre: "XTB",         tipo: "Broker Acciones & CFD", descripcion: "Uno de los brokers más populares en LATAM con oficina en Chile. Plataforma xStation con herramientas avanzadas de análisis técnico.",               activos: ["Acciones", "ETFs", "Forex", "Cripto"],           rating: 4.5, comision: "0% en acciones reales",   ideal: "Inversores bolsa",      href: "https://www.xtb.com",         color: "#1565C0" },
  { nombre: "eToro",       tipo: "Broker Social",         descripcion: "Plataforma de trading social que permite copiar las estrategias de inversores exitosos. Muy popular para principiantes.",                            activos: ["Acciones", "Cripto", "ETFs", "Forex"],           rating: 4.3, comision: "Sin comisión en acciones", ideal: "Principiantes",         href: "https://www.etoro.com",       color: "#00C853" },
  { nombre: "Pepperstone", tipo: "Broker ECN",            descripcion: "Broker australiano regulado con spreads muy competitivos y soporte completo en español. Favorito de traders profesionales en LATAM.",               activos: ["Forex", "Índices", "Materias primas", "Cripto"],  rating: 4.7, comision: "Desde 0.0 pips",          ideal: "Traders profesionales", href: "https://www.pepperstone.com", color: "#FF6B35" },
];

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}

const categoriaColores: Record<string, string> = {
  'Cripto':              '#F59E0B',
  'Criptomonedas':       '#F59E0B',
  'Trading':             '#3B82F6',
  'Bolsa':               '#10B981',
  'Economía':            '#8B5CF6',
  'Forex':               '#EC4899',
  'Inversión':           '#06B6D4',
  'Inversiones':         '#06B6D4',
  'Mercados':            '#D4A843',
  'Finanzas Personales': '#14B8A6',
  'Fintech':             '#F97316',
  'Impuestos':           '#A78BFA',
};
---

<Layout>
  <slot name="head" slot="head">
    <title>Inversax — Cripto, Trading y Finanzas en Español</title>
    <meta name="description" content="Noticias, precios y herramientas de cripto, trading, bolsa, forex y economía actualizadas para Latinoamérica. Todo en español." />
    <link rel="canonical" href="https://inversax.com" />
  </slot>

  <Hero />

  <!-- ── 1. ÚLTIMAS NOTICIAS ───────────────────────────────── -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-2.5">
          <Flame size={18} class="text-[#D4A843]" />
          <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Últimas Noticias</h2>
        </div>
        <a href="/noticias" class="flex items-center gap-1.5 text-sm text-white/40 hover:text-[#D4A843] no-underline transition-colors duration-200">
          Ver todas <ArrowRight size={14} />
        </a>
      </div>

      {noticiaPrincipal ? (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
          <a href={`/noticias/${noticiaPrincipal.slug}`} class="lg:col-span-2 group relative rounded-2xl overflow-hidden bg-[#111318] border border-white/[0.07] no-underline flex flex-col min-h-[380px] hover:border-white/20 transition-colors duration-300">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0B0D] via-[#0A0B0D]/50 to-transparent z-10"></div>
            <div class="absolute inset-0">
              {noticiaPrincipal.imagen
                ? <img src={noticiaPrincipal.imagen} alt={noticiaPrincipal.titulo} class="w-full h-full object-cover" />
                : <div class="w-full h-full" style="background: linear-gradient(135deg, #1A1D24 0%, #23272F 100%);"></div>
              }
            </div>
            <div class="relative z-20 mt-auto p-6 flex flex-col gap-3">
              <div class="flex items-center gap-2 flex-wrap">
                {noticiaPrincipal.categoria && (
                  <span class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">{noticiaPrincipal.categoria.nombre}</span>
                )}
                {noticiaPrincipal.pais && noticiaPrincipal.pais.codigo !== 'global' && (
                  <span class="text-white/40 text-[10px] border border-white/20 px-2 py-0.5 rounded uppercase">{noticiaPrincipal.pais.nombre}</span>
                )}
                <span class="text-white/30 text-xs flex items-center gap-1 ml-auto"><Clock size={11} />{formatFecha(noticiaPrincipal.creadoEn)}</span>
              </div>
              <h3 class="font-bold text-white text-xl sm:text-2xl leading-snug group-hover:text-[#D4A843] transition-colors duration-200" style="font-family: 'Syne', sans-serif;">{noticiaPrincipal.titulo}</h3>
              {noticiaPrincipal.resumen && <p class="text-white/50 text-sm leading-relaxed line-clamp-2">{noticiaPrincipal.resumen}</p>}
            </div>
          </a>

          <div class="flex flex-col gap-3">
            {noticiasSecundarias.slice(0, 4).map((n) => (
              <a href={`/noticias/${n.slug}`} class="group flex gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-3.5 no-underline transition-colors duration-200">
                {n.imagen && (
                  <div class="w-16 h-16 rounded-lg overflow-hidden bg-[#1A1D24] flex-shrink-0">
                    <img src={n.imagen} alt={n.titulo} class="w-full h-full object-cover" />
                  </div>
                )}
                <div class="flex-1 flex flex-col gap-1.5 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    {n.categoria && <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{n.categoria.nombre}</span>}
                    <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto"><Clock size={9} />{formatFecha(n.creadoEn)}</span>
                  </div>
                  <h4 class="text-white text-sm font-medium leading-snug group-hover:text-[#D4A843] transition-colors duration-200 line-clamp-2" style="font-family: 'Syne', sans-serif;">{n.titulo}</h4>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <Flame size={32} class="text-white/10 mb-3" />
          <p class="text-white/30 text-sm">Aún no hay noticias publicadas</p>
        </div>
      )}

      {noticiasSecundarias.length > 4 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-5">
          {noticiasSecundarias.slice(4).map((n) => (
            <a href={`/noticias/${n.slug}`} class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-4 no-underline transition-colors duration-200">
