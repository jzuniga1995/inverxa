    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Herramientas financieras de Inversax",
    "url": "https://inversax.com/herramientas",
    "numberOfItems": 5,
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Mercados Cripto",    "url": "https://inversax.com/herramientas/cripto"   },
      { "@type": "ListItem", "position": 2, "name": "Forex",              "url": "https://inversax.com/herramientas/forex"    },
      { "@type": "ListItem", "position": 3, "name": "Metales Preciosos",  "url": "https://inversax.com/herramientas/metales"  },
      { "@type": "ListItem", "position": 4, "name": "Acciones",           "url": "https://inversax.com/herramientas/acciones" },
      { "@type": "ListItem", "position": 5, "name": "Precio del Dólar",   "url": "https://inversax.com/herramientas/dolar"    }
    ]
  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — SiteNavigationElement
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SiteLinksSearchBox",
    "url": "https://inversax.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://inversax.com/noticias?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />

</slot>

  <Hero />

  <!-- ── 1. ÚLTIMAS NOTICIAS ───────────────────────────────── -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-2.5">
          <Flame size={18} class="text-[#D4A843]" />
          <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Últimas Noticias</h2>
        </div>
        <a href="/noticias" class="flex items-center gap-1.5 text-sm text-white/40 hover:text-[#D4A843] no-underline transition-colors duration-200">
          Ver todas <ArrowRight size={14} />
        </a>
      </div>

      {noticiaPrincipal ? (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
          <a href={`/noticias/${noticiaPrincipal.slug}`} class="lg:col-span-2 group relative rounded-2xl overflow-hidden bg-[#111318] border border-white/[0.07] no-underline flex flex-col min-h-[380px] hover:border-white/20 transition-colors duration-300">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0B0D] via-[#0A0B0D]/50 to-transparent z-10"></div>
            <div class="absolute inset-0">
              {noticiaPrincipal.imagen
                ? <img src={noticiaPrincipal.imagen} alt={noticiaPrincipal.titulo} class="w-full h-full object-cover" />
                : <div class="w-full h-full" style="background: linear-gradient(135deg, #1A1D24 0%, #23272F 100%);"></div>
              }
            </div>
            <div class="relative z-20 mt-auto p-6 flex flex-col gap-3">
              <div class="flex items-center gap-2 flex-wrap">
                {noticiaPrincipal.categoria && (
                  <span class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">{noticiaPrincipal.categoria.nombre}</span>
                )}
                {noticiaPrincipal.pais && noticiaPrincipal.pais.codigo !== 'global' && (
                  <span class="text-white/40 text-[10px] border border-white/20 px-2 py-0.5 rounded uppercase">{noticiaPrincipal.pais.nombre}</span>
                )}
                <span class="text-white/30 text-xs flex items-center gap-1 ml-auto"><Clock size={11} />{formatFecha(noticiaPrincipal.creadoEn)}</span>
              </div>
              <h3 class="font-bold text-white text-xl sm:text-2xl leading-snug group-hover:text-[#D4A843] transition-colors duration-200" style="font-family: 'Syne', sans-serif;">{noticiaPrincipal.titulo}</h3>
              {noticiaPrincipal.resumen && <p class="text-white/50 text-sm leading-relaxed line-clamp-2">{noticiaPrincipal.resumen}</p>}
            </div>
          </a>

          <div class="flex flex-col gap-3">
            {noticiasSecundarias.slice(0, 4).map((n) => (
              <a href={`/noticias/${n.slug}`} class="group flex gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-3.5 no-underline transition-colors duration-200">
                {n.imagen && (
                  <div class="w-16 h-16 rounded-lg overflow-hidden bg-[#1A1D24] flex-shrink-0">
                    <img src={n.imagen} alt={n.titulo} class="w-full h-full object-cover" />
                  </div>
                )}
                <div class="flex-1 flex flex-col gap-1.5 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    {n.categoria && <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{n.categoria.nombre}</span>}
                    <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto"><Clock size={9} />{formatFecha(n.creadoEn)}</span>
                  </div>
                  <h4 class="text-white text-sm font-medium leading-snug group-hover:text-[#D4A843] transition-colors duration-200 line-clamp-2" style="font-family: 'Syne', sans-serif;">{n.titulo}</h4>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <Flame size={32} class="text-white/10 mb-3" />
          <p class="text-white/30 text-sm">Aún no hay noticias publicadas</p>
        </div>
      )}

      {noticiasSecundarias.length > 4 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-5">
          {noticiasSecundarias.slice(4).map((n) => (
            <a href={`/noticias/${n.slug}`} class="group flex flex-col gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-4 no-underline transition-colors duration-200">
              {n.imagen && <div class="w-full h-36 rounded-lg overflow-hidden bg-[#1A1D24]"><img src={n.imagen} alt={n.titulo} class="w-full h-full object-cover" /></div>}
              <div class="flex items-center gap-2">
                {n.categoria && <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{n.categoria.nombre}</span>}
                <span class="text-white/25 text-[10px] flex items-center gap-0.5 ml-auto"><Clock size={9} />{formatFecha(n.creadoEn)}</span>
              </div>
              <h4 class="text-white text-sm font-medium leading-snug group-hover:text-[#D4A843] transition-colors duration-200 line-clamp-2" style="font-family: 'Syne', sans-serif;">{n.titulo}</h4>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ── 2. EXPLORA POR CATEGORÍA ──────────────────────────── -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14 border-t border-white/[0.07]" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">
