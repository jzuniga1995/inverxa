---
export const prerender = false;
// src/pages/index.astro — Homepage enfocada en calculadoras y herramientas
import Layout from '../layouts/Layout.astro';
import { getArticulos, getCategorias } from '../db/queries';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, stale-while-revalidate=3600');

const db = Astro.locals.db;
const [articulos, categorias] = await Promise.all([
  getArticulos(db, 3),
  getCategorias(db),
]);

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 3600000);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas}h`;
  const dias = Math.floor(horas / 24);
  if (dias === 1) return 'Ayer';
  return `Hace ${dias} días`;
}

const calculadoras = [
  {
    href:  '/herramientas/calculadoras/interes-compuesto',
    titulo: 'Interés Compuesto',
    desc:   'Visualiza cómo crece tu dinero con el poder del tiempo',
    svg:    `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    href:  '/herramientas/calculadoras/prestamo',
    titulo: 'Calculadora de Préstamo',
    desc:   'Calcula cuotas y el costo total de cualquier crédito',
    svg:    `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
  },
  {
    href:  '/herramientas/calculadoras/hipoteca',
    titulo: 'Calculadora de Hipoteca',
    desc:   'Simula la cuota mensual y amortización de tu vivienda',
    svg:    `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  },
  {
    href:  '/herramientas/calculadoras/roi',
    titulo: 'ROI de Inversión',
    desc:   'Mide el retorno real de cualquier inversión fácilmente',
    svg:    `<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>`,
  },
  {
    href:  '/herramientas/calculadoras/conversion-divisas',
    titulo: 'Conversión de Divisas',
    desc:   'Convierte entre USD, EUR, ARS, COP, MXN y más al instante',
    svg:    `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  },
  {
    href:  '/herramientas/calculadoras/cripto-ganancias',
    titulo: 'Ganancias en Cripto',
    desc:   'Calcula tus ganancias o pérdidas en cualquier criptomoneda',
    svg:    `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
];

const herramientas = [
  {
    href:   '/herramientas/cripto',
    titulo: 'Mercados Cripto',
    desc:   'BTC, ETH, SOL y más en tiempo real',
    color:  '#1D4ED8',
    svg:    `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    href:   '/herramientas/forex',
    titulo: 'Divisas Forex',
    desc:   'EUR/USD, GBP/USD y todos los pares principales',
    color:  '#15803D',
    svg:    `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  },
  {
    href:   '/herramientas/dolar',
    titulo: 'Precio del Dólar',
    desc:   'Tasas oficiales y paralelas en toda Latam',
    color:  '#B45309',
    svg:    `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  },
  {
    href:   '/herramientas/acciones',
    titulo: 'Acciones',
    desc:   'AAPL, NVDA, MSFT, TSLA y más',
    color:  '#374151',
    svg:    `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
  },
  {
    href:   '/herramientas/metales',
    titulo: 'Metales Preciosos',
    desc:   'Oro, plata, platino y paladio al instante',
    color:  '#B45309',
    svg:    `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  },
];
---

<Layout categorias={categorias}>

<slot name="head" slot="head">
  <title>Inversax — Calculadoras Financieras y Herramientas de Trading en Español</title>
  <meta name="description" content="Calculadoras de interés compuesto, préstamos, hipotecas y ROI. Precios en tiempo real de cripto, forex y acciones. Comparador de brokers para Latinoamérica." />
  <meta name="author"  content="José Zúniga" />
  <meta name="robots"  content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="keywords" content="calculadora financiera, calculadora interés compuesto, calculadora hipoteca, calculadora préstamo, herramientas trading, precio bitcoin, forex latinoamerica, comparar brokers" />
  <link rel="canonical" href="https://inversax.com" />

  <link rel="alternate" hreflang="es"       href="https://inversax.com" />
  <link rel="alternate" hreflang="es-MX"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-AR"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-CO"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-CL"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-PE"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-VE"    href="https://inversax.com" />
  <link rel="alternate" hreflang="es-ES"    href="https://inversax.com" />
  <link rel="alternate" hreflang="x-default" href="https://inversax.com" />

  <meta property="og:site_name"    content="Inversax" />
  <meta property="og:type"         content="website" />
  <meta property="og:title"        content="Inversax — Calculadoras Financieras y Herramientas de Trading" />
  <meta property="og:description"  content="Calculadoras financieras precisas, precios en tiempo real y comparador de brokers en español para inversores latinoamericanos." />
  <meta property="og:url"          content="https://inversax.com" />
  <meta property="og:image"        content="https://inversax.com/og/home.png" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@inversax" />
  <meta name="twitter:title"       content="Inversax — Calculadoras Financieras y Herramientas de Trading" />
  <meta name="twitter:description" content="Calculadoras financieras, precios en tiempo real y comparador de brokers en español para Latinoamérica." />
  <meta name="twitter:image"       content="https://inversax.com/og/home.png" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Inversax",
    "url": "https://inversax.com",
    "description": "Calculadoras financieras y herramientas de trading en español para Latinoamérica",
    "inLanguage": "es",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://inversax.com/noticias?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  })} />
</slot>

<!-- ════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════ -->
<section style="background:#FFFFFF; border-bottom:1px solid #E2DDD8;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 sm:py-20 lg:py-24">
    <div class="max-w-3xl">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6"
           style="background:#FFF5EE; border:1px solid #FFD4A8;">
        <span class="w-2 h-2 rounded-full" style="background:#FF8C42;"></span>
        <span class="text-xs font-semibold" style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
          Herramientas gratuitas en español
        </span>
      </div>

      <h1 class="font-bold leading-[1.1] mb-5"
          style="font-family:'DM Sans',sans-serif; color:#1A1A1A; font-size:clamp(32px,5vw,60px);">
        Calcula, analiza<br class="hidden sm:block" />
        e invierte mejor
      </h1>

      <p class="text-lg leading-relaxed mb-8"
         style="color:#555555; font-family:'DM Sans',sans-serif; max-width:560px;">
        Calculadoras financieras precisas, precios en tiempo real de cripto y forex,
        y el mejor comparador de brokers para el inversor latinoamericano.
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="/herramientas/calculadoras"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm no-underline transition-all duration-200"
           style="background:#FF8C42; color:white;"
           onmouseover="this.style.background='#E87832'; this.style.transform='translateY(-1px)';"
           onmouseout="this.style.background='#FF8C42'; this.style.transform='translateY(0)';">
          Ver calculadoras
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="/herramientas/comparar-brokers"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm no-underline transition-all duration-200"
           style="background:#F5F2EE; color:#1A1A1A; border:1px solid #E2DDD8;"
           onmouseover="this.style.background='#E8E3DB'; this.style.transform='translateY(-1px)';"
           onmouseout="this.style.background='#F5F2EE'; this.style.transform='translateY(0)';">
          Comparar Brokers
        </a>
      </div>

      <!-- Stats rápidos -->
      <div class="flex flex-wrap gap-6 mt-10 pt-8" style="border-top:1px solid #E2DDD8;">
        {[
          { n: '12+',   label: 'Calculadoras'        },
          { n: '5',     label: 'Herramientas de mercado' },
          { n: '100%',  label: 'Gratis en español'   },
        ].map(({ n, label }) => (
          <div class="flex flex-col gap-0.5">
            <span class="font-bold text-2xl" style="color:#1A1A1A; font-family:'DM Sans',sans-serif;">{n}</span>
            <span class="text-sm" style="color:#888888; font-family:'DM Sans',sans-serif;">{label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════
     CALCULADORAS FINANCIERAS (6 cards)
════════════════════════════════════════════════ -->
<section style="background:#F7F7F5; padding:64px 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <div class="flex items-end justify-between mb-8">
      <div>
        <span class="block text-xs font-bold uppercase tracking-widest mb-2"
              style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
          Calculadoras financieras
        </span>
        <h2 class="font-bold"
            style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:clamp(22px,3vw,30px);">
          Toma mejores decisiones financieras
        </h2>
      </div>
      <a href="/herramientas/calculadoras"
         class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold no-underline transition-colors duration-200"
         style="color:#FF8C42;"
         onmouseover="this.style.color='#E87832';"
         onmouseout="this.style.color='#FF8C42';">
        Ver todas las calculadoras
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {calculadoras.map((calc) => (
        <a href={calc.href}
           class="group flex flex-col gap-4 p-6 rounded-xl no-underline transition-all duration-200"
           style="background:#FFFFFF; border:1px solid #E2DDD8;"
           onmouseover="this.style.borderColor='#FF8C42'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(255,140,66,0.10)';"
           onmouseout="this.style.borderColor='#E2DDD8'; this.style.transform='translateY(0)'; this.style.boxShadow='none';">

          <!-- Ícono -->
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
               style="background:#FFF5EE;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="#FF8C42" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 set:html={calc.svg} />
          </div>

          <!-- Texto -->
          <div class="flex-1">
            <h3 class="font-semibold mb-1"
                style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:16px;">
              {calc.titulo}
            </h3>
            <p class="text-sm leading-relaxed" style="color:#888888; font-family:'DM Sans',sans-serif;">
              {calc.desc}
            </p>
          </div>

          <!-- CTA -->
          <div class="flex items-center gap-1 text-sm font-semibold" style="color:#FF8C42;">
            Calcular
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Ver todas (mobile) -->
    <div class="sm:hidden mt-6 text-center">
      <a href="/herramientas/calculadoras"
         class="inline-flex items-center gap-1.5 text-sm font-semibold no-underline"
         style="color:#FF8C42;">
        Ver todas las calculadoras →
      </a>
    </div>

  </div>
</section>

<!-- ════════════════════════════════════════════════
     HERRAMIENTAS DE MERCADO
════════════════════════════════════════════════ -->
<section style="background:#FFFFFF; border-top:1px solid #E2DDD8; border-bottom:1px solid #E2DDD8; padding:64px 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <div class="flex items-end justify-between mb-8">
      <div>
        <span class="block text-xs font-bold uppercase tracking-widest mb-2"
              style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
          Datos en tiempo real
        </span>
        <h2 class="font-bold"
            style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:clamp(22px,3vw,30px);">
          Herramientas de mercado
        </h2>
      </div>
      <a href="/herramientas"
         class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold no-underline"
         style="color:#FF8C42;"
         onmouseover="this.style.color='#E87832';"
         onmouseout="this.style.color='#FF8C42';">
        Ver todas
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
      {herramientas.map((h) => (
        <a href={h.href}
           class="flex flex-col gap-3 p-5 rounded-xl no-underline transition-all duration-200"
           style="background:#F7F7F5; border:1px solid #E2DDD8;"
           onmouseover="this.style.background='#FFFFFF'; this.style.borderColor='#D0C9C0'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)';"
           onmouseout="this.style.background='#F7F7F5'; this.style.borderColor='#E2DDD8'; this.style.boxShadow='none';">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0"
               style={`background:${h.color}18;`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke={h.color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 set:html={h.svg} />
          </div>
          <div>
            <h3 class="font-semibold text-sm mb-0.5"
                style="color:#1A1A1A; font-family:'DM Sans',sans-serif;">
              {h.titulo}
            </h3>
            <p class="text-xs leading-relaxed" style="color:#888888; font-family:'DM Sans',sans-serif;">
              {h.desc}
            </p>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<!-- ════════════════════════════════════════════════
     COMPARAR BROKERS — CTA
════════════════════════════════════════════════ -->
<section style="background:#F7F7F5; padding:64px 0;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 p-8 rounded-2xl"
         style="background:#FFFFFF; border:1px solid #E2DDD8;">
      <div class="flex-1">
        <span class="block text-xs font-bold uppercase tracking-widest mb-2" style="color:#FF8C42;">
          Comparador de brokers
        </span>
        <h2 class="font-bold mb-2"
            style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:clamp(20px,2.5vw,28px);">
          Encuentra el mejor broker para ti
        </h2>
        <p class="text-sm leading-relaxed" style="color:#555555; font-family:'DM Sans',sans-serif; max-width:480px;">
          Compara spreads, comisiones, regulación, depósito mínimo y plataformas de los principales
          brokers disponibles en Latinoamérica.
        </p>
      </div>
      <div class="flex flex-col gap-3 flex-shrink-0 w-full sm:w-auto">
        <a href="/herramientas/comparar-brokers"
           class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm no-underline transition-all duration-200 whitespace-nowrap"
           style="background:#FF8C42; color:white;"
           onmouseover="this.style.background='#E87832';"
           onmouseout="this.style.background='#FF8C42';">
          Comparar brokers ahora
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <div class="flex items-center gap-4 text-xs" style="color:#888888; font-family:'DM Sans',sans-serif;">
          <span class="flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Regulados y verificados
          </span>
          <span class="flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2.5">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            Actualizado mensualmente
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════
     ÚLTIMOS ARTÍCULOS (3, lista minimalista)
════════════════════════════════════════════════ -->
{articulos.length > 0 && (
  <section style="background:#FFFFFF; border-top:1px solid #E2DDD8; padding:64px 0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <div class="flex items-center justify-between mb-8">
        <div>
          <span class="block text-xs font-bold uppercase tracking-widest mb-2"
                style="color:#888888; font-family:'DM Sans',sans-serif;">
            Contenido editorial
          </span>
          <h2 class="font-bold"
              style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:clamp(20px,2.5vw,28px);">
            Últimos artículos
          </h2>
        </div>
        <a href="/noticias"
           class="text-sm font-semibold no-underline transition-colors duration-200"
           style="color:#888888;"
           onmouseover="this.style.color='#1A1A1A';"
           onmouseout="this.style.color='#888888';">
          Ver todos →
        </a>
      </div>

      <div class="flex flex-col" style="border-top:1px solid #E2DDD8;">
        {articulos.map((art) => (
          <a href={`/noticias/${art.slug}`}
             class="flex items-center justify-between gap-4 py-4 no-underline rounded-lg transition-all duration-150"
             style="border-bottom:1px solid #E2DDD8; padding-left:0; padding-right:0;"
             onmouseover="this.style.paddingLeft='12px'; this.style.paddingRight='12px'; this.style.marginLeft='-12px'; this.style.marginRight='-12px'; this.style.background='#F7F7F5';"
             onmouseout="this.style.paddingLeft='0'; this.style.paddingRight='0'; this.style.marginLeft='0'; this.style.marginRight='0'; this.style.background='';">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                {art.categoria && (
                  <span class="text-[10px] font-bold uppercase tracking-wider flex-shrink-0"
                        style="color:#FF8C42; font-family:'DM Sans',sans-serif;">
                    {art.categoria.nombre}
                  </span>
                )}
                <span class="text-[11px]"
                      style="color:#BBBBBB; font-family:'DM Sans',sans-serif;">
                  {formatFecha(art.creadoEn)}
                </span>
              </div>
              <h3 class="font-semibold leading-snug"
                  style="color:#1A1A1A; font-family:'DM Sans',sans-serif; font-size:15px;">
                {art.titulo}
              </h3>
            </div>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="#CCCCCC" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="flex-shrink-0">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
