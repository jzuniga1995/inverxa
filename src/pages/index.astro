               style="border-bottom: 1px solid rgba(245,240,232,0.1);"
               class="lg:border-b-0 lg:border-r-[1px] lg:border-r-[rgba(245,240,232,0.1)]">
            <div>
              <span class="inline-block text-[10px] font-bold uppercase tracking-[0.22em] mb-4 px-2.5 py-1"
                    style="background: #B91C1C; color: #F5F0E8; font-family: 'DM Sans', sans-serif;">
                {conceptoHoy.categoria}
              </span>
              <h3 class="font-bold leading-[1.1] mt-1"
                  style="font-family: 'Playfair Display', serif; color: #F5F0E8; font-size: clamp(28px, 3vw, 42px);">
