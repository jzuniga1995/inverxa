---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { TrendingUp, TrendingDown, ArrowRight, Calculator, DollarSign, BarChart2, Clock, Flame } from 'lucide-astro';
import { getArticulos, getArticulosDestacados, getCategorias } from '../db/queries';

// ── Datos reales desde Neon ──────────────────────────────────
const [todasNoticias, destacados, categoriasDB] = await Promise.all([
  getArticulos(5),
  getArticulosDestacados(1),
  getCategorias(),
]);

// Noticia principal: primero intentamos un destacado, si no el más reciente
const noticiaPrincipal = destacados[0] ?? todasNoticias[0] ?? null;

// Noticias secundarias: las 4 siguientes excluyendo la principal
const noticiasSecundarias = todasNoticias
  .filter(n => n.slug !== noticiaPrincipal?.slug)
  .slice(0, 4);

// Precios hardcodeados por ahora — en el futuro vendrán de una API como CoinGecko
const precios = [
  { symbol: "BTC",  name: "Bitcoin",   price: "$98,420",  change: "+2.4%",  cap: "$1.94T", up: true  },
  { symbol: "ETH",  name: "Ethereum",  price: "$3,812",   change: "+1.8%",  cap: "$458B",  up: true  },
  { symbol: "BNB",  name: "BNB",       price: "$624.1",   change: "+0.9%",  cap: "$90B",   up: true  },
  { symbol: "SOL",  name: "Solana",    price: "$192.4",   change: "-0.6%",  cap: "$88B",   up: false },
  { symbol: "XRP",  name: "XRP",       price: "$2.18",    change: "-1.2%",  cap: "$124B",  up: false },
  { symbol: "ADA",  name: "Cardano",   price: "$0.84",    change: "+3.1%",  cap: "$29B",   up: true  },
];

const herramientas = [
  { titulo: "Calculadora Cripto",  desc: "Convierte y calcula ganancias al instante",        href: "/herramientas/calculadora", icon: "calc"   },
  { titulo: "Precio del Dólar",    desc: "Tipo de cambio oficial y paralelo por país",        href: "/herramientas/dolar",       icon: "dollar" },
  { titulo: "Gráficas en vivo",    desc: "Visualiza movimientos del mercado en tiempo real",  href: "/herramientas/graficas",    icon: "chart"  },
];

function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}
---

<Layout>
  <slot name="head" slot="head">
    <title>Inversax — Cripto, Trading y Finanzas en Español</title>
    <meta name="description" content="Noticias, precios y herramientas de cripto, trading y bolsa actualizadas para Latinoamérica. Todo en español." />
    <link rel="canonical" href="https://inversax.com" />
  </slot>

  <!-- HERO -->
  <Hero />

  <!-- NOTICIAS -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">

      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-2.5">
          <Flame size={18} class="text-[#D4A843]" />
          <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Últimas Noticias</h2>
        </div>
        <a href="/noticias" class="flex items-center gap-1.5 text-sm text-white/40 hover:text-[#D4A843] no-underline transition-colors duration-200">
          Ver todas <ArrowRight size={14} />
        </a>
      </div>

      {noticiaPrincipal ? (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <!-- Noticia destacada -->
          <a href={`/noticias/${noticiaPrincipal.slug}`} class="lg:col-span-2 group relative rounded-2xl overflow-hidden bg-[#111318] border border-white/[0.07] no-underline flex flex-col min-h-[360px] hover:border-white/20 transition-colors duration-300">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0A0B0D] via-[#0A0B0D]/60 to-transparent z-10"></div>
            <div class="absolute inset-0">
              {noticiaPrincipal.imagen
                ? <img src={noticiaPrincipal.imagen} alt={noticiaPrincipal.titulo} class="w-full h-full object-cover" />
                : <div class="w-full h-full" style="background: linear-gradient(135deg, #1A1D24 0%, #23272F 100%);"></div>
              }
            </div>
            <div class="relative z-20 mt-auto p-6 flex flex-col gap-3">
              <div class="flex items-center gap-2">
                {noticiaPrincipal.categoria && (
                  <span class="bg-[#D4A843] text-[#0A0B0D] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                    {noticiaPrincipal.categoria.nombre}
                  </span>
                )}
                <span class="text-white/30 text-xs flex items-center gap-1">
                  <Clock size={11} />{formatFecha(noticiaPrincipal.creadoEn)}
                </span>
              </div>
              <h3 class="font-bold text-white text-xl leading-snug group-hover:text-[#D4A843] transition-colors duration-200" style="font-family: 'Syne', sans-serif;">
                {noticiaPrincipal.titulo}
              </h3>
              {noticiaPrincipal.resumen && (
                <p class="text-white/50 text-sm leading-relaxed">{noticiaPrincipal.resumen}</p>
              )}
            </div>
          </a>

          <!-- Noticias secundarias -->
          <div class="flex flex-col gap-4">
            {noticiasSecundarias.map((n) => (
              <a href={`/noticias/${n.slug}`} class="group flex gap-3 bg-[#111318] border border-white/[0.07] hover:border-white/20 rounded-xl p-4 no-underline transition-colors duration-200">
                {n.imagen && (
                  <div class="w-16 h-16 rounded-lg overflow-hidden bg-[#1A1D24] flex-shrink-0">
                    <img src={n.imagen} alt={n.titulo} class="w-full h-full object-cover" />
                  </div>
                )}
                <div class="flex-1 flex flex-col gap-1.5 min-w-0">
                  <div class="flex items-center gap-2">
                    {n.categoria && (
                      <span class="text-[#D4A843] text-[10px] font-bold uppercase tracking-wider">{n.categoria.nombre}</span>
                    )}
                    <span class="text-white/25 text-[10px] flex items-center gap-0.5">
                      <Clock size={9} />{formatFecha(n.creadoEn)}
                    </span>
                  </div>
                  <h4 class="text-white text-sm font-medium leading-snug group-hover:text-[#D4A843] transition-colors duration-200 line-clamp-2" style="font-family: 'Syne', sans-serif;">
                    {n.titulo}
                  </h4>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <!-- Estado vacío -->
        <div class="flex flex-col items-center justify-center py-20 bg-[#111318] border border-white/[0.07] rounded-2xl">
          <Flame size={32} class="text-white/10 mb-3" />
          <p class="text-white/30 text-sm">Aún no hay noticias publicadas</p>
        </div>
      )}
    </div>
  </section>

  <!-- PRECIOS DE MERCADO -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14 border-t border-white/[0.07]" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">

      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-2.5">
          <BarChart2 size={18} class="text-[#D4A843]" />
          <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Precios del Mercado</h2>
        </div>
        <a href="/cripto" class="flex items-center gap-1.5 text-sm text-white/40 hover:text-[#D4A843] no-underline transition-colors duration-200">
          Ver todos <ArrowRight size={14} />
        </a>
      </div>

      <div class="bg-[#111318] border border-white/[0.07] rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3 sm:grid-cols-4 px-4 sm:px-6 py-3 border-b border-white/[0.07]">
          <span class="text-white/30 text-xs font-medium uppercase tracking-wider">Activo</span>
          <span class="text-white/30 text-xs font-medium uppercase tracking-wider text-right">Precio</span>
          <span class="text-white/30 text-xs font-medium uppercase tracking-wider text-right">24h</span>
          <span class="hidden sm:block text-white/30 text-xs font-medium uppercase tracking-wider text-right">Cap. Mercado</span>
        </div>

        {precios.map((coin) => (
          <a href={`/cripto/${coin.symbol.toLowerCase()}`} class="grid grid-cols-3 sm:grid-cols-4 px-4 sm:px-6 py-4 border-b border-white/[0.07] last:border-none hover:bg-white/5 transition-colors duration-200 no-underline cursor-pointer">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center flex-shrink-0">
                <span class="text-[10px] font-bold text-white/60">{coin.symbol.slice(0,2)}</span>
              </div>
              <div class="min-w-0">
                <div class="font-bold text-sm text-white truncate" style="font-family: 'Syne', sans-serif;">{coin.symbol}</div>
                <div class="text-xs text-white/40 truncate">{coin.name}</div>
              </div>
            </div>
            <div class="flex items-center justify-end">
              <span class="font-semibold text-sm text-white" style="font-family: 'Syne', sans-serif;">{coin.price}</span>
            </div>
            <div class="flex items-center justify-end">
              <span class={`flex items-center gap-1 text-sm font-medium ${coin.up ? 'text-emerald-400' : 'text-red-400'}`}>
                {coin.up ? <TrendingUp size={13} /> : <TrendingDown size={13} />}
                {coin.change}
              </span>
            </div>
            <div class="hidden sm:flex items-center justify-end">
              <span class="text-sm text-white/50">{coin.cap}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HERRAMIENTAS RÁPIDAS -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14 border-t border-white/[0.07]" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">

      <div class="flex items-center gap-2.5 mb-8">
        <Calculator size={18} class="text-[#D4A843]" />
        <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Herramientas</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {herramientas.map((h) => (
          <a href={h.href} class="group flex flex-col gap-4 bg-[#111318] border border-white/[0.07] hover:border-[#D4A843]/30 rounded-2xl p-6 no-underline transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-10 h-10 rounded-xl bg-[#D4A843]/10 flex items-center justify-center text-[#D4A843]">
              {h.icon === "calc"   && <Calculator size={18} />}
              {h.icon === "dollar" && <DollarSign size={18} />}
              {h.icon === "chart"  && <BarChart2 size={18} />}
            </div>
            <div class="flex flex-col gap-1">
              <span class="font-bold text-white text-[15px] group-hover:text-[#D4A843] transition-colors duration-200" style="font-family: 'Syne', sans-serif;">{h.titulo}</span>
              <span class="text-white/40 text-sm leading-relaxed">{h.desc}</span>
            </div>
            <span class="flex items-center gap-1 text-[#D4A843] text-sm font-medium mt-auto">
              Usar ahora <ArrowRight size={14} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPLORAR POR CATEGORÍA -->
  <section class="bg-[#0A0B0D] px-4 sm:px-6 py-14 border-t border-white/[0.07]" style="font-family: 'DM Sans', sans-serif;">
    <div class="max-w-7xl mx-auto">

      <div class="flex items-center gap-2.5 mb-8">
        <TrendingUp size={18} class="text-[#D4A843]" />
        <h2 class="font-bold text-white text-xl" style="font-family: 'Syne', sans-serif;">Explorar por Categoría</h2>
      </div>

      <div class="flex flex-wrap gap-3">
        {categoriasDB.map((cat) => (
          <a
            href={`/noticias?categoria=${cat.slug}`}
            class="group flex items-center gap-2 bg-[#111318] border border-white/[0.07] hover:border-[#D4A843]/40 hover:bg-[#D4A843]/5 px-4 py-2.5 rounded-xl no-underline transition-all duration-200"
          >
            <span class="text-white/70 group-hover:text-[#D4A843] text-sm font-medium transition-colors duration-200">
              {cat.nombre}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

