export const prerender = false;
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { TrendingUp, ArrowRight, DollarSign, BarChart2,GitCompare, Clock, Flame, BookOpen, Layers, Landmark, Calculator } from 'lucide-astro';
import { getArticulos, getArticulosDestacados, getCategorias, getArticulosPorCategorias } from '../db/queries';
import { getCloudinaryUrl } from '../lib/cloudinary';

// ── Solo DB (rápido, local) ── no más fetchPrecios/obtenerForex/fetchMetales en SSR
const db = Astro.locals.db;

const [todasNoticias, destacados, categorias] = await Promise.all([
  getArticulos(db, 20),
  getArticulosDestacados(db, 3),
  getCategorias(db),
]);

const noticiaPrincipal    = destacados[0] ?? todasNoticias[0] ?? null;
const noticiasSecundarias = todasNoticias
  .filter(n => n.slug !== noticiaPrincipal?.slug);

const noticiasPorCategoria = await getArticulosPorCategorias(db, categorias.map(c => c.slug), 4);
const primeraConNoticias = categorias.find(c => (noticiasPorCategoria[c.slug]?.length ?? 0) > 0);

const herramientas = [
  { titulo: "Mercados Cripto",    desc: "Precios en vivo y gráficas de las principales criptomonedas.", href: "/herramientas/cripto",              icon: "chart"    },
  { titulo: "Forex",              desc: "Tipos de cambio de divisas globales y monedas LATAM.",          href: "/herramientas/forex",               icon: "forex"    },
  { titulo: "Metales Preciosos",  desc: "Precios de oro, plata, platino y paladio por onza troy.",       href: "/herramientas/metales",             icon: "layers"   },
  { titulo: "Acciones",           desc: "Cotizaciones en tiempo real del mercado estadounidense.",        href: "/herramientas/acciones",            icon: "acciones" },
  { titulo: "Precio del Dólar",   desc: "Dólar oficial y paralelo (blue en Argentina) por país.",        href: "/herramientas/dolar",               icon: "dollar"   },
 { titulo: "Calculadoras de Trading", desc: "Calcula pips, tamaño de posición, ganancias y margen para Forex.", href: "/herramientas/calculadora-trading", icon: "calc2" },
  { titulo: "Calculadora Cripto", desc: "Convertí cripto a pesos, calculá ganancias y comisiones.",      href: "/herramientas/calculadora-cripto",  icon: "calc"     },
  { titulo: "Comparar Brokers",   desc: "Compará spreads, depósitos, regulación y plataformas de los principales brokers para LATAM.", href: "/herramientas/comparar-brokers", icon: "compare"  },
];
// ── CONCEPTO DEL DÍA ─────────────────────────────────────────
const conceptos = [
  { termino: "Bitcoin (BTC)",           categoria: "Cripto",    definicion: "La primera criptomoneda descentralizada del mundo, creada en 2009 por Satoshi Nakamoto. Opera sin bancos ni gobiernos usando tecnología blockchain.", ejemplo: "Si hubieras invertido $100 en Bitcoin en 2010, hoy tendrías millones." },
  { termino: "Blockchain",              categoria: "Cripto",    definicion: "Registro digital distribuido e inmutable donde se almacenan transacciones en bloques encadenados. Nadie puede modificar los datos sin consenso de la red.", ejemplo: "Cuando envías Bitcoin, la transacción queda grabada para siempre en la blockchain." },
  { termino: "Halving",                 categoria: "Cripto",    definicion: "Evento que ocurre cada ~4 años y reduce a la mitad la recompensa que reciben los mineros de Bitcoin. Históricamente dispara el precio por la menor oferta.", ejemplo: "El halving de 2024 redujo la recompensa de 6.25 BTC a 3.125 BTC por bloque." },
  { termino: "Spread",                  categoria: "Trading",   definicion: "Diferencia entre el precio de compra (ask) y el precio de venta (bid) de un activo. Es el costo implícito de cada operación en muchos brokers.", ejemplo: "Si el EUR/USD tiene un spread de 2 pips, pagas eso solo por abrir la operación." },
  { termino: "Apalancamiento",          categoria: "Trading",   definicion: "Permite operar con más dinero del que tienes depositado. Un apalancamiento 1:10 significa que con $100 controlas $1,000 en el mercado.", ejemplo: "Con apalancamiento 1:100 y $500, puedes abrir una posición de $50,000 en forex." },
  { termino: "Stop Loss",               categoria: "Trading",   definicion: "Orden automática que cierra tu posición al alcanzar un precio determinado, limitando tus pérdidas. Es la herramienta de gestión de riesgo más básica.", ejemplo: "Compras BTC a $95,000 y pones un stop loss en $90,000 para no perder más del 5%." },
  { termino: "ETF",                     categoria: "Bolsa",     definicion: "Fondo cotizado en bolsa que replica el rendimiento de un índice, sector o activo. Permite diversificar comprando un solo instrumento.", ejemplo: "El ETF SPY replica el S&P 500, dándote exposición a las 500 empresas más grandes de EE.UU." },
  { termino: "Capitalización bursátil", categoria: "Bolsa",     definicion: "Valor total de mercado de una empresa, calculado multiplicando el precio de la acción por el número de acciones en circulación.", ejemplo: "Apple tiene una capitalización de más de $3 billones, siendo la empresa más valiosa del mundo." },
  { termino: "Inflación",               categoria: "Economía",  definicion: "Aumento sostenido del nivel general de precios con el tiempo, que reduce el poder adquisitivo del dinero. Se mide con el IPC.", ejemplo: "Con una inflación del 10%, lo que hoy cuesta $100 costará $110 el próximo año." },
  { termino: "Staking",                 categoria: "Cripto",    definicion: "Proceso de bloquear criptomonedas en una red para validar transacciones y obtener recompensas. Similar a un depósito a plazo fijo.", ejemplo: "Al hacer staking de ETH puedes ganar entre 3% y 5% anual en recompensas." },
  { termino: "DeFi",                    categoria: "Cripto",    definicion: "Finanzas descentralizadas: servicios financieros (préstamos, trading, ahorro) que funcionan en blockchain sin bancos ni intermediarios.", ejemplo: "En Uniswap puedes intercambiar tokens directamente sin crear cuenta ni verificar identidad." },
  { termino: "Soporte y Resistencia",   categoria: "Trading",   definicion: "Niveles de precio donde históricamente el mercado ha rebotado (soporte) o frenado su subida (resistencia). Claves en análisis técnico.", ejemplo: "Si Bitcoin rebota tres veces en $90,000, ese nivel es un soporte fuerte." },
  { termino: "Par de divisas",          categoria: "Forex",     definicion: "Cotización de dos monedas entre sí. El EUR/USD indica cuántos dólares cuesta un euro. La primera moneda es la base, la segunda es la cotizada.", ejemplo: "EUR/USD = 1.08 significa que 1 euro vale 1.08 dólares." },
  { termino: "Vela japonesa",           categoria: "Trading",   definicion: "Representación gráfica del precio que muestra apertura, cierre, máximo y mínimo en un período. Verde significa subida, roja significa bajada.", ejemplo: "Una vela verde con cuerpo largo indica que los compradores dominaron toda la sesión." },
  { termino: "Altcoin",                 categoria: "Cripto",    definicion: "Cualquier criptomoneda que no sea Bitcoin. El término viene de 'alternative coin'. Ethereum, Solana y XRP son ejemplos populares.", ejemplo: "Ethereum es la altcoin más grande del mercado por capitalización." },
  { termino: "Diversificación",         categoria: "Inversión", definicion: "Estrategia de distribuir el capital en diferentes activos para reducir el riesgo. Si uno cae, los otros pueden compensar las pérdidas.", ejemplo: "En lugar de poner todo en Bitcoin, distribuyes 40% en BTC, 30% en ETH y 30% en acciones." },
  { termino: "Liquidez",                categoria: "Mercados",  definicion: "Facilidad con la que un activo puede comprarse o venderse sin afectar significativamente su precio. Mayor volumen = mayor liquidez.", ejemplo: "Bitcoin tiene alta liquidez; una NFT rara puede tener muy poca y tardas semanas en venderla." },
  { termino: "Whale",                   categoria: "Cripto",    definicion: "Término para referirse a inversores que poseen grandes cantidades de una criptomoneda y cuyas compras o ventas pueden mover el mercado.", ejemplo: "Cuando una wallet mueve 10,000 BTC, el mercado entra en alerta por el posible impacto." },
  { termino: "IPO",                     categoria: "Bolsa",     definicion: "Oferta Pública Inicial: primera vez que una empresa vende acciones al público en bolsa. Es como la empresa 'debuta' en el mercado.", ejemplo: "Cuando Airbnb hizo su IPO en 2020, las acciones subieron un 113% el primer día." },
  { termino: "Bull Market",             categoria: "Mercados",  definicion: "Período prolongado de tendencia alcista en los mercados financieros. Se considera bull market cuando los precios suben más del 20% desde mínimos.", ejemplo: "El bull market de Bitcoin en 2020-2021 llevó el precio de $10,000 a casi $70,000." },
  { termino: "Bear Market",             categoria: "Mercados",  definicion: "Período prolongado de caída de precios, generalmente del 20% o más desde máximos recientes. Puede durar meses o años.", ejemplo: "El bear market cripto de 2022 hizo caer a Bitcoin de $69,000 a menos de $16,000." },
  { termino: "HODL",                    categoria: "Cripto",    definicion: "Estrategia de mantener criptomonedas a largo plazo sin vender, independientemente de la volatilidad. Nació de un error tipográfico de 'hold'.", ejemplo: "Los HODLers que compraron BTC en 2017 y aguantaron el crash de 2018 obtuvieron grandes ganancias." },
];
const ahora       = new Date();
const diaDelAno   = Math.floor((ahora.getTime() - new Date(ahora.getFullYear(), 0, 0).getTime()) / 86400000);
const conceptoHoy = conceptos[diaDelAno % conceptos.length];


function formatFecha(fecha: Date | null) {
  if (!fecha) return '';
  const diff  = Date.now() - new Date(fecha).getTime();
  const horas = Math.floor(diff / 1000 / 60 / 60);
  if (horas < 1)  return 'Hace unos minutos';
  if (horas < 24) return `Hace ${horas} ${horas === 1 ? 'hora' : 'horas'}`;
  const dias = Math.floor(horas / 24);
  return `Hace ${dias} ${dias === 1 ? 'día' : 'días'}`;
}

const categoriaColores: Record<string, string> = {
