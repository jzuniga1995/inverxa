  <section style="background: #FAFAF8; border-bottom: 1px solid #E5E0D8;" class="px-4 sm:px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8 pb-4 border-b border-[#E5E0D8]">
        <h2 class="font-bold text-2xl sm:text-3xl" style="font-family: 'Playfair Display', serif; color: #1C1917;">
          Últimas Noticias
        </h2>
        <a href="/noticias" class="flex items-center gap-1.5 text-sm no-underline transition-colors duration-200 hover:opacity-70"
           style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
          Ver todas <ArrowRight size={14} />
        </a>
      </div>

      {noticiasSecundarias.slice(3).length === 0 ? (
        <div class="flex flex-col items-center justify-center py-20 border border-[#E5E0D8]" style="background: #F0EDE7;">
          <p class="text-sm" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Aún no hay noticias publicadas</p>
        </div>
      ) : (
        <>
          {/* Patrón: hero → 2 medianas → 2 mini → repite */}
          {(() => {
            const arts = noticiasSecundarias.slice(3);
            const grupos: typeof arts[] = [];
            for (let i = 0; i < arts.length; i += 5) grupos.push(arts.slice(i, i + 5));
            return grupos.map((grupo) => (
              <div class="mb-10 last:mb-0">

                {/* — Card HERO (full width) — */}
                {grupo[0] && (
                  <a href={`/noticias/${grupo[0].slug}`}
                     class="block group no-underline mb-6 pb-6 border-b border-[#E5E0D8]">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                      <div class="overflow-hidden" style="aspect-ratio: 16/9;">
                        {grupo[0].imagen
                          ? <img src={getCloudinaryUrl(grupo[0].imagen, 800)!}
                                 alt={grupo[0].titulo}
                                 width="800" height="450"
                                 loading="lazy"
                                 class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
                          : <div class="w-full h-full" style="background: #E8E3DB;"></div>
                        }
                      </div>
                      <div class="flex flex-col justify-center gap-3">
                        {grupo[0].categoria && (
                          <span class="text-[11px] font-bold uppercase tracking-[0.2em]"
                                style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                            {grupo[0].categoria.nombre}
                          </span>
                        )}
                        <h3 class="font-bold leading-[1.15] text-[#1C1917] group-hover:text-[#B91C1C] transition-colors duration-200"
                            style="font-family: 'Playfair Display', serif; font-size: clamp(22px, 2.4vw, 32px);">
                          {grupo[0].titulo}
                        </h3>
                        {grupo[0].resumen && (
                          <p class="text-sm leading-relaxed line-clamp-3"
                             style="color: #78716C; font-family: 'DM Sans', sans-serif;">
                            {grupo[0].resumen}
                          </p>
                        )}
                        <span class="text-xs flex items-center gap-1.5"
                              style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
                          <Clock size={11} />{formatFecha(grupo[0].creadoEn)}
                        </span>
                      </div>
                    </div>
                  </a>
                )}

                {/* — 2 cards MEDIANAS — */}
                {grupo.slice(1, 3).length > 0 && (
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-6 pb-6 border-b border-[#E5E0D8]">
                    {grupo.slice(1, 3).map((n) => (
                      <a href={`/noticias/${n.slug}`}
                         class="group no-underline flex flex-col gap-3">
                        <div class="overflow-hidden" style="aspect-ratio: 4/3;">
                          {n.imagen
                            ? <img src={getCloudinaryUrl(n.imagen, 600)!}
                                   alt={n.titulo}
                                   width="600" height="450"
                                   loading="lazy"
                                   class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
                            : <div class="w-full h-full" style="background: #E8E3DB;"></div>
                          }
                        </div>
                        {n.categoria && (
                          <span class="text-[10px] font-bold uppercase tracking-[0.18em]"
                                style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                            {n.categoria.nombre}
                          </span>
                        )}
                        <h4 class="font-bold leading-snug text-[#1C1917] group-hover:text-[#B91C1C] transition-colors duration-200 line-clamp-3"
                            style="font-family: 'Playfair Display', serif; font-size: 18px;">
                          {n.titulo}
                        </h4>
                        <span class="text-xs" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
                          {formatFecha(n.creadoEn)}
                        </span>
                      </a>
                    ))}
                  </div>
                )}

                {/* — 2 cards MINI (sin imagen) — */}
                {grupo.slice(3, 5).length > 0 && (
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {grupo.slice(3, 5).map((n) => (
                      <a href={`/noticias/${n.slug}`}
                         class="group no-underline flex gap-4 items-start py-2"
                         style="border-left: 3px solid #B91C1C; padding-left: 14px;">
                        <div class="flex flex-col gap-1.5 min-w-0">
                          {n.categoria && (
                            <span class="text-[10px] font-bold uppercase tracking-[0.15em]"
                                  style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                              {n.categoria.nombre}
                            </span>
                          )}
                          <h4 class="font-bold leading-snug text-[#1C1917] group-hover:text-[#B91C1C] transition-colors duration-200 line-clamp-2"
                              style="font-family: 'Playfair Display', serif; font-size: 15px;">
                            {n.titulo}
                          </h4>
                          <span class="text-[11px]" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
                            {formatFecha(n.creadoEn)}
                          </span>
                        </div>
                      </a>
                    ))}
                  </div>
                )}

              </div>
            ));
          })()}
        </>
      )}
    </div>
  </section>

  <!-- ── 2. EXPLORA POR CATEGORÍA ──────────────────────────── -->
  <section style="background: #FAFAF8; border-bottom: 1px solid #E5E0D8;" class="px-4 sm:px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[#E5E0D8]">
        <Layers size={17} style="color: #B91C1C;" />
        <h2 class="font-bold text-2xl sm:text-3xl" style="font-family: 'Playfair Display', serif; color: #1C1917;">
          Explora por Categoría
        </h2>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-3 mb-6 scrollbar-hide">
        {categorias.map((cat) => {
          const color  = categoriaColores[cat.nombre] ?? '#B91C1C';
          const activa = cat.slug === primeraConNoticias?.slug;
          return (
            <button
              data-tab={cat.slug}
              data-color={color}
              class={`tab-btn flex-shrink-0 text-xs font-semibold px-4 py-2 border transition-all duration-200 cursor-pointer whitespace-nowrap uppercase tracking-wider ${
                activa ? '' : 'bg-transparent hover:opacity-70'
              }`}
              style={activa
                ? `background: ${color}15; border-color: ${color}; color: ${color}; font-family: 'DM Sans', sans-serif;`
                : `background: transparent; border-color: #D6D0C8; color: #78716C; font-family: 'DM Sans', sans-serif;`}
            >
              {cat.nombre}
            </button>
          );
        })}
      </div>
      <div id="cat-panels">
        {categorias.map((cat) => {
          const noticias = noticiasPorCategoria[cat.slug] ?? [];
          const activa   = cat.slug === primeraConNoticias?.slug;
          const color    = categoriaColores[cat.nombre] ?? '#B91C1C';
          return (
            <div data-panel={cat.slug} class={`cat-panel ${activa ? '' : 'hidden'}`}>
              {noticias.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
                  {noticias.map((n) => (
                    <a href={`/noticias/${n.slug}`}
                       class="group flex flex-col no-underline transition-all duration-200 hover:-translate-y-0.5"
                       style="border: 1px solid #E5E0D8; background: #FFFFFF;">
                      <div class="w-full overflow-hidden flex-shrink-0" style="aspect-ratio: 4/3;">
                        {n.imagen
                          ? <img src={getCloudinaryUrl(n.imagen, 400)!}
                                 alt={n.titulo}
                                 width="400" height="300"
                                 loading="lazy"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                          : <div class="w-full h-full" style={`background: ${color}12;`}></div>
                        }
                      </div>
                      <div class="flex flex-col gap-2 p-4">
                        <span class="text-[10px] flex items-center gap-1"
                              style={`color: ${color}; font-family: 'DM Sans', sans-serif;`}>
                          <Clock size={9} />{formatFecha(n.creadoEn)}
                        </span>
                        <h4 class="font-bold leading-snug line-clamp-2 group-hover:opacity-70 transition-opacity duration-200"
                            style="font-family: 'Playfair Display', serif; color: #1C1917; font-size: 15px;">
                          {n.titulo}
                        </h4>
                      </div>
                    </a>
                  ))}
                </div>
              ) : (
                <div class="flex flex-col items-center justify-center py-16 border border-[#E5E0D8]" style="background: #F0EDE7;">
                  <p class="text-sm" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
                    Próximamente noticias de {cat.nombre}
                  </p>
                </div>
              )}
              <div class="flex justify-end mt-5">
                <a href={`/${cat.slug}`}
                   class="flex items-center gap-1.5 text-sm no-underline hover:opacity-70 transition-opacity duration-200"
                   style={`color: ${color}; font-family: 'DM Sans', sans-serif;`}>
                  Ver todo en {cat.nombre} <ArrowRight size={14} />
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── 3. CONCEPTO DEL DÍA ───────────────────────────────── -->
  <section style="background: #FAFAF8; border-bottom: 1px solid #E5E0D8;" class="px-4 sm:px-6 py-12">
