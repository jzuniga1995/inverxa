            <div class="p-5" style="border-left: 3px solid #B91C1C; background: rgba(245,240,232,0.04);">
              <span class="block text-[10px] font-bold uppercase tracking-[0.2em] mb-2"
                    style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
                Ejemplo práctico
              </span>
              <p class="text-sm leading-relaxed"
                 style="color: rgba(245,240,232,0.6); font-family: 'DM Sans', sans-serif; font-style: italic;">
                {conceptoHoy.ejemplo}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

