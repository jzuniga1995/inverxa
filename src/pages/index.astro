    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Inversax",
    "url": "https://inversax.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://inversax.com/favicon.png",
      "width": 512,
      "height": 512
    },
    "sameAs": [
      "https://twitter.com/inversax",
      "https://www.instagram.com/inversax",
      "https://www.youtube.com/@inversax"
    ],
"areaServed": [
  "AR","BO","BR","CL","CO","CU","EC","MX","PY","PE","UY","VE",
