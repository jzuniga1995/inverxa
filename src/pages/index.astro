            <span class="text-xs font-semibold uppercase tracking-wider" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Empresa</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-right" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Precio</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-right" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Cambio</span>
            <span class="hidden sm:block text-xs font-semibold uppercase tracking-wider text-right" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Sector</span>
          </div>
          <div id="acciones-loading">
            {[...Array(6)].map(() => (
              <div class="grid grid-cols-3 sm:grid-cols-4 px-4 sm:px-6 py-4" style="border-bottom: 1px solid #E5E0D8;">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full animate-pulse flex-shrink-0" style="background: #E5E0D8;"></div>
                  <div class="flex flex-col gap-1.5">
                    <div class="w-12 h-3 rounded animate-pulse" style="background: #E5E0D8;"></div>
                    <div class="w-20 h-2.5 rounded animate-pulse" style="background: #E5E0D8;"></div>
                  </div>
                </div>
                <div class="flex items-center justify-end"><div class="w-16 h-3 rounded animate-pulse" style="background: #E5E0D8;"></div></div>
                <div class="flex items-center justify-end"><div class="w-14 h-3 rounded animate-pulse" style="background: #E5E0D8;"></div></div>
                <div class="hidden sm:flex items-center justify-end"><div class="w-20 h-3 rounded animate-pulse" style="background: #E5E0D8;"></div></div>
              </div>
            ))}
          </div>
          <div id="acciones-content" class="hidden"></div>
          <div id="acciones-error" class="hidden px-6 py-10 text-center text-sm" style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">
            No se pudieron cargar las cotizaciones
          </div>
        </div>
        <div class="flex justify-end mt-3">
          <a href="/herramientas/acciones" class="flex items-center gap-1.5 text-sm no-underline hover:opacity-70 transition-opacity"
             style="color: #374151; font-family: 'DM Sans', sans-serif;">
            Ver todas <ArrowRight size={14} />
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── 6. HERRAMIENTAS ───────────────────────────────────── -->
  <section style="background: #FAFAF8;" class="px-4 sm:px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8 pb-4 border-b border-[#E5E0D8]">
        <div class="flex items-center gap-2.5">
          <BarChart2 size={17} style="color: #B91C1C;" />
          <h2 class="font-bold text-2xl sm:text-3xl" style="font-family: 'Playfair Display', serif; color: #1C1917;">
            Herramientas
          </h2>
        </div>
        <a href="/herramientas" class="flex items-center gap-1.5 text-sm no-underline hover:opacity-70 transition-opacity"
           style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
          Ver todas <ArrowRight size={14} />
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {herramientas.map((h) => (
          <a href={h.href}
             class="group flex flex-col gap-4 no-underline transition-all duration-200 hover:-translate-y-0.5"
             style="border: 1px solid #E5E0D8; background: #FFFFFF; padding: 24px;">

            <!-- Cabecera: ícono + dato vivo -->
            <div class="flex items-start justify-between">
              <div class="w-9 h-9 flex items-center justify-center flex-shrink-0"
                   style="background: #B91C1C14; color: #B91C1C;">
                {h.icon === "chart"    && <BarChart2   size={17} />}
                {h.icon === "forex"    && <TrendingUp  size={17} />}
                {h.icon === "layers"   && <Layers      size={17} />}
                {h.icon === "acciones" && <Landmark    size={17} />}
                {h.icon === "dollar"   && <DollarSign  size={17} />}
                {h.icon === "calc"     && <Calculator  size={17} />}
                {h.icon === "compare"  && <GitCompare  size={17} />}
                {h.icon === "calc2"    && <Calculator  size={17} />}
              </div>
              <!-- Dato vivo según tipo de herramienta -->
              {h.icon === "chart" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">BTC</span>
                  <span data-live="btc-price"
                        class="font-bold text-sm animate-pulse"
                        style="color: #1D4ED8; font-family: 'DM Sans', sans-serif;">···</span>
                </span>
              )}
              {h.icon === "forex" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">EUR/USD</span>
                  <span data-live="eurusd-rate"
                        class="font-bold text-sm animate-pulse"
                        style="color: #15803D; font-family: 'DM Sans', sans-serif;">···</span>
                </span>
              )}
              {h.icon === "layers" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Oro / oz</span>
                  <span data-live="gold-price"
                        class="font-bold text-sm animate-pulse"
                        style="color: #B45309; font-family: 'DM Sans', sans-serif;">···</span>
                </span>
              )}
              {h.icon === "acciones" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">NYSE · NASDAQ</span>
                  <span class="inline-block w-12 h-1.5 mt-1" style="background: linear-gradient(90deg, #374151 60%, #D6D0C8 60%);"></span>
                </span>
              )}
              {h.icon === "dollar" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">16 países</span>
                  <span class="font-bold text-sm" style="color: #374151; font-family: 'DM Sans', sans-serif;">USD</span>
                </span>
              )}
              {(h.icon === "calc" || h.icon === "calc2") && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Riesgo</span>
                  <span class="font-bold text-sm" style="color: #374151; font-family: 'DM Sans', sans-serif;">%</span>
                </span>
              )}
              {h.icon === "compare" && (
                <span class="text-right flex-shrink-0">
                  <span class="block text-[10px] uppercase tracking-widest mb-0.5"
                        style="color: #A8A29E; font-family: 'DM Sans', sans-serif;">Brokers</span>
                  <span class="font-bold text-sm" style="color: #374151; font-family: 'DM Sans', sans-serif;">12+</span>
                </span>
              )}
            </div>

            <!-- Título + descripción -->
            <div class="flex flex-col gap-1 flex-1">
              <span class="font-bold text-[15px] group-hover:opacity-70 transition-opacity duration-200"
                    style="color: #1C1917; font-family: 'DM Sans', sans-serif;">
                {h.titulo}
              </span>
              <span class="text-sm leading-relaxed" style="color: #78716C; font-family: 'DM Sans', sans-serif;">
                {h.desc}
              </span>
            </div>

            <!-- CTA -->
            <span class="flex items-center gap-1 text-sm font-semibold mt-auto group-hover:gap-2 transition-all duration-200"
                  style="color: #B91C1C; font-family: 'DM Sans', sans-serif;">
              Abrir <ArrowRight size={13} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<!-- ── TABS CATEGORÍAS JS ─────────────────────────────────── -->
<script>
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.cat-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      const color  = tab.dataset.color ?? '#B91C1C';
      tabs.forEach((t) => {
        t.style.background  = 'transparent';
        t.style.borderColor = '#D6D0C8';
        t.style.color       = '#78716C';
      });
      tab.style.background  = `${color}15`;
      tab.style.borderColor = color;
      tab.style.color       = color;
      panels.forEach((p) => p.classList.toggle('hidden', p.dataset.panel !== target));
    });
  });
</script>

<!-- ── MERCADO: TABS + CARGA CLIENT-SIDE ─────────────────── -->
<script>
  // ── Helpers de formato ───────────────────────────────────
  const fmtPrice = (p: number) => {
    if (!p) return '—';
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  };
  const fmtCap = (n: number) => {
    if (!n) return '—';
    if (n >= 1e12) return `$${(n / 1e12).toFixed(2)}T`;
    if (n >= 1e9)  return `$${(n / 1e9).toFixed(0)}B`;
    return `$${(n / 1e6).toFixed(0)}M`;
  };
  const fmtForex = (p: number) => {
    if (!p) return '—';
    if (p >= 100) return p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    return p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 });
  };

  const nombreForex: Record<string, string> = {
    'EUR/USD': 'Euro / Dólar', 'GBP/USD': 'Libra / Dólar', 'USD/JPY': 'Dólar / Yen',
    'USD/MXN': 'Dólar / Peso Mexicano', 'USD/ARS': 'Dólar / Peso Argentino',
    'USD/COP': 'Dólar / Peso Colombiano', 'USD/CLP': 'Dólar / Peso Chileno',
    'USD/BRL': 'Dólar / Real Brasileño', 'USD/PEN': 'Dólar / Sol Peruano',
  };

  const dominiosAcciones: Record<string, string> = {
    AAPL: 'apple.com', MSFT: 'microsoft.com', GOOGL: 'google.com',
    AMZN: 'amazon.com', NVDA: 'nvidia.com', META: 'meta.com',
    TSLA: 'tesla.com', JPM: 'jpmorganchase.com', BAC: 'bankofamerica.com',
    GS: 'goldmansachs.com', XOM: 'exxonmobil.com', CVX: 'chevron.com',
    KO: 'coca-cola.com', MCD: 'mcdonalds.com', SPY: 'ssga.com', QQQ: 'invesco.com',
  };

  // ── Estado de carga por panel ─────────────────────────────
  const loaded: Record<string, boolean> = { cripto: false, forex: false, metales: false, acciones: false };

  // ── Loaders ───────────────────────────────────────────────
  async function cargarCripto() {
    if (loaded.cripto) return;
    loaded.cripto = true;
    try {
      const HOME_IDS = ['bitcoin', 'ethereum', 'binancecoin', 'solana', 'ripple', 'cardano'];
      const res  = await fetch('/api/precios');
      const data = await res.json() as any[];
      const rows = document.getElementById('cripto-rows')!;
      rows.innerHTML = data.filter((c: any) => HOME_IDS.includes(c.id)).map((coin: any) => {
        const up = coin.change24 >= 0;
        return `
          <a href="/herramientas/cripto/${coin.id}" data-coin-id="${coin.id}"
            class="grid grid-cols-3 sm:grid-cols-4 px-4 sm:px-6 py-4 no-underline transition-colors duration-200"
            style="border-bottom: 1px solid #E5E0D8;"
            onmouseover="this.style.background='#F5F1EC'" onmouseout="this.style.background=''">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center" style="background: #F0EDE7;">
                ${coin.image ? `<img src="${coin.image}" alt="${coin.name}" class="w-full h-full object-cover" loading="lazy" />` : `<span class="text-[10px] font-bold" style="color:#78716C">${coin.symbol.slice(0,2)}</span>`}
              </div>
              <div class="min-w-0">
                <div class="font-bold text-sm" style="color:#1C1917">${coin.symbol.toUpperCase()}</div>
                <div class="text-xs truncate" style="color:#78716C">${coin.name}</div>
              </div>
            </div>
            <div class="flex items-center justify-end">
              <span class="font-semibold text-sm" style="color:#1C1917">${fmtPrice(coin.price)}</span>
            </div>
            <div class="flex items-center justify-end">
              <span class="flex items-center gap-1 text-sm font-medium" style="color:${up ? '#15803D' : '#B91C1C'}">
                ${up ? '▲' : '▼'} ${up ? '+' : ''}${coin.change24.toFixed(2)}%
              </span>
            </div>
            <div class="hidden sm:flex items-center justify-end">
              <span class="text-sm" style="color:#A8A29E">${fmtCap(coin.marketCap)}</span>
            </div>
          </a>`;
      }).join('');
      document.getElementById('cripto-skeleton')!.classList.add('hidden');
      document.getElementById('cripto-content')!.classList.remove('hidden');
      // Actualiza datos en vivo en cards de herramientas
      const btc = data.find((c: any) => c.id === 'bitcoin');
      if (btc) {
        document.querySelectorAll<HTMLElement>('[data-live="btc-price"]').forEach(el => {
          el.textContent = fmtPrice(btc.price);
          el.classList.remove('animate-pulse');
        });
      }
    } catch { /* muestra skeleton */ }
  }

  async function cargarForex() {
    if (loaded.forex) return;
    loaded.forex = true;
    try {
      const res  = await fetch('/api/forex');
      const json = await res.json() as any;
      const data = json.ok ? json.data.slice(0, 6) : [];
      const rows = document.getElementById('forex-rows')!;
      rows.innerHTML = data.map((f: any) => `
        <a href="/herramientas/forex/${f.par.replace('/', '-').toLowerCase()}"
          class="grid grid-cols-2 sm:grid-cols-3 px-4 sm:px-6 py-4 no-underline transition-colors duration-200"
          style="border-bottom: 1px solid #E5E0D8;"
          onmouseover="this.style.background='#F5F1EC'" onmouseout="this.style.background=''">
          <div class="flex items-center gap-2 sm:gap-3 min-w-0">
            <div class="relative w-8 h-8 flex-shrink-0">
              <img src="https://flagcdn.com/w40/${f.banderaBase.toLowerCase()}.png" class="absolute top-0 left-0 w-5 h-5 rounded-full object-cover" style="border:1px solid #E5E0D8" onerror="this.style.display='none'" />
              <img src="https://flagcdn.com/w40/${f.banderaCotizada.toLowerCase()}.png" class="absolute bottom-0 right-0 w-5 h-5 rounded-full object-cover" style="border:1px solid #E5E0D8" onerror="this.style.display='none'" />
            </div>
            <div class="font-bold text-sm" style="color:#1C1917">${f.par}</div>
          </div>
          <div class="flex items-center justify-end">
            <span class="font-semibold text-sm" style="color:#1C1917">${fmtForex(f.precio)}</span>
          </div>
          <div class="hidden sm:flex items-center justify-end">
            <span class="text-xs truncate" style="color:#78716C">${nombreForex[f.par] ?? f.par}</span>
          </div>
        </a>`).join('');
      document.getElementById('forex-skeleton')!.classList.add('hidden');
      document.getElementById('forex-content')!.classList.remove('hidden');
      // Actualiza EUR/USD en cards de herramientas
      const eurusd = data.find((f: any) => f.par === 'EUR/USD');
      if (eurusd) {
        document.querySelectorAll<HTMLElement>('[data-live="eurusd-rate"]').forEach(el => {
          el.textContent = fmtForex(eurusd.precio);
          el.classList.remove('animate-pulse');
        });
      }
    } catch { /* muestra skeleton */ }
  }

  async function cargarMetales() {
    if (loaded.metales) return;
    loaded.metales = true;
    try {
      const res  = await fetch('/api/metales');
      const json = await res.json() as any;
      const data = json.ok ? json.data.slice(0, 4) : [];
      const rows = document.getElementById('metales-rows')!;
      rows.innerHTML = data.map((m: any) => {
        const precio = m.precio > 0
          ? `$${m.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
          : '—';
        return `
          <a href="/herramientas/metales/${m.slug}"
            class="grid grid-cols-2 sm:grid-cols-3 px-4 sm:px-6 py-4 no-underline transition-colors duration-200"
            style="border-bottom: 1px solid #E5E0D8;"
            onmouseover="this.style.background='#F5F1EC'" onmouseout="this.style.background=''">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center" style="background:#F0EDE7; border:1px solid #E5E0D8;">
                <span class="text-xs font-bold" style="color:#B45309">${m.simbolo.slice(1,3)}</span>
              </div>
              <div class="min-w-0">
                <div class="font-bold text-sm" style="color:#1C1917">${m.nombre}</div>
                <div class="text-xs" style="color:#78716C">${m.unidad} troy</div>
              </div>
            </div>
            <div class="flex items-center justify-end">
              <span class="font-semibold text-sm" style="color:#1C1917">${precio}</span>
            </div>
            <div class="hidden sm:flex items-center justify-end">
              <span class="text-xs" style="color:#A8A29E">${m.simbolo}</span>
            </div>
          </a>`;
      }).join('');
      document.getElementById('metales-skeleton')!.classList.add('hidden');
      document.getElementById('metales-content')!.classList.remove('hidden');
      // Actualiza Oro en cards de herramientas
      const oro = data.find((m: any) => m.slug === 'oro' || m.simbolo === 'XAU');
      if (oro && oro.precio > 0) {
        document.querySelectorAll<HTMLElement>('[data-live="gold-price"]').forEach(el => {
          el.textContent = `$${oro.precio.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}`;
          el.classList.remove('animate-pulse');
        });
      }
    } catch { /* muestra skeleton */ }
  }

  async function cargarAcciones() {
    if (loaded.acciones) return;
    loaded.acciones = true;
    try {
      const res  = await fetch('/api/acciones?limit=6');
      const json = await res.json() as any;
      if (!json.ok) throw new Error();
      const content = document.getElementById('acciones-content')!;
      content.innerHTML = json.data.map((a: any) => {
        const precio    = a.precio > 0 ? `$${a.precio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : '—';
        const cambio    = a.precio > 0 ? `${a.cambioPct >= 0 ? '+' : ''}${a.cambioPct.toFixed(2)}%` : '—';
        const colorC    = a.alza ? 'text-emerald-400' : 'text-red-400';
        const dominio   = dominiosAcciones[a.ticker] ?? '';
        const logo      = dominio
          ? `<img src="https://www.google.com/s2/favicons?domain=${dominio}&sz=64" alt="${a.nombre}" class="w-5 h-5 object-contain" onerror="this.style.display='none'" />`
          : `<span class="text-[9px] font-bold" style="color:#78716C;">${a.ticker.slice(0,2)}</span>`;
        const colorCambio = a.alza ? '#15803D' : '#DC2626';
        return `
          <a href="/herramientas/acciones/${a.slug}"
            class="grid grid-cols-3 sm:grid-cols-4 px-4 sm:px-6 py-4 no-underline transition-colors duration-200"
            style="border-bottom: 1px solid #E5E0D8;"
            onmouseover="this.style.background='#F5F1EC'" onmouseout="this.style.background=''">
            <div class="flex items-center gap-2 sm:gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center" style="background:#F0EDE7; border:1px solid #E5E0D8;">${logo}</div>
              <div class="min-w-0">
                <div class="font-bold text-sm" style="color:#1C1917;">${a.ticker}</div>
                <div class="text-xs truncate" style="color:#78716C;">${a.nombre}</div>
              </div>
            </div>
            <div class="flex items-center justify-end">
              <span class="font-semibold text-sm" style="color:#1C1917;">${precio}</span>
            </div>
            <div class="flex items-center justify-end">
              ${precio === '—' ? '<span class="text-sm" style="color:#A8A29E;">—</span>' : `<span class="flex items-center gap-1 text-sm font-medium" style="color:${colorCambio};">${a.alza ? '▲' : '▼'} ${cambio}</span>`}
            </div>
            <div class="hidden sm:flex items-center justify-end">
              <span class="text-xs" style="color:#A8A29E;">${a.sector}</span>
            </div>
          </a>`;
      }).join('');
      document.getElementById('acciones-loading')!.classList.add('hidden');
      content.classList.remove('hidden');
    } catch {
      document.getElementById('acciones-loading')!.classList.add('hidden');
      document.getElementById('acciones-error')!.classList.remove('hidden');
    }
  }

// ── Tabs lógica + carga lazy ──────────────────────────────
  const mktTabs   = document.querySelectorAll<HTMLButtonElement>('.market-tab');
  const mktPanels = document.querySelectorAll<HTMLElement>('.mkt-panel');
  const loaders   = [cargarCripto, cargarForex, cargarMetales, cargarAcciones];

  const mktActiveColors = ['#1D4ED8', '#15803D', '#B45309', '#374151'];

  mktTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      mktTabs.forEach(t => {
        t.style.background  = 'transparent';
        t.style.borderColor = '#D6D0C8';
        t.style.color       = '#78716C';
      });
      const c = mktActiveColors[i] ?? '#B91C1C';
      tab.style.background  = `${c}15`;
      tab.style.borderColor = c;
      tab.style.color       = c;
      mktPanels.forEach((p, j) => p.classList.toggle('hidden', i !== j));
      loaders[i]?.();
    });
  });

  // Carga cripto al inicio (tab activo por defecto)
  cargarCripto();

</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

