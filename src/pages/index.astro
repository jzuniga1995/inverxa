  })} />

  <!-- ═══════════════════════════════════════
       JSON-LD — WebPage
  ═══════════════════════════════════════ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Inversax — Cripto, Trading y Finanzas en Español",
    "description": "Noticias, precios en vivo y herramientas de cripto, forex, bolsa y metales en español para Latinoamérica.",
    "url": "https://inversax.com",
    "inLanguage": "es",
    "isPartOf": {
      "@type": "WebSite",
      "name": "Inversax",
      "url": "https://inversax.com"
    },
