</Layout>

<!-- ── TABS MERCADO JS ──────────────────────────────────────── -->
<script>
  const mktTabs   = document.querySelectorAll<HTMLButtonElement>('.market-tab');
  const mktPanels = document.querySelectorAll<HTMLElement>('.mkt-panel');

  mktTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => {
      mktTabs.forEach(t => {
        t.style.background  = '';
        t.style.borderColor = '';
        t.style.color       = '';
        t.classList.remove('font-semibold');
        t.classList.add('text-white/40', 'border-white/[0.07]');
      });
      tab.style.background  = '#D4A843';
      tab.style.borderColor = '#D4A843';
      tab.style.color       = '#0A0B0D';
      tab.classList.add('font-semibold');
      tab.classList.remove('text-white/40', 'border-white/[0.07]');
      mktPanels.forEach((p, j) => p.classList.toggle('hidden', i !== j));
    });
  });
</script>

<!-- ── TABS CATEGORÍAS JS ─────────────────────────────────── -->
<script>
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.cat-panel');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      const color  = tab.dataset.color ?? '#D4A843';

      tabs.forEach((t) => {
        t.style.background  = '';
        t.style.borderColor = '';
        t.style.color       = '';
        t.classList.remove('font-semibold');
        t.classList.add('text-white/40', 'border-white/[0.07]');
      });

      tab.style.background  = color;
      tab.style.borderColor = color;
      tab.style.color       = '#0A0B0D';
      tab.classList.add('font-semibold');
      tab.classList.remove('text-white/40', 'border-white/[0.07]');

      panels.forEach((p) => {
        p.classList.toggle('hidden', p.dataset.panel !== target);
      });
    });
  });
</script>

<!-- ── POLLING CRIPTO ─────────────────────────────────────── -->
<script>
  const HOME_IDS = ['bitcoin', 'ethereum', 'binancecoin', 'solana', 'ripple', 'cardano'];

  const formatPrice = (p: number) => {
    if (!p) return '—';
    if (p >= 1000) return `$${p.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
    if (p >= 1)    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    return `$${p.toLocaleString('en-US', { minimumFractionDigits: 4, maximumFractionDigits: 4 })}`;
  };
  const formatCap = (n: number) => {
    if (!n) return '—';
    if (n >= 1e12) return `$${(n / 1e12).toFixed(2)}T`;
    if (n >= 1e9)  return `$${(n / 1e9).toFixed(0)}B`;
    return `$${(n / 1e6).toFixed(0)}M`;
  };

  async function actualizarPrecios() {
    try {
      const res  = await fetch('/api/precios');
      if (!res.ok) return;
      const data = await res.json();
      data.filter((c: any) => HOME_IDS.includes(c.id)).forEach((coin: any) => {
        const fila = document.querySelector(`[data-coin-id="${coin.id}"]`);
        if (!fila) return;
        const up       = coin.change24 >= 0;
        const elPrice  = fila.querySelector('[data-field="price"]');
        const elChange = fila.querySelector('[data-field="change"]');
        const elCap    = fila.querySelector('[data-field="cap"]');
        if (elPrice)  elPrice.textContent  = formatPrice(coin.price);
        if (elCap)    elCap.textContent    = formatCap(coin.marketCap);
        if (elChange) {
          elChange.textContent = `${up ? '▲' : '▼'} ${up ? '+' : ''}${coin.change24.toFixed(2)}%`;
          elChange.className   = `flex items-center gap-1 text-sm font-medium ${up ? 'text-emerald-400' : 'text-red-400'}`;
        }
      });
    } catch (e) { console.error('[Home polling cripto]', e); }
  }

  setInterval(actualizarPrecios, 300_000);
</script>

